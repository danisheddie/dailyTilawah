Һ ЩұЩ„Ш·Щ‘ЩҗЩҠЩҶЩҗ ЩғЩҺЩҮЩҺЩҠЩ’ЩҖЩ”ЩҺШ©Щҗ ЩұЩ„Ш·Щ‘ЩҺЩҠЩ’ШұЩҗ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩү ЩҒЩҺШӘЩҺЩҶЩҒЩҸШ®ЩҸ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҒЩҺШӘЩҺЩғЩҸЩҲЩҶЩҸ Ш·ЩҺЩҠЩ’ШұЩӢЫўШ§ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩү Ы– ЩҲЩҺШӘЩҸШЁЩ’ШұЩҗШҰЩҸ ЩұЩ„Щ’ШЈЩҺЩғЩ’Щ…ЩҺЩҮЩҺ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШЁЩ’ШұЩҺШөЩҺ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩү Ы– ЩҲЩҺШҘЩҗШ°Щ’ ШӘЩҸШ®Щ’ШұЩҗШ¬ЩҸ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҺЩүЩ° ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩү Ы– ЩҲЩҺШҘЩҗШ°Щ’ ЩғЩҺЩҒЩҺЩҒЩ’ШӘЩҸ ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ Ш№ЩҺЩҶЩғЩҺ ШҘЩҗШ°Щ’ Ш¬ЩҗШҰЩ’ШӘЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҒЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШҘЩҗЩҶЩ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ШіЩҗШӯЩ’ШұЩҢЫӯ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҢЫӯ"},{"key":"5:111","surah":5,"ayah":111,"num":780,"page":126,"words":[{"code":"пІҷ","page":126,"end":false},{"code":"пІҡ","page":126,"end":false},{"code":"пІӣ","page":126,"end":false},{"code":"пІң","page":126,"end":false},{"code":"пІқ","page":126,"end":false},{"code":"пІһ","page":126,"end":false},{"code":"пІҹ","page":126,"end":false},{"code":"пІ ","page":126,"end":false},{"code":"пІЎ","page":126,"end":false},{"code":"пІў","page":126,"end":false},{"code":"пІЈ","page":126,"end":false},{"code":"пІӨ","page":126,"end":false},{"code":"пІҘ","page":126,"end":false},{"code":"пІҰ","page":126,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ШЈЩҺЩҲЩ’ШӯЩҺЩҠЩ’ШӘЩҸ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’ШӯЩҺЩҲЩҺШ§ШұЩҗЩҠЩ‘ЩҗЩҖЫ§ЩҶЩҺ ШЈЩҺЩҶЩ’ ШЎЩҺШ§Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩү ЩҲЩҺШЁЩҗШұЩҺШіЩҸЩҲЩ„ЩҗЩү ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Щ…ЩҺЩҶЩ‘ЩҺШ§ ЩҲЩҺЩұШҙЩ’ЩҮЩҺШҜЩ’ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҶЩҺШ§ Щ…ЩҸШіЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"5:112","surah":5,"ayah":112,"num":781,"page":126,"words":[{"code":"пІ§","page":126,"end":false},{"code":"пІЁ","page":126,"end":false},{"code":"пІ©","page":126,"end":false},{"code":"пІӘ","page":126,"end":false},{"code":"пІ«","page":126,"end":false},{"code":"пІ¬","page":126,"end":false},{"code":"пІӯ","page":126,"end":false},{"code":"пІ®","page":126,"end":false},{"code":"пІҜ","page":126,"end":false},{"code":"пІ°","page":126,"end":false},{"code":"пІұ","page":126,"end":false},{"code":"пІІ","page":126,"end":false},{"code":"пІі","page":126,"end":false},{"code":"пІҙ","page":126,"end":false},{"code":"пІөпІ¶","page":126,"end":false},{"code":"пІ·","page":126,"end":false},{"code":"пІё","page":126,"end":false},{"code":"пІ№","page":126,"end":false},{"code":"пІә","page":126,"end":false},{"code":"пІ»","page":126,"end":false},{"code":"пІј","page":126,"end":false},{"code":"пІҪ","page":126,"end":true}],"text":"ШҘЩҗШ°Щ’ ЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ’ШӯЩҺЩҲЩҺШ§ШұЩҗЩҠЩ‘ЩҸЩҲЩҶЩҺ ЩҠЩҺЩҖЩ°Ш№ЩҗЩҠШіЩҺЩү ЩұШЁЩ’ЩҶЩҺ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ ЩҮЩҺЩ„Щ’ ЩҠЩҺШіЩ’ШӘЩҺШ·ЩҗЩҠШ№ЩҸ ШұЩҺШЁЩ‘ЩҸЩғЩҺ ШЈЩҺЩҶ ЩҠЩҸЩҶЩҺШІЩ‘ЩҗЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҺШ§Щ“ШҰЩҗШҜЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ Ы– ЩӮЩҺШ§Щ„ЩҺ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"5:113","surah":5,"ayah":113,"num":782,"page":126,"words":[{"code":"пІҫ","page":126,"end":false},{"code":"пІҝ","page":126,"end":false},{"code":"піҖ","page":126,"end":false},{"code":"піҒ","page":126,"end":false},{"code":"піӮ","page":126,"end":false},{"code":"піғ","page":126,"end":false},{"code":"пі„","page":126,"end":false},{"code":"пі…","page":126,"end":false},{"code":"піҶ","page":126,"end":false},{"code":"піҮ","page":126,"end":false},{"code":"піҲ","page":126,"end":false},{"code":"піү","page":126,"end":false},{"code":"піҠ","page":126,"end":false},{"code":"піӢ","page":126,"end":false},{"code":"піҢ","page":126,"end":false},{"code":"піҚ","page":126,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҶЩҸШұЩҗЩҠШҜЩҸ ШЈЩҺЩҶ ЩҶЩ‘ЩҺШЈЩ’ЩғЩҸЩ„ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ЩҲЩҺШӘЩҺШ·Щ’Щ…ЩҺШҰЩҗЩҶЩ‘ЩҺ ЩӮЩҸЩ„ЩҸЩҲШЁЩҸЩҶЩҺШ§ ЩҲЩҺЩҶЩҺШ№Щ’Щ„ЩҺЩ…ЩҺ ШЈЩҺЩҶ ЩӮЩҺШҜЩ’ ШөЩҺШҜЩҺЩӮЩ’ШӘЩҺЩҶЩҺШ§ ЩҲЩҺЩҶЩҺЩғЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҖЩ°ЩҮЩҗШҜЩҗЩҠЩҶЩҺ"}]}
піҚ","end":true}]}],"verses":[{"key":"5:109","surah":5,"ayah":109,"num":778,"page":126,"words":[{"code":"пұҒ пұӮ","page":126,"end":false},{"code":"пұғ","page":126,"end":false},{"code":"пұ„","page":126,"end":false},{"code":"пұ…","page":126,"end":false},{"code":"пұҶ","page":126,"end":false},{"code":"пұҮ","page":126,"end":false},{"code":"пұҲпұү","page":126,"end":false},{"code":"пұҠ","page":126,"end":false},{"code":"пұӢ","page":126,"end":false},{"code":"пұҢ","page":126,"end":false},{"code":"пұҚпұҺ","page":126,"end":false},{"code":"пұҸ","page":126,"end":false},{"code":"пұҗ","page":126,"end":false},{"code":"пұ‘","page":126,"end":false},{"code":"пұ’","page":126,"end":false},{"code":"пұ“","page":126,"end":true}],"text":"Ыһ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШ¬Щ’Щ…ЩҺШ№ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„ШұЩ‘ЩҸШіЩҸЩ„ЩҺ ЩҒЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ Щ…ЩҺШ§Ш°ЩҺШ§Щ“ ШЈЩҸШ¬ЩҗШЁЩ’ШӘЩҸЩ…Щ’ Ы– ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ Ш№ЩҗЩ„Щ’Щ…ЩҺ Щ„ЩҺЩҶЩҺШ§Щ“ Ы– ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ ШЈЩҺЩҶШӘЩҺ Ш№ЩҺЩ„Щ‘ЩҺЩҖЩ°Щ…ЩҸ ЩұЩ„Щ’ШәЩҸЩҠЩҸЩҲШЁЩҗ"},{"key":"5:110","surah":5,"ayah":110,"num":779,"page":126,"words":[{"code":"пұ”","page":126,"end":false},{"code":"пұ•","page":126,"end":false},{"code":"пұ–","page":126,"end":false},{"code":"пұ—","page":126,"end":false},{"code":"пұҳ","page":126,"end":false},{"code":"пұҷ","page":126,"end":false},{"code":"пұҡ","page":126,"end":false},{"code":"пұӣ","page":126,"end":false},{"code":"пұң","page":126,"end":false},{"code":"пұқ","page":126,"end":false},{"code":"пұһ","page":126,"end":false},{"code":"пұҹ","page":126,"end":false},{"code":"пұ ","page":126,"end":false},{"code":"пұЎ","page":126,"end":false},{"code":"пұў","page":126,"end":false},{"code":"пұЈ","page":126,"end":false},{"code":"пұӨ","page":126,"end":false},{"code":"пұҘ","page":126,"end":false},{"code":"пұҰ","page":126,"end":false},{"code":"пұ§пұЁ","page":126,"end":false},{"code":"пұ©","page":126,"end":false},{"code":"пұӘ","page":126,"end":false},{"code":"пұ«","page":126,"end":false},{"code":"пұ¬","page":126,"end":false},{"code":"пұӯ","page":126,"end":false},{"code":"пұ®п
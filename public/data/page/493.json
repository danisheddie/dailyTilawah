[{"code":"піӢ","end":false},{"code":"піҢ","end":false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":true}]}],"verses":[{"key":"43:48","surah":43,"ayah":48,"num":4373,"page":493,"words":[{"code":"пұҒ","page":493,"end":false},{"code":"пұӮ","page":493,"end":false},{"code":"пұғ","page":493,"end":false},{"code":"пұ„","page":493,"end":false},{"code":"пұ…","page":493,"end":false},{"code":"пұҶ","page":493,"end":false},{"code":"пұҮ","page":493,"end":false},{"code":"пұҲ","page":493,"end":false},{"code":"пұүпұҠ","page":493,"end":false},{"code":"пұӢ","page":493,"end":false},{"code":"пұҢ","page":493,"end":false},{"code":"пұҚ","page":493,"end":false},{"code":"пұҺ","page":493,"end":false},{"code":"пұҸ","page":493,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ЩҶЩҸШұЩҗЩҠЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶЩ’ ШЎЩҺШ§ЩҠЩҺШ©ЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҗЩүЩҺ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ Щ…ЩҗЩҶЩ’ ШЈЩҸШ®Щ’ШӘЩҗЩҮЩҺШ§ Ы– ЩҲЩҺШЈЩҺШ®ЩҺШ°Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҲЩҶЩҺ"},{"key":"43:49","surah":43,"ayah":49,"num":4374,"page":493,"words":[{"code":"пұҗ","page":493,"end":false},{"code":"пұ‘","page":493,"end":false},{"code":"пұ’","page":493,"end":false},{"code":"пұ“","page":493,"end":false},{"code":"пұ”","page":493,"end":false},{"code":"пұ•","page":493,"end":false},{"code":"пұ–","page":493,"end":false},{"code":"пұ—","page":493,"end":false},{"code":"пұҳ","page":493,"end":false},{"code":"пұҷ","page":493,"end":false},{"code":"пұҡ","page":493,"end":false},{"code":"пұӣ","page":493,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺ ЩұЩ„ШіЩ‘ЩҺШ§ШӯЩҗШұЩҸ ЩұШҜЩ’Ш№ЩҸ Щ„ЩҺЩҶЩҺШ§ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺЩҮЩҗШҜЩҺ Ш№ЩҗЩҶШҜЩҺЩғЩҺ ШҘЩҗЩҶЩ‘ЩҺЩҶЩҺШ§ Щ„ЩҺЩ…ЩҸЩҮЩ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"43:50","surah":43,"ayah":50,"num":4375,"page":493,"words":[{"code":"пұң","page":493,"end":false},{"code":"пұқ","page":493,"end":false},{"code":"пұһ","page":493,"end":false},{"code":"пұҹ","page":493,"end":false},{"code":"пұ ","page":493,"end":false},{"code":"пұЎ","page":493,"end":false},{"code":"пұў","page":493,"end":false},{"code":"пұЈ","page":493,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ЩғЩҺШҙЩҺЩҒЩ’ЩҶЩҺШ§ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ШҘЩҗШ°ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҠЩҺЩҶЩғЩҸШ«ЩҸЩҲЩҶЩҺ"},{"key":"43:51","surah":43,"ayah":51,"num":4376,"page":493,"words":[{"code":"пұӨ","page":493,"end":false},{"code":"пұҘ","page":493,"end":false},{"code":"пұҰ","page":493,"end":false},{"code":"пұ§","page":493,"end":false},{"code":"пұЁ","page":493,"end":false},{"code":"пұ©","page":493,"end":false},{"code":"пұӘ","page":493,"end":false},{"code":"пұ«","page":493,"end":false},{"code":"пұ¬","page":493,"end":false},{"code":"пұӯ","page":493,"end":false},{"code":"пұ®","page":493,"end":false},{"code":"пұҜ","page":493,"end":false},{"code":"пұ°","page":493,"end":false},{"code":"пұұ","page":493,"end":false},{"code":"пұІпұі","page":493,"end":false},{"code":"пұҙ","page":493,"end":false},{"code":"пұө","page":493,"end":false},{"code":"пұ¶","page":493,"end":true}],"text":"ЩҲЩҺЩҶЩҺШ§ШҜЩҺЩүЩ° ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҸ ЩҒЩҗЩү ЩӮЩҺЩҲЩ’Щ…ЩҗЩҮЩҗЫҰ ЩӮЩҺШ§Щ„ЩҺ ЩҠЩҺЩҖЩ°ЩӮЩҺЩҲЩ’Щ…Щҗ ШЈЩҺЩ„ЩҺЩҠЩ’ШіЩҺ Щ„ЩҗЩү Щ…ЩҸЩ„Щ’ЩғЩҸ Щ…ЩҗШөЩ’ШұЩҺ ЩҲЩҺЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩүЩ“ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ШӘЩҸШЁЩ’ШөЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"43:52","surah":43,"ayah":52,"num":4377,"page":493,"words":[{"code":"пұ·","page":493,"end":false},{"code":"пұё","page":493,"end":false},{"code":"пұ№","page":493,"end":false},{"code":"пұә","page":493,"end":false},{"code":"пұ»","page":493,"end":false},{"code":"пұј","page":493,"end":false},{"code":"пұҪ","page":493,"end":false},{"code":"пұҫ","page":493,"end":false},{"code":"пұҝ","page":493,"end":false},{"code":"пІҖ","page":493,"end":false},{"code":"пІҒ","page":493,"end":false},{"code":"пІӮ","page":493,"end":true}],"text":"ШЈЩҺЩ…Щ’ ШЈЩҺЩҶЩҺШ§Ы  Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҮЩҸЩҲЩҺ Щ…ЩҺЩҮЩҗЩҠЩҶЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺ
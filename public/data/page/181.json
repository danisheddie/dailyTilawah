alse},{"code":"пұҶ","page":181,"end":false},{"code":"пұҮ","page":181,"end":false},{"code":"пұҲ","page":181,"end":false},{"code":"пұү","page":181,"end":false},{"code":"пұҠ","page":181,"end":false},{"code":"пұӢ","page":181,"end":false},{"code":"пұҢ","page":181,"end":false},{"code":"пұҚпұҺ","page":181,"end":false},{"code":"пұҸ","page":181,"end":false},{"code":"пұҗ","page":181,"end":false},{"code":"пұ‘","page":181,"end":false},{"code":"пұ’","page":181,"end":false},{"code":"пұ“","page":181,"end":false},{"code":"пұ”","page":181,"end":false},{"code":"пұ•","page":181,"end":false},{"code":"пұ–","page":181,"end":false},{"code":"пұ—","page":181,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩ„Щ‘ЩҺШ§ ЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШөЩҸШҜЩ‘ЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҗ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…Щҗ ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҺЩҮЩҸЫҘЩ“ Ыҡ ШҘЩҗЩҶЩ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШӨЩҸЩҮЩҸЫҘЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ’Щ…ЩҸШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"8:35","surah":8,"ayah":35,"num":1195,"page":181,"words":[{"code":"пұҳ","page":181,"end":false},{"code":"пұҷ","page":181,"end":false},{"code":"пұҡ","page":181,"end":false},{"code":"пұӣ","page":181,"end":false},{"code":"пұң","page":181,"end":false},{"code":"пұқ","page":181,"end":false},{"code":"пұһ","page":181,"end":false},{"code":"пұҹпұ ","page":181,"end":false},{"code":"пұЎ","page":181,"end":false},{"code":"пұў","page":181,"end":false},{"code":"пұЈ","page":181,"end":false},{"code":"пұӨ","page":181,"end":false},{"code":"пұҘ","page":181,"end":false},{"code":"пұҰ","page":181,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ ШөЩҺЩ„ЩҺШ§ШӘЩҸЩҮЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ’ШЁЩҺЩҠЩ’ШӘЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҸЩғЩҺШ§Щ“ШЎЩӢЫӯ ЩҲЩҺШӘЩҺШөЩ’ШҜЩҗЩҠЩҺШ©ЩӢЫӯ Ыҡ ЩҒЩҺШ°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ШЁЩҗЩ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"8:36","surah":8,"ayah":36,"num":1196,"page":181,"words":[{"code":"пұ§","page":181,"end":false},{"code":"пұЁ","page":181,"end":false},{"code":"пұ©","page":181,"end":false},{"code":"пұӘ","page":181,"end":false},{"code":"пұ«","page":181,"end":false},{"code":"пұ¬","page":181,"end":false},{"code":"пұӯ","page":181,"end":false},{"code":"пұ®","page":181,"end":false},{"code":"пұҜпұ°","page":181,"end":false},{"code":"пұұ","page":181,"end":false},{"code":"пұІ","page":181,"end":false},{"code":"пұі","page":181,"end":false},{"code":"пұҙ","page":181,"end":false},{"code":"пұө","page":181,"end":false},{"code":"пұ¶","page":181,"end":false},{"code":"пұ·пұё","page":181,"end":false},{"code":"пұ№","page":181,"end":false},{"code":"пұә","page":181,"end":false},{"code":"пұ»","page":181,"end":false},{"code":"пұј","page":181,"end":false},{"code":"пұҪ","page":181,"end":false},{"code":"пұҫ","page":181,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҗЩҠЩҺШөЩҸШҜЩ‘ЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶ ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҒЩҺШіЩҺЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺЩҮЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ШӘЩҺЩғЩҸЩҲЩҶЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШӯЩҺШіЩ’ШұЩҺШ©ЩӢЫӯ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸШәЩ’Щ„ЩҺШЁЩҸЩҲЩҶЩҺ Ы— ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ ЩҠЩҸШӯЩ’ШҙЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"8:37","surah":8,"ayah":37,"num":1197,"page":181,"words":[{"code":"пұҝ","page":181,"end":false},{"code":"пІҖ","page":181,"end":false},{"code":"пІҒ","page":181,"end":false},{"code":"пІӮ","page":181,"end":false},{"code":"пІғ","page":181,"end":false},{"code":"пІ„","page":181,"end":false},{"code":"пІ…","page":181,"end":false},{"code":"пІҶ","page":181,"end":false},{"code":"пІҮ","page":181,"end":false},{"code":"пІҲ","page":181,"end":false},{"code":"пІү","page":181,"end":false},{"code":"пІҠ","page":181,"end":false},{"code":"пІӢ","page":181,"end":false},{"code":"пІҢ","page":181,"end":false},{"code":"пІҚпІҺ","page":181,"end":false},{"code":"пІҸ","page":181,"end":false},{"code":"пІҗ","page":181,"end":false},{"code":"пІ‘","page":181,"end":false},{"code":"пІ’","page":181,"end":true}],"text":"Щ„ЩҗЩҠЩҺЩ…ЩҗЩҠШІЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Ш®ЩҺШЁЩҗЩҠШ«ЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Ш·Щ‘ЩҺЩҠЩ‘ЩҗШЁЩҗ ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҺ ЩұЩ„Щ’Ш®ЩҺШЁЩҗЩҠШ«ЩҺ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў ЩҒЩҺЩҠЩҺШұЩ’ЩғЩҸЩ…ЩҺЩҮЩҸЫҘ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ ЩҒЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҺЩҮЩҸЫҘ ЩҒЩҗЩү Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш®ЩҺЩҖЩ°ШіЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"8:38","surah":8,"ayah":38,"num":1198,"page":181,"words":[{"code":"пІ“","page":181,"end":false},{"code":"пІ”","page":181,"end":false},{"code":"пІ•","page":181,"end":false},{"code":"пІ–","page":181,"end":false},{"code":"пІ—","page":181,"end":false},{"code":"пІҳ","page":181,"end":false},{"code":"пІҷ","page":181,"end":false},{"code":"пІҡ","page":181,"end":false},{"code":"пІӣ","page":181,"end":false},{"code":"пІң","page":181,"end":false},{"code":"пІқ","page":181,"end":false},{"code":"пІһ","page":181,"end":false},{"code":"пІҹ","page":181,"end":false},{"code":"пІ ","page":181,"end":false},{"code":"пІЎ","page":181,"end":false},{"code":"пІў","page":181,"end":false},{"code":"пІЈ","page":181,"end":true}],"text":"ЩӮЩҸЩ„ Щ„Щ‘ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶ ЩҠЩҺЩҶШӘЩҺЩҮЩҸЩҲШ§Ыҹ ЩҠЩҸШәЩ’ЩҒЩҺШұЩ’ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩӮЩҺШҜЩ’ ШіЩҺЩ„ЩҺЩҒЩҺ ЩҲЩҺШҘЩҗЩҶ ЩҠЩҺШ№ЩҸЩҲШҜЩҸЩҲШ§Ыҹ ЩҒЩҺЩӮЩҺШҜЩ’ Щ…ЩҺШ¶ЩҺШӘЩ’ ШіЩҸЩҶЩ‘ЩҺШӘЩҸ ЩұЩ„Щ’ШЈЩҺЩҲЩ‘ЩҺЩ„ЩҗЩҠЩҶЩҺ"},{"key":"8:39","surah":8,"ayah":39,"num":1199,"page":181,"words":[{"code":"пІӨ","page":181,"end":false},{"code":"пІҘ","page":181,"end":false},{"code":"пІҰ","page":181,"end":false},{"code":"пІ§","page":181,"end":false},{"code":"пІЁ","page":181,"end":false},{"code":"пІ©","page":181,"end":false},{"code":"пІӘ","page":181,"end":false},{"code":"пІ«","page":181,"end":false},{"code":"пІ¬пІӯ","page":181,"end":false},{"code":"пІ®","page":181,"end":false},{"code":"пІҜ","page":181,"end":false},{"code":"пІ°","page":181,"end":false},{"code":"пІұ","page":181,"end":false},{"code":"пІІ","page":181,"end":false},{"code":"пІі","page":181,"end":false},{"code":"пІҙ","page":181,"end":false},{"code":"пІө","page":181,"end":true}],"text":"ЩҲЩҺЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲЩҮЩҸЩ…Щ’ ШӯЩҺШӘЩ‘ЩҺЩүЩ° Щ„ЩҺШ§ ШӘЩҺЩғЩҸЩҲЩҶЩҺ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢЫӯ ЩҲЩҺЩҠЩҺЩғЩҸЩҲЩҶЩҺ ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҸ ЩғЩҸЩ„Щ‘ЩҸЩҮЩҸЫҘ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҒЩҺШҘЩҗЩҶЩҗ ЩұЩҶШӘЩҺЩҮЩҺЩҲЩ’Ш§Ыҹ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҗЩ…ЩҺШ§ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫӯ"},{"key":"8:40","surah":8,"ayah":40,"num":1200,"page":181,"words":[{"code":"пІ¶","page":181,"end":false},{"code":"пІ·","page":181,"end":false},{"code":"пІё","page":181,"end":false},{"code":"пІ№","page":181,"end":false},{"code":"пІә","page":181,"end":false},{"code":"пІ»пІј","page":181,"end":false},{"code":"пІҪ","page":181,"end":false},{"code":"пІҫ","page":181,"end":false},{"code":"пІҝ","page":181,"end":false},{"code":"піҖ","page":181,"end":false},{"code":"піҒ","page":181,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҲЩ’Ш§Ыҹ ЩҒЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҺЩҲЩ’Щ„ЩҺЩүЩ°ЩғЩҸЩ…Щ’ Ыҡ ЩҶЩҗШ№Щ’Щ…ЩҺ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’Щ„ЩҺЩүЩ° ЩҲЩҺЩҶЩҗШ№Щ’Щ…ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШөЩҗЩҠШұЩҸ"}]}
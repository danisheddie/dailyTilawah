false},{"code":"пұҺ","page":282,"end":false},{"code":"пұҸ","page":282,"end":false},{"code":"пұҗ","page":282,"end":false},{"code":"пұ‘пұ’","page":282,"end":false},{"code":"пұ“","page":282,"end":false},{"code":"пұ”","page":282,"end":false},{"code":"пұ•","page":282,"end":false},{"code":"пұ–","page":282,"end":false},{"code":"пұ—","page":282,"end":true}],"text":"ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШіЩ’ШұЩҺЩүЩ° ШЁЩҗШ№ЩҺШЁЩ’ШҜЩҗЩҮЩҗЫҰ Щ„ЩҺЩҠЩ’Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҗ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…Щҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҗ ЩұЩ„Щ’ШЈЩҺЩӮЩ’ШөЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ШЁЩҺЩҖЩ°ШұЩҺЩғЩ’ЩҶЩҺШ§ ШӯЩҺЩҲЩ’Щ„ЩҺЩҮЩҸЫҘ Щ„ЩҗЩҶЩҸШұЩҗЩҠЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶЩ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§Щ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҮЩҸЩҲЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҗЩҠШ№ЩҸ ЩұЩ„Щ’ШЁЩҺШөЩҗЩҠШұЩҸ"},{"key":"17:2","surah":17,"ayah":2,"num":2031,"page":282,"words":[{"code":"пұҳ","page":282,"end":false},{"code":"пұҷ","page":282,"end":false},{"code":"пұҡ","page":282,"end":false},{"code":"пұӣ","page":282,"end":false},{"code":"пұң","page":282,"end":false},{"code":"пұқ","page":282,"end":false},{"code":"пұһ","page":282,"end":false},{"code":"пұҹ","page":282,"end":false},{"code":"пұ ","page":282,"end":false},{"code":"пұЎ","page":282,"end":false},{"code":"пұў","page":282,"end":false},{"code":"пұЈ","page":282,"end":false},{"code":"пұӨ","page":282,"end":true}],"text":"ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҸЩҲШіЩҺЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩҮЩҸШҜЩӢЫӯЩү Щ„Щ‘ЩҗШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩү ЩҲЩҺЩғЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"17:3","surah":17,"ayah":3,"num":2032,"page":282,"words":[{"code":"пұҘ","page":282,"end":false},{"code":"пұҰ","page":282,"end":false},{"code":"пұ§","page":282,"end":false},{"code":"пұЁ","page":282,"end":false},{"code":"пұ©пұӘ","page":282,"end":false},{"code":"пұ«","page":282,"end":false},{"code":"пұ¬","page":282,"end":false},{"code":"пұӯ","page":282,"end":false},{"code":"пұ®","page":282,"end":false},{"code":"пұҜ","page":282,"end":true}],"text":"Ш°ЩҸШұЩ‘ЩҗЩҠЩ‘ЩҺШ©ЩҺ Щ…ЩҺЩҶЩ’ ШӯЩҺЩ…ЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҺШ№ЩҺ ЩҶЩҸЩҲШӯЩҚ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺШЁЩ’ШҜЩӢЫӯШ§ ШҙЩҺЩғЩҸЩҲШұЩӢЫӯШ§"},{"key":"17:4","surah":17,"ayah":4,"num":2033,"page":282,"words":[{"code":"пұ°","page":282,"end":false},{"code":"пұұ","page":282,"end":false},{"code":"пұІ","page":282,"end":false},{"code":"пұі","page":282,"end":false},{"code":"пұҙ","page":282,"end":false},{"code":"пұө","page":282,"end":false},{"code":"пұ¶","page":282,"end":false},{"code":"пұ·","page":282,"end":false},{"code":"пұё","page":282,"end":false},{"code":"пұ№","page":282,"end":false},{"code":"пұә","page":282,"end":false},{"code":"пұ»","page":282,"end":false},{"code":"пұј","page":282,"end":false},{"code":"пұҪ","page":282,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ¶ЩҺЩҠЩ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩүЩ° ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ„ЩҺШӘЩҸЩҒЩ’ШіЩҗШҜЩҸЩҶЩ‘ЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ…ЩҺШұЩ‘ЩҺШӘЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺЩ„ЩҺШӘЩҺШ№Щ’Щ„ЩҸЩҶЩ‘ЩҺ Ш№ЩҸЩ„ЩҸЩҲЩ‘ЩӢЫӯШ§ ЩғЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"17:5","surah":17,"ayah":5,"num":2034,"page":282,"words":[{"code":"пұҫ","page":282,"end":false},{"code":"пұҝ","page":282,"end":false},{"code":"пІҖ","page":282,"end":false},{"code":"пІҒ","page":282,"end":false},{"code":"пІӮ","page":282,"end":false},{"code":"пІғ","page":282,"end":false},{"code":"пІ„","page":282,"end":false},{"code":"пІ…","page":282,"end":false},{"code":"пІҶ","page":282,"end":false},{"code":"пІҮ","page":282,"end":false},{"code":"пІҲ","page":282,"end":false},{"code":"пІү","page":282,"end":false},{"code":"пІҠ","page":282,"end":false},{"code":"пІӢпІҢ","page":282,"end":false},{"code":"пІҚ","page":282,"end":false},{"code":"пІҺ","page":282,"end":false},{"code":"пІҸ","page":282,"end":false},{"code":"пІҗ","page":282,"end":true}],"text":"ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ ЩҲЩҺШ№Щ’ШҜЩҸ ШЈЩҸЩҲЩ„ЩҺЩүЩ°ЩҮЩҸЩ…ЩҺШ§ ШЁЩҺШ№ЩҺШ«Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ш№ЩҗШЁЩҺШ§ШҜЩӢЫӯШ§ Щ„Щ‘ЩҺЩҶЩҺШ§Щ“ ШЈЩҸЩҲЫҹЩ„ЩҗЩү ШЁЩҺШЈЩ’ШіЩҚЫў ШҙЩҺШҜЩҗЩҠШҜЩҚЫў ЩҒЩҺШ¬ЩҺШ§ШіЩҸЩҲШ§Ыҹ Ш®ЩҗЩ„ЩҺЩҖЩ°Щ„ЩҺ ЩұЩ„ШҜЩ‘ЩҗЩҠЩҺШ§ШұЩҗ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩҲЩҺШ№Щ’ШҜЩӢЫӯШ§ Щ…Щ‘ЩҺЩҒЩ’Ш№ЩҸЩҲЩ„ЩӢЫӯШ§"},{"key":"17:6","surah":17,"ayah":6,"num":2035,"page":282,"words":[{"code":"пІ‘","page":282,"end":false},{"code":"пІ’","page":282,"end":false},{"code":"пІ“","page":282,"end":false},{"code":"пІ”","page":282,"end":false},{"code":"пІ•","page":282,"end":false},{"code":"пІ–","page":282,"end":false},{"code":"пІ—","page":282,"end":false},{"code":"пІҳ","page":282,"end":false},{"code":"пІҷ","page":282,"end":false},{"code":"пІҡ","page":282,"end":false},{"code":"пІӣ","page":282,"end":false},{"code":"пІң","page":282,"end":true}],"text":"Ш«ЩҸЩ…Щ‘ЩҺ ШұЩҺШҜЩҺШҜЩ’ЩҶЩҺШ§ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҺШұЩ‘ЩҺШ©ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩ…Щ’ШҜЩҺШҜЩ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ… ШЁЩҗШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҚЫў ЩҲЩҺШЁЩҺЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ…Щ’ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ ЩҶЩҺЩҒЩҗЩҠШұЩӢШ§"},{"key":"17:7","surah":17,"ayah":7,"num":2036,"page":282,"words":[{"code":"пІқ","page":282,"end":false},{"code":"пІһ","page":282,"end":false},{"code":"пІҹ","page":282,"end":false},{"code":"пІ пІЎ","page":282,"end":false},{"code":"пІў","page":282,"end":false},{"code":"пІЈ","page":282,"end":false},{"code":"пІӨпІҘ","page":282,"end":false},{"code":"пІҰ","page":282,"end":false},{"code":"пІ§","page":282,"end":false},{"code":"пІЁ","page":282,"end":false},{"code":"пІ©","page":282,"end":false},{"code":"пІӘ","page":282,"end":false},{"code":"пІ«","page":282,"end":false},{"code":"пІ¬","page":282,"end":false},{"code":"пІӯ","page":282,"end":false},{"code":"пІ®","page":282,"end":false},{"code":"пІҜ","page":282,"end":false},{"code":"пІ°","page":282,"end":false},{"code":"пІұ","page":282,"end":false},{"code":"пІІ","page":282,"end":false},{"code":"пІі","page":282,"end":false},{"code":"пІҙ","page":282,"end":false},{"code":"пІө","page":282,"end":false},{"code":"пІ¶","page":282,"end":true}],"text":"ШҘЩҗЩҶЩ’ ШЈЩҺШӯЩ’ШіЩҺЩҶШӘЩҸЩ…Щ’ ШЈЩҺШӯЩ’ШіЩҺЩҶШӘЩҸЩ…Щ’ Щ„ЩҗШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ Ы– ЩҲЩҺШҘЩҗЩҶЩ’ ШЈЩҺШіЩҺШЈЩ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩҮЩҺШ§ Ыҡ ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ ЩҲЩҺШ№Щ’ШҜЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Щ„ЩҗЩҠЩҺШіЩҸЩҖЫҘЩ“ЩҖЩ”ЩҸЩҲШ§Ыҹ ЩҲЩҸШ¬ЩҸЩҲЩҮЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҗЩҠЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҺ ЩғЩҺЩ…ЩҺШ§ ШҜЩҺШ®ЩҺЩ„ЩҸЩҲЩҮЩҸ ШЈЩҺЩҲЩ‘ЩҺЩ„ЩҺ Щ…ЩҺШұЩ‘ЩҺШ©ЩҚЫў ЩҲЩҺЩ„ЩҗЩҠЩҸШӘЩҺШЁЩ‘ЩҗШұЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Ш№ЩҺЩ„ЩҺЩҲЩ’Ш§Ыҹ ШӘЩҺШӘЩ’ШЁЩҗЩҠШұЩӢШ§"}]}
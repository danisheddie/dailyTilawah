ЩҺШ§ШӘЩҺШӘЩ’ ЩғЩҸЩ„Щ‘ЩҺ ЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩҶЩ‘ЩҺ ШіЩҗЩғЩ‘ЩҗЩҠЩҶЩӢЫӯШ§ ЩҲЩҺЩӮЩҺШ§Щ„ЩҺШӘЩҗ ЩұШ®Щ’ШұЩҸШ¬Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ Ы– ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШұЩҺШЈЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЫҘЩ“ ШЈЩҺЩғЩ’ШЁЩҺШұЩ’ЩҶЩҺЩҮЩҸЫҘ ЩҲЩҺЩӮЩҺШ·Щ‘ЩҺШ№Щ’ЩҶЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩӮЩҸЩ„Щ’ЩҶЩҺ ШӯЩҺЩҖЩ°ШҙЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ШЁЩҺШҙЩҺШұЩӢШ§ ШҘЩҗЩҶЩ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩҢЫӯ ЩғЩҺШұЩҗЩҠЩ…ЩҢЫӯ"},{"key":"12:32","surah":12,"ayah":32,"num":1628,"page":239,"words":[{"code":"пұЈ","page":239,"end":false},{"code":"пұӨ","page":239,"end":false},{"code":"пұҘ","page":239,"end":false},{"code":"пұҰ","page":239,"end":false},{"code":"пұ§пұЁ","page":239,"end":false},{"code":"пұ©","page":239,"end":false},{"code":"пұӘ","page":239,"end":false},{"code":"пұ«","page":239,"end":false},{"code":"пұ¬","page":239,"end":false},{"code":"пұӯпұ®","page":239,"end":false},{"code":"пұҜ","page":239,"end":false},{"code":"пұ°","page":239,"end":false},{"code":"пұұ","page":239,"end":false},{"code":"пұІ","page":239,"end":false},{"code":"пұі","page":239,"end":false},{"code":"пұҙ","page":239,"end":false},{"code":"пұө","page":239,"end":false},{"code":"пұ¶","page":239,"end":false},{"code":"пұ·","page":239,"end":false},{"code":"пұё","page":239,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺШӘЩ’ ЩҒЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҸЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Щ„ЩҸЩ…Щ’ШӘЩҸЩҶЩ‘ЩҺЩҶЩҗЩү ЩҒЩҗЩҠЩҮЩҗ Ы– ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШұЩҺЩ°ЩҲЩҺШҜШӘЩ‘ЩҸЩҮЩҸЫҘ Ш№ЩҺЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҗЩҮЩҗЫҰ ЩҒЩҺЩұШіЩ’ШӘЩҺШ№Щ’ШөЩҺЩ…ЩҺ Ы– ЩҲЩҺЩ„ЩҺШҰЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„Щ’ Щ…ЩҺШ§Щ“ ШЎЩҺШ§Щ…ЩҸШұЩҸЩҮЩҸЫҘ Щ„ЩҺЩҠЩҸШіЩ’Ш¬ЩҺЩҶЩҺЩҶЩ‘ЩҺ ЩҲЩҺЩ„ЩҺЩҠЩҺЩғЩҸЩҲЩҶЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°ШәЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"12:33","surah":12,"ayah":33,"num":1629,"page":239,"words":[{"code":"пұ№","page":239,"end":false},{"code":"пұә","page":239,"end":false},{"code":"пұ»","page":239,"end":false},{"code":"пұј","page":239,"end":false},{"code":"пұҪ","page":239,"end":false},{"code":"пұҫ","page":239,"end":false},{"code":"пұҝ","page":239,"end":false},{"code":"пІҖпІҒ","page":239,"end":false},{
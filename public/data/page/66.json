§","page":66,"end":false},{"code":"пІЁ","page":66,"end":false},{"code":"пІ©","page":66,"end":false},{"code":"пІӘпІ«","page":66,"end":false},{"code":"пІ¬","page":66,"end":false},{"code":"пІӯ","page":66,"end":false},{"code":"пІ®","page":66,"end":false},{"code":"пІҜ","page":66,"end":false},{"code":"пІ°","page":66,"end":false},{"code":"пІұпІІ","page":66,"end":false},{"code":"пІі","page":66,"end":false},{"code":"пІҙ","page":66,"end":false},{"code":"пІө","page":66,"end":false},{"code":"пІ¶","page":66,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ Щ„ЩҗЩ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҸ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"3:130","surah":3,"ayah":130,"num":423,"page":66,"words":[{"code":"пІ·","page":66,"end":false},{"code":"пІё","page":66,"end":false},{"code":"пІ№","page":66,"end":false},{"code":"пІә","page":66,"end":false},{"code":"пІ»","page":66,"end":false},{"code":"пІј","page":66,"end":false},{"code":"пІҪ","page":66,"end":false},{"code":"пІҫпІҝ","page":66,"end":false},{"code":"піҖ","page":66,"end":false},{"code":"піҒ","page":66,"end":false},{"code":"піӮ","page":66,"end":false},{"code":"піғ","page":66,"end":false},{"code":"пі„","page":66,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Щ“Ш§Ыҹ ШЈЩҺШ¶Щ’Ш№ЩҺЩҖЩ°ЩҒЩӢЫӯШ§ Щ…Щ‘ЩҸШ¶ЩҺЩҖЩ°Ш№ЩҺЩҒЩҺШ©ЩӢЫӯ Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"3:131","surah":3,"ayah":131,"num":424,"page":66,"words":[{"code":"пі…","page":66,"end":false},{"code":"піҶ","page":66,"end":false},{"code":"піҮ","page":66,"end":false},{"code":"піҲ","page":66,"end":false},{"code":"піү","page":66,"end":false},{"code":"піҠ","page":66,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҺ ЩұЩ„Щ‘ЩҺШӘЩҗЩүЩ“ ШЈЩҸШ№ЩҗШҜЩ‘ЩҺШӘЩ’ Щ„ЩҗЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"3:132","surah":3,"ayah":132,"num":425,"page":66,"words":[{"code":"піӢ","page":66,"end":false},{"code":"піҢ","page":66,"end":false},{"code":"піҚ","page":66,"end":false},{"code":"піҺ","page":66,"end":false},{"code":"піҸ","page":66,"end":false},{"code":"піҗ","page":66,"end":true}],"text":"ЩҲЩҺШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸШұЩ’ШӯЩҺЩ…ЩҸЩҲЩҶЩҺ"}]}
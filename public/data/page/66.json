age":66,"end":false},{"code":"пұӨ","page":66,"end":false},{"code":"пұҘ","page":66,"end":false},{"code":"пұҰ","page":66,"end":false},{"code":"пұ§","page":66,"end":false},{"code":"пұЁ","page":66,"end":true}],"text":"ШҘЩҗШ°Щ’ ШӘЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҗЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ШЈЩҺЩ„ЩҺЩҶ ЩҠЩҺЩғЩ’ЩҒЩҗЩҠЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ЩҠЩҸЩ…ЩҗШҜЩ‘ЩҺЩғЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ… ШЁЩҗШ«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҺШ©Щҗ ШЎЩҺШ§Щ„ЩҺЩҖЩ°ЩҒЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©Щҗ Щ…ЩҸЩҶШІЩҺЩ„ЩҗЩҠЩҶЩҺ"},{"key":"3:125","surah":3,"ayah":125,"num":418,"page":66,"words":[{"code":"пұ©пұӘ","page":66,"end":false},{"code":"пұ«","page":66,"end":false},{"code":"пұ¬","page":66,"end":false},{"code":"пұӯ","page":66,"end":false},{"code":"пұ®","page":66,"end":false},{"code":"пұҜ","page":66,"end":false},{"code":"пұ°","page":66,"end":false},{"code":"пұұ","page":66,"end":false},{"code":"пұІ","page":66,"end":false},{"code":"пұі","page":66,"end":false},{"code":"пұҙ","page":66,"end":false},{"code":"пұө","page":66,"end":false},{"code":"пұ¶","page":66,"end":false},{"code":"пұ·","page":66,"end":false},{"code":"пұё","page":66,"end":false},{"code":"пұ№","page":66,"end":true}],"text":"ШЁЩҺЩ„ЩҺЩүЩ°Щ“ Ыҡ ШҘЩҗЩҶ ШӘЩҺШөЩ’ШЁЩҗШұЩҸЩҲШ§Ыҹ ЩҲЩҺШӘЩҺШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩҲЩҺЩҠЩҺШЈЩ’ШӘЩҸЩҲЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҒЩҺЩҲЩ’ШұЩҗЩҮЩҗЩ…Щ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩҠЩҸЩ…Щ’ШҜЩҗШҜЩ’ЩғЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ… ШЁЩҗШ®ЩҺЩ…Щ’ШіЩҺШ©Щҗ ШЎЩҺШ§Щ„ЩҺЩҖЩ°ЩҒЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©Щҗ Щ…ЩҸШіЩҺЩҲЩ‘ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"3:126","surah":3,"ayah":126,"num":419,"page":66,"words":[{"code":"пұә","page":66,"end":false},{"code":"пұ»","page":66,"end":false},{"code":"пұј","page":66,"end":false},{"code":"пұҪ","page":66,"end":false},{"code":"пұҫ","page":66,"end":false},{"code":"пұҝ","page":66,"end":false},{"code":"пІҖ","page":66,"end":false},{"code":"пІҒ","page":66,"end":false},{"code":"пІӮпІғ","page":66,"end":false},{"code":"пІ„","page":66,"end":false},{"code":"пІ…","page":66,"end":false},{"code":"пІҶ","page":66,"end":false},{"code":"пІҮ","page":66,"end":false},{"code":"пІҲ","page"
de":"піӢ","end":false},{"code":"піҢ","end":true}]}],"verses":[{"key":"36:71","surah":36,"ayah":71,"num":3776,"page":445,"words":[{"code":"пұҒ","page":445,"end":false},{"code":"пұӮ","page":445,"end":false},{"code":"пұғ","page":445,"end":false},{"code":"пұ„","page":445,"end":false},{"code":"пұ…","page":445,"end":false},{"code":"пұҶ","page":445,"end":false},{"code":"пұҮ","page":445,"end":false},{"code":"пұҲ","page":445,"end":false},{"code":"пұү","page":445,"end":false},{"code":"пұҠ","page":445,"end":false},{"code":"пұӢ","page":445,"end":false},{"code":"пұҢ","page":445,"end":false},{"code":"пұҚ","page":445,"end":true}],"text":"ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҺШӘЩ’ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҶЩҺШ§Щ“ ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…ЩӢЫӯШ§ ЩҒЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺЩҮЩҺШ§ Щ…ЩҺЩҖЩ°Щ„ЩҗЩғЩҸЩҲЩҶЩҺ"},{"key":"36:72","surah":36,"ayah":72,"num":3777,"page":445,"words":[{"code":"пұҺ","page":445,"end":false},{"code":"пұҸ","page":445,"end":false},{"code":"пұҗ","page":445,"end":false},{"code":"пұ‘","page":445,"end":false},{"code":"пұ’","page":445,"end":false},{"code":"пұ“","page":445,"end":false},{"code":"пұ”","page":445,"end":true}],"text":"ЩҲЩҺШ°ЩҺЩ„Щ‘ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШұЩҺЩғЩҸЩҲШЁЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҺШ§ ЩҠЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ"},{"key":"36:73","surah":36,"ayah":73,"num":3778,"page":445,"words":[{"code":"пұ•","page":445,"end":false},{"code":"пұ–","page":445,"end":false},{"code":"пұ—","page":445,"end":false},{"code":"пұҳпұҷ","page":445,"end":false},{"code":"пұҡ","page":445,"end":false},{"code":"пұӣ","page":445,"end":false},{"code":"пұң","page":445,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҺЩҶЩҺЩҖЩ°ЩҒЩҗШ№ЩҸ ЩҲЩҺЩ…ЩҺШҙЩҺШ§ШұЩҗШЁЩҸ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ЩҠЩҺШҙЩ’ЩғЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"36:74","surah":36,"ayah":74,"num":3779,"page":445,"words":[{"code":"пұқ","page":445,"end":false},{"code":"пұһ","page":445,"end":false},{"code":"пұҹ","page":445,"end":false},{"code":"пұ ","page":445,"end":false},{"code":"пұЎ","page":445,"end":false},{"code":"пұў","page":445,"end":false},{"code":"пұЈ","page":445,"end":false},{"code":"пұӨ","page":445,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺШ®ЩҺШ°ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЎЩҺШ§Щ„ЩҗЩҮЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҸЩҶШөЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"36:75","surah":36,"ayah":75,"num":3780,"page":445,"words":[{"code":"пұҘ","page":445,"end":false},{"code":"пұҰ","page":445,"end":false},{"code":"пұ§","page":445,"end":false},{"code":"пұЁ","page":445,"end":false},{"code":"пұ©","page":445,"end":false},{"code":"пұӘ","page":445,"end":false},{"code":"пұ«","page":445,"end":false},{"code":"пұ¬","page":445,"end":true}],"text":"Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШ·ЩҗЩҠШ№ЩҸЩҲЩҶЩҺ ЩҶЩҺШөЩ’ШұЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш¬ЩҸЩҶШҜЩҢЫӯ Щ…Щ‘ЩҸШӯЩ’Ш¶ЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"36:76","surah":36,"ayah":76,"num":3781,"page":445,"words":[{"code":"пұӯ","page":445,"end":false},{"code":"пұ®","page":445,"end":false},{"code":"пұҜпұ°","page":445,"end":false},{"code":"пұұ","page":445,"end":false},{"code":"пұІ","page":445,"end":false},{"code":"пұі","page":445,"end":false},{"code":"пұҙ","page":445,"end":false},{"code":"пұө","page":445,"end":false},{"code":"пұ¶","page":445,"end":false},{"code":"пұ·","page":445,"end":true}],"text":"ЩҒЩҺЩ„ЩҺШ§ ЩҠЩҺШӯЩ’ШІЩҸЩҶЩғЩҺ ЩӮЩҺЩҲЩ’Щ„ЩҸЩҮЩҸЩ…Щ’ Ыҳ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩҶЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Щ…ЩҺШ§ ЩҠЩҸШіЩҗШұЩ‘ЩҸЩҲЩҶЩҺ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҸШ№Щ’Щ„ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"36:77","surah":36,"ayah":77,"num":3782,"page":445,"words":[{"code":"пұё","page":445,"end":false},{"code":"пұ№","page":445,"end":false},{"code":"пұә","page":445,"end":false},{"code":"пұ»","page":445,"end":false},{"code":"пұј","page":445,"end":false},{"code":"пұҪ","page":445,"end":false},{"code":"пұҫ","page":445,"end":false},{"code":"пұҝ","page":445,"end":false},{"code":"пІҖ","page":445,"end":false},{"code":"пІҒ","page":445,"end":false},{"code":"пІӮ","page":445,"end":false},{"code":"пІғ","page":445,"end":true}],"text":"ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҸ ШЈЩҺЩҶЩ‘ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺЩҖ
:559,"end":false},{"code":"піҗ","page":559,"end":true}],"text":"ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩӢЫӯШ§ ЩҠЩҺШӘЩ’Щ„ЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗЩҠЩҸШ®Щ’ШұЩҗШ¬ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ Щ…ЩҗЩҶЩҺ ЩұЩ„ШёЩ‘ЩҸЩ„ЩҸЩ…ЩҺЩҖЩ°ШӘЩҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҸЩҲШұЩҗ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЫў ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩҠЩҺШ№Щ’Щ…ЩҺЩ„Щ’ ШөЩҺЩҖЩ°Щ„ЩҗШӯЩӢЫӯШ§ ЩҠЩҸШҜЩ’Ш®ЩҗЩ„Щ’ЩҮЩҸ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺШЁЩҺШҜЩӢЫӯШ§ Ы– ЩӮЩҺШҜЩ’ ШЈЩҺШӯЩ’ШіЩҺЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩҮЩҸЫҘ ШұЩҗШІЩ’ЩӮЩӢШ§"},{"key":"65:12","surah":65,"ayah":12,"num":5229,"page":559,"words":[{"code":"пі‘","page":559,"end":false},{"code":"пі’","page":559,"end":false},{"code":"пі“","page":559,"end":false},{"code":"пі”","page":559,"end":false},{"code":"пі•","page":559,"end":false},{"code":"пі–","page":559,"end":false},{"code":"пі—","page":559,"end":false},{"code":"піҳпіҷ","page":559,"end":false},{"code":"піҡ","page":559,"end":false},{"code":"піӣ","page":559,"end":false},{"code":"пің","page":559,"end":false},{"code":"піқ","page":559,"end":false},{"code":"піһ","page":559,"end":false},{"code":"піҹ","page":559,"end":false},{"code":"пі ","page":559,"end":false},{"code":"піЎ","page":559,"end":false},{"code":"піў","page":559,"end":false},{"code":"піЈ","page":559,"end":false},{"code":"піӨ","page":559,"end":false},{"code":"піҘ","page":559,"end":false},{"code":"піҰ","page":559,"end":false},{"code":"пі§","page":559,"end":false},{"code":"піЁ","page":559,"end":false},{"code":"пі©","page":559,"end":false},{"code":"піӘ","page":559,"end":false},{"code":"пі«","page":559,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺ ШіЩҺШЁЩ’Ш№ЩҺ ШіЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҚЫў ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ…ЩҗШ«Щ’Щ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҠЩҺШӘЩҺЩҶЩҺШІЩ‘ЩҺЩ„ЩҸ ЩұЩ„Щ’ШЈЩҺЩ…Щ’ШұЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩҶЩ‘ЩҺ Щ„ЩҗШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢЫӯ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺШҜЩ’ ШЈЩҺШӯЩҺШ§Ш·ЩҺ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҗЩ„Щ’Щ…ЩӢЫўШ§"}]}
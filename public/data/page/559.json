e},{"code":"пұў","page":559,"end":false},{"code":"пұЈ","page":559,"end":false},{"code":"пұӨ","page":559,"end":true}],"text":"ШЈЩҺШіЩ’ЩғЩҗЩҶЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩ’ ШӯЩҺЩҠЩ’Ш«ЩҸ ШіЩҺЩғЩҺЩҶШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҲЩҸШ¬Щ’ШҜЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШ¶ЩҺШ§Щ“ШұЩ‘ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ„ЩҗШӘЩҸШ¶ЩҺЩҠЩ‘ЩҗЩӮЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ Ыҡ ЩҲЩҺШҘЩҗЩҶ ЩғЩҸЩҶЩ‘ЩҺ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°ШӘЩҗ ШӯЩҺЩ…Щ’Щ„ЩҚЫў ЩҒЩҺШЈЩҺЩҶЩҒЩҗЩӮЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШ¶ЩҺШ№Щ’ЩҶЩҺ ШӯЩҺЩ…Щ’Щ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ Ыҡ ЩҒЩҺШҘЩҗЩҶЩ’ ШЈЩҺШұЩ’Ш¶ЩҺШ№Щ’ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩҖЩ”ЩҺШ§ШӘЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЈЩҸШ¬ЩҸЩҲШұЩҺЩҮЩҸЩҶЩ‘ЩҺ Ы– ЩҲЩҺШЈЩ’ШӘЩҺЩ…ЩҗШұЩҸЩҲШ§Ыҹ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҚЫў Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҺШ№ЩҺШ§ШіЩҺШұЩ’ШӘЩҸЩ…Щ’ ЩҒЩҺШіЩҺШӘЩҸШұЩ’Ш¶ЩҗШ№ЩҸ Щ„ЩҺЩҮЩҸЫҘЩ“ ШЈЩҸШ®Щ’ШұЩҺЩүЩ°"},{"key":"65:7","surah":65,"ayah":7,"num":5224,"page":559,"words":[{"code":"пұҘ","page":559,"end":false},{"code":"пұҰ","page":559,"end":false},{"code":"пұ§","page":559,"end":false},{"code":"пұЁ","page":559,"end":false},{"code":"пұ©пұӘ","page":559,"end":false},{"code":"пұ«","page":559,"end":false},{"code":"пұ¬","page":559,"end":false},{"code":"пұӯ","page":559,"end":false},{"code":"пұ®","page":559,"end":false},{"code":"пұҜ","page":559,"end":false},{"code":"пұ°","page":559,"end":false},{"code":"пұұ","page":559,"end":false},{"code":"пұІпұі","page":559,"end":false},{"code":"пұҙ","page":559,"end":false},{"code":"пұө","page":559,"end":false},{"code":"пұ¶","page":559,"end":false},{"code":"пұ·","page":559,"end":false},{"code":"пұё","page":559,"end":false},{"code":"пұ№","page":559,"end":false},{"code":"пұәпұ»","page":559,"end":false},{"code":"пұј","page":559,"end":false},{"code":"пұҪ","page":559,"end":false},{"code":"пұҫ","page":559,"end":false},{"code":"пұҝ","page":559,"end":false},{"code":"пІҖ","page":559,"end":false},{"code":"пІҒ","page":559,"end":true}],"text":"Щ„ЩҗЩҠЩҸЩҶЩҒЩҗЩӮЩ’ Ш°ЩҸЩҲ ШіЩҺШ№ЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶ ШіЩҺШ№ЩҺШӘЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺЩ…ЩҺЩҶ ЩӮЩҸШҜЩҗШұЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШұЩҗШІЩ’ЩӮЩҸЩҮЩҸЫҘ ЩҒЩҺЩ„Щ’ЩҠЩҸЩҶЩҒЩҗЩӮЩ’ Щ…ЩҗЩ…Щ‘ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩүЩ°ЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ Щ„ЩҺШ§ ЩҠЩҸЩғЩҺЩ„Щ‘ЩҗЩҒЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҶЩҺЩҒЩ’ШіЩӢШ§ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩүЩ°ЩҮЩҺШ§ Ыҡ ШіЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҺШ№Щ’ШҜЩҺ Ш№ЩҸШіЩ’ШұЩҚЫў ЩҠЩҸШіЩ’ШұЩӢЫӯШ§"},{"key":"65:8","surah":65,"ayah":8,"num":5225,"page":559,"words":[{"code":"пІӮ","page":559,"end":false},{"code":"пІғ","page":559,"end":false},{"code":"пІ„","page":559,"end":false},{"code":"пІ…","page":559,"end":false},{"code":"пІҶ","page":559,"end":false},{"code":"пІҮ","page":559,"end":false},{"code":"пІҲ","page":559,"end":false},{"code":"пІү","page":559,"end":false},{"code":"пІҠ","page":559,"end":false},{"code":"пІӢ","page":559,"end":false},{"code":"пІҢ","page":559,"end":false},{"code":"пІҚ","page":559,"end":false},{"code":"пІҺ","page":559,"end":false},{"code":"пІҸ","page":559,"end":false},{"code":"пІҗ","page":559,"end":true}],"text":"ЩҲЩҺЩғЩҺШЈЩҺЩҠЩ‘ЩҗЩҶ Щ…Щ‘ЩҗЩҶ ЩӮЩҺШұЩ’ЩҠЩҺШ©ЩҚ Ш№ЩҺШӘЩҺШӘЩ’ Ш№ЩҺЩҶЩ’ ШЈЩҺЩ…Щ’ШұЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҺШ§ ЩҲЩҺШұЩҸШіЩҸЩ„ЩҗЩҮЩҗЫҰ ЩҒЩҺШӯЩҺШ§ШіЩҺШЁЩ’ЩҶЩҺЩҖЩ°ЩҮЩҺШ§ ШӯЩҗШіЩҺШ§ШЁЩӢЫӯШ§ ШҙЩҺШҜЩҗЩҠШҜЩӢЫӯШ§ ЩҲЩҺШ№ЩҺШ°Щ‘ЩҺШЁЩ’ЩҶЩҺЩҖЩ°ЩҮЩҺШ§ Ш№ЩҺШ°ЩҺШ§ШЁЩӢЫӯШ§ ЩҶЩ‘ЩҸЩғЩ’ШұЩӢЫӯШ§"},{"key":"65:9","surah":65,"ayah":9,"num":5226,"page":559,"words":[{"code":"пІ‘","page":559,"end":false},{"code":"пІ’","page":559,"end":false},{"code":"пІ“","page":559,"end":false},{"code":"пІ”","page":559,"end":false},{"code":"пІ•","page":559,"end":false},{"code":"пІ–","page":559,"end":false},{"code":"пІ—","page":559,"end":false},{"code":"пІҳ","page":559,"end":true}],"text":"ЩҒЩҺШ°ЩҺШ§ЩӮЩҺШӘЩ’ ЩҲЩҺШЁЩҺШ§Щ„ЩҺ ШЈЩҺЩ…Щ’ШұЩҗЩҮЩҺШ§ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШ©ЩҸ ШЈЩҺЩ…Щ’ШұЩҗЩҮЩҺШ§ Ш®ЩҸШіЩ’ШұЩӢШ§"},{"key":"65:10","surah":65,"ayah":10,"num":5227,"page":559,"words":[{"code":"пІҷ","page":559,"end":false},{"code":"пІҡ","page":559,"end":false},{"code":"пІӣ","page":559,"end":false},{"code":"пІң","page":559,"end":false},{"code":"пІқпІһ","page":559,"end":false},{"code":"пІҹ","page":559,"end":false},{"code":"пІ ","page":559,"end":false},{"code":"пІЎ","page":559,"end":fal
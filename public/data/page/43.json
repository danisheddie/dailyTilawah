":43,"end":false},{"code":"пі„","page":43,"end":false},{"code":"пі…","page":43,"end":false},{"code":"піҶ","page":43,"end":false},{"code":"піҮ","page":43,"end":false},{"code":"піҲпіү","page":43,"end":false},{"code":"піҠ","page":43,"end":false},{"code":"піӢ","page":43,"end":false},{"code":"піҢ","page":43,"end":false},{"code":"піҚ","page":43,"end":false},{"code":"піҺ","page":43,"end":false},{"code":"піҸ","page":43,"end":false},{"code":"піҗ","page":43,"end":false},{"code":"пі‘","page":43,"end":false},{"code":"пі’","page":43,"end":false},{"code":"пі“","page":43,"end":false},{"code":"пі”","page":43,"end":false},{"code":"пі•","page":43,"end":true}],"text":"ШЈЩҺЩҲЩ’ ЩғЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩү Щ…ЩҺШұЩ‘ЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩӮЩҺШұЩ’ЩҠЩҺШ©ЩҚЫў ЩҲЩҺЩҮЩҗЩүЩҺ Ш®ЩҺШ§ЩҲЩҗЩҠЩҺШ©ЩҢ Ш№ЩҺЩ„ЩҺЩүЩ° Ш№ЩҸШұЩҸЩҲШҙЩҗЩҮЩҺШ§ ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺЩҶЩ‘ЩҺЩүЩ° ЩҠЩҸШӯЩ’ЩүЩҗЫҰ ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҺШ№Щ’ШҜЩҺ Щ…ЩҺЩҲЩ’ШӘЩҗЩҮЩҺШ§ Ы– ЩҒЩҺШЈЩҺЩ…ЩҺШ§ШӘЩҺЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗШ§ЫҹШҰЩҺШ©ЩҺ Ш№ЩҺШ§Щ…ЩҚЫў Ш«ЩҸЩ…Щ‘ЩҺ ШЁЩҺШ№ЩҺШ«ЩҺЩҮЩҸЫҘ Ы– ЩӮЩҺШ§Щ„ЩҺ ЩғЩҺЩ…Щ’ Щ„ЩҺШЁЩҗШ«Щ’ШӘЩҺ Ы– ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҺШЁЩҗШ«Щ’ШӘЩҸ ЩҠЩҺЩҲЩ’Щ…ЩӢШ§ ШЈЩҺЩҲЩ’ ШЁЩҺШ№Щ’Ш¶ЩҺ ЩҠЩҺЩҲЩ’Щ…ЩҚЫў Ы– ЩӮЩҺШ§Щ„ЩҺ ШЁЩҺЩ„ Щ„Щ‘ЩҺШЁЩҗШ«Щ’ШӘЩҺ Щ…ЩҗШ§ЫҹШҰЩҺШ©ЩҺ Ш№ЩҺШ§Щ…ЩҚЫў ЩҒЩҺЩұЩҶШёЩҸШұЩ’ ШҘЩҗЩ„ЩҺЩүЩ° Ш·ЩҺШ№ЩҺШ§Щ…ЩҗЩғЩҺ ЩҲЩҺШҙЩҺШұЩҺШ§ШЁЩҗЩғЩҺ Щ„ЩҺЩ…Щ’ ЩҠЩҺШӘЩҺШіЩҺЩҶЩ‘ЩҺЩҮЩ’ Ы– ЩҲЩҺЩұЩҶШёЩҸШұЩ’ ШҘЩҗЩ„ЩҺЩүЩ° ШӯЩҗЩ…ЩҺШ§ШұЩҗЩғЩҺ ЩҲЩҺЩ„ЩҗЩҶЩҺШ¬Щ’Ш№ЩҺЩ„ЩҺЩғЩҺ ШЎЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Ы– ЩҲЩҺЩұЩҶШёЩҸШұЩ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Ш№ЩҗШёЩҺШ§Щ…Щҗ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩҶЩҸЩҶШҙЩҗШІЩҸЩҮЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ЩҶЩҺЩғЩ’ШіЩҸЩҲЩҮЩҺШ§ Щ„ЩҺШӯЩ’Щ…ЩӢЫӯШ§ Ыҡ ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҺ Щ„ЩҺЩҮЩҸЫҘ ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢЫӯ"}]}
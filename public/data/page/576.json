ҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩӢЫӯШ§ Ыҷ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШұЩ’ШӘЩҺШ§ШЁЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸЩҲШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ Ыҷ ЩҲЩҺЩ„ЩҗЩҠЩҺЩӮЩҸЩҲЩ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ… Щ…Щ‘ЩҺШұЩҺШ¶ЩҢЫӯ ЩҲЩҺЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Ш°ЩҺШ§Щ“ ШЈЩҺШұЩҺШ§ШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩү Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Ш¬ЩҸЩҶЩҸЩҲШҜЩҺ ШұЩҺШЁЩ‘ЩҗЩғЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҗЩүЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш°ЩҗЩғЩ’ШұЩҺЩүЩ° Щ„ЩҗЩ„Щ’ШЁЩҺШҙЩҺШұЩҗ"},{"key":"74:32","surah":74,"ayah":32,"num":5527,"page":576,"words":[{"code":"пІҙ","page":576,"end":false},{"code":"пІө","page":576,"end":false},{"code":"пІ¶","page":576,"end":true}],"text":"ЩғЩҺЩ„Щ‘ЩҺШ§ ЩҲЩҺЩұЩ„Щ’ЩӮЩҺЩ…ЩҺШұЩҗ"},{"key":"74:33","surah":74,"ayah":33,"num":5528,"page":576,"words":[{"code":"пІ·","page":576,"end":false},{"code":"пІё","page":576,"end":false},{"code":"пІ№","page":576,"end":false},{"code":"пІә","page":576,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ШҘЩҗШ°Щ’ ШЈЩҺШҜЩ’ШЁЩҺШұЩҺ"},{"key":"74:34","surah":74,"ayah":34,"num":5529,"page":576,"words":[{"code":"пІ»","page":576,"end":false},{"code":"пІј","page":576,"end":false},{"code":"пІҪ","page":576,"end":false},{"code":"пІҫ","page":576,"end":true}],"text":"ЩҲЩҺЩұЩ„ШөЩ‘ЩҸШЁЩ’ШӯЩҗ ШҘЩҗШ°ЩҺШ§Щ“ ШЈЩҺШіЩ’ЩҒЩҺШұЩҺ"},{"key":"74:35","surah":74,"ayah":35,"num":5530,"page":576,"words":[{"code":"пІҝ","page":576,"end":false},{"code":"піҖ","page":576,"end":false},{"code":"піҒ","page":576,"end":false},{"code":"піӮ","page":576,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩҮЩҺШ§ Щ„ЩҺШҘЩҗШӯЩ’ШҜЩҺЩү ЩұЩ„Щ’ЩғЩҸШЁЩҺШұЩҗ"},{"key":"74:36","surah":74,"ayah":36,"num":5531,"page":576,"words":[{"code":"піғ","page":576,"end":false},{"code":"пі„","page":576,"end":false},{"code":"пі…","page":576,"end":true}],"text":"ЩҶЩҺШ°ЩҗЩҠШұЩӢЫӯШ§ Щ„Щ‘ЩҗЩ„Щ’ШЁЩҺШҙЩҺШұЩҗ"},{"key":"74:37","surah":74,"ayah":37,"num":5532,"page":576,
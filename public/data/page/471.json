nd":false},{"code":"пұҰ","page":471,"end":false},{"code":"пұ§","page":471,"end":false},{"code":"пұЁ","page":471,"end":false},{"code":"пұ©пұӘ","page":471,"end":false},{"code":"пұ«","page":471,"end":false},{"code":"пұ¬","page":471,"end":false},{"code":"пұӯ","page":471,"end":false},{"code":"пұ®","page":471,"end":false},{"code":"пұҜ","page":471,"end":false},{"code":"пұ°","page":471,"end":false},{"code":"пұұпұІ","page":471,"end":false},{"code":"пұі","page":471,"end":false},{"code":"пұҙ","page":471,"end":false},{"code":"пұө","page":471,"end":false},{"code":"пұ¶","page":471,"end":false},{"code":"пұ·","page":471,"end":false},{"code":"пұё","page":471,"end":false},{"code":"пұ№","page":471,"end":false},{"code":"пұә","page":471,"end":false},{"code":"пұ»","page":471,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸШ¬ЩҺЩҖЩ°ШҜЩҗЩ„ЩҸЩҲЩҶЩҺ ЩҒЩҗЩүЩ“ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ШіЩҸЩ„Щ’Ш·ЩҺЩҖЩ°ЩҶЩҚ ШЈЩҺШӘЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ы– ЩғЩҺШЁЩҸШұЩҺ Щ…ЩҺЩӮЩ’ШӘЩӢШ§ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШ№ЩҗЩҶШҜЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҺШ·Щ’ШЁЩҺШ№ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ЩӮЩҺЩ„Щ’ШЁЩҗ Щ…ЩҸШӘЩҺЩғЩҺШЁЩ‘ЩҗШұЩҚЫў Ш¬ЩҺШЁЩ‘ЩҺШ§ШұЩҚЫў"},{"key":"40:36","surah":40,"ayah":36,"num":4169,"page":471,"words":[{"code":"пұј","page":471,"end":false},{"code":"пұҪ","page":471,"end":false},{"code":"пұҫ","page":471,"end":false},{"code":"пұҝ","page":471,"end":false},{"code":"пІҖ","page":471,"end":false},{"code":"пІҒ","page":471,"end":false},{"code":"пІӮ","page":471,"end":false},{"code":"пІғ","page":471,"end":false},{"code":"пІ„","page":471,"end":false},{"code":"пІ…","page":471,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҸ ЩҠЩҺЩҖЩ°ЩҮЩҺЩҖЩ°Щ…ЩҺЩҖЩ°ЩҶЩҸ ЩұШЁЩ’ЩҶЩҗ Щ„ЩҗЩү ШөЩҺШұЩ’ШӯЩӢЫӯШ§ Щ„Щ‘ЩҺШ№ЩҺЩ„Щ‘ЩҗЩүЩ“ ШЈЩҺШЁЩ’Щ„ЩҸШәЩҸ ЩұЩ„Щ’ШЈЩҺШіЩ’ШЁЩҺЩҖЩ°ШЁЩҺ"},{"key":"40:37","surah":40,"ayah":37,"num":4170,"page":471,"words":[{"code":"пІҶ","page":471,"end":false},{"code":"пІҮ","page":471,"end":false},{"code":"пІҲ","page":471,"end":false},{"code":"пІү","page":471,"end":false},{"code":"пІҠ","page":471,"end":false},{"code":"пІӢ","page":471,"end":false},{"code":"пІҢ","page":471,"end":false},{"code":"пІҚ","page":471,"end":false},{"code":"пІҺпІҸ","page":471,"end":false},{"code":"пІҗ","page":471,"end":false},{"code":"пІ‘","page":471,"end":false},{"code":"пІ’","page":471,"end":false},{"code":"пІ“","page":471,"end":false},{"code":"пІ”","page":471,"end":false},{"code":"пІ•","page":471,"end":false},{"code":"пІ–","page":471,"end":false},{"code":"пІ—пІҳ","page":471,"end":false},{"code":"пІҷ","page":471,"end":false},{"code":"пІҡ","page":471,"end":false},{"code":"пІӣ","page":471,"end":false},{"code":"пІң","page":471,"end":false},{"code":"пІқ","page":471,"end":false},{"code":"пІһ","page":471,"end":false},{"code":"пІҹ","page":471,"end":true}],"text":"ШЈЩҺШіЩ’ШЁЩҺЩҖЩ°ШЁЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҒЩҺШЈЩҺШ·Щ‘ЩҺЩ„ЩҗШ№ЩҺ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҗ Щ…ЩҸЩҲШіЩҺЩүЩ° ЩҲЩҺШҘЩҗЩҶЩ‘ЩҗЩү Щ„ЩҺШЈЩҺШёЩҸЩҶЩ‘ЩҸЩҮЩҸЫҘ ЩғЩҺЩҖЩ°Ш°ЩҗШЁЩӢЫӯШ§ Ыҡ ЩҲЩҺЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ШІЩҸЩҠЩ‘ЩҗЩҶЩҺ Щ„ЩҗЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ШіЩҸЩҲЩ“ШЎЩҸ Ш№ЩҺЩ…ЩҺЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШөЩҸШҜЩ‘ЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺЩҠЩ’ШҜЩҸ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҒЩҗЩү ШӘЩҺШЁЩҺШ§ШЁЩҚЫў"},{"key":"40:38","surah":40,"ayah":38,"num":4171,"page":471,"words":[{"code":"пІ ","page":471,"end":false},{"code":"пІЎ","page":471,"end":false},{"code":"пІў","page":471,"end":false},{"code":"пІЈ","page":471,"end":false},{"code":"пІӨ","page":471,"end":false},{"code":"пІҘ","page":471,"end":false},{"code":"пІҰ","page":471,"end":false},{"code":"пІ§","page":471,"end":false},{"code":"пІЁ","page":471,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ЩҠЩҺЩҖЩ°ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩҶЩҗ ШЈЩҺЩҮЩ’ШҜЩҗЩғЩҸЩ…Щ’ ШіЩҺШЁЩҗЩҠЩ„ЩҺ ЩұЩ„ШұЩ‘ЩҺШҙЩҺШ§ШҜЩҗ"},{"key":"40:39","surah":40,"ayah":39,"num":4172,"page":471,"words":[{"code":"пІ©","page":471,"end":false},{"code":"пІӘ","page":471,"end":false},{"code":"пІ«","page":471,"end":false},{"code":"пІ¬","page":471,"end":false},{"co
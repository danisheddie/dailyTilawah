417,"end":false},{"code":"пұ…","page":417,"end":false},{"code":"пұҶ","page":417,"end":false},{"code":"пұҮ","page":417,"end":false},{"code":"пұҲ","page":417,"end":false},{"code":"пұү","page":417,"end":false},{"code":"пұҠ","page":417,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҶЩҸШ°ЩҗЩҠЩӮЩҺЩҶЩ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„Щ’ШЈЩҺШҜЩ’ЩҶЩҺЩүЩ° ШҜЩҸЩҲЩҶЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„Щ’ШЈЩҺЩғЩ’ШЁЩҺШұЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҲЩҶЩҺ"},{"key":"32:22","surah":32,"ayah":22,"num":3525,"page":417,"words":[{"code":"пұӢ","page":417,"end":false},{"code":"пұҢ","page":417,"end":false},{"code":"пұҚ","page":417,"end":false},{"code":"пұҺ","page":417,"end":false},{"code":"пұҸ","page":417,"end":false},{"code":"пұҗ","page":417,"end":false},{"code":"пұ‘","page":417,"end":false},{"code":"пұ’","page":417,"end":false},{"code":"пұ“пұ”","page":417,"end":false},{"code":"пұ•","page":417,"end":false},{"code":"пұ–","page":417,"end":false},{"code":"пұ—","page":417,"end":false},{"code":"пұҳ","page":417,"end":false},{"code":"пұҷ","page":417,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶЩ’ ШЈЩҺШёЩ’Щ„ЩҺЩ…ЩҸ Щ…ЩҗЩ…Щ‘ЩҺЩҶ Ш°ЩҸЩғЩ‘ЩҗШұЩҺ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ Ш«ЩҸЩ…Щ‘ЩҺ ШЈЩҺШ№Щ’ШұЩҺШ¶ЩҺ Ш№ЩҺЩҶЩ’ЩҮЩҺШ§Щ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШ¬Щ’ШұЩҗЩ…ЩҗЩҠЩҶЩҺ Щ…ЩҸЩҶШӘЩҺЩӮЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"32:23","surah":32,"ayah":23,"num":3526,"page":417,"words":[{"code":"пұҡ","page":417,"end":false},{"code":"пұӣ","page":417,"end":false},{"code":"пұң","page":417,"end":false},{"code":"пұқ","page":417,"end":false},{"code":"пұһ","page":417,"end":false},{"code":"пұҹ","page":417,"end":false},{"code":"пұ ","page":417,"end":false},{"code":"пұЎ","page":417,"end":false},{"code":"пұў","page":417,"end":false},{"code":"пұЈпұӨ","page":417,"end":false},{"code":"пұҘ","page":417,"end":false},{"code":"пұҰ","page":417,"end":false},{"code":"пұ§","page":417,"end":false},{"code":"пұЁ","page":417,"end":false},{"code":"пұ©","page":417,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҸЩҲШіЩҺЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺЩғЩҸЩҶ ЩҒЩҗЩү Щ…ЩҗШұЩ’ЩҠЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶ Щ„Щ‘ЩҗЩӮЩҺШ§Щ“ШҰЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩҮЩҸШҜЩӢЫӯЩү Щ„Щ‘ЩҗШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ"},{"key":"32:24","surah":32,"ayah":24,"num":3527,"page":417,"words":[{"code":"пұӘ","page":417,"end":false},{"code":"пұ«","page":417,"end":false},{"code":"пұ¬","page":417,"end":false},{"code":"пұӯ","page":417,"end":false},{"code":"пұ®","page":417,"end":false},{"code":"пұҜ","page":417,"end":false},{"code":"пұ°пұұ","page":417,"end":false},{"code":"пұІ","page":417,"end":false},{"code":"пұі","page":417,"end":false},{"code":"пұҙ","page":417,"end":false},{"code":"пұө","page":417,"end":true}],"text":"ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШЈЩҺШҰЩҗЩ…Щ‘ЩҺШ©ЩӢЫӯ ЩҠЩҺЩҮЩ’ШҜЩҸЩҲЩҶЩҺ ШЁЩҗШЈЩҺЩ…Щ’ШұЩҗЩҶЩҺШ§ Щ„ЩҺЩ…Щ‘ЩҺШ§ ШөЩҺШЁЩҺШұЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҠЩҸЩҲЩӮЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"32:25","surah":32,"ayah":25,"num":3528,"page":417,"words":[{"code":"пұ¶","page":417,"end":false},{"code":"пұ·","page":417,"end":false},{"code":"пұё","page":417,"end":false},{"code":"пұ№","page":417,"end":false},{"code":"пұә","page":417,"end":false},{"code":"пұ»","page":417,"end":false},{"code":"пұј","page":417,"end":false},{"code":"пұҪ","page":417,"end":false},{"code":"пұҫ","page":417,"end":false},{"code":"пұҝ","page":417,"end":false},{"code":"пІҖ","page":417,"end":false},{"code":"пІҒ","page":417,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ЩҮЩҸЩҲЩҺ ЩҠЩҺЩҒЩ’ШөЩҗЩ„ЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ ЩҒЩҗЩҠЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҗ ЩҠЩҺШ®Щ’ШӘЩҺЩ„ЩҗЩҒЩҸЩҲЩҶЩҺ"},{"key":"32:26","surah":32,"ayah":26,"num":3529,"page":417,"words":[{"code":"пІӮ","page":417,"end":false},{"code":"пІғ","page":417,"end":false},{"code":"пІ„","page":417,"end":false},{"code":"пІ…","page":417,"end":false},{"code":"пІҶ","page":417,"end":false},{"code":"пІҮ","page":417,"end":false},{"code":"пІҲ","page":417,"end":false},{"code":"пІү","page":417,"end":false},{"code":"пІҠ","page":417,"end":false},{"code":"пІӢ","page":417,"end":false},{"code":"пІҢ","page":417,"end":false},{"code":"пІҚпІҺ","page":417,"end":false},{"code":"пІҸ","page":417,"end":false},{"code":"пІҗ","page":417,"end":false},{"code":"пІ‘","page":417,"end":false},{"code":"пІ’пІ“","page":417,"end":false},{"code":"пІ”","page":417,"end":false},{"code":"пІ•","page":417,"end":false},{"code":"пІ–","page":417,"end":true}],"text":"ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺЩҮЩ’ШҜЩҗ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺЩ…Щ’ ШЈЩҺЩҮЩ’Щ„ЩҺЩғЩ’ЩҶЩҺШ§ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҸШұЩҸЩҲЩҶЩҗ ЩҠЩҺЩ…Щ’ШҙЩҸЩҲЩҶЩҺ ЩҒЩҗЩү Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҶЩҗЩҮЩҗЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"32:27","surah":32,"ayah":27,"num":3530,"page":417,"words":[{"code":"пІ—","page":417,"end":false},{"code":"пІҳ","page":417,"end":false},{"code":"пІҷ","page":417,"end":false},{"code":"пІҡ","page":417,"end":false},{"code":"пІӣ","page":417,"end":false},{"code":"пІң","page":417,"end":false},{"code":"пІқ","page":417,"end":false},{"code":"пІһ","page":417,"end":false},{"code":"пІҹ","page":417,"end":false},{"code":"пІ ","page":417,"end":false},{"code":"пІЎ","page":417,"end":false},{"code":"пІў","page":417,"end":false},{"code":"пІЈ","page":417,"end":false},{"code":"пІӨ","page":417,"end":false},{"code":"пІҘпІҰ","page":417,"end":false},{"code":"пІ§","page":417,"end":false},{"code":"пІЁ","page":417,"end":false},{"code":"пІ©","page":417,"end":true}],"text":"ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺШ§ ЩҶЩҺШіЩҸЩҲЩӮЩҸ ЩұЩ„Щ’Щ…ЩҺШ§Щ“ШЎЩҺ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩұЩ„Щ’Ш¬ЩҸШұЩҸШІЩҗ ЩҒЩҺЩҶЩҸШ®Щ’ШұЩҗШ¬ЩҸ ШЁЩҗЩҮЩҗЫҰ ШІЩҺШұЩ’Ш№ЩӢЫӯШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸ ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩҒЩҸШіЩҸЩҮЩҸЩ…Щ’ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ЩҠЩҸШЁЩ’ШөЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"32:28","surah":32,"ayah":28,"num":3531,"page":417,"words":[{"code":"пІӘ","page":417,"end":false},{"code":"пІ«","page":417,"end":false},{"code":"пІ¬","page":417,"end":false},{"code":"пІӯ","page":417,"end":false},{"code":"пІ®","page":417,"end":false},{"code":"пІҜ","page":417,"end":false},{"code":"пІ°","page":417,"end":false},{"code":"пІұ","page":417,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Щ…ЩҺШӘЩҺЩүЩ° ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩҒЩҺШӘЩ’ШӯЩҸ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШөЩҺЩҖЩ°ШҜЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"32:29","surah":32,"ayah":29,"num":3532,"page":417,"words":[{"code":"пІІ","page":417,"end":false},{"code":"пІі","page":417,"end":false},{"code":"пІҙ","page":417,"end":false},{"code":"пІө","page":417,"end":false},{"code":"пІ¶","page":417,"end":false},{"code":"пІ·","page":417,"end":false},{"code":"пІё","page":417,"end":false},{"code":"пІ№","page":417,"end":false},{"code":"пІә","page":417,"end":false},{"code":"пІ»","page":417,"end":false},{"code":"пІј","page":417,"end":false},{"code":"пІҪ","page":417,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩҒЩҺШӘЩ’ШӯЩҗ Щ„ЩҺШ§ ЩҠЩҺЩҶЩҒЩҺШ№ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҠЩҸЩҶШёЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"32:30","surah":32,"ayah":30,"num":3533,"page":417,"words":[{"code":"пІҫ","page":417,"end":false},{"code":"пІҝ","page":417,"end":false},{"code":"піҖ","page":417,"end":false},{"code":"піҒ","page":417,"end":false},{"code":"піӮ","page":417,"end":false},{"code":"піғ","page":417,"end":true}],"text":"ЩҒЩҺШЈЩҺШ№Щ’ШұЩҗШ¶Щ’ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҲЩҺЩұЩҶШӘЩҺШёЩҗШұЩ’ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҸЩҶШӘЩҺШёЩҗШұЩҸЩҲЩҶЩҺ"}]}
ЩҲЩҺЩ„ЩҺШЈЩҸШҜЩ’Ш®ЩҗЩ„ЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш«ЩҺЩҲЩҺШ§ШЁЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҗЩҶШҜЩҺЩҮЩҸЫҘ ШӯЩҸШіЩ’ЩҶЩҸ ЩұЩ„Ш«Щ‘ЩҺЩҲЩҺШ§ШЁЩҗ"},{"key":"3:196","surah":3,"ayah":196,"num":489,"page":76,"words":[{"code":"пұ°","page":76,"end":false},{"code":"пұұ","page":76,"end":false},{"code":"пұІ","page":76,"end":false},{"code":"пұі","page":76,"end":false},{"code":"пұҙ","page":76,"end":false},{"code":"пұө","page":76,"end":false},{"code":"пұ¶","page":76,"end":false},{"code":"пұ·","page":76,"end":true}],"text":"Щ„ЩҺШ§ ЩҠЩҺШәЩҸШұЩ‘ЩҺЩҶЩ‘ЩҺЩғЩҺ ШӘЩҺЩӮЩҺЩ„Щ‘ЩҸШЁЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЁЩҗЩ„ЩҺЩҖЩ°ШҜЩҗ"},{"key":"3:197","surah":3,"ayah":197,"num":490,"page":76,"words":[{"code":"пұё","page":76,"end":false},{"code":"пұ№","page":76,"end":false},{"code":"пұә","page":76,"end":false},{"code":"пұ»","page":76,"end":false},{"code":"пұјпұҪ","page":76,"end":false},{"code":"пұҫ","page":76,"end":false},{"code":"пұҝ","page":76,"end":false},{"code":"пІҖ","page":76,"end":true}],"text":"Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҢЫӯ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩҢЫӯ Ш«ЩҸЩ…Щ‘ЩҺ Щ…ЩҺШЈЩ’ЩҲЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ Ыҡ ЩҲЩҺШЁЩҗШҰЩ’ШіЩҺ ЩұЩ„Щ’Щ…ЩҗЩҮЩҺШ§ШҜЩҸ"},{"key":"3:198","surah":3,"ayah":198,"num":491,"page":76,"words":[{"code":"пІҒ","page":76,"end":false},{"code":"пІӮ","page":76,"end":false},{"code":"пІғ","page":76,"end":false},{"code":"пІ„","page":76,"end":false},{"code":"пІ…","page":76,"end":false},{"code":"пІҶ","page":76,"end":false},{"code":"пІҮ","page":76,"end":false},{"code":"пІҲ","page":76,"end":false},{"code":"пІү","page":76,"end":false},{"code":"пІҠ","page":76,"end":false},{"code":"пІӢ","page":76,"end":false},{"code":"пІҢ","page":76,"end":false},{"code":"пІҚ","page":76,"end":false},{"code":"пІҺ","page":76,"end":false},{"code":"пІҸ","page":76,"end":false},{"code":"пІҗпІ‘","page":76,"end":false},{"code":"пІ’","page":76,"end":false},{"code":"пІ“","page":76,"end":false},{"code":"пІ”","page":76,"end":false},{"code":"пІ•","page":76,"end":false},{"code":"пІ–","page":76,"end":false},{"code":"пІ—","page":76,"end":true}],"text":"Щ„ЩҺЩҖЩ°ЩғЩҗЩҶЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШӘЩ‘ЩҺЩӮЩҺЩҲЩ’Ш§Ыҹ ШұЩҺШЁЩ‘ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҢЫӯ ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҶЩҸШІЩҸЩ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩ…ЩҺШ§ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ’ШЈЩҺШЁЩ’ШұЩҺШ§ШұЩҗ"},{"key":"3:199","surah":3,"ayah":199,"num":492,"page":76,"words":[{"code":"пІҳ","page":76,"end":false},{"code":"пІҷ","page":76,"end":false},{"code":"пІҡ","page":76,"end":false},{"code":"пІӣ","page":76,"end":false},{"code":"пІң","page":76,"end":false},{"code":"пІқ","page":76,"end":false},{"code":"пІһ","page":76,"end":false},{"code":"пІҹ","page":76,"end":false},{"code":"пІ ","page":76,"end":false},{"code":"пІЎ","page":76,"end":false},{"code":"пІў","page":76,"end":false},{"code":"пІЈ","page":76,"end":false},{"code":"пІӨ","page":76,"end":false},{"code":"пІҘ","page":76,"end":false},{"code":"пІҰ","page":76,"end":false},{"code":"пІ§","page":76,"end":false},{"code":"пІЁ","page":76,"end":false},{"code":"пІ©","page":76,"end":false},{"code":"пІӘ","page":76,"end":false},{"code":"пІ«","page":76,"end":false},{"code":"пІ¬пІӯ","page":76,"end":false},{"code":"пІ®","page":76,"end":false},{"code":"пІҜ","page":76,"end":false},{"code":"пІ°","page":76,"end":false},{"code":"пІұ","page":76,"end":false},{"code":"пІІпІі","page":76,"end":false},{"code":"пІҙ","page":76,"end":false},{"code":"пІө","page":76,"end":false},{"code":"пІ¶","page":76,"end":false},{"code":"пІ·","page":76,"end":false},{"code":"пІё","page":76,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ„ЩҺЩ…ЩҺЩҶ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ш®ЩҺЩҖЩ°ШҙЩҗШ№ЩҗЩҠЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺШ§ ЩҠЩҺШҙЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш«ЩҺЩ…ЩҺЩҶЩӢЫӯШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢШ§ Ы— ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩҸЩҮЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШіЩҺШұЩҗЩҠШ№ЩҸ ЩұЩ„Щ’ШӯЩҗШіЩҺШ§ШЁЩҗ"},{"key":"3:200","surah":3,"ayah":200,"num":493,"page":76,"words":[{"code":"пІ№","page":76,"end":false},{"code":"пІә","page":76,"end":false},{"code":"пІ»","page":76,"end":false},{"code":"пІј","page":76,"end":false},{"code":"пІҪ","page":76,"end":false},{"code":"пІҫ","page":76,"end":false},{"code":"пІҝ","page":76,"end":false},{"code":"піҖ","page":76,"end":false},{"code":"піҒ","page":76,"end":false},{"code":"піӮ","page":76,"end":false},{"code":"піғ","page":76,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШөЩ’ШЁЩҗШұЩҸЩҲШ§Ыҹ ЩҲЩҺШөЩҺШ§ШЁЩҗШұЩҸЩҲШ§Ыҹ ЩҲЩҺШұЩҺШ§ШЁЩҗШ·ЩҸЩҲШ§Ыҹ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"}]}
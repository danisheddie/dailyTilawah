:false},{"code":"пұӣ","page":435,"end":false},{"code":"пұң","page":435,"end":false},{"code":"пұқ","page":435,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ШҘЩҗЩҶЩ‘ЩҺ ЩҲЩҺШ№Щ’ШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӯЩҺЩӮЩ‘ЩҢЫӯ Ы– ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШәЩҸШұЩ‘ЩҺЩҶЩ‘ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©ЩҸ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШәЩҸШұЩ‘ЩҺЩҶЩ‘ЩҺЩғЩҸЩ… ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ШәЩҺШұЩҸЩҲШұЩҸ"},{"key":"35:6","surah":35,"ayah":6,"num":3666,"page":435,"words":[{"code":"пұһ","page":435,"end":false},{"code":"пұҹ","page":435,"end":false},{"code":"пұ ","page":435,"end":false},{"code":"пұЎ","page":435,"end":false},{"code":"пұў","page":435,"end":false},{"code":"пұЈпұӨ","page":435,"end":false},{"code":"пұҘ","page":435,"end":false},{"code":"пұҰ","page":435,"end":false},{"code":"пұ§","page":435,"end":false},{"code":"пұЁ","page":435,"end":false},{"code":"пұ©","page":435,"end":false},{"code":"пұӘ","page":435,"end":false},{"code":"пұ«","page":435,"end":false},{"code":"пұ¬","page":435,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺШҜЩҸЩҲЩ‘ЩҢЫӯ ЩҒЩҺЩұШӘЩ‘ЩҺШ®ЩҗШ°ЩҸЩҲЩҮЩҸ Ш№ЩҺШҜЩҸЩҲЩ‘ЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҠЩҺШҜЩ’Ш№ЩҸЩҲШ§Ыҹ ШӯЩҗШІЩ’ШЁЩҺЩҮЩҸЫҘ Щ„ЩҗЩҠЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҗ ЩұЩ„ШіЩ‘ЩҺШ№ЩҗЩҠШұЩҗ"},{"key":"35:7","surah":35,"ayah":7,"num":3667,"page":435,"words":[{"code":"пұӯ","page":435,"end":false},{"code":"пұ®","page":435,"end":false},{"code":"пұҜ","page":435,"end":false},{"code":"пұ°","page":435,"end":false},{"code":"пұұпұІ","page":435,"end":false},{"code":"пұі","page":435,"end":false},{"code":"пұҙ","page":435,"end":false},{"code":"пұө","page":435,"end":false},{"code":"пұ¶","page":435,"end":false},{"code":"пұ·","page":435,"end":false},{"code":"пұё","page":435,"end":false},{"code":"пұ№","page":435,"end":false},{"code":"пұә","page":435,"end":false},{"code":"пұ»","page":435,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ ШҙЩҺШҜЩҗЩҠШҜЩҢЫӯ Ы– ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺ
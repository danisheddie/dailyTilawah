age":541,"words":[{"code":"пұҒ","page":541,"end":false},{"code":"пұӮ","page":541,"end":false},{"code":"пұғ","page":541,"end":false},{"code":"пұ„","page":541,"end":false},{"code":"пұ…","page":541,"end":false},{"code":"пұҶ","page":541,"end":false},{"code":"пұҮ","page":541,"end":false},{"code":"пұҲ","page":541,"end":false},{"code":"пұү","page":541,"end":false},{"code":"пұҠ","page":541,"end":false},{"code":"пұӢпұҢ","page":541,"end":false},{"code":"пұҚ","page":541,"end":false},{"code":"пұҺ","page":541,"end":false},{"code":"пұҸ","page":541,"end":false},{"code":"пұҗ","page":541,"end":false},{"code":"пұ‘","page":541,"end":false},{"code":"пұ’","page":541,"end":false},{"code":"пұ“","page":541,"end":false},{"code":"пұ”","page":541,"end":false},{"code":"пұ•","page":541,"end":false},{"code":"пұ–","page":541,"end":false},{"code":"пұ—","page":541,"end":false},{"code":"пұҳ","page":541,"end":false},{"code":"пұҷпұҡ","page":541,"end":false},{"code":"пұӣ","page":541,"end":false},{"code":"пұң","page":541,"end":false},{"code":"пұқ","page":541,"end":false},{"code":"пұһ","page":541,"end":false},{"code":"пұҹ","page":541,"end":true}],"text":"Щ„ЩҺЩӮЩҺШҜЩ’ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§ ШұЩҸШіЩҸЩ„ЩҺЩҶЩҺШ§ ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҺШ№ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҗЩҠШІЩҺШ§ЩҶЩҺ Щ„ЩҗЩҠЩҺЩӮЩҸЩҲЩ…ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ШЁЩҗЩұЩ„Щ’ЩӮЩҗШіЩ’Ш·Щҗ Ы– ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ ЩұЩ„Щ’ШӯЩҺШҜЩҗЩҠШҜЩҺ ЩҒЩҗЩҠЩҮЩҗ ШЁЩҺШЈЩ’ШіЩҢЫӯ ШҙЩҺШҜЩҗЩҠШҜЩҢЫӯ ЩҲЩҺЩ…ЩҺЩҶЩҺЩҖЩ°ЩҒЩҗШ№ЩҸ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺЩ„ЩҗЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺЩҶ ЩҠЩҺЩҶШөЩҸШұЩҸЩҮЩҸЫҘ ЩҲЩҺШұЩҸШіЩҸЩ„ЩҺЩҮЩҸЫҘ ШЁЩҗЩұЩ„Щ’ШәЩҺЩҠЩ’ШЁЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺЩҲЩҗЩүЩ‘ЩҢ Ш№ЩҺШІЩҗЩҠШІЩҢЫӯ"},{"key":"57:26","surah":57,"ayah":26,"num":5101,"page":541,"words":[{"code":"пұ ","page":541,"end":false},{"code":"пұЎ","page":541,"end":false},{"code":"пұў","page":541,"end":false},{"code":"пұЈ","page":541,"end":false},{"code":"пұӨ","page":541,"end":false},{"code":"пұҘ","page":541,"end":false},{"code":"пұҰ","page":541,"end":false},{"code":"пұ§","page":541,"end":false},{"code":"пұЁпұ©","page":541,"end":false},{"code":"пұӘ","page":541,"end":false},{"code":"пұ«пұ¬","page":541,"end":false},{"code":"пұӯ","page":541,"end":false},{"code":"пұ®","page":541,"end":false},{"code":"пұҜ","page":541,"end":false},{"code":"пұ°","page":541,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§ ЩҶЩҸЩҲШӯЩӢЫӯШ§ ЩҲЩҺШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҺ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩҒЩҗЩү Ш°ЩҸШұЩ‘ЩҗЩҠЩ‘ЩҺШӘЩҗЩҮЩҗЩ…ЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҸШЁЩҸЩҲЩ‘ЩҺШ©ЩҺ ЩҲЩҺЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ Ы– ЩҒЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҸЩҮЩ’ШӘЩҺШҜЩҚЫў Ы– ЩҲЩҺЩғЩҺШ«ЩҗЩҠШұЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"57:27","surah":57,"ayah":27,"num":5102,"page":541,"words":[{"code":"пұұ","page":541,"end":false},{"code":"пұІ","page":541,"end":false},{"code":"пұі","page":541,"end":false},{"code":"пұҙ","page":541,"end":false},{"code":"пұө","page":541,"end":false},{"code":"пұ¶","page":541,"end":false},{"code":"пұ·","page":541,"end":false},{"code":"пұё","page":541,"end":false},{"code":"пұ№","page":541,"end":false},{"code":"пұә","page":541,"end":false},{"code":"пұ»пұј","page":541,"end":false},{"code":"пұҪ","page":541,"end":false},{"code":"пұҫ","page":541,"end":false},{"code":"пұҝ","page":541,"end":false},{"code":"пІҖ","page":541,"end":false},{"code":"пІҒ","page":541,"end":false},{"code":"пІӮ","page":541,"end":false},{"code":"пІғпІ„","page":541,"end":false},{"code":"пІ…","page":541,"end":false},{"code":"пІҶ","page":541,"end":false},{"code":"пІҮ","page":541,"end":false},{"code":"пІҲ","page":541,"end":false},{"code":"пІү","page":541,"end":false},{"code":"пІҠ","page":541,"end":false},{"code":"пІӢ","page":541,"end":false},{"code":"пІҢ","page":541,"end":false},{"code":"пІҚ","page":541,"end":false},{"code":"пІҺ","page":541,"end":false},{"code":"пІҸ","page":541,"end":false},{"code":"пІҗ","page":541,"end":false},{"code":"пІ‘пІ’","page":541,"end":false},{"code":"пІ“","page":541,"end":false},{"code":"пІ”","page":541,"end":false},{"code":"пІ•","page":541,"end":false},{"code":"пІ–","page":541,"end":false},{"code":"пІ—пІҳ","page":541,"end":false},{"code":"пІҷ","page":541,"end":false},{"code":"пІҡ","page":541,"end":false},{"code":"пІӣ","page":541,"end":false},{"code":"пІң","page":541,"end":true}],"text":"Ш«ЩҸЩ…Щ‘ЩҺ ЩӮЩҺЩҒЩ‘ЩҺЩҠЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЎЩҺШ§Ш«ЩҺЩҖЩ°ШұЩҗЩҮЩҗЩ… ШЁЩҗШұЩҸШіЩҸЩ„ЩҗЩҶЩҺШ§ ЩҲЩҺЩӮЩҺЩҒЩ‘ЩҺЩҠЩ’ЩҶЩҺШ§ ШЁЩҗШ№ЩҗЩҠШіЩҺЩү ЩұШЁЩ’ЩҶЩҗ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩұЩ„Щ’ШҘЩҗЩҶШ¬ЩҗЩҠЩ„ЩҺ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҸЩҲЩҮЩҸ ШұЩҺШЈЩ’ЩҒЩҺШ©ЩӢЫӯ ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢЫӯ ЩҲЩҺШұЩҺЩҮЩ’ШЁЩҺШ§ЩҶЩҗЩҠЩ‘ЩҺШ©ЩӢ ЩұШЁЩ’ШӘЩҺШҜЩҺШ№ЩҸЩҲЩҮЩҺШ§ Щ…ЩҺШ§ ЩғЩҺШӘЩҺШЁЩ’ЩҶЩҺЩҖЩ°ЩҮЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ ШұЩҗШ¶Щ’ЩҲЩҺЩ°ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩ…ЩҺШ§ ШұЩҺШ№ЩҺЩҲЩ’ЩҮЩҺШ§ ШӯЩҺЩӮЩ‘ЩҺ ШұЩҗШ№ЩҺШ§ЩҠЩҺШӘЩҗЩҮЩҺШ§ Ы– ЩҒЩҺЩҖЩ”ЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩҺЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺЩғЩҺШ«ЩҗЩҠШұЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"57:28","surah":57,"ayah":28,"num":5103,"page":541,"words":[{"code":"пІқ","page":541,"end":false},{"code":"пІһ","page":541,"end":false},{"code":"пІҹ","page":541,"end":false},{"code":"пІ ","page":541,"end":false},{"code":"пІЎ","page":541,"end":false},{"code":"пІў","page":541,"end":false},{"code":"пІЈ","page":541,"end":false},{"code":"пІӨ","page":541,"end":false},{"code":"пІҘ","page":541,"end":false},{"code":"пІҰ","page":541,"end":false},{"code":"пІ§","page":541,"end":false},{"code":"пІЁ","page":541,"end":false},{"code":"пІ©","page":541,"end":false},{"code":"пІӘ","page":541,"end":false},{"code":"пІ«","page":541,"end":false},{"code":"пІ¬","page":541,"end":false},{"code":"пІӯ","page":541,"end":false},{"code":"пІ®пІҜ","page":541,"end":false},{"code":"пІ°","page":541,"end":false},{"code":"пІұ","page":541,"end":false},{"code":"пІІ","page":541,"end":false},{"code":"пІі","page":541,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШЎЩҺШ§Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ ЩҠЩҸШӨЩ’ШӘЩҗЩғЩҸЩ…Щ’ ЩғЩҗЩҒЩ’Щ„ЩҺЩҠЩ’ЩҶЩҗ Щ…ЩҗЩҶ ШұЩ‘ЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҶЩҸЩҲШұЩӢЫӯШ§ ШӘЩҺЩ…Щ’ШҙЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"57:29","surah":57,"ayah":29,"num":5104,"page":541,"words":[{"code":"пІҙ","page":541,"end":false},{"code":"пІө","page":541,"end":false},{"code":"пІ¶","page":541,"end":false},{"code":"пІ·","page":541,"end":false},{"code":"пІё","page":541,"end":false},{"code":"пІ№","page":541,"end":false},{"code":"пІә","page":541,"end":false},{"code":"пІ»","page":541,"end":false},{"code":"пІј","page":541,"end":false},{"code":"пІҪ","page":541,"end":false},{"code":"пІҫ","page":541,"end":false},{"code":"пІҝ","page":541,"end":false},{"code":"піҖ","page":541,"end":false},{"code":"піҒ","page":541,"end":false},{"code":"піӮ","page":541,"end":false},{"code":"піғ","page":541,"end":false},{"code":"пі„","page":541,"end":false},{"code":"пі…піҶ","page":541,"end":false},{"code":"піҮ","page":541,"end":false},{"code":"піҲ","page":541,"end":false},{"code":"піү","page":541,"end":false},{"code":"піҠ","page":541,"end":false},{"code":"піӢ","page":541,"end":true}],"text":"Щ„Щ‘ЩҗШҰЩҺЩ„Щ‘ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҺ ШЈЩҺЩҮЩ’Щ„ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ШЈЩҺЩ„Щ‘ЩҺШ§ ЩҠЩҺЩӮЩ’ШҜЩҗШұЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ШҙЩҺЩүЩ’ШЎЩҚЫў Щ…Щ‘ЩҗЩҶ ЩҒЩҺШ¶Щ’Щ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҷ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ’ЩҒЩҺШ¶Щ’Щ„ЩҺ ШЁЩҗЩҠЩҺШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҸШӨЩ’ШӘЩҗЩҠЩҮЩҗ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш°ЩҸЩҲ ЩұЩ„Щ’ЩҒЩҺШ¶Щ’Щ„Щҗ ЩұЩ„Щ’Ш№ЩҺШёЩҗЩҠЩ…Щҗ"}]}
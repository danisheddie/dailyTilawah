"31:2","surah":31,"ayah":2,"num":3471,"page":411,"words":[{"code":"пұғ","page":411,"end":false},{"code":"пұ„","page":411,"end":false},{"code":"пұ…","page":411,"end":false},{"code":"пұҶ","page":411,"end":false},{"code":"пұҮ","page":411,"end":true}],"text":"ШӘЩҗЩ„Щ’ЩғЩҺ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…Щҗ"},{"key":"31:3","surah":31,"ayah":3,"num":3472,"page":411,"words":[{"code":"пұҲ","page":411,"end":false},{"code":"пұү","page":411,"end":false},{"code":"пұҠ","page":411,"end":false},{"code":"пұӢ","page":411,"end":true}],"text":"ЩҮЩҸШҜЩӢЫӯЩү ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"31:4","surah":31,"ayah":4,"num":3473,"page":411,"words":[{"code":"пұҢ","page":411,"end":false},{"code":"пұҚ","page":411,"end":false},{"code":"пұҺ","page":411,"end":false},{"code":"пұҸ","page":411,"end":false},{"code":"пұҗ","page":411,"end":false},{"code":"пұ‘","page":411,"end":false},{"code":"пұ’","page":411,"end":false},{"code":"пұ“","page":411,"end":false},{"code":"пұ”","page":411,"end":false},{"code":"пұ•","page":411,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩӮЩҗЩҠЩ…ЩҸЩҲЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩҠЩҸШӨЩ’ШӘЩҸЩҲЩҶЩҺ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ЩҮЩҸЩ…Щ’ ЩҠЩҸЩҲЩӮЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"31:5","surah":31,"ayah":5,"num":3474,"page":411,"words":[{"code":"пұ–","page":411,"end":false},{"code":"пұ—","page":411,"end":false},{"code":"пұҳ","page":411,"end":false},{"code":"пұҷ","page":411,"end":false},{"code":"пұҡпұӣ","page":411,"end":false},{"code":"пұң","page":411,"end":false},{"code":"пұқ","page":411,"end":false},{"code":"пұһ","page":411,"end":false},{"code":"пұҹ","page":411,"end":true}],"text":"ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҮЩҸШҜЩӢЫӯЩү Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"31:6","surah":31,"ayah":6,"num":3475,"page":411,"words":[{"code":"пұ ","page":411,"end":false},{"code":"пұЎ","page":411,"end":false},{"code":"пұў","page":411,"end":false},{"code":"пұЈ","page":411,"end":false},{"code":"пұӨ","page":411,"end":false},{"code":"пұҘ","page":411,"end":false},{"code":"пұҰ","page":411,"end":false},{"code":"пұ§","page":411,"end":false},{"code":"пұЁ","page":411,"end":false},{"code":"пұ©","page":411,"end":false},{"code":"пұӘ","page":411,"end":false},{"code":"пұ«","page":411,"end":false},{"code":"пұ¬","page":411,"end":false},{"code":"пұӯпұ®","page":411,"end":false},{"code":"пұҜ","page":411,"end":false},{"code":"пұ°","page":411,"end":false},{"code":"пұұ","page":411,"end":false},{"code":"пұІ","page":411,"end":false},{"code":"пұі","page":411,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ…ЩҺЩҶ ЩҠЩҺШҙЩ’ШӘЩҺШұЩҗЩү Щ„ЩҺЩҮЩ’ЩҲЩҺ ЩұЩ„Щ’ШӯЩҺШҜЩҗЩҠШ«Щҗ Щ„ЩҗЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҺ Ш№ЩҺЩҶ ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ Ш№ЩҗЩ„Щ’Щ…ЩҚЫў ЩҲЩҺЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҺЩҮЩҺШ§ ЩҮЩҸШІЩҸЩҲЩӢШ§ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ Щ…Щ‘ЩҸЩҮЩҗЩҠЩҶЩҢЫӯ"},{"key":"31:7","surah":31,"ayah":7,"num":3476,"page":411,"words":[{"code":"пұҙ","page":411,"end":false},{"code":"пұө","page":411,"end":false},{"code":"пұ¶","page":411,"end":false},{"code":"пұ·","page":411,"end":false},{"code":"пұё","page":411,"end":false},{"code":"пұ№","page":411,"end":false},{"code":"пұә","page":411,"end":false},{"code":"пұ»","page":411,"end":false},{"code":"пұј","page":411,"end":false},{"code":"пұҪ","page":411,"end":false},{"code":"пұҫ","page":411,"end":false},{"code":"пұҝ","page":411,"end":false},{"code":"пІҖпІҒ","page":411,"end":false},{"code":"пІӮ","page":411,"end":false},{"code":"пІғ","page":411,"end":false},{"code":"пІ„","page":411,"end":false},{"code":"пІ…","page":411,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШӘЩҸШӘЩ’Щ„ЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҸЩҶЩҺШ§ ЩҲЩҺЩ„Щ‘ЩҺЩүЩ° Щ…ЩҸШіЩ’ШӘЩҺЩғЩ’ШЁЩҗШұЩӢЫӯШ§ ЩғЩҺШЈЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШіЩ’Щ…ЩҺШ№Щ’ЩҮЩҺШ§ ЩғЩҺШЈЩҺЩҶЩ‘ЩҺ ЩҒЩҗЩүЩ“ ШЈЩҸШ°ЩҸЩҶЩҺЩҠЩ’ЩҮЩҗ ЩҲЩҺЩӮЩ’ШұЩӢЫӯШ§ Ы– ЩҒЩҺШЁЩҺШҙЩ‘ЩҗШұЩ’ЩҮЩҸ ШЁЩҗШ№ЩҺШ°ЩҺШ§ШЁЩҚ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҚ"},{"key":"31:8","surah":31,"ayah":8,"num":3477,"page":411,"words":[{"code":"пІҶ","page":411,"end":false},{"code":"пІҮ","page":411,"end":false},{"code":"пІҲ","page":411,"end":false},{"code":"пІү","page":411,"end":false},{"code":"пІҠ","page":411,"end":false},{"code":"пІӢ","page":411,"end":false},{"code":"пІҢ","page":411,"end":false},{"code":"пІҚ","page":411,"end":false},{"code":"пІҺ","page":411,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ№ЩҗЩҠЩ…Щҗ"},{"key":"31:9","surah":31,"ayah":9,"num":3478,"page":411,"words":[{"code":"пІҸ","page":411,"end":false},{"code":"пІҗпІ‘","page":411,"end":false},{"code":"пІ’","page":411,"end":false},{"code":"пІ“","page":411,"end":false},{"code":"пІ”пІ•","page":411,"end":false},{"code":"пІ–","page":411,"end":false},{"code":"пІ—","page":411,"end":false},{"code":"пІҳ","page":411,"end":false},{"code":"пІҷ","page":411,"end":true}],"text":"Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ы– ЩҲЩҺШ№Щ’ШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӯЩҺЩӮЩ‘ЩӢЫӯШ§ Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"},{"key":"31:10","surah":31,"ayah":10,"num":3479,"page":411,"words":[{"code":"пІҡ","page":411,"end":false},{"code":"пІӣ","page":411,"end":false},{"code":"пІң","page":411,"end":false},{"code":"пІқ","page":411,"end":false},{"code":"пІһпІҹ","page":411,"end":false},{"code":"пІ ","page":411,"end":false},{"code":"пІЎ","page":411,"end":false},{"code":"пІў","page":411,"end":false},{"code":"пІЈ","page":411,"end":false},{"code":"пІӨ","page":411,"end":false},{"code":"пІҘ","page":411,"end":false},{"code":"пІҰ","page":411,"end":false},{"code":"пІ§","page":411,"end":false},{"code":"пІЁ","page":411,"end":false},{"code":"пІ©","page":411,"end":false},{"code":"пІӘ","page":411,"end":false},{"code":"пІ«пІ¬","page":411,"end":false},{"code":"пІӯ","page":411,"end":false},{"code":"пІ®","page":411,"end":false},{"code":"пІҜ","page":411,"end":false},{"code":"пІ°","page":411,"end":false},{"code":"пІұ","page":411,"end":false},{"code":"пІІ","page":411,"end":false},{"code":"пІі","page":411,"end":false},{"code":"пІҙ","page":411,"end":false},{"code":"пІө","page":411,"end":false},{"code":"пІ¶","page":411,"end":false},{"code":"пІ·","page":411,"end":true}],"text":"Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ Ш№ЩҺЩ…ЩҺШҜЩҚЫў ШӘЩҺШұЩҺЩҲЩ’ЩҶЩҺЩҮЩҺШ§ Ы– ЩҲЩҺШЈЩҺЩ„Щ’ЩӮЩҺЩүЩ° ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШұЩҺЩҲЩҺЩ°ШіЩҗЩүЩҺ ШЈЩҺЩҶ ШӘЩҺЩ…ЩҗЩҠШҜЩҺ ШЁЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЁЩҺШ«Щ‘ЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩҚЫў Ыҡ ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ Щ…ЩҺШ§Щ“ШЎЩӢЫӯ ЩҒЩҺШЈЩҺЩҶЫўШЁЩҺШӘЩ’ЩҶЩҺШ§ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШІЩҺЩҲЩ’Ш¬ЩҚЫў ЩғЩҺШұЩҗЩҠЩ…ЩҚ"},{"key":"31:11","surah":31,"ayah":11,"num":3480,"page":411,"words":[{"code":"пІё","page":411,"end":false},{"code":"пІ№","page":411,"end":false},{"code":"пІә","page":411,"end":false},{"code":"пІ»","page":411,"end":false},{"code":"пІј","page":411,"end":false},{"code":"пІҪ","page":411,"end":false},{"code":"пІҫ","page":411,"end":false},{"code":"пІҝ","page":411,"end":false},{"code":"піҖпіҒ","page":411,"end":false},{"code":"піӮ","page":411,"end":false},{"code":"піғ","page":411,"end":false},{"code":"пі„","page":411,"end":false},{"code":"пі…","page":411,"end":false},{"code":"піҶ","page":411,"end":false},{"code":"піҮ","page":411,"end":true}],"text":"ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Ш®ЩҺЩ„Щ’ЩӮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺШЈЩҺШұЩҸЩҲЩҶЩҗЩү Щ…ЩҺШ§Ш°ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЫҰ Ыҡ ШЁЩҺЩ„Щҗ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ ЩҒЩҗЩү Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҚЫў Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҚЫў"}]}
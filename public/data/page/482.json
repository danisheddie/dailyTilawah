 ШЁЩҗШ№ЩҗЩ„Щ’Щ…ЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҸЩҶЩҺШ§ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ШЈЩҺЩҠЩ’ЩҶЩҺ ШҙЩҸШұЩҺЩғЩҺШ§Щ“ШЎЩҗЩү ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Ш°ЩҺЩҶЩ‘ЩҺЩҖЩ°ЩғЩҺ Щ…ЩҺШ§ Щ…ЩҗЩҶЩ‘ЩҺШ§ Щ…ЩҗЩҶ ШҙЩҺЩҮЩҗЩҠШҜЩҚЫў"},{"key":"41:48","surah":41,"ayah":48,"num":4266,"page":482,"words":[{"code":"пұЎ","page":482,"end":false},{"code":"пұў","page":482,"end":false},{"code":"пұЈ","page":482,"end":false},{"code":"пұӨ","page":482,"end":false},{"code":"пұҘ","page":482,"end":false},{"code":"пұҰ","page":482,"end":false},{"code":"пұ§пұЁ","page":482,"end":false},{"code":"пұ©","page":482,"end":false},{"code":"пұӘ","page":482,"end":false},{"code":"пұ«","page":482,"end":false},{"code":"пұ¬","page":482,"end":false},{"code":"пұӯ","page":482,"end":false},{"code":"пұ®","page":482,"end":true}],"text":"ЩҲЩҺШ¶ЩҺЩ„Щ‘ЩҺ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Ы– ЩҲЩҺШёЩҺЩҶЩ‘ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ Щ…Щ‘ЩҺШӯЩҗЩҠШөЩҚЫў"},{"key":"41:49","surah":41,"ayah":49,"num":4267,"page":482,"words":[{"code":"пұҜ","page":482,"end":false},{"code":"пұ°","page":482,"end":false},{"code":"пұұ","page":482,"end":false},{"code":"пұІ","page":482,"end":false},{"code":"пұі","page":482,"end":false},{"code":"пұҙ","page":482,"end":false},{"code":"пұө","page":482,"end":false},{"code":"пұ¶","page":482,"end":false},{"code":"пұ·","page":482,"end":false},{"code":"пұё","page":482,"end":false},{"code":"пұ№","page":482,"end":false},{"code":"пұә","page":482,"end":true}],"text":"Щ„Щ‘ЩҺШ§ ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ…ЩҸ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҸ Щ…ЩҗЩҶ ШҜЩҸШ№ЩҺШ§Щ“ШЎЩҗ ЩұЩ„Щ’Ш®ЩҺЩҠЩ’ШұЩҗ ЩҲЩҺШҘЩҗЩҶ Щ…Щ‘ЩҺШіЩ‘ЩҺЩҮЩҸ ЩұЩ„ШҙЩ‘ЩҺШұЩ‘ЩҸ ЩҒЩҺЩҠЩҺЩҖЩ”ЩҸЩҲШіЩҢЫӯ ЩӮЩҺЩҶЩҸЩҲШ·ЩҢЫӯ"},{"key":"41:50","surah":41,"ayah":50,"num":4268,"page":482,"words":[{"code":"пұ»","page":482,"end":false},{"code":"пұј","page":482,"end":false},{"code":"пұҪ","page":482,"end":false},{"code":"пұҫ","page":482,"end":false},{"code":"пұҝ","page":482,"end":false},{"code":"пІҖ","page":482,"end":false},{"code":"пІҒ","page":482,"end":false},{"code":"пІӮ","page
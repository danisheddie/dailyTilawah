":"піҳ","page":120,"end":false},{"code":"піҷ","page":120,"end":false},{"code":"піҡ","page":120,"end":false},{"code":"піӣ","page":120,"end":false},{"code":"пің","page":120,"end":false},{"code":"піқ","page":120,"end":false},{"code":"піһ","page":120,"end":false},{"code":"піҹ","page":120,"end":false},{"code":"пі ","page":120,"end":false},{"code":"піЎ","page":120,"end":false},{"code":"піў","page":120,"end":false},{"code":"піЈ","page":120,"end":false},{"code":"піӨ","page":120,"end":false},{"code":"піҘ","page":120,"end":false},{"code":"піҰ","page":120,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҮЩ’Щ„ЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ„ЩҺШ§ ШӘЩҺШәЩ’Щ„ЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШҜЩҗЩҠЩҶЩҗЩғЩҸЩ…Щ’ ШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҮЩ’ЩҲЩҺШ§Щ“ШЎЩҺ ЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩӮЩҺШҜЩ’ Ш¶ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ ЩҲЩҺШЈЩҺШ¶ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ ЩҲЩҺШ¶ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶ ШіЩҺЩҲЩҺШ§Щ“ШЎЩҗ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ"},{"key":"5:78","surah":5,"ayah":78,"num":747,"page":121,"words":[{"code":"пұҒ","page":121,"end":false},{"code":"пұӮ","page":121,"end":false},{"code":"пұғ","page":121,"end":false},{"code":"пұ„","page":121,"end":false},{"code":"пұ…","page":121,"end":false},{"code":"пұҶ","page":121,"end":false},{"code":"пұҮ","page":121,"end":false},{"code":"пұҲ","page":121,"end":false},{"code":"пұү","page":121,"end":false},{"code":"пұҠ","page":121,"end":false},{"code":"пұӢ","page":121,"end":false},{"code":"пұҢпұҚ","page":121,"end":false},{"code":"пұҺ","page":121,"end":false},{"code":"пұҸ","page":121,"end":false},{"code":"пұҗ","page":121,"end":false},{"code":"пұ‘","page":121,"end":false},{"code":"пұ’","page":121,"end":false},{"code":"пұ“","page":121,"end":true}],"text":"Щ„ЩҸШ№ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЫў ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° Щ„ЩҗШіЩҺШ§ЩҶЩҗ ШҜЩҺШ§ЩҲЩҸЫҘШҜЩҺ ЩҲЩҺШ№ЩҗЩҠШіЩҺЩү ЩұШЁЩ’ЩҶЩҗ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺШөЩҺЩҲШ§Ыҹ ЩҲЩ‘ЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"5:79","sur
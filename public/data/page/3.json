":"піү","end":false},{"code":"піҠ","end":false},{"code":"піӢ","end":false},{"code":"піҢ","end":false},{"code":"піҚ","end":false},{"code":"піҺ","end":true}]}],"verses":[{"key":"2:6","surah":2,"ayah":6,"num":13,"page":3,"words":[{"code":"пұҒ","page":3,"end":false},{"code":"пұӮ","page":3,"end":false},{"code":"пұғ","page":3,"end":false},{"code":"пұ„","page":3,"end":false},{"code":"пұ…","page":3,"end":false},{"code":"пұҶ","page":3,"end":false},{"code":"пұҮ","page":3,"end":false},{"code":"пұҲ","page":3,"end":false},{"code":"пұү","page":3,"end":false},{"code":"пұҠ","page":3,"end":false},{"code":"пұӢ","page":3,"end":false},{"code":"пұҢ","page":3,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШіЩҺЩҲЩҺШ§Щ“ШЎЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШЎЩҺШЈЩҺЩҶШ°ЩҺШұЩ’ШӘЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩ…Щ’ Щ„ЩҺЩ…Щ’ ШӘЩҸЩҶШ°ЩҗШұЩ’ЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"2:7","surah":2,"ayah":7,"num":14,"page":3,"words":[{"code":"пұҚ","page":3,"end":false},{"code":"пұҺ","page":3,"end":false},{"code":"пұҸ","page":3,"end":false},{"code":"пұҗ","page":3,"end":false},{"code":"пұ‘","page":3,"end":false},{"code":"пұ’пұ“","page":3,"end":false},{"code":"пұ”","page":3,"end":false},{"code":"пұ•","page":3,"end":false},{"code":"пұ–пұ—","page":3,"end":false},{"code":"пұҳ","page":3,"end":false},{"code":"пұҷ","page":3,"end":false},{"code":"пұҡ","page":3,"end":false},{"code":"пұӣ","page":3,"end":true}],"text":"Ш®ЩҺШӘЩҺЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШ№ЩҺЩ„ЩҺЩүЩ° ШіЩҺЩ…Щ’Ш№ЩҗЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺШ№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШЁЩ’ШөЩҺЩҖЩ°ШұЩҗЩҮЩҗЩ…Щ’ ШәЩҗШҙЩҺЩҖЩ°ЩҲЩҺШ©ЩҢЫӯ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:8","surah":2,"ayah":8,"num":15,"page":3,"words":[{"code":"пұң","page":3,"end":false},{"code":"пұқ","page":3,"end":false},{"code":"пұһ","page":3,"end":false},{"code":"пұҹ","page":3,"end":false},{"code":"пұ ","page":3,"end":false},{"code":"пұЎ","page":3,"end":false},{"code":"пұў","page":3,"end":false},{"code":"пұЈ","page":3,"end":false},{"code":"пұӨ","page":3,"end":false},{"code":"пұҘ","page":3,"end":false},{"code":"пұҰ","page":3,"end":false},{"code":"пұ§","page":3,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ…ЩҺЩҶ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ ШЎЩҺШ§Щ…ЩҺЩҶЩ‘ЩҺШ§ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЁЩҗЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩ… ШЁЩҗЩ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"2:9","surah":2,"ayah":9,"num":16,"page":3,"words":[{"code":"пұЁ","page":3,"end":false},{"code":"пұ©","page":3,"end":false},{"code":"пұӘ","page":3,"end":false},{"code":"пұ«","page":3,"end":false},{"code":"пұ¬","page":3,"end":false},{"code":"пұӯ","page":3,"end":false},{"code":"пұ®","page":3,"end":false},{"code":"пұҜ","page":3,"end":false},{"code":"пұ°","page":3,"end":false},{"code":"пұұ","page":3,"end":false},{"code":"пұІ","page":3,"end":true}],"text":"ЩҠЩҸШ®ЩҺЩҖЩ°ШҜЩҗШ№ЩҸЩҲЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ®Щ’ШҜЩҺШ№ЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШҙЩ’Ш№ЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"2:10","surah":2,"ayah":10,"num":17,"page":3,"words":[{"code":"пұі","page":3,"end":false},{"code":"пұҙ","page":3,"end":false},{"code":"пұө","page":3,"end":false},{"code":"пұ¶","page":3,"end":false},{"code":"пұ·","page":3,"end":false},{"code":"пұёпұ№","page":3,"end":false},{"code":"пұә","page":3,"end":false},{"code":"пұ»","page":3,"end":false},{"code":"пұј","page":3,"end":false},{"code":"пұҪ","page":3,"end":false},{"code":"пұҫ","page":3,"end":false},{"code":"пұҝ","page":3,"end":false},{"code":"пІҖ","page":3,"end":true}],"text":"ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ… Щ…Щ‘ЩҺШұЩҺШ¶ЩҢЫӯ ЩҒЩҺШІЩҺШ§ШҜЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШұЩҺШ¶ЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’Ш°ЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"2:11","surah":2,"ayah":11,"num":18,"page":3,"words":[{"code":"пІҒ","page":3,"end":false},{"code":"пІӮ","page":3,"end":false},{"code":"пІғ","page":3,"end":false},{"code":"пІ„","page":3,"end":false},{"code":"пІ…","page":3,"end":false},{"code":"пІҶ","page":3,"end":false},{"code":"пІҮ","page":3,"end":false},{"code":"пІҲ","page":3,"end":false},{"code":"пІү","page":3,"end":false},{"code":"пІҠ","page":3,"end":false},{"code":"пІӢ","page":3,"end":false},{"code":"пІҢ","page":3,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ШӘЩҸЩҒЩ’ШіЩҗШҜЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҶЩҺШӯЩ’ЩҶЩҸ Щ…ЩҸШөЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"2:12","surah":2,"ayah":12,"num":19,"page":3,"words":[{"code":"пІҚ","page":3,"end":false},{"code":"пІҺ","page":3,"end":false},{"code":"пІҸ","page":3,"end":false},{"code":"пІҗ","page":3,"end":false},{"code":"пІ‘","page":3,"end":false},{"code":"пІ’","page":3,"end":false},{"code":"пІ“","page":3,"end":false},{"code":"пІ”","page":3,"end":true}],"text":"ШЈЩҺЩ„ЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’ШіЩҗШҜЩҸЩҲЩҶЩҺ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ Щ„Щ‘ЩҺШ§ ЩҠЩҺШҙЩ’Ш№ЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"2:13","surah":2,"ayah":13,"num":20,"page":3,"words":[{"code":"пІ•","page":3,"end":false},{"code":"пІ–","page":3,"end":false},{"code":"пІ—","page":3,"end":false},{"code":"пІҳ","page":3,"end":false},{"code":"пІҷ","page":3,"end":false},{"code":"пІҡ","page":3,"end":false},{"code":"пІӣ","page":3,"end":false},{"code":"пІң","page":3,"end":false},{"code":"пІқ","page":3,"end":false},{"code":"пІһ","page":3,"end":false},{"code":"пІҹ","page":3,"end":false},{"code":"пІ пІЎ","page":3,"end":false},{"code":"пІў","page":3,"end":false},{"code":"пІЈ","page":3,"end":false},{"code":"пІӨ","page":3,"end":false},{"code":"пІҘ","page":3,"end":false},{"code":"пІҰ","page":3,"end":false},{"code":"пІ§","page":3,"end":false},{"code":"пІЁ","page":3,"end":false},{"code":"пІ©","page":3,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЎЩҺШ§Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ЩғЩҺЩ…ЩҺШ§Щ“ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ЩғЩҺЩ…ЩҺШ§Щ“ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ЩұЩ„ШіЩ‘ЩҸЩҒЩҺЩҮЩҺШ§Щ“ШЎЩҸ Ы— ШЈЩҺЩ„ЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩҮЩҸЩ…ЩҸ ЩұЩ„ШіЩ‘ЩҸЩҒЩҺЩҮЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ Щ„Щ‘ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:14","surah":2,"ayah":14,"num":21,"page":3,"words":[{"code":"пІӘ","page":3,"end":false},{"code":"пІ«","page":3,"end":false},{"code":"пІ¬","page":3,"end":false},{"code":"пІӯ","page":3,"end":false},{"code":"пІ®","page":3,"end":false},{"code":"пІҜ","page":3,"end":false},{"code":"пІ°","page":3,"end":false},{"code":"пІұ","page":3,"end":false},{"code":"пІІ","page":3,"end":false},{"code":"пІі","page":3,"end":false},{"code":"пІҙ","page":3,"end":false},{"code":"пІө","page":3,"end":false},{"code":"пІ¶","page":3,"end":false},{"code":"пІ·","page":3,"end":false},{"code":"пІё","page":3,"end":false},{"code":"пІ№","page":3,"end":false},{"code":"пІә","page":3,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ Щ„ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Щ…ЩҺЩҶЩ‘ЩҺШ§ ЩҲЩҺШҘЩҗШ°ЩҺШ§ Ш®ЩҺЩ„ЩҺЩҲЩ’Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° ШҙЩҺЩҠЩҺЩҖЩ°Ш·ЩҗЩҠЩҶЩҗЩҮЩҗЩ…Щ’ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ Щ…ЩҺШ№ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҶЩҺШӯЩ’ЩҶЩҸ Щ…ЩҸШіЩ’ШӘЩҺЩҮЩ’ШІЩҗШЎЩҸЩҲЩҶЩҺ"},{"key":"2:15","surah":2,"ayah":15,"num":22,"page":3,"words":[{"code":"пІ»","page":3,"end":false},{"code":"пІј","page":3,"end":false},{"code":"пІҪ","page":3,"end":false},{"code":"пІҫ","page":3,"end":false},{"code":"пІҝ","page":3,"end":false},{"code":"піҖ","page":3,"end":false},{"code":"піҒ","page":3,"end":false},{"code":"піӮ","page":3,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҺШіЩ’ШӘЩҺЩҮЩ’ШІЩҗШҰЩҸ ШЁЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺЩҠЩҺЩ…ЩҸШҜЩ‘ЩҸЩҮЩҸЩ…Щ’ ЩҒЩҗЩү Ш·ЩҸШәЩ’ЩҠЩҺЩҖЩ°ЩҶЩҗЩҮЩҗЩ…Щ’ ЩҠЩҺШ№Щ’Щ…ЩҺЩҮЩҸЩҲЩҶЩҺ"},{"key":"2:16","surah":2,"ayah":16,"num":23,"page":3,"words":[{"code":"піғ","page":3,"end":false},{"code":"пі„","page":3,"end":false},{"code":"пі…","page":3,"end":false},{"code":"піҶ","page":3,"end":false},{"code":"піҮ","page":3,"end":false},{"code":"піҲ","page":3,"end":false},{"code":"піү","page":3,"end":false},{"code":"піҠ","page":3,"end":false},{"code":"піӢ","page":3,"end":false},{"code":"піҢ","page":3,"end":false},{"code":"піҚ","page":3,"end":false},{"code":"піҺ","page":3,"end":true}],"text":"ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШҙЩ’ШӘЩҺШұЩҺЩҲЩҸШ§Ыҹ ЩұЩ„Ш¶Щ‘ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҺШ©ЩҺ ШЁЩҗЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° ЩҒЩҺЩ…ЩҺШ§ ШұЩҺШЁЩҗШӯЩҺШӘ ШӘЩ‘ЩҗШ¬ЩҺЩҖЩ°ШұЩҺШӘЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ Щ…ЩҸЩҮЩ’ШӘЩҺШҜЩҗЩҠЩҶЩҺ"}]}
rue}]}],"verses":[{"key":"39:68","surah":39,"ayah":68,"num":4126,"page":466,"words":[{"code":"пұҒ","page":466,"end":false},{"code":"пұӮ","page":466,"end":false},{"code":"пұғ","page":466,"end":false},{"code":"пұ„","page":466,"end":false},{"code":"пұ…","page":466,"end":false},{"code":"пұҶ","page":466,"end":false},{"code":"пұҮ","page":466,"end":false},{"code":"пұҲ","page":466,"end":false},{"code":"пұү","page":466,"end":false},{"code":"пұҠ","page":466,"end":false},{"code":"пұӢ","page":466,"end":false},{"code":"пұҢ","page":466,"end":false},{"code":"пұҚ","page":466,"end":false},{"code":"пұҺпұҸ","page":466,"end":false},{"code":"пұҗ","page":466,"end":false},{"code":"пұ‘","page":466,"end":false},{"code":"пұ’","page":466,"end":false},{"code":"пұ“","page":466,"end":false},{"code":"пұ”","page":466,"end":false},{"code":"пұ•","page":466,"end":false},{"code":"пұ–","page":466,"end":false},{"code":"пұ—","page":466,"end":false},{"code":"пұҳ","page":466,"end":true}],"text":"ЩҲЩҺЩҶЩҸЩҒЩҗШ®ЩҺ ЩҒЩҗЩү ЩұЩ„ШөЩ‘ЩҸЩҲШұЩҗ ЩҒЩҺШөЩҺШ№ЩҗЩӮЩҺ Щ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩҶ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– Ш«ЩҸЩ…Щ‘ЩҺ ЩҶЩҸЩҒЩҗШ®ЩҺ ЩҒЩҗЩҠЩҮЩҗ ШЈЩҸШ®Щ’ШұЩҺЩүЩ° ЩҒЩҺШҘЩҗШ°ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩӮЩҗЩҠЩҺШ§Щ…ЩҢЫӯ ЩҠЩҺЩҶШёЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"39:69","surah":39,"ayah":69,"num":4127,"page":466,"words":[{"code":"пұҷ","page":466,"end":false},{"code":"пұҡ","page":466,"end":false},{"code":"пұӣ","page":466,"end":false},{"code":"пұң","page":466,"end":false},{"code":"пұқ","page":466,"end":false},{"code":"пұһ","page":466,"end":false},{"code":"пұҹ","page":466,"end":false},{"code":"пұ ","page":466,"end":false},{"code":"пұЎ","page":466,"end":false},{"code":"пұў","page":466,"end":false},{"code":"пұЈ","page":466,"end":false},{"code":"пұӨ","page":466,"end":false},{"code":"пұҘ","page":466,"end":false},{"code":"пұҰ","page":466,"end":false},{"code":"пұ§","page":466,"end":false},{"code":"пұЁ","page":466,"end":true}],"text":"ЩҲЩҺШЈЩҺШҙЩ’ШұЩҺЩӮЩҺШӘЩҗ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ ШЁЩҗЩҶЩҸЩҲШұЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҺШ§ ЩҲЩҺЩҲЩҸШ¶ЩҗШ№ЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҸ ЩҲЩҺШ¬ЩҗШ§ЫҹЩүЩ“ШЎЩҺ ШЁЩҗЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩҗЩҖЫ§ЩҶЩҺ ЩҲЩҺЩұЩ„ШҙЩ‘ЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҗ ЩҲЩҺЩӮЩҸШ¶ЩҗЩүЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"39:70","surah":39,"ayah":70,"num":4128,"page":466,"words":[{"code":"пұ©","page":466,"end":false},{"code":"пұӘ","page":466,"end":false},{"code":"пұ«","page":466,"end":false},{"code":"пұ¬","page":466,"end":false},{"code":"пұӯ","page":466,"end":false},{"code":"пұ®","page":466,"end":false},{"code":"пұҜ","page":466,"end":false},{"code":"пұ°","page":466,"end":false},{"code":"пұұ","page":466,"end":false},{"code":"пұІ","page":466,"end":true}],"text":"ЩҲЩҺЩҲЩҸЩҒЩ‘ЩҗЩҠЩҺШӘЩ’ ЩғЩҸЩ„Щ‘ЩҸ ЩҶЩҺЩҒЩ’ШіЩҚЫў Щ…Щ‘ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҺШӘЩ’ ЩҲЩҺЩҮЩҸЩҲЩҺ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗЩ…ЩҺШ§ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"39:71","surah":39,"ayah":71,"num":4129,"page":466,"words":[{"code":"пұі","page":466,"end":false},{"code":"пұҙ","page":466,"end":false},{"code":"пұө","page":466,"end":false},{"code":"пұ¶","page":466,"end":false},{"code":"пұ·","page":466,"end":false},{"code":"пұёпұ№","page":466,"end":false},{"code":"пұә","page":466,"end":false},{"code":"пұ»","page":466,"end":false},{"code":"пұј","page":466,"end":false},{"code":"пұҪ","page":466,"end":false},{"code":"пұҫ","page":466,"end":false},{"code":"пұҝ","page":466,"end":false},{"code":"пІҖ","page":466,"end":false},{"code":"пІҒ","page":466,"end":false},{"code":"пІӮ","page":466,"end":false},{"code":"пІғ","page":466,"end":false},{"code":"пІ„","page":466,"end":false},{"code":"пІ…","page":466,"end":false},{"code":"пІҶ","page":466,"end":false},{"code":"пІҮ","page":466,"end":false},{"code":"пІҲ","page":466,"end":false},{"code":"пІү","page":466,"end":false},{"code":"пІҠ","page":466,"end":false},{"code":"пІӢ","page":466,"end":false},{"code":"пІҢ","page":466,"end":false},{"code":"пІҚпІҺ","page":466,"end":false},{"code":"пІҸ","page":466,"end":false},{"code":"пІҗ","page":466,"end":false},{"code":"пІ‘","page":466,"end":false},{"code":"пІ’","page":466,"end":false},{"code":"пІ“","page":466,"end":false},{"code":"пІ”","page":466,"end":false},{"code":"пІ•","page":466,"end":false},{"code":"пІ–","page":466,"end":false},{"code":"пІ—","page":466,"end":true}],"text":"ЩҲЩҺШіЩҗЩҠЩӮЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ ШІЩҸЩ…ЩҺШұЩӢШ§ Ы– ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲЩҮЩҺШ§ ЩҒЩҸШӘЩҗШӯЩҺШӘЩ’ ШЈЩҺШЁЩ’ЩҲЩҺЩ°ШЁЩҸЩҮЩҺШ§ ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш®ЩҺШІЩҺЩҶЩҺШӘЩҸЩҮЩҺШ§Щ“ ШЈЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШЈЩ’ШӘЩҗЩғЩҸЩ…Щ’ ШұЩҸШіЩҸЩ„ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩғЩҸЩ…Щ’ ЩҠЩҺШӘЩ’Щ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҸЩҶШ°ЩҗШұЩҸЩҲЩҶЩҺЩғЩҸЩ…Щ’ Щ„ЩҗЩӮЩҺШ§Щ“ШЎЩҺ ЩҠЩҺЩҲЩ’Щ…ЩҗЩғЩҸЩ…Щ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Ыҡ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШЁЩҺЩ„ЩҺЩүЩ° ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ’ ШӯЩҺЩӮЩ‘ЩҺШӘЩ’ ЩғЩҺЩ„ЩҗЩ…ЩҺШ©ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"39:72","surah":39,"ayah":72,"num":4130,"page":466,"words":[{"code":"пІҳ","page":466,"end":false},{"code":"пІҷ","page":466,"end":false},{"code":"пІҡ","page":466,"end":false},{"code":"пІӣ","page":466,"end":false},{"code":"пІң","page":466,"end":false},{"code":"пІқпІһ","page":466,"end":false},{"code":"пІҹ","page":466,"end":false},{"code":"пІ ","page":466,"end":false},{"code":"пІЎ","page":466,"end":false},{"code":"пІў","page":466,"end":true}],"text":"ЩӮЩҗЩҠЩ„ЩҺ ЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШЁЩ’ЩҲЩҺЩ°ШЁЩҺ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ы– ЩҒЩҺШЁЩҗШҰЩ’ШіЩҺ Щ…ЩҺШ«Щ’ЩҲЩҺЩү ЩұЩ„Щ’Щ…ЩҸШӘЩҺЩғЩҺШЁЩ‘ЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"39:73","surah":39,"ayah":73,"num":4131,"page":466,"words":[{"code":"пІЈ","page":466,"end":false},{"code":"пІӨ","page":466,"end":false},{"code":"пІҘ","page":466,"end":false},{"code":"пІҰ","page":466,"end":false},{"code":"пІ§","page":466,"end":false},{"code":"пІЁ","page":466,"end":false},{"code":"пІ©пІӘ","page":466,"end":false},{"code":"пІ«","page":466,"end":false},{"code":"пІ¬","page":466,"end":false},{"code":"пІӯ","page":466,"end":false},{"code":"пІ®","p
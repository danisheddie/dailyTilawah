lse},{"code":"пұӮ","page":202,"end":false},{"code":"пұғ","page":202,"end":false},{"code":"пұ„","page":202,"end":false},{"code":"пұ…пұҶ","page":202,"end":false},{"code":"пұҮ","page":202,"end":false},{"code":"пұҲ","page":202,"end":false},{"code":"пұү","page":202,"end":false},{"code":"пұҠ","page":202,"end":false},{"code":"пұӢ","page":202,"end":false},{"code":"пұҢ","page":202,"end":false},{"code":"пұҚ","page":202,"end":false},{"code":"пұҺ","page":202,"end":false},{"code":"пұҸ","page":202,"end":false},{"code":"пұҗ","page":202,"end":false},{"code":"пұ‘пұ’","page":202,"end":false},{"code":"пұ“","page":202,"end":false},{"code":"пұ”","page":202,"end":false},{"code":"пұ•","page":202,"end":false},{"code":"пұ–","page":202,"end":false},{"code":"пұ—","page":202,"end":false},{"code":"пұҳ","page":202,"end":false},{"code":"пұҷ","page":202,"end":false},{"code":"пұҡ","page":202,"end":false},{"code":"пұӣ","page":202,"end":false},{"code":"пұң","page":202,"end":false},{"code":"пұқ","page":202,"end":false},{"code":"пұһ","page":202,"end":false},{"code":"пұҹ","page":202,"end":false},{"code":"пұ ","page":202,"end":false},{"code":"пұЎ","page":202,"end":true}],"text":"ЩҠЩҺШ№Щ’ШӘЩҺШ°ЩҗШұЩҸЩҲЩҶЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШҘЩҗШ°ЩҺШ§ ШұЩҺШ¬ЩҺШ№Щ’ШӘЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ыҡ ЩӮЩҸЩ„ Щ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШӘЩҺШ°ЩҗШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҶ ЩҶЩ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩӮЩҺШҜЩ’ ЩҶЩҺШЁЩ‘ЩҺШЈЩҺЩҶЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҶЩ’ ШЈЩҺШ®Щ’ШЁЩҺШ§ШұЩҗЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШіЩҺЩҠЩҺШұЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ…ЩҺЩ„ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҸЩҮЩҸЫҘ Ш«ЩҸЩ…Щ‘ЩҺ ШӘЩҸШұЩҺШҜЩ‘ЩҸЩҲЩҶЩҺ ШҘЩҗЩ„ЩҺЩүЩ° Ш№ЩҺЩҖЩ°Щ„ЩҗЩ…Щҗ ЩұЩ„Щ’ШәЩҺЩҠЩ’ШЁЩҗ ЩҲЩҺЩұЩ„ШҙЩ‘ЩҺЩҮЩҺЩҖЩ°ШҜЩҺШ©Щҗ ЩҒЩҺЩҠЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"9:95","surah":9,"ayah":95,"num":1330,"page":202,"words":[{"code":"пұў","page":202,"end":false},{"code":"пұЈ","page":202,"end":false},{"code":"пұӨ","page":202,"end":false},{"code":"пұҘ","page":202,"end":false},{"code":"пұҰ","page":202,"end":false},{"code":"пұ§","page":202,"end":false},{"code":"пұЁ","page":202,"end":false},{"code":"пұ©пұӘ","page":202,"end":false},{"code":"пұ«","page":202,"end":false},{"code":"пұ¬пұӯ","page":202,"end":false},{"code":"пұ®","page":202,"end":false},{"code":"пұҜпұ°","page":202,"end":false},{"code":"пұұ","page":202,"end":false},{"code":"пұІ","page":202,"end":false},{"code":"пұі","page":202,"end":false},{"code":"пұҙ","page":202,"end":false},{"code":"пұө","page":202,"end":false},{"code":"пұ¶","page":202,"end":false},{"code":"пұ·","page":202,"end":true}],"text":"ШіЩҺЩҠЩҺШӯЩ’Щ„ЩҗЩҒЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺЩғЩҸЩ…Щ’ ШҘЩҗШ°ЩҺШ§ ЩұЩҶЩӮЩҺЩ„ЩҺШЁЩ’ШӘЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Щ„ЩҗШӘЩҸШ№Щ’ШұЩҗШ¶ЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҒЩҺШЈЩҺШ№Щ’ШұЩҗШ¶ЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ШұЩҗШ¬Щ’ШіЩҢЫӯ Ы– ЩҲЩҺЩ…ЩҺШЈЩ’ЩҲЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ Ш¬ЩҺШІЩҺШ§Щ“ШЎЩӢЫў ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"9:96","surah":9,"ayah":96,"num":1331,"page":202,"words":[{"code":"пұё","page":202,"end":false},{"code":"пұ№","page":202,"end":false},{"code":"пұә","page":202,"end":false},{"code":"пұ»пұј","page":202,"end":false},{"code":"пұҪ","page":202,"end":false},{"code":"пұҫ","page":202,"end":false},{"code":"пұҝ","page":202,"end":false},{"code":"пІҖ","page":202,"end":false},{"code":"пІҒ","page":202,"end":false},{"code":"пІӮ","page":202,"end":false},{"code":"пІғ","page":202,"end":false},{"code":"пІ„","page":202,"end":false},{"code":"пІ…","page":202,"end":false},{"code":"пІҶ","page":202,"end":false},{"code":"пІҮ","page":202,"end":true}],"text":"ЩҠЩҺШӯЩ’Щ„ЩҗЩҒЩҸЩҲЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Щ„ЩҗШӘЩҺШұЩ’Ш¶ЩҺЩҲЩ’Ш§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҒЩҺШҘЩҗЩҶ ШӘЩҺШұЩ’Ш¶ЩҺЩҲЩ’Ш§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҺШұЩ’Ш¶ЩҺЩүЩ° Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"9:97","surah":9,"ayah":97,"num":1332,"page":202,"words":[{"code":"пІҲ","page":202,"end":false},{"code":"пІү","page":202,"end":false},{"code":"пІҠ","page":202,"end":false},{"code":"пІӢ","page":202,"end":false},{"code":"пІҢ","page":202,"end":false},{"code":"пІҚ","page":202,"end":false},{"code":"пІҺ","page":202,"end":false},{"code":"пІҸ","page":202,"end":false},{"code":"пІҗ","page":202,"end":false},{"code":"пІ‘","page":202,"end":false},{"code":"пІ’","page":202,"end":false},{"code":"пІ“","page":202,"end":false},{"code":"пІ”пІ•","page":202,"end":false},{"code":"пІ–","page":202,"end":false},{"code":"пІ—","page":202,"end":false},{"code":"пІҳ","page":202,"end":false},{"code":"пІҷ","page":202,"end":true}],"text":"ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ§ШЁЩҸ ШЈЩҺШҙЩҺШҜЩ‘ЩҸ ЩғЩҸЩҒЩ’ШұЩӢЫӯШ§ ЩҲЩҺЩҶЩҗЩҒЩҺШ§ЩӮЩӢЫӯШ§ ЩҲЩҺШЈЩҺШ¬Щ’ШҜЩҺШұЩҸ ШЈЩҺЩ„Щ‘ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ШӯЩҸШҜЩҸЩҲШҜЩҺ Щ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"},{"key":"9:98","surah":9,"ayah":98,"num":1333,"page":202,"words":[{"code":"пІҡ","page":202,"end":false},{"code":"пІӣ","page":202,"end":false},{"code":"пІң","page":202,"end":false},{"code":"пІқ","page":202,"end":false},{"code":"пІһ","page":202,"end":false},{"code":"пІҹ","page":202,"end":false},{"code":"пІ ","page":202,"end":false},{"code":"пІЎ","page":202,"end":false},{"code":"пІў","page":202,"end":false},{"code":"пІЈпІӨ","page":202,"end":false},{"code":"пІҘ","page":202,"end":false},{"code":"пІҰ","page":202,"end":false},{"code":"пІ§пІЁ","page":202,"end":false},{"code":"пІ©","page":202,"end":false},{"code":"пІӘ","page":202,"end":false},{"code":"пІ«","page":202,"end":false},{"code":"пІ¬","page":202,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ§ШЁЩҗ Щ…ЩҺЩҶ ЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸ Щ…ЩҺШ§ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸ Щ…ЩҺШәЩ’ШұЩҺЩ…ЩӢЫӯШ§ ЩҲЩҺЩҠЩҺШӘЩҺШұЩҺШЁЩ‘ЩҺШөЩҸ ШЁЩҗЩғЩҸЩ…ЩҸ ЩұЩ„ШҜЩ‘ЩҺЩҲЩҺШ§Щ“ШҰЩҗШұЩҺ Ыҡ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШҜЩҺШ§Щ“ШҰЩҗШұЩҺШ©ЩҸ ЩұЩ„ШіЩ‘ЩҺЩҲЩ’ШЎЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩ…ЩҗЩҠШ№ЩҢ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"9:99","surah":9,"ayah":99,"num":1334,"page":202,"words":[{"code":"пІӯ","page":202,"end":false},{"code":"пІ®","page":202,"end":false},{"code":"пІҜ","page":202,"end":false},{"code":"пІ°","page":202,"end":false},{"code":"пІұ","page":202,"end":false},{"code":"пІІ","page":202,"end":false},{"code":"пІі","page":202,"end":false},{"code":"пІҙ","page":202,"end":false},{"code":"пІө","page":202,"end":false},{"code":"пІ¶","page":202,"end":false},{"code":"пІ·","page":202,"end":false},{"code":"пІё","page":202,"end":false},{"code":"пІ№","page":202,"end":false},{"code":"пІә","page":202,"end":false},{"code":"пІ»пІј","page":202,"end":false},{"code":"пІҪ","page":202,"end":false},{"code":"пІҫ","page":202,"end":false},{"code":"пІҝ","page":202,"end":false},{"code":"піҖпіҒ","page":202,"end":false},{"code":"піӮ","page":202,"end":false},{"code":"піғ","page":202,"end":false},{"code":"пі„","page":202,"end":false},{"code":"пі…піҶ","page":202,"end":false},{"code":"піҮ","page":202,"end":false},{"code":"піҲ","page":202,"end":false},{"code":"піү","page":202,"end":false},{"code":"піҠ","page":202,"end":false},{"code":"піӢ","page":202,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ§ШЁЩҗ Щ…ЩҺЩҶ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ ЩҲЩҺЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸ Щ…ЩҺШ§ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸ ЩӮЩҸШұЩҸШЁЩҺЩҖЩ°ШӘЩҚ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШөЩҺЩ„ЩҺЩҲЩҺЩ°ШӘЩҗ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ Ыҡ ШЈЩҺЩ„ЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҺШ§ ЩӮЩҸШұЩ’ШЁЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЩ…Щ’ Ыҡ ШіЩҺЩҠЩҸШҜЩ’Ш®ЩҗЩ„ЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҗЩү ШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"}]}
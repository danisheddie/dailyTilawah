se},{"code":"пІӮ","page":79,"end":false},{"code":"пІғ","page":79,"end":false},{"code":"пІ„","page":79,"end":false},{"code":"пІ…","page":79,"end":false},{"code":"пІҶ","page":79,"end":false},{"code":"пІҮпІҲ","page":79,"end":false},{"code":"пІү","page":79,"end":false},{"code":"пІҠ","page":79,"end":false},{"code":"пІӢ","page":79,"end":false},{"code":"пІҢ","page":79,"end":false},{"code":"пІҚ","page":79,"end":false},{"code":"пІҺ","page":79,"end":false},{"code":"пІҸ","page":79,"end":false},{"code":"пІҗ","page":79,"end":false},{"code":"пІ‘пІ’","page":79,"end":false},{"code":"пІ“","page":79,"end":false},{"code":"пІ”","page":79,"end":false},{"code":"пІ•","page":79,"end":false},{"code":"пІ–","page":79,"end":false},{"code":"пІ—","page":79,"end":false},{"code":"пІҳ","page":79,"end":false},{"code":"пІҷ","page":79,"end":false},{"code":"пІҡ","page":79,"end":false},{"code":"пІӣпІң","page":79,"end":false},{"code":"пІқ","page":79,"end":false},{"code":"пІһ","page":79,"end":false},{"code":"пІҹпІ ","page":79,"end":false},{"code":"пІЎ","page":79,"end":false},{"code":"пІў","page":79,"end":false},{"code":"пІЈ","page":79,"end":false},{"code":"пІӨ","page":79,"end":true}],"text":"Ыһ ЩҲЩҺЩ„ЩҺЩғЩҸЩ…Щ’ ЩҶЩҗШөЩ’ЩҒЩҸ Щ…ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҸЩғЩҸЩ…Щ’ ШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҶ Щ„Щ‘ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ ЩҒЩҺЩ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„ШұЩ‘ЩҸШЁЩҸШ№ЩҸ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩ’ЩҶЩҺ Ыҡ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ ЩҲЩҺШөЩҗЩҠЩ‘ЩҺШ©ЩҚЫў ЩҠЩҸЩҲШөЩҗЩҠЩҶЩҺ ШЁЩҗЩҮЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ШҜЩҺЩҠЩ’ЩҶЩҚЫў Ыҡ ЩҲЩҺЩ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩұЩ„ШұЩ‘ЩҸШЁЩҸШ№ЩҸ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩ’ШӘЩҸЩ…Щ’ ШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҶ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ ЩҒЩҺЩ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩұЩ„Ш«Щ‘ЩҸЩ…ЩҸЩҶЩҸ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩ’ШӘЩҸЩ… Ыҡ Щ…Щ‘ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ ЩҲЩҺШөЩҗЩҠЩ‘ЩҺШ©ЩҚЫў ШӘЩҸЩҲШөЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ШҜЩҺЩҠЩ’ЩҶЩҚЫў Ы— ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ ШұЩҺШ¬ЩҸЩ„ЩҢЫӯ ЩҠЩҸЩҲШұЩҺШ«ЩҸ ЩғЩҺЩ„ЩҺЩҖЩ°Щ„ЩҺШ©ЩӢ ШЈЩҺЩҲЩҗ ЩұЩ…Щ’ШұЩҺШЈЩҺШ©ЩҢЫӯ ЩҲЩҺЩ„ЩҺЩҮЩҸЫҘЩ“ ШЈЩҺШ®ЩҢ ШЈЩҺЩҲЩ’ ШЈЩҸШ®Щ’ШӘЩҢЫӯ ЩҒЩҺЩ„ЩҗЩғЩҸЩ„Щ‘Щҗ ЩҲЩҺЩ°ШӯЩҗШҜЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ ЩұЩ„ШіЩ‘ЩҸШҜЩҸШіЩҸ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ Щ…ЩҗЩҶ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҒЩҺЩҮЩҸЩ…Щ’ ШҙЩҸШұЩҺЩғЩҺШ§Щ“ШЎЩҸ ЩҒЩҗЩү ЩұЩ„Ш«Щ‘ЩҸЩ„ЩҸШ«Щҗ Ыҡ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ ЩҲЩҺШөЩҗЩҠЩ‘ЩҺШ©ЩҚЫў ЩҠЩҸЩҲШөЩҺЩүЩ° ШЁЩҗЩҮЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ШҜЩҺЩҠЩ’ЩҶЩҚ ШәЩҺЩҠЩ’ШұЩҺ Щ…ЩҸШ¶ЩҺШ§Щ“ШұЩ‘ЩҚЫў Ыҡ ЩҲЩҺШөЩҗЩҠЩ‘ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ ШӯЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"4:13","surah":4,"ayah":13,"num":506,"page":79,"words":[{"code":"пІҘ","page":79,"end":false},{"code":"пІҰ","page":79,"end":false},{"code":"пІ§пІЁ","page":79,"end":false},{"code":"пІ©","page":79,"end":false},{"code":"пІӘ","page":79,"end":false},{"code":"пІ«","page":79,"end":false},{"code":"пІ¬","page":79,"end":false},{"code":"пІӯ","page":79,"end":false},{"code":"пІ®","page":79,"end":false},{"code":"пІҜ","page":79,"end":false},{"code":"пІ°","page":79,"end":false},{"code":"пІұ","page":79,"end":false},{"code":"пІІ","page":79,"end":false},{"code":"пІі","page":79,"end":false},{"code":"пІҙпІө","page":79,"end":false},{"code":"пІ¶","page":79,"end":false},{"code":"пІ·","page":79,"end":false},{"code":"пІё","page":79,"end":false},{"code":"пІ№","page":79,"end":true}],"text":"ШӘЩҗЩ„Щ’ЩғЩҺ ШӯЩҸШҜЩҸЩҲШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШ·ЩҗШ№Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ЩҠЩҸШҜЩ’Ш®ЩҗЩ„Щ’ЩҮЩҸ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ыҡ ЩҲЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩұЩ„Щ’ЩҒЩҺЩҲЩ’ШІЩҸ ЩұЩ„Щ’Ш№ЩҺШёЩҗЩҠЩ…ЩҸ"},{"key":"4:14","surah":4,"ayah":14,"num":507,"page":79,"words":[{"code":"пІә","page":79,"end":false},{"code":"пІ»","page":79,"end":false},{"code":"пІј","page":79,"end":false},{"code":"пІҪ","page":79,"end":false},{"code":"пІҫ","page":79,"end":false},{"code":"пІҝ","page":79,"end":false},{"code":"піҖ","page":79,"end":false},{"code":"піҒ","page":79,"end":false},{"code":"піӮ","page":79,"end":false},{"code":"піғ
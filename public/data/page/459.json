":false},{"code":"пұ©","page":459,"end":true}],"text":"Ш®ЩҺЩ„ЩҺЩӮЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҚЫў ЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩҚЫў Ш«ЩҸЩ…Щ‘ЩҺ Ш¬ЩҺШ№ЩҺЩ„ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШІЩҺЩҲЩ’Ш¬ЩҺЩҮЩҺШ§ ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ Ш«ЩҺЩ…ЩҺЩҖЩ°ЩҶЩҗЩҠЩҺШ©ЩҺ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҚЫў Ыҡ ЩҠЩҺШ®Щ’Щ„ЩҸЩӮЩҸЩғЩҸЩ…Щ’ ЩҒЩҗЩү ШЁЩҸШ·ЩҸЩҲЩҶЩҗ ШЈЩҸЩ…Щ‘ЩҺЩҮЩҺЩҖЩ°ШӘЩҗЩғЩҸЩ…Щ’ Ш®ЩҺЩ„Щ’ЩӮЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Ш®ЩҺЩ„Щ’ЩӮЩҚЫў ЩҒЩҗЩү ШёЩҸЩ„ЩҸЩ…ЩҺЩҖЩ°ШӘЩҚЫў Ш«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҚЫў Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…Щ’ Щ„ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸЩ„Щ’ЩғЩҸ Ы– Щ„ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ Ы– ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺЩүЩ° ШӘЩҸШөЩ’ШұЩҺЩҒЩҸЩҲЩҶЩҺ"},{"key":"39:7","surah":39,"ayah":7,"num":4065,"page":459,"words":[{"code":"пұӘ","page":459,"end":false},{"code":"пұ«","page":459,"end":false},{"code":"пұ¬","page":459,"end":false},{"code":"пұӯ","page":459,"end":false},{"code":"пұ®","page":459,"end":false},{"code":"пұҜпұ°","page":459,"end":false},{"code":"пұұ","page":459,"end":false},{"code":"пұІ","page":459,"end":false},{"code":"пұі","page":459,"end":false},{"code":"пұҙпұө","page":459,"end":false},{"code":"пұ¶","page":459,"end":false},{"code":"пұ·","page":459,"end":false},{"code":"пұё","page":459,"end":false},{"code":"пұ№пұә","page":459,"end":false},{"code":"пұ»","page":459,"end":false},{"code":"пұј","page":459,"end":false},{"code":"пұҪ","page":459,"end":false},{"code":"пұҫ","page":459,"end":false},{"code":"пұҝпІҖ","page":459,"end":false},{"code":"пІҒ","page":459,"end":false},{"code":"пІӮ","page":459,"end":false},{"code":"пІғ","page":459,"end":false},{"code":"пІ„","page":459,"end":false},{"code":"пІ…","page":459,"end":false},{"code":"пІҶ","page":459,"end":false},{"code":"пІҮ","page":459,"end":false},{"code":"пІҲпІү","page":459,"end":false},{"code":"пІҠ","page":459,"end":false},{"code":"пІӢ","page":459,"end":false},{"code":"пІҢ","page":459,"end":false},{"code":"пІҚ","page":459,"end":false},{"code":"пІҺ","page":459,"end":true}],"text":"ШҘЩҗЩҶ ШӘЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲШ§Ыҹ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҶЩҗЩүЩ‘ЩҢ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШұЩ’Ш¶ЩҺЩүЩ° Щ„ЩҗШ№ЩҗШЁЩҺШ§ШҜЩҗЩҮЩҗ ЩұЩ„Щ’ЩғЩҸЩҒЩ’ШұЩҺ Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҺШҙЩ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҠЩҺШұЩ’Ш¶ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШІЩҗШұЩҸ ЩҲЩҺШ§ШІЩҗШұЩҺШ©ЩҢЫӯ ЩҲЩҗШІЩ’ШұЩҺ ШЈЩҸШ®Щ’ШұЩҺЩүЩ° Ы— Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩғЩҸЩ… Щ…Щ‘ЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩғЩҸЩ…Щ’ ЩҒЩҺЩҠЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗШ°ЩҺШ§ШӘЩҗ ЩұЩ„ШөЩ‘ЩҸШҜЩҸЩҲШұЩҗ"},{"key":"39:8","surah":39,"ayah":8,"num":4066,"page":459,"words":[{"code":"пІҸ пІҗ","page":459,"end":false},{"code":"пІ‘","page":459,"end":false},{"code":"пІ’","page":459,"end":false},{"code":"пІ“","page":459,"end":false},{"code":"пІ”","page":459,"end":false},{"code":"пІ•","page":459,"end":false},{"code":"пІ–","page":459,"end":false},{"code":"пІ—","page":459,"end":false},{"code":"пІҳ","page":459,"end":false},{"code":"пІҷ","page":459,"end":false},{"code":"пІҡ","page":459,"end":false},{"code":"пІӣ","page":459,"end":false},{"code":"пІң","page":459,"end":false},{"code":"пІқ","page":459,"end":false},{"code":"пІһ","page":459,"end":false},{"code":"пІҹ","page":459,"end":false},{"code":"пІ ","page":459,"end":false},{"code":"пІЎ","page":459,"end":false},{"code":"пІў","page":459,"end":false},{"code":"пІЈ","page":459,"end":false},{"code":"пІӨ","page":459,"end":false},{"code":"пІҘ","page":459,"end":false},{"code":"пІҰ","page":459,"end":false},{"code":"пІ§","page":459,"end":false},{"code":"пІЁ","page":459,"end":false},{"code":"пІ©пІӘ","page":459,"end":false},{"code":"пІ«","page":459,"end":false},{"code":"пІ¬","page":459,"end":false},{"code":"пІӯ","page":459,"end":false},{"code":"пІ®","page":459,"end":false},{"code":"пІҜ","page":459,"end":false},{"code":"пІ°","page":459,"end":false},{"code":"пІұ","page":459,"end":false},{"code":"пІІ","page":459,"end":false},{"code":"пІі","page":459,"end":true}],"text":"Ыһ ЩҲЩҺШҘЩҗШ°ЩҺШ§ Щ…ЩҺШіЩ‘ЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҺ Ш¶ЩҸШұЩ‘ЩҢЫӯ ШҜЩҺШ№ЩҺШ§ ШұЩҺШЁЩ‘ЩҺЩҮЩҸЫ
end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":true},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–пі—","end":false}]},{"lineNumber":15,"words":[{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":true}]}],"verses":[{"key":"20:126","surah":20,"ayah":126,"num":2474,"page":321,"words":[{"code":"пұҒ","page":321,"end":false},{"code":"пұӮ","page":321,"end":false},{"code":"пұғ","page":321,"end":false},{"code":"пұ„","page":321,"end":false},{"code":"пұ…пұҶ","page":321,"end":false},{"code":"пұҮ","page":321,"end":false},{"code":"пұҲ","page":321,"end":false},{"code":"пұү","page":321,"end":false},{"code":"пұҠ","page":321,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЈЩҺШӘЩҺШӘЩ’ЩғЩҺ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҸЩҶЩҺШ§ ЩҒЩҺЩҶЩҺШіЩҗЩҠШӘЩҺЩҮЩҺШ§ Ы– ЩҲЩҺЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҸЩҶШіЩҺЩүЩ°"},{"key":"20:127","surah":20,"ayah":127,"num":2475,"page":321,"words":[{"code":"пұӢ","page":321,"end":false},{"code":"пұҢ","page":321,"end":false},{"code":"пұҚ","page":321,"end":false},{"code":"пұҺ","page":321,"end":false},{"code":"пұҸ","page":321,"end":false},{"code":"пұҗ","page":321,"end":false},{"code":"пұ‘","page":321,"end":false},{"code":"пұ’пұ“","page":321,"end":false},{"code":"пұ”","page":321,"end":false},{"code":"пұ•","page":321,"end":false},{"code":"пұ–","page":321,"end":false},{"code":"пұ—","page":321,"end":false},{"code":"пұҳ","page":321,"end":true}],"text":"ЩҲЩҺЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҶЩҺШ¬Щ’ШІЩҗЩү Щ…ЩҺЩҶЩ’ ШЈЩҺШіЩ’ШұЩҺЩҒЩҺ ЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЫў ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩ„ЩҺШ№ЩҺШ°ЩҺШ§ШЁЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ШЈЩҺШҙЩҺШҜЩ‘ЩҸ ЩҲЩҺШЈЩҺШЁЩ’ЩӮЩҺЩүЩ°Щ“"},{"key":"20:128","surah":20,"ayah":128,"num":2476,"page":321,"words":[{"code":"пұҷ","page":321,"end":false},{"code":"пұҡ","page":321,"end":false},{"code":"пұӣ","page":321,"end":false},{"code":"пұң","page":321,"end":false},{"code":"пұқ","page":321,"end":false},{"code":"пұһ","page":321,"end":false},{"code":"пұҹ","page":321,"end":false},{"code":"пұ ","page":321,"end":false},{"code":"пұЎ","page":321,"end":false},{"code":"пұў","page":321,"end":false},{"code":"пұЈпұӨ","page":321,"end":false},{"code":"пұҘ","page":321,"end":false},{"code":"пұҰ","page":321,"end":false},{"code":"пұ§","page":321,"end":false},{"code":"пұЁ","page":321,"end":false},{"code":"пұ©","page":321,"end":false},{"code":"пұӘ","page":321,"end":false},{"code":"пұ«","page":321,"end":true}],"text":"ШЈЩҺЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺЩҮЩ’ШҜЩҗ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺЩ…Щ’ ШЈЩҺЩҮЩ’Щ„ЩҺЩғЩ’ЩҶЩҺШ§ ЩӮЩҺШЁЩ’Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҸШұЩҸЩҲЩҶЩҗ ЩҠЩҺЩ…Щ’ШҙЩҸЩҲЩҶЩҺ ЩҒЩҗЩү Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҶЩҗЩҮЩҗЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗШЈЩҸЩҲЫҹЩ„ЩҗЩү ЩұЩ„ЩҶЩ‘ЩҸЩҮЩҺЩүЩ°"},{"key":"20:129","surah":20,"ayah":129,"num":2477,"page":321,"words":[{"code":"пұ¬","page":321,"end":false},{"code":"пұӯ","page":321,"end":false},{"code":"пұ®","page":321,"end":false},{"code":"пұҜ","page":321,"end":false},{"code":"пұ°","page":321,"end":false},{"code":"пұұ","page":321,"end":false},{"code":"пұІ","page":321,"end":false},{"code":"пұі","page":321,"end":false},{"code":"пұҙ","page":321,"end":false},{"code":"пұө","page":321,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩғЩҺЩ„ЩҗЩ…ЩҺШ©ЩҢЫӯ ШіЩҺШЁЩҺЩӮЩҺШӘЩ’ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҺ Щ„ЩҺЩғЩҺШ§ЩҶЩҺ Щ„ЩҗШІЩҺШ§Щ…ЩӢЫӯШ§ ЩҲЩҺШЈЩҺШ¬ЩҺЩ„ЩҢЫӯ Щ…Щ‘ЩҸШіЩҺЩ…Щ‘ЩӢЫӯЩү"},{"key":"20:130","surah":20,"ayah":130,"num":2478,"page":321,"words":[{"code":"пұ¶","page":321,"end":false},{"code":"пұ·","page":321,"end":false},{"code":"пұё","page":321,"end":false},{"code":"пұ№","page":321,"end":false},{"code":"пұә","page":321,"end":false},{"code":"пұ»","page":321,"end":false},{"code":"пұј","page":321,"end":false},{"code":"пұҪ","page":321,"end":false},{"code":"пұҫ","page":321,"end":false},{"code":"пұҝ","page":321,"end":false},{"code":"пІҖ","page":321,"end":false},{"code":"пІҒпІӮ","page":321,"end":false},{"code":"пІғ","page":321,"end":false},{"code":"пІ„","page":321,"end":false},{"code":"пІ…","page":321,"end":false},{"code":"пІҶ","page":321,"end":false},{"code":"пІҮ","page":321,"end":false},{"code":"пІҲ","page":321,"end":false},{"code":"пІү","page":321,"end":false},{"code":"пІҠ","page":321,"end":false},{"code":"пІӢ","page":321,"end":true}],"text":"ЩҒЩҺЩұШөЩ’ШЁЩҗШұЩ’ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺШ§ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ЩҲЩҺШіЩҺШЁЩ‘ЩҗШӯЩ’ ШЁЩҗШӯЩҺЩ…Щ’ШҜЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҺ ЩӮЩҺШЁЩ’Щ„ЩҺ Ш·ЩҸЩ„ЩҸЩҲШ№Щҗ ЩұЩ„ШҙЩ‘ЩҺЩ…Щ’ШіЩҗ ЩҲЩҺЩӮЩҺШЁЩ’Щ„ЩҺ ШәЩҸШұЩҸЩҲШЁЩҗЩҮЩҺШ§ Ы– ЩҲЩҺЩ…ЩҗЩҶЩ’ ШЎЩҺШ§ЩҶЩҺШ§Щ“ШҰЩҗ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҒЩҺШіЩҺШЁЩ‘ЩҗШӯЩ’ ЩҲЩҺШЈЩҺШ·Щ’ШұЩҺШ§ЩҒЩҺ ЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҺ ШӘЩҺШұЩ’Ш¶ЩҺЩүЩ°"},{"key":"20:131","surah":20,"ayah":131,"num":2479,"page":321,"words":[{"code":"пІҢ","page":321,"end":false},{"code":"пІҚ","page":321,"end":false},{"code":"пІҺ","page":321,"end":false},{"code":"пІҸ","page":321,"end":false},{"code":"пІҗ","page":321,"end":false},{"code":"пІ‘","page":321,"end":false},{"code":"пІ’","page":321,"end":false},{"code":"пІ“","page":321,"end":false},{"code":"пІ”","page":321,"end":false},{"code":"пІ•","page":321,"end":false},{"code":"пІ–","page":321,"end":false},{"code":"пІ—","page":321,"end":false},{"code":"пІҳ","page":321,"end":false},{"code":"пІҷпІҡ","page":321,"end":false},{"code":"пІӣ","page":321,"end":false},{"code":"пІң","page":321,"end":false},{"code":"пІқ","page":321,"end":false},{"code":"пІһ","page":321,"end":false},{"code":"пІҹ","page":321,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩ…ЩҸШҜЩ‘ЩҺЩҶЩ‘ЩҺ Ш№ЩҺЩҠЩ’ЩҶЩҺЩҠЩ’ЩғЩҺ ШҘЩҗЩ„ЩҺЩүЩ° Щ…ЩҺШ§ Щ…ЩҺШӘЩ‘ЩҺШ№Щ’ЩҶЩҺШ§ ШЁЩҗЩҮЩҗЫҰЩ“ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШІЩҺЩҮЩ’ШұЩҺШ©ЩҺ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Щ„ЩҗЩҶЩҺЩҒЩ’ШӘЩҗЩҶЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҗ Ыҡ ЩҲЩҺШұЩҗШІЩ’ЩӮЩҸ ШұЩҺШЁЩ‘ЩҗЩғЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ ЩҲЩҺШЈЩҺШЁЩ’ЩӮЩҺЩүЩ°"},{"key":"20:132","surah":20,"ayah":132,"num":2480,"page":321,"words":[{"code":"пІ ","page":321,"end":false},{"code":"
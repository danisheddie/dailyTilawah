пұҲ","page":545,"end":false},{"code":"пұү","page":545,"end":false},{"code":"пұҠ","page":545,"end":false},{"code":"пұӢ","page":545,"end":false},{"code":"пұҢ","page":545,"end":false},{"code":"пұҚ","page":545,"end":false},{"code":"пұҺ","page":545,"end":false},{"code":"пұҸ","page":545,"end":false},{"code":"пұҗ","page":545,"end":false},{"code":"пұ‘","page":545,"end":false},{"code":"пұ’","page":545,"end":false},{"code":"пұ“","page":545,"end":false},{"code":"пұ”","page":545,"end":false},{"code":"пұ•пұ–","page":545,"end":false},{"code":"пұ—","page":545,"end":false},{"code":"пұҳ","page":545,"end":false},{"code":"пұҷ","page":545,"end":false},{"code":"пұҡ","page":545,"end":false},{"code":"пұӣ","page":545,"end":false},{"code":"пұң","page":545,"end":false},{"code":"пұқ","page":545,"end":false},{"code":"пұһпұҹ","page":545,"end":false},{"code":"пұ ","page":545,"end":false},{"code":"пұЎ","page":545,"end":false},{"code":"пұў","page":545,"end":false},{"code":"пұЈ","page":545,"end":false},{"code":"пұӨ","page":545,"end":false},{"code":"пұҘ","page":545,"end":false},{"code":"пұҰ","page":545,"end":false},{"code":"пұ§пұЁ","page":545,"end":false},{"code":"пұ©","page":545,"end":false},{"code":"пұӘ","page":545,"end":false},{"code":"пұ«","page":545,"end":false},{"code":"пұ¬","page":545,"end":false},{"code":"пұӯпұ®","page":545,"end":false},{"code":"пұҜ","page":545,"end":false},{"code":"пұ°","page":545,"end":false},{"code":"пұұпұІ","page":545,"end":false},{"code":"пұі","page":545,"end":false},{"code":"пұҙ","page":545,"end":false},{"code":"пұө","page":545,"end":false},{"code":"пұ¶","page":545,"end":false},{"code":"пұ·","page":545,"end":false},{"code":"пұё","page":545,"end":false},{"code":"пұ№","page":545,"end":true}],"text":"Щ„Щ‘ЩҺШ§ ШӘЩҺШ¬ЩҗШҜЩҸ ЩӮЩҺЩҲЩ’Щ…ЩӢЫӯШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ ЩҠЩҸЩҲЩҺШ§Щ“ШҜЩ‘ЩҸЩҲЩҶЩҺ Щ…ЩҺЩҶЩ’ ШӯЩҺШ§Щ“ШҜЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§ШЁЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШҘЩҗШ®Щ’ЩҲЩҺЩ°ЩҶЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ Ш№ЩҺШҙЩҗЩҠШұЩҺШӘЩҺЩҮЩҸЩ…Щ’ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩғЩҺШӘЩҺШЁЩҺ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҺ ЩҲЩҺШЈЩҺЩҠЩ‘ЩҺШҜЩҺЩҮЩҸЩ… ШЁЩҗШұЩҸЩҲШӯЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ Ы– ЩҲЩҺЩҠЩҸШҜЩ’Ш®ЩҗЩ„ЩҸЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ыҡ ШұЩҺШ¶ЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҲЩҺШұЩҺШ¶ЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШӯЩҗШІЩ’ШЁЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ШЈЩҺЩ„ЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺ ШӯЩҗШІЩ’ШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"59:1","surah":59,"ayah":1,"num":5127,"page":545,"words":[{"code":"пұә","page":545,"end":false},{"code":"пұ»","page":545,"end":false},{"code":"пұј","page":545,"end":false},{"code":"пұҪ","page":545,"end":false},{"code":"пұҫ","page":545,"end":false},{"code":"пұҝ","page":545,"end":false},{"code":"пІҖ","page":545,"end":false},{"code":"пІҒпІӮ","page":545,"end":false},{"code":"пІғ","page":545,"end":false},{"code":"пІ„","page":545,"end":false},{"code":"пІ…","page":545,"end":false},{"code":"пІҶ","page":545,"end":true}],"text":"ШіЩҺШЁЩ‘ЩҺШӯЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы– ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"},{"key":"59:2","surah":59,"ayah":2,"num":5128,"page":545,"words":[{"code":"пІҮ","page":545,"end":false},{"code":"пІҲ","page":545,"end":false},{"code":"пІү","page":545,"end":false},{"code":"пІҠ","page":545,"end":false},{"code":"пІӢ","page":545,"end":false},{"code":"пІҢ","page":545,"end":false},{"code":"пІҚ","page":545,"end":false},{"code":"пІҺ","page":545,"end":false},{"code":"пІҸ","page":545,"end":false},{"code":"пІҗ","page":545,"end":false},{"code":"пІ‘","page":545,"end":false},{"code":"пІ’пІ“","page":545,"end":false},{"code":"пІ”","page":545,"end":false},{"code":"пІ•","page":545,"end":false},{"code":"пІ–","page":545,"end":false},{"code":"пІ—пІҳ","page":545,"end":false},{"code":"пІҷ","page":545,"end":false},{"code":"пІҡ","page":545,"end":false},{"code":"пІӣ","page":545,"end":false},{"code":"пІң","page":545,"end":false},{"code":"пІқ","page":545,"end":false},{"code":"пІһ","page":545,"end":false},{"code":"пІҹ","page":545,"end":false},{"code":"пІ ","page":545,"end":false},{"code":"пІЎ","page":545,"end":false},{"code":"пІў","page":545,"end":false},{"code":"пІЈ","page":545,"end":false},{"code":"пІӨпІҘ","page":545,"end":false},{"code":"пІҰ","page":545,"end":false},{"code":"пІ§","page":545,"end":false},{"code":"пІЁ","page":545,"end":false},{"code":"пІ©пІӘ","page":545,"end":false},{"code":"пІ«","page":545,"end":false},{"code":"пІ¬","page":545,"end":false},{"code":"пІӯ","page":545,"end":false},{"code":"пІ®","page":545,"end":false},{"code":"пІҜ","page":545,"end":false},{"code":"пІ°","page":545,"end":false},{"code":"пІұ","page":545,"end":false},{"code":"пІІ","page":545,"end":false},{"code":"пІі","page":545,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШ®Щ’ШұЩҺШ¬ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ…ЩҗЩҶ ШҜЩҗЩҠЩҺЩҖЩ°ШұЩҗЩҮЩҗЩ…Щ’ Щ„ЩҗШЈЩҺЩҲЩ‘ЩҺЩ„Щҗ ЩұЩ„Щ’ШӯЩҺШҙЩ’ШұЩҗ Ыҡ Щ…ЩҺШ§ ШёЩҺЩҶЩҺЩҶШӘЩҸЩ…Щ’ ШЈЩҺЩҶ ЩҠЩҺШ®Щ’ШұЩҸШ¬ЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺШёЩҺЩҶЩ‘ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ЩҶЩҗШ№ЩҺШӘЩҸЩҮЩҸЩ…Щ’ ШӯЩҸШөЩҸЩҲЩҶЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺШЈЩҺШӘЩҺЩүЩ°ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҶЩ’ ШӯЩҺЩҠЩ’Ш«ЩҸ Щ„ЩҺЩ…Щ’ ЩҠЩҺШӯЩ’ШӘЩҺШіЩҗШЁЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺЩӮЩҺШ°ЩҺЩҒЩҺ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…ЩҸ ЩұЩ„ШұЩ‘ЩҸШ№Щ’ШЁЩҺ Ыҡ ЩҠЩҸШ®Щ’ШұЩҗШЁЩҸЩҲЩҶЩҺ ШЁЩҸЩҠЩҸЩҲШӘЩҺЩҮЩҸЩ… ШЁЩҗШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩҠЩ’ШҜЩҗЩү ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҒЩҺЩұШ№Щ’ШӘЩҺШЁЩҗШұЩҸЩҲШ§Ыҹ ЩҠЩҺЩҖЩ°Щ“ШЈЩҸЩҲЫҹЩ„ЩҗЩү ЩұЩ„Щ’ШЈЩҺШЁЩ’ШөЩҺЩҖЩ°ШұЩҗ"},{"key":"59:3","surah":59,"ayah":3,"num":5129,"page":545,"words":[{"code":"пІҙ","page":545,"end":false},{"code":"пІө","page":545,"end":false},{"code":"пІ¶","page":545,"end":false},{"code":"пІ·","page":545,"end":false},{"code":"пІё","page":545,"end":false},{"code":"пІ№","page":545,"end":false},{"code":"пІә","page":545,"end":false},{"code":"пІ»","page":545,"end":false},{"code":"пІјпІҪ","page":545,"end":false},{"code":"пІҫ","page":545,"end":false},{"code":"пІҝ","page":545,"end":false},{"code":"піҖ","page":545,"end":false},{"code":"піҒ","page":545,"end":false},{"code":"піӮ","page":545,"end":false},{"code":"піғ","page":545,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’Щ„ЩҺШ§Щ“ ШЈЩҺЩҶ ЩғЩҺШӘЩҺШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’Ш¬ЩҺЩ„ЩҺШ§Щ“ШЎЩҺ Щ„ЩҺШ№ЩҺШ°Щ‘ЩҺШЁЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ"}]}
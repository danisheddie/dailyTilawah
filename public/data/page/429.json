ШұЩҺЩҲЩҺШ§ШӯЩҸЩҮЩҺШ§ ШҙЩҺЩҮЩ’ШұЩҢЫӯ Ы– ЩҲЩҺШЈЩҺШіЩҺЩ„Щ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЫҘ Ш№ЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„Щ’ЩӮЩҗШ·Щ’ШұЩҗ Ы– ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш¬ЩҗЩҶЩ‘Щҗ Щ…ЩҺЩҶ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩҠЩҺШҜЩҺЩҠЩ’ЩҮЩҗ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШІЩҗШәЩ’ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ш№ЩҺЩҶЩ’ ШЈЩҺЩ…Щ’ШұЩҗЩҶЩҺШ§ ЩҶЩҸШ°ЩҗЩӮЩ’ЩҮЩҸ Щ…ЩҗЩҶЩ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„ШіЩ‘ЩҺШ№ЩҗЩҠШұЩҗ"},{"key":"34:13","surah":34,"ayah":13,"num":3619,"page":429,"words":[{"code":"пІұ","page":429,"end":false},{"code":"пІІ","page":429,"end":false},{"code":"пІі","page":429,"end":false},{"code":"пІҙ","page":429,"end":false},{"code":"пІө","page":429,"end":false},{"code":"пІ¶","page":429,"end":false},{"code":"пІ·","page":429,"end":false},{"code":"пІё","page":429,"end":false},{"code":"пІ№","page":429,"end":false},{"code":"пІә","page":429,"end":false},{"code":"пІ»пІј","page":429,"end":false},{"code":"пІҪ","page":429,"end":false},{"code":"пІҫ","page":429,"end":false},{"code":"пІҝ","page":429,"end":false},{"code":"піҖпіҒ","page":429,"end":false},{"code":"піӮ","page":429,"end":false},{"code":"піғ","page":429,"end":false},{"code":"пі„","page":429,"end":false},{"code":"пі…","page":429,"end":false},{"code":"піҶ","page":429,"end":true}],"text":"ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ§ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Щ…ЩҗЩҶ Щ…Щ‘ЩҺШӯЩҺЩҖЩ°ШұЩҗЩҠШЁЩҺ ЩҲЩҺШӘЩҺЩ…ЩҺЩҖЩ°Ш«ЩҗЩҠЩ„ЩҺ ЩҲЩҺШ¬ЩҗЩҒЩҺШ§ЩҶЩҚЫў ЩғЩҺЩұЩ„Щ’Ш¬ЩҺЩҲЩҺШ§ШЁЩҗ ЩҲЩҺЩӮЩҸШҜЩҸЩҲШұЩҚЫў ШұЩ‘ЩҺШ§ШіЩҗЩҠЩҺЩҖЩ°ШӘЩҚ Ыҡ ЩұШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Щ„ЩҺ ШҜЩҺШ§ЩҲЩҸЫҘШҜЩҺ ШҙЩҸЩғЩ’ШұЩӢЫӯШ§ Ыҡ ЩҲЩҺЩӮЩҺЩ„ЩҗЩҠЩ„ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗШЁЩҺШ§ШҜЩҗЩүЩҺ ЩұЩ„ШҙЩ‘ЩҺЩғЩҸЩҲШұЩҸ"},{"key":"34:14","surah":34,"ayah":14,"num":3620,"page":429,"words":[{"code":"піҮ","page":429,"end":false},{"code":"піҲ","page":429,"end":false},{"code":"піү","page":429,"end":false},{"code":"піҠ","page":429,"end":false},{"code":"піӢ","page":429,"end":false},{"code":"піҢ","page":429,"end":false},{"code":"піҚ","page":429,"end":false},{"code":"піҺ","page":429,"end":false},{"code":"піҸ","page":429,"end":false},{"code":"піҗ","page":429,"end":
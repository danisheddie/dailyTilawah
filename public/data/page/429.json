9,"end":false},{"code":"пұ ","page":429,"end":false},{"code":"пұЎ","page":429,"end":false},{"code":"пұў","page":429,"end":false},{"code":"пұЈ","page":429,"end":false},{"code":"пұӨ","page":429,"end":false},{"code":"пұҘ","page":429,"end":false},{"code":"пұҰ","page":429,"end":false},{"code":"пұ§","page":429,"end":false},{"code":"пұЁ","page":429,"end":false},{"code":"пұ©пұӘ","page":429,"end":false},{"code":"пұ«","page":429,"end":false},{"code":"пұ¬","page":429,"end":false},{"code":"пұӯ","page":429,"end":false},{"code":"пұ®","page":429,"end":false},{"code":"пұҜ","page":429,"end":false},{"code":"пұ°","page":429,"end":false},{"code":"пұұ","page":429,"end":false},{"code":"пұІ","page":429,"end":true}],"text":"ШЈЩҺЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° Щ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ Ш®ЩҺЩ„Щ’ЩҒЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ШҘЩҗЩҶ ЩҶЩ‘ЩҺШҙЩҺШЈЩ’ ЩҶЩҺШ®Щ’ШіЩҗЩҒЩ’ ШЁЩҗЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ШЈЩҺЩҲЩ’ ЩҶЩҸШіЩ’ЩӮЩҗШ·Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩғЩҗШіЩҺЩҒЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗЩғЩҸЩ„Щ‘Щҗ Ш№ЩҺШЁЩ’ШҜЩҚЫў Щ…Щ‘ЩҸЩҶЩҗЩҠШЁЩҚЫў"},{"key":"34:10","surah":34,"ayah":10,"num":3616,"page":429,"words":[{"code":"пұі пұҙ","page":429,"end":false},{"code":"пұө","page":429,"end":false},{"code":"пұ¶","page":429,"end":false},{"code":"пұ·","page":429,"end":false},{"code":"пұёпұ№","page":429,"end":false},{"code":"пұә","page":429,"end":false},{"code":"пұ»","page":429,"end":false},{"code":"пұј","page":429,"end":false},{"code":"пұҪпұҫ","page":429,"end":false},{"code":"пұҝ","page":429,"end":false},{"code":"пІҖ","page":429,"end":false},{"code":"пІҒ","page":429,"end":false},{"code":"пІӮ","page":429,"end":true}],"text":"Ыһ ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ ШҜЩҺШ§ЩҲЩҸЫҘШҜЩҺ Щ…ЩҗЩҶЩ‘ЩҺШ§ ЩҒЩҺШ¶Щ’Щ„ЩӢЫӯШ§ Ы– ЩҠЩҺЩҖЩ°Ш¬ЩҗШЁЩҺШ§Щ„ЩҸ ШЈЩҺЩҲЩ‘ЩҗШЁЩҗЩү Щ…ЩҺШ№ЩҺЩҮЩҸЫҘ ЩҲЩҺЩұЩ„Ш·Щ‘ЩҺЩҠЩ’ШұЩҺ Ы– ЩҲЩҺШЈЩҺЩ„ЩҺЩҶЩ‘ЩҺШ§ Щ„ЩҺЩҮЩҸ ЩұЩ„Щ’ШӯЩҺШҜЩҗЩҠШҜЩҺ"},{"key":"34:11","surah":34
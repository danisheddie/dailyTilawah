ШәЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ ШЁЩҺЩҠЩ’ЩҶЩҗЩү ЩҲЩҺШЁЩҺЩҠЩ’ЩҶЩҺ ШҘЩҗШ®Щ’ЩҲЩҺШӘЩҗЩүЩ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҗЩү Щ„ЩҺШ·ЩҗЩҠЩҒЩҢЫӯ Щ„Щ‘ЩҗЩ…ЩҺШ§ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"},{"key":"12:101","surah":12,"ayah":101,"num":1697,"page":247,"words":[{"code":"пІӯ пІ®","page":247,"end":false},{"code":"пІҜ","page":247,"end":false},{"code":"пІ°","page":247,"end":false},{"code":"пІұ","page":247,"end":false},{"code":"пІІ","page":247,"end":false},{"code":"пІі","page":247,"end":false},{"code":"пІҙ","page":247,"end":false},{"code":"пІө","page":247,"end":false},{"code":"пІ¶пІ·","page":247,"end":false},{"code":"пІё","page":247,"end":false},{"code":"пІ№","page":247,"end":false},{"code":"пІә","page":247,"end":false},{"code":"пІ»","page":247,"end":false},{"code":"пІј","page":247,"end":false},{"code":"пІҪ","page":247,"end":false},{"code":"пІҫ","page":247,"end":false},{"code":"пІҝпіҖ","page":247,"end":false},{"code":"піҒ","page":247,"end":false},{"code":"піӮ","page":247,"end":false},{"code":"піғ","page":247,"end":false},{"code":"пі„","page":247,"end":false},{"code":"пі…","page":247,"end":true}],"text":"Ыһ ШұЩҺШЁЩ‘Щҗ ЩӮЩҺШҜЩ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ШӘЩҺЩҶЩҗЩү Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸЩ„Щ’ЩғЩҗ ЩҲЩҺШ№ЩҺЩ„Щ‘ЩҺЩ…Щ’ШӘЩҺЩҶЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„Щҗ ЩұЩ„Щ’ШЈЩҺШӯЩҺШ§ШҜЩҗЩҠШ«Щҗ Ыҡ ЩҒЩҺШ§Ш·ЩҗШұЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҺЩҶШӘЩҺ ЩҲЩҺЩ„ЩҗЩүЩ‘ЩҗЫҰ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҲЩҺЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ы– ШӘЩҺЩҲЩҺЩҒЩ‘ЩҺЩҶЩҗЩү Щ…ЩҸШіЩ’Щ„ЩҗЩ…ЩӢЫӯШ§ ЩҲЩҺШЈЩҺЩ„Щ’ШӯЩҗЩӮЩ’ЩҶЩҗЩү ШЁЩҗЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҗЩҠЩҶЩҺ"},{"key":"12:102","surah":12,"ayah":102,"num":1698,"page":247,"words":[{"code":"піҶ","page":247,"end":false},{"code":"піҮ","page":247,"end":false},{"code":"піҲ","page":247,"end":false},{"code":"піү","page":247,"end":false},{"code":"піҠ","page":247,"end":false},{"code":"піӢпіҢ","page":247,"end":false},{"code":"піҚ","page":247,"end":false},{"code":"піҺ","page":247,"end":false},{"code":"піҸ","page":247,"end":false},{"code":"
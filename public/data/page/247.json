піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false}]},{"lineNumber":15,"words":[{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":true},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":true}]}],"verses":[{"key":"12:96","surah":12,"ayah":96,"num":1692,"page":247,"words":[{"code":"пұҒ","page":247,"end":false},{"code":"пұӮ","page":247,"end":false},{"code":"пұғ","page":247,"end":false},{"code":"пұ„","page":247,"end":false},{"code":"пұ…","page":247,"end":false},{"code":"пұҶ","page":247,"end":false},{"code":"пұҮ","page":247,"end":false},{"code":"пұҲ","page":247,"end":false},{"code":"пұүпұҠ","page":247,"end":false},{"code":"пұӢ","page":247,"end":false},{"code":"пұҢ","page":247,"end":false},{"code":"пұҚ","page":247,"end":false},{"code":"пұҺ","page":247,"end":false},{"code":"пұҸ","page":247,"end":false},{"code":"пұҗ","page":247,"end":false},{"code":"пұ‘","page":247,"end":false},{"code":"пұ’","page":247,"end":false},{"code":"пұ“","page":247,"end":false},{"code":"пұ”","page":247,"end":false},{"code":"пұ•","page":247,"end":false},{"code":"пұ–","page":247,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ Ш¬ЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ’ШЁЩҺШҙЩҗЩҠШұЩҸ ШЈЩҺЩ„Щ’ЩӮЩҺЩүЩ°ЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҲЩҺШ¬Щ’ЩҮЩҗЩҮЩҗЫҰ ЩҒЩҺЩұШұЩ’ШӘЩҺШҜЩ‘ЩҺ ШЁЩҺШөЩҗЩҠШұЩӢЫӯШ§ Ы– ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺЩ„ЩҺЩ…Щ’ ШЈЩҺЩӮЩҸЩ„ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩ‘ЩҗЩүЩ“ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ Щ„ЩҺШ§ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"12:97","surah":12,"ayah":97,"num":1693,"page":247,"words":[{"code":"пұ—","page":247,"end":false},{"code":"пұҳ","page":247,"end":false},{"code":"пұҷ","page":247,"end":false},{"code":"пұҡ","page":247,"end":false},{"code":"пұӣ","page":247,"end":false},{"code":"пұң","page":247,"end":false},{"code":"пұқ","page":247,"end":false},{"code":"пұһ","page":247,"end":false},{"code":"пұҹ","page":247,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШ§ЩҶЩҺШ§ ЩұШіЩ’ШӘЩҺШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩҶЩҺШ§ Ш°ЩҸЩҶЩҸЩҲШЁЩҺЩҶЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩғЩҸЩҶЩ‘ЩҺШ§ Ш®ЩҺЩҖЩ°Ш·ЩҗЩҖЩ”ЩҗЩҠЩҶЩҺ"},{"key":"12:98","surah":12,"ayah":98,"num":1694,"page":247,"words":[{"code":"пұ ","page":247,"end":false},{"code":"пұЎ","page":247,"end":false},{"code":"пұў","page":247,"end":false},{"code":"пұЈ","page":247,"end":false},{"code":"пұӨпұҘ","page":247,"end":false},{"code":"пұҰ","page":247,"end":false},{"code":"пұ§","page":247,"end":false},{"code":"пұЁ","page":247,"end":false},{"code":"пұ©","page":247,"end":false},{"code":"пұӘ","page":247,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШіЩҺЩҲЩ’ЩҒЩҺ ШЈЩҺШіЩ’ШӘЩҺШәЩ’ЩҒЩҗШұЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҗЩүЩ“ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ШәЩҺЩҒЩҸЩҲШұЩҸ ЩұЩ„ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҸ"},{"key":"12:99","surah":12,"ayah":99,"num":1695,"page":247,"words":[{"code":"пұ«","page":247,"end":false},{"code":"пұ¬","page":247,"end":false},{"code":"пұӯ","page":247,"end":false},{"code":"пұ®","page":247,"end":false},{"code":"пұҜ","page":247,"end":false},{"code":"пұ°","page":247,"end":false},{"code":"пұұ","page":247,"end":false},{"code":"пұІ","page":247,"end":false},{"code":"пұі","page":247,"end":false},{"code":"пұҙ","page":247,"end":false},{"code":"пұө","page":247,"end":false},{"code":"пұ¶","page":247,"end":false},{"code":"пұ·","page":247,"end":false},{"code":"пұё","page":247,"end":false},{"code":"пұ№","page":247,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШҜЩҺШ®ЩҺЩ„ЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҠЩҸЩҲШіЩҸЩҒЩҺ ШЎЩҺШ§ЩҲЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЈЩҺШЁЩҺЩҲЩҺЩҠЩ’ЩҮЩҗ ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗШөЩ’ШұЩҺ ШҘЩҗЩҶ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЎЩҺШ§Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"12:100","surah":12,"ayah":100,"num":1696,"page":247,"words":[{"code":"пұә","page":247,"end":false},{"code":"пұ»","page":247,"end":false},{"code":"пұј","page":247,"end":false},{"code":"пұҪ","page":247,"end":false},{"code":"пұҫ","page":247,"end":false},{"code":"пұҝ","page":247,"end":false},{"code":"пІҖпІҒ","page":247,"end":false},{"code":"пІӮ","page":247,"e
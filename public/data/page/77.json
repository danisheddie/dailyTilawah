:"пі‘","end":false},{"code":"пі’пі“","end":false},{"code":"пі”","end":false}]},{"lineNumber":15,"words":[{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷпіҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":true}]}],"verses":[{"key":"4:1","surah":4,"ayah":1,"num":494,"page":77,"words":[{"code":"пұҒ","page":77,"end":false},{"code":"пұӮ","page":77,"end":false},{"code":"пұғ","page":77,"end":false},{"code":"пұ„","page":77,"end":false},{"code":"пұ…","page":77,"end":false},{"code":"пұҶ","page":77,"end":false},{"code":"пұҮ","page":77,"end":false},{"code":"пұҲ","page":77,"end":false},{"code":"пұү","page":77,"end":false},{"code":"пұҠ","page":77,"end":false},{"code":"пұӢ","page":77,"end":false},{"code":"пұҢ","page":77,"end":false},{"code":"пұҚ","page":77,"end":false},{"code":"пұҺ","page":77,"end":false},{"code":"пұҸ","page":77,"end":false},{"code":"пұҗ","page":77,"end":false},{"code":"пұ‘пұ’","page":77,"end":false},{"code":"пұ“","page":77,"end":false},{"code":"пұ”","page":77,"end":false},{"code":"пұ•","page":77,"end":false},{"code":"пұ–","page":77,"end":false},{"code":"пұ—","page":77,"end":false},{"code":"пұҳпұҷ","page":77,"end":false},{"code":"пұҡ","page":77,"end":false},{"code":"пұӣ","page":77,"end":false},{"code":"пұң","page":77,"end":false},{"code":"пұқ","page":77,"end":false},{"code":"пұһ","page":77,"end":false},{"code":"пұҹ","page":77,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҚЫў ЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩҚЫў ЩҲЩҺШ®ЩҺЩ„ЩҺЩӮЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШІЩҺЩҲЩ’Ш¬ЩҺЩҮЩҺШ§ ЩҲЩҺШЁЩҺШ«Щ‘ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ ШұЩҗШ¬ЩҺШ§Щ„ЩӢЫӯШ§ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ ЩҲЩҺЩҶЩҗШіЩҺШ§Щ“ШЎЩӢЫӯ Ыҡ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ШӘЩҺШіЩҺШ§Щ“ШЎЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’ШӯЩҺШ§Щ…ЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШұЩҺЩӮЩҗЩҠШЁЩӢЫӯШ§"},{"key":"4:2","surah":4,"ayah":2,"num":495,"page":77,"words":[{"code":"пұ ","page":77,"end":false},{"code":"пұЎ","page":77,"end":false},{"code":"пұўпұЈ","page":77,"end":false},{"code":"пұӨ","page":77,"end":false},{"code":"пұҘ","page":77,"end":false},{"code":"пұҰ","page":77,"end":false},{"code":"пұ§пұЁ","page":77,"end":false},{"code":"пұ©","page":77,"end":false},{"code":"пұӘ","page":77,"end":false},{"code":"пұ«","page":77,"end":false},{"code":"пұ¬","page":77,"end":false},{"code":"пұӯпұ®","page":77,"end":false},{"code":"пұҜ","page":77,"end":false},{"code":"пұ°","page":77,"end":false},{"code":"пұұ","page":77,"end":false},{"code":"пұІ","page":77,"end":false},{"code":"пұі","page":77,"end":true}],"text":"ЩҲЩҺШЎЩҺШ§ШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ°Щ“ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩҺШЁЩҺШҜЩ‘ЩҺЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш®ЩҺШЁЩҗЩҠШ«ЩҺ ШЁЩҗЩұЩ„Ш·Щ‘ЩҺЩҠЩ‘ЩҗШЁЩҗ Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩғЩҺШ§ЩҶЩҺ ШӯЩҸЩҲШЁЩӢЫӯШ§ ЩғЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"4:3","surah":4,"ayah":3,"num":496,"page":77,"words":[{"code":"пұҙ","page":77,"end":false},{"code":"пұө","page":77,"end":false},{"code":"пұ¶","page":77,"end":false},{"code":"пұ·","page":77,"end":false},{"code":"пұё","page":77,"end":false},{"code":"пұ№","page":77,"end":false},{"code":"пұә","page":77,"end":false},{"code":"пұ»","page":77,"end":false},{"code":"пұј","page":77,"end":false},{"code":"пұҪ","page":77,"end":false},{"code":"пұҫ","page":77,"end":false},{"code":"пұҝ","page":77,"end":false},{"code":"пІҖ","page":77,"end":false},{"code":"пІҒ","page":77,"end":false},{"code":"пІӮпІғ","page":77,"end":false},{"code":"пІ„","page":77,"end":false},{"code":"пІ…","page":77,"end":false},{"code":"пІҶ","page":77,"end":false},{"code":"пІҮ","page":77,"end":false},{"code":"пІҲ","page":77,"end":false},{"code":"пІү","page":77,"end":false},{"code":"пІҠ","page":77,"end":false},{"code":"пІӢ","page":77,"end":false},{"code":"пІҢпІҚ","page":77,"end":false},{"code":"пІҺ","page":77,"end":false},{"code":"пІҸ","page":77,"end":false},{"code":"пІҗ","page":77,"end":false},{"code":"пІ‘","page":77,"end":false},{"code":"пІ’","page":77,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ’ Ш®ЩҗЩҒЩ’ШӘЩҸЩ…Щ’ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҸЩӮЩ’ШіЩҗШ·ЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ° ЩҒЩҺЩұЩҶЩғЩҗШӯЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Ш·ЩҺШ§ШЁЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ Щ…ЩҺШ«Щ’ЩҶЩҺЩүЩ° ЩҲЩҺШ«ЩҸЩ„ЩҺЩҖЩ°Ш«ЩҺ ЩҲЩҺШұЩҸШЁЩҺЩҖЩ°Ш№ЩҺ Ы– ЩҒЩҺШҘЩҗЩҶЩ’ Ш®ЩҗЩҒЩ’ШӘЩҸЩ…Щ’ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШҜЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҺЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩӢ ШЈЩҺЩҲЩ’ Щ…ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ…Щ’ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЈЩҺШҜЩ’ЩҶЩҺЩүЩ°Щ“ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШ№ЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ"},{"key":"4:4","surah":4,"ayah":4,"num":497,"page":77,"words":[{"code":"пІ“","page":77,"end":false},{"code":"пІ”","page":77,"end":false},{"code":"пІ•","page":77,"end":false},{"code":"пІ–пІ—","page":77,"end":false},{"code":"пІҳ","page":77,"end":false},{"code":"пІҷ","page":77,"end":false},{"code":"пІҡ","page":77,"end":false},{"code":"пІӣ","page":77,"end":false},{"code":"пІң","page":77,"end":false},{"code":"пІқ","page":77,"end":false},{"code":"пІһ","page":77,"end":false},{"code":"пІҹ","page":77,"end":false},{"code":"пІ ","page":77,"end":false},{"code":"пІЎ","page":77,"end":false},{"code":"пІў","page":77,"end":true}],"text":"ЩҲЩҺШЎЩҺШ§ШӘЩҸЩҲШ§Ыҹ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҺ ШөЩҺШҜЩҸЩӮЩҺЩҖЩ°ШӘЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҶЩҗШӯЩ’Щ„ЩҺШ©ЩӢЫӯ Ыҡ ЩҒЩҺШҘЩҗЩҶ Ш·ЩҗШЁЩ’ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩҶ ШҙЩҺЩүЩ’ШЎЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ ЩҶЩҺЩҒЩ’ШіЩӢЫӯШ§ ЩҒЩҺЩғЩҸЩ„ЩҸЩҲЩҮЩҸ ЩҮЩҺЩҶЩҗЩҠЩ“ЩҖЩ”ЩӢЫӯШ§ Щ…Щ‘ЩҺШұЩҗЩҠЩ“ЩҖЩ”ЩӢЫӯШ§"},{"key":"4:5","surah":4,"ayah":5,"num":498,"page":77,"words":[{"code":"пІЈ","page":77,"end":false},{"code":"пІӨ","page":77,"end":false},{"code":"пІҘ","page":77,"end":false},{"code":"пІҰ","page":77,"end":false},{"code":"пІ§","page":77,"end":false},{"code":"пІЁ","page":77,"end":false},{"code":"пІ©","page":77,"end":false},{"code":"пІӘ","page":77,"end":false},{"code":"пІ«","page":77,"end":false},{"code":"пІ¬","page":77,"end":false},{"code":"пІӯ","page":77,"end":false},{"code":"пІ®","page":77,"end":false},{"code":"пІҜ","page":77,"end":false},{"code":"пІ°","page":77,"end":false},{"code":"пІұ","page":77,"end":false},{"code":"пІІ","page":77,"end":false},{"code":"пІі","page":77,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШӨЩ’ШӘЩҸЩҲШ§Ыҹ ЩұЩ„ШіЩ‘ЩҸЩҒЩҺЩҮЩҺШ§Щ“ШЎЩҺ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШӘЩҗЩү Ш¬ЩҺШ№ЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩӢЫӯШ§ ЩҲЩҺЩұШұЩ’ШІЩҸЩӮЩҸЩҲЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҲЩҺЩұЩғЩ’ШіЩҸЩҲЩҮЩҸЩ…Щ’ ЩҲЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺЩҲЩ’Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҺШ№Щ’ШұЩҸЩҲЩҒЩӢЫӯШ§"},{"key":"4:6","surah":4,"ayah":6,"num":499,"page":77,"words":[{"code":"пІҙ","page":77,"end":false},{"code":"пІө","page":77,"end":false},{"code":"пІ¶","page":77,"end":false},{"code":"пІ·","page":77,"end":false},{"code":"пІё","page":77,"end":false},{"code":"пІ№","page":77,"end":false},{"code":"пІә","page":77,"end":false},{"code":"пІ»","page":77,"end":false},{"code":"пІј","page":77,"end":false},{"code":"пІҪ","page":77,"end":false},{"code":"пІҫ","page":77,"end":false},{"code":"пІҝ","page":77,"end":false},{"code":"піҖпіҒ","page":77,"end":false},{"code":"піӮ","page":77,"end":false},{"code":"піғ","page":77,"end":false},{"code":"пі„","page":77,"end":false},{"code":"пі…","page":77,"end":false},{"code":"піҶ","page":77,"end":false},{"code":"піҮпіҲ","page":77,"end":false},{"code":"піү","page":77,"end":false},{"code":"піҠ","page":77,"end":false},{"code":"піӢ","page":77,"end":false},{"code":"піҢпіҚ","page":77,"end":false},{"code":"піҺ","page":77,"end":false},{"code":"піҸ","page":77,"end":false},{"code":"піҗ","page":77,"end":false},{"code":"пі‘","page":77,"end":false},{"code":"пі’пі“","page":77,"end":false},{"code":"пі”","page":77,"end":false},{"code":"пі•","page":77,"end":false},{"code":"пі–","page":77,"end":false},{"code":"пі—","page":77,"end":false},{"code":"піҳ","page":77,"end":false},{"code":"піҷпіҡ","page":77,"end":false},{"code":"піӣ","page":77,"end":false},{"code":"пің","page":77,"end":false},{"code":"піқ","page":77,"end":false},{"code":"піһ","page":77,"end":true}],"text":"ЩҲЩҺЩұШЁЩ’ШӘЩҺЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ° ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§ ШЁЩҺЩ„ЩҺШәЩҸЩҲШ§Ыҹ ЩұЩ„ЩҶЩ‘ЩҗЩғЩҺШ§ШӯЩҺ ЩҒЩҺШҘЩҗЩҶЩ’ ШЎЩҺШ§ЩҶЩҺШіЩ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШұЩҸШҙЩ’ШҜЩӢЫӯШ§ ЩҒЩҺЩұШҜЩ’ЩҒЩҺШ№ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҮЩҺШ§Щ“ ШҘЩҗШіЩ’ШұЩҺШ§ЩҒЩӢЫӯШ§ ЩҲЩҺШЁЩҗШҜЩҺШ§ШұЩӢШ§ ШЈЩҺЩҶ ЩҠЩҺЩғЩ’ШЁЩҺШұЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ ШәЩҺЩҶЩҗЩҠЩ‘ЩӢЫӯШ§ ЩҒЩҺЩ„Щ’ЩҠЩҺШіЩ’ШӘЩҺШ№Щ’ЩҒЩҗЩҒЩ’ Ы– ЩҲЩҺЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ ЩҒЩҺЩӮЩҗЩҠШұЩӢЫӯШ§ ЩҒЩҺЩ„Щ’ЩҠЩҺШЈЩ’ЩғЩҸЩ„Щ’ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ Ыҡ ЩҒЩҺШҘЩҗШ°ЩҺШ§ ШҜЩҺЩҒЩҺШ№Щ’ШӘЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺШЈЩҺШҙЩ’ЩҮЩҗШҜЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ыҡ ЩҲЩҺЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӯЩҺШіЩҗЩҠШЁЩӢЫӯШ§"}]}
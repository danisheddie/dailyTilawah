:"пІҫ","page":78,"end":false},{"code":"пІҝ","page":78,"end":false},{"code":"піҖпіҒ","page":78,"end":false},{"code":"піӮ","page":78,"end":false},{"code":"піғ","page":78,"end":false},{"code":"пі„","page":78,"end":false},{"code":"пі…","page":78,"end":false},{"code":"піҶ","page":78,"end":false},{"code":"піҮ","page":78,"end":false},{"code":"піҲ","page":78,"end":false},{"code":"піүпіҠ","page":78,"end":false},{"code":"піӢ","page":78,"end":false},{"code":"піҢ","page":78,"end":false},{"code":"піҚпіҺ","page":78,"end":false},{"code":"піҸ","page":78,"end":false},{"code":"піҗ","page":78,"end":false},{"code":"пі‘","page":78,"end":false},{"code":"пі’","page":78,"end":false},{"code":"пі“","page":78,"end":false},{"code":"пі”","page":78,"end":true}],"text":"ЩҠЩҸЩҲШөЩҗЩҠЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҗЩүЩ“ ШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҗЩғЩҸЩ…Щ’ Ы– Щ„ЩҗЩ„Ш°Щ‘ЩҺЩғЩҺШұЩҗ Щ…ЩҗШ«Щ’Щ„ЩҸ ШӯЩҺШёЩ‘Щҗ ЩұЩ„Щ’ШЈЩҸЩҶШ«ЩҺЩҠЩҺЩҠЩ’ЩҶЩҗ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҸЩҶЩ‘ЩҺ ЩҶЩҗШіЩҺШ§Щ“ШЎЩӢЫӯ ЩҒЩҺЩҲЩ’ЩӮЩҺ ЩұШ«Щ’ЩҶЩҺШӘЩҺЩҠЩ’ЩҶЩҗ ЩҒЩҺЩ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ Ш«ЩҸЩ„ЩҸШ«ЩҺШ§ Щ…ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ Ы– ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺШӘЩ’ ЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩӢЫӯ ЩҒЩҺЩ„ЩҺЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҗШөЩ’ЩҒЩҸ Ыҡ ЩҲЩҺЩ„ЩҗШЈЩҺШЁЩҺЩҲЩҺЩҠЩ’ЩҮЩҗ Щ„ЩҗЩғЩҸЩ„Щ‘Щҗ ЩҲЩҺЩ°ШӯЩҗШҜЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ ЩұЩ„ШіЩ‘ЩҸШҜЩҸШіЩҸ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ ШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ Ыҡ ЩҒЩҺШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҶ Щ„Щ‘ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ ЩҲЩҺЩҲЩҺШұЩҗШ«ЩҺЩҮЩҸЫҘЩ“ ШЈЩҺШЁЩҺЩҲЩҺШ§ЩҮЩҸ ЩҒЩҺЩ„ЩҗШЈЩҸЩ…Щ‘ЩҗЩҮЩҗ ЩұЩ„Ш«Щ‘ЩҸЩ„ЩҸШ«ЩҸ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩҮЩҸЫҘЩ“ ШҘЩҗШ®Щ’ЩҲЩҺШ©ЩҢЫӯ ЩҒЩҺЩ„ЩҗШЈЩҸЩ…Щ‘ЩҗЩҮЩҗ ЩұЩ„ШіЩ‘ЩҸШҜЩҸШіЩҸ Ыҡ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ ЩҲЩҺШөЩҗЩҠЩ‘ЩҺШ©ЩҚЫў ЩҠЩҸЩҲШөЩҗЩү ШЁЩҗЩҮЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ШҜЩҺЩҠЩ’ЩҶЩҚ Ы— ШЎЩҺШ§ШЁЩҺШ§Щ“ШӨЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШӨЩҸЩғЩҸЩ…Щ’ Щ„ЩҺШ§ ШӘЩҺШҜЩ’ШұЩҸЩҲЩҶЩҺ ШЈЩҺЩҠЩ‘ЩҸЩҮЩҸЩ…Щ’ ШЈЩҺЩӮЩ’ШұЩҺШЁЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҶЩҺЩҒЩ’Ш№ЩӢЫӯШ§ Ыҡ ЩҒЩҺШұЩҗЩҠШ¶ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢЫӯШ§"}]}
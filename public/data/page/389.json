alse},{"code":"пұҘ","page":389,"end":false},{"code":"пұҰ","page":389,"end":false},{"code":"пұ§","page":389,"end":false},{"code":"пұЁ","page":389,"end":false},{"code":"пұ©","page":389,"end":false},{"code":"пұӘ","page":389,"end":false},{"code":"пұ«","page":389,"end":false},{"code":"пұ¬","page":389,"end":false},{"code":"пұӯ","page":389,"end":false},{"code":"пұ®","page":389,"end":false},{"code":"пұҜ","page":389,"end":false},{"code":"пұ°","page":389,"end":false},{"code":"пұұ","page":389,"end":false},{"code":"пұІ","page":389,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЈЩҺШӘЩҺЩүЩ°ЩҮЩҺШ§ ЩҶЩҸЩҲШҜЩҗЩүЩҺ Щ…ЩҗЩҶ ШҙЩҺЩҖЩ°Ш·ЩҗШҰЩҗ ЩұЩ„Щ’ЩҲЩҺШ§ШҜЩҗ ЩұЩ„Щ’ШЈЩҺЩҠЩ’Щ…ЩҺЩҶЩҗ ЩҒЩҗЩү ЩұЩ„Щ’ШЁЩҸЩӮЩ’Ш№ЩҺШ©Щҗ ЩұЩ„Щ’Щ…ЩҸШЁЩҺЩҖЩ°ШұЩҺЩғЩҺШ©Щҗ Щ…ЩҗЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺШ¬ЩҺШұЩҺШ©Щҗ ШЈЩҺЩҶ ЩҠЩҺЩҖЩ°Щ…ЩҸЩҲШіЩҺЩүЩ°Щ“ ШҘЩҗЩҶЩ‘ЩҗЩүЩ“ ШЈЩҺЩҶЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШұЩҺШЁЩ‘ЩҸ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"28:31","surah":28,"ayah":31,"num":3283,"page":389,"words":[{"code":"пұі","page":389,"end":false},{"code":"пұҙ","page":389,"end":false},{"code":"пұөпұ¶","page":389,"end":false},{"code":"пұ·","page":389,"end":false},{"code":"пұё","page":389,"end":false},{"code":"пұ№","page":389,"end":false},{"code":"пұә","page":389,"end":false},{"code":"пұ»","page":389,"end":false},{"code":"пұј","page":389,"end":false},{"code":"пұҪ","page":389,"end":false},{"code":"пұҫ","page":389,"end":false},{"code":"пұҝпІҖ","page":389,"end":false},{"code":"пІҒ","page":389,"end":false},{"code":"пІӮ","page":389,"end":false},{"code":"пІғ","page":389,"end":false},{"code":"пІ„пІ…","page":389,"end":false},{"code":"пІҶ","page":389,"end":false},{"code":"пІҮ","page":389,"end":false},{"code":"пІҲ","page":389,"end":false},{"code":"пІү","page":389,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶЩ’ ШЈЩҺЩ„Щ’ЩӮЩҗ Ш№ЩҺШөЩҺШ§ЩғЩҺ Ы– ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШұЩҺШЎЩҺШ§ЩҮЩҺШ§ ШӘЩҺЩҮЩ’ШӘЩҺШІЩ‘ЩҸ ЩғЩҺШЈЩҺЩҶЩ‘ЩҺЩҮЩҺШ§ Ш¬ЩҺШ§Щ“ЩҶЩ‘ЩҢЫӯ ЩҲЩҺЩ„Щ‘ЩҺЩүЩ° Щ…ЩҸШҜЩ’ШЁЩҗШұЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҸШ№ЩҺЩӮЩ‘ЩҗШЁЩ’ Ыҡ ЩҠЩҺЩҖЩ°Щ…ЩҸЩҲШіЩҺЩүЩ°Щ“ ШЈЩҺЩӮЩ’ШЁЩҗЩ„Щ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ®ЩҺЩҒЩ’ Ы– ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"28:32","surah":28,"ayah":32,"num":3284,"page":389,"words":[{"code":"пІҠ","page":389,"end":false},{"code":"пІӢ","page":389,"end":false},{"code":"пІҢ","page":389,"end":false},{"code":"пІҚ","page":389,"end":false},{"code":"пІҺ","page":389,"end":false},{"code":"пІҸ","page":389,"end":false},{"code":"пІҗ","page":389,"end":false},{"code":"пІ‘","page":389,"end":false},{"code":"пІ’","page":389,"end":false},{"code":"пІ“","page":389,"end":false},{"code":"пІ”","page":389,"end":false},{"code":"пІ•","page":389,"end":false},{"code":"пІ–","page":389,"end":false},{"code":"пІ—пІҳ","page":389,"end":false},{"code":"пІҷ","page":389,"end":false},{"code":"пІҡ","page":389,"end":false},{"code":"пІӣ","page":389,"end":false},{"code":"пІң","page":389,"end":false},{"code":"пІқ","page":389,"end":false},{"code":"пІһ","page":389,"end":false},{"code":"пІҹпІ ","page":389,"end":false},{"code":"пІЎ","page":389,"end":false},{"code":"пІў","page":389,"end":false},{"code":"пІЈ","page":389,"end":false},{"code":"пІӨ","page":389,"end":false},{"code":"пІҘ","page":389,"end":true}],"text":"ЩұШіЩ’Щ„ЩҸЩғЩ’ ЩҠЩҺШҜЩҺЩғЩҺ ЩҒЩҗЩү Ш¬ЩҺЩҠЩ’ШЁЩҗЩғЩҺ ШӘЩҺШ®Щ’ШұЩҸШ¬Щ’ ШЁЩҺЩҠЩ’Ш¶ЩҺШ§Щ“ШЎЩҺ Щ…ЩҗЩҶЩ’ ШәЩҺЩҠЩ’ШұЩҗ ШіЩҸЩҲЩ“ШЎЩҚЫў ЩҲЩҺЩұШ¶Щ’Щ…ЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ Ш¬ЩҺЩҶЩҺШ§ШӯЩҺЩғЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺЩҮЩ’ШЁЩҗ Ы– ЩҒЩҺШ°ЩҺЩ°ЩҶЩҗЩғЩҺ ШЁЩҸШұЩ’ЩҮЩҺЩҖЩ°ЩҶЩҺШ§ЩҶЩҗ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҺ ШҘЩҗЩ„ЩҺЩүЩ° ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ЩҲЩҺЩ…ЩҺЩ„ЩҺШҘЩҗЩҠЫҹЩҮЩҗЫҰЩ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩӮЩҺЩҲЩ’Щ…ЩӢЫӯШ§ ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"28:33","surah":28,"ayah":33,"num":3285,"page":389,"words":[{"code":"пІҰ","page":389,"end":false},{"code":"пІ§","page":389,"end":false},{"code":"пІЁ","page":389,"end":false},{"code":"пІ©","page":389,"end":false},{"code":"пІӘ","page":389,"end":false},{"code":"пІ«","page":389,"end":false},{"code":"пІ¬","page":389,"end":false},{"code":"пІӯ","page":389,"end":false},{"code":"пІ®","page":389,"end":false},{"code":"пІҜ","page":389,"end":true}],"text":"ЩӮЩҺ
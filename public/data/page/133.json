false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false}]},{"lineNumber":15,"words":[{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":true}]}],"verses":[{"key":"6:45","surah":6,"ayah":45,"num":834,"page":133,"words":[{"code":"пұҒ","page":133,"end":false},{"code":"пұӮ","page":133,"end":false},{"code":"пұғ","page":133,"end":false},{"code":"пұ„","page":133,"end":false},{"code":"пұ…пұҶ","page":133,"end":false},{"code":"пұҮ","page":133,"end":false},{"code":"пұҲ","page":133,"end":false},{"code":"пұү","page":133,"end":false},{"code":"пұҠ","page":133,"end":false},{"code":"пұӢ","page":133,"end":true}],"text":"ЩҒЩҺЩӮЩҸШ·ЩҗШ№ЩҺ ШҜЩҺШ§ШЁЩҗШұЩҸ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩұЩ„Щ’ШӯЩҺЩ…Щ’ШҜЩҸ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ШұЩҺШЁЩ‘Щҗ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"6:46","surah":6,"ayah":46,"num":835,"page":133,"words":[{"code":"пұҢ","page":133,"end":false},{"code":"пұҚ","page":133,"end":false},{"code":"пұҺ","page":133,"end":false},{"code":"пұҸ","page":133,"end":false},{"code":"пұҗ","page":133,"end":false},{"code":"пұ‘","page":133,"end":false},{"code":"пұ’","page":133,"end":false},{"code":"пұ“","page":133,"end":false},{"code":"пұ”","page":133,"end":false},{"code":"пұ•","page":133,"end":false},{"code":"пұ–","page":133,"end":false},{"code":"пұ—","page":133,"end":false},{"code":"пұҳ","page":133,"end":false},{"code":"пұҷ","page":133,"end":false},{"code":"пұҡ","page":133,"end":false},{"code":"пұӣпұң","page":133,"end":false},{"code":"пұқ","page":133,"end":false},{"code":"пұһ","page":133,"end":false},{"code":"пұҹ","page":133,"end":false},{"code":"пұ ","page":133,"end":false},{"code":"пұЎ","page":133,"end":false},{"code":"пұў","page":133,"end":false},{"code":"пұЈ","page":133,"end":false},{"code":"пұӨ","page":133,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШЈЩҺШұЩҺШЎЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ШҘЩҗЩҶЩ’ ШЈЩҺШ®ЩҺШ°ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩ…Щ’Ш№ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШЁЩ’ШөЩҺЩҖЩ°ШұЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШ®ЩҺШӘЩҺЩ…ЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩғЩҸЩ… Щ…Щ‘ЩҺЩҶЩ’ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҢ ШәЩҺЩҠЩ’ШұЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩғЩҸЩ… ШЁЩҗЩҮЩҗ Ы— ЩұЩҶШёЩҸШұЩ’ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩҶЩҸШөЩҺШұЩ‘ЩҗЩҒЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ Ш«ЩҸЩ…Щ‘ЩҺ ЩҮЩҸЩ…Щ’ ЩҠЩҺШөЩ’ШҜЩҗЩҒЩҸЩҲЩҶЩҺ"},{"key":"6:47","surah":6,"ayah":47,"num":836,"page":133,"words":[{"code":"пұҘ","page":133,"end":false},{"code":"пұҰ","page":133,"end":false},{"code":"пұ§","page":133,"end":false},{"code":"пұЁ","page":133,"end":false},{"code":"пұ©","page":133,"end":false},{"code":"пұӘ","page":133,"end":false},{"code":"пұ«","page":133,"end":false},{"code":"пұ¬","page":133,"end":false},{"code":"пұӯ","page":133,"end":false},{"code":"пұ®","page":133,"end":false},{"code":"пұҜ","page":133,"end":false},{"code":"пұ°","page":133,"end":false},{"code":"пұұ","page":133,"end":false},{"code":"пұІ","page":133,"end":false},{"code":"пұі","page":133,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШЈЩҺШұЩҺШЎЩҺЩҠЩ’ШӘЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩ’ ШЈЩҺШӘЩҺЩүЩ°ЩғЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҺШәЩ’ШӘЩҺШ©ЩӢ ШЈЩҺЩҲЩ’ Ш¬ЩҺЩҮЩ’ШұЩҺШ©ЩӢ ЩҮЩҺЩ„Щ’ ЩҠЩҸЩҮЩ’Щ„ЩҺЩғЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…ЩҸ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"6:48","surah":6,"ayah":48,"num":837,"page":133,"words":[{"code":"пұҙ","page":133,"end":false},{"code":"пұө","page":133,"end":false},{"code":"пұ¶","page":133,"end":false},{"code":"пұ·","page":133,"end":false},{"code":"пұё","page":133,"end":false},{"code":"пұ№пұә","page":133,"end":false},{"code":"пұ»","page":133,"end":false},{"code":"пұј","page":133,"end":false},{"code":"пұҪ","page":133,"end":false},{"code":"пұҫ","page":133,"end":false},{"code":"пұҝ","page":133,"end":false},{"code":"пІҖ","page":133,"end":false},{"code":"пІҒ","page":133,"end":false},{"code":"пІӮ","page":133,"end":false},{"code":"пІғ","page":133,"end":false},{"code":"пІ„","page":133,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ЩҶЩҸШұЩ’ШіЩҗЩ„ЩҸ ЩұЩ„Щ’Щ…ЩҸШұЩ’ШіЩҺЩ„ЩҗЩҠЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҸШЁЩҺШҙЩ‘ЩҗШұЩҗЩҠЩҶЩҺ ЩҲЩҺЩ…ЩҸЩҶШ°ЩҗШұЩҗЩҠЩҶЩҺ Ы– ЩҒЩҺЩ…ЩҺЩҶЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ЩҲЩҺШЈЩҺШөЩ’Щ„ЩҺШӯЩҺ ЩҒЩҺЩ„ЩҺШ§ Ш®ЩҺЩҲЩ’ЩҒЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҠЩҺШӯЩ’ШІЩҺЩҶЩҸЩҲЩҶЩҺ"},{"key":"6:49","surah":6,"ayah":49,"num":838,"page":133,"words":[{"code":"пІ…","page":133,"end":false},{"code":"пІҶ","page":133,"end":false},{"code":"пІҮ","page":133,"end":false},{"code":"пІҲ","page":133,"end":false},{"code":"пІү","page":133,"end":false},{"code":"пІҠ","page":133,"end":false},{"code":"пІӢ","page":133,"end":false},{"code":"пІҢ","page":133,"end":false},{"code":"пІҚ","page":133,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҠЩҺЩ…ЩҺШіЩ‘ЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩҒЩ’ШіЩҸЩӮЩҸЩҲЩҶЩҺ"},{"key":"6:50","surah":6,"ayah":50,"num":839,"page":133,"words":[{"code":"пІҺ","page":133,"end":false},{"code":"пІҸ","page":133,"end":false},{"code":"пІҗ","page":133,"end":false},{"code":"пІ‘","page":133,"end":false},{"code":"пІ’","page":133,"end":false},{"code":"пІ“","page":133,"end":false},{"code":"пІ”","page":133,"end":false},{"code":"пІ•","page":133,"end":false},{"code":"пІ–","page":133,"end":false},{"code":"пІ—","page":133,"end":false},{"code":"пІҳ","page":133,"end":false},{"code":"пІҷ","page":133,"end":false},{"code":"пІҡ","page":133,"end":false},{"code":"пІӣ","page":133,"end":false},{"code":"пІңпІқ","page":133,"end":false},{"code":"пІһ","page":133,"end":false},{"code":"пІҹ","page":133,"end":false},{"code":"пІ ","page":133,"end":false},{"code":"пІЎ","page":133,"end":false},{"code":"пІў","page":133,"end":false},{"code":"пІЈпІӨ","page":133,"end":false},{"code":"пІҘ","page":133,"end":false},{"code":"пІҰ","page":133,"end":false},{"code":"пІ§","page":133,"end":false},{"code":"пІЁ","page":133,"end":false},{"code":"пІ©пІӘ","page":133,"end":false},{"code":"пІ«","page":133,"end":false},{"code":"пІ¬","page":133,"end":false},{"code":"пІӯ","page":133,"end":true}],"text":"ЩӮЩҸЩ„ Щ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҗЩү Ш®ЩҺШІЩҺШ§Щ“ШҰЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ЩұЩ„Щ’ШәЩҺЩҠЩ’ШЁЩҺ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩ‘ЩҗЩү Щ…ЩҺЩ„ЩҺЩғЩҢ Ы– ШҘЩҗЩҶЩ’ ШЈЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ЩҠЩҸЩҲШӯЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩүЩ‘ЩҺ Ыҡ ЩӮЩҸЩ„Щ’ ЩҮЩҺЩ„Щ’ ЩҠЩҺШіЩ’ШӘЩҺЩҲЩҗЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ…ЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’ШЁЩҺШөЩҗЩҠШұЩҸ Ыҡ ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩҺЩҒЩҺЩғЩ‘ЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"6:51","surah":6,"ayah":51,"num":840,"page":133,"words":[{"code":"пІ®","page":133,"end":false},{"code":"пІҜ","page":133,"end":false},{"code":"пІ°","page":133,"end":false},{"code":"пІұ","page":133,"end":false},{"code":"пІІ","page":133,"end":false},{"code":"пІі","page":133,"end":false},{"code":"пІҙ","page":133,"end":false},{"code":"пІө","page":133,"end":false},{"code":"пІ¶","page":133,"end":false},{"code":"пІ·","page":133,"end":false},{"code":"пІё","page":133,"end":false},{"code":"пІ№","page":133,"end":false},{"code":"пІә","page":133,"end":false},{"code":"пІ»","page":133,"end":false},{"code":"пІј","page":133,"end":false},{"code":"пІҪ","page":133,"end":false},{"code":"пІҫ","page":133,"end":false},{"code":"пІҝ","page":133,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶШ°ЩҗШұЩ’ ШЁЩҗЩҮЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШ®ЩҺШ§ЩҒЩҸЩҲЩҶЩҺ ШЈЩҺЩҶ ЩҠЩҸШӯЩ’ШҙЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Ыҷ Щ„ЩҺЩҠЩ’ШіЩҺ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЫҰ ЩҲЩҺЩ„ЩҗЩүЩ‘ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ ШҙЩҺЩҒЩҗЩҠШ№ЩҢЫӯ Щ„Щ‘ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"6:52","surah":6,"ayah":52,"num":841,"page":133,"words":[{"code":"піҖ","page":133,"end":false},{"code":"піҒ","page":133,"end":false},{"code":"піӮ","page":133,"end":false},{"code":"піғ","page":133,"end":false},{"code":"пі„","page":133,"end":false},{"code":"пі…","page":133,"end":false},{"code":"піҶ","page":133,"end":false},{"code":"піҮ","page":133,"end":false},{"code":"піҲпіү","page":133,"end":false},{"code":"піҠ","page":133,"end":false},{"code":"піӢ","page":133,"end":false},{"code":"піҢ","page":133,"end":false},{"cod
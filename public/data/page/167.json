ah":138,"num":1092,"page":167,"words":[{"code":"пұҒ","page":167,"end":false},{"code":"пұӮ","page":167,"end":false},{"code":"пұғ","page":167,"end":false},{"code":"пұ„","page":167,"end":false},{"code":"пұ…","page":167,"end":false},{"code":"пұҶ","page":167,"end":false},{"code":"пұҮ","page":167,"end":false},{"code":"пұҲ","page":167,"end":false},{"code":"пұү","page":167,"end":false},{"code":"пұҠ","page":167,"end":false},{"code":"пұӢпұҢ","page":167,"end":false},{"code":"пұҚ","page":167,"end":false},{"code":"пұҺ","page":167,"end":false},{"code":"пұҸ","page":167,"end":false},{"code":"пұҗ","page":167,"end":false},{"code":"пұ‘","page":167,"end":false},{"code":"пұ’","page":167,"end":false},{"code":"пұ“","page":167,"end":false},{"code":"пұ”пұ•","page":167,"end":false},{"code":"пұ–","page":167,"end":false},{"code":"пұ—","page":167,"end":false},{"code":"пұҳ","page":167,"end":false},{"code":"пұҷ","page":167,"end":false},{"code":"пұҡ","page":167,"end":true}],"text":"ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҲЩҺШІЩ’ЩҶЩҺШ§ ШЁЩҗШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩұЩ„Щ’ШЁЩҺШӯЩ’ШұЩҺ ЩҒЩҺШЈЩҺШӘЩҺЩҲЩ’Ш§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ° ЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҺШ№Щ’ЩғЩҸЩҒЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШөЩ’ЩҶЩҺШ§Щ…ЩҚЫў Щ„Щ‘ЩҺЩҮЩҸЩ…Щ’ Ыҡ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҠЩҺЩҖЩ°Щ…ЩҸЩҲШіЩҺЩү ЩұШ¬Щ’Ш№ЩҺЩ„ Щ„Щ‘ЩҺЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩӢЫӯШ§ ЩғЩҺЩ…ЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЎЩҺШ§Щ„ЩҗЩҮЩҺШ©ЩҢЫӯ Ыҡ ЩӮЩҺШ§Щ„ЩҺ ШҘЩҗЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ ЩӮЩҺЩҲЩ’Щ…ЩҢЫӯ ШӘЩҺШ¬Щ’ЩҮЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"7:139","surah":7,"ayah":139,"num":1093,"page":167,"words":[{"code":"пұӣ","page":167,"end":false},{"code":"пұң","page":167,"end":false},{"code":"пұқ","page":167,"end":false},{"code":"пұһ","page":167,"end":false},{"code":"пұҹ","page":167,"end":false},{"code":"пұ ","page":167,"end":false},{"code":"пұЎ","page":167,"end":false},{"code":"пұў","page":167,"end":false},{"code":"пұЈ","page":167,"end":false},{"code":"пұӨ","page":167,"end":false},{"code":"пұҘ","page":167,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ Щ…ЩҸШӘЩҺШЁЩ‘ЩҺШұЩҢЫӯ Щ…Щ‘ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҗ ЩҲЩҺШЁЩҺЩҖЩ°Ш·ЩҗЩ„ЩҢЫӯ Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"7:140","surah":7,"ayah":140,"num":1094,"page":167,"words":[{"code":"пұҰ","page":167,"end":false},{"code":"пұ§","page":167,"end":false},{"code":"пұЁ","page":167,"end":false},{"code":"пұ©","page":167,"end":false},{"code":"пұӘ","page":167,"end":false},{"code":"пұ«","page":167,"end":false},{"code":"пұ¬","page":167,"end":false},{"code":"пұӯ","page":167,"end":false},{"code":"пұ®","page":167,"end":false},{"code":"пұҜ","page":167,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺШЁЩ’ШәЩҗЩҠЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩӢЫӯШ§ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"7:141","surah":7,"ayah":141,"num":1095,"page":167,"words":[{"code":"пұ°","page":167,"end":false},{"code":"пұұ","page":167,"end":false},{"code":"пұІ","page":167,"end":false},{"code":"пұі","page":167,"end":false},{"code":"пұҙ","page":167,"end":false},{"code":"пұө","page":167,"end":false},{"code":"пұ¶","page":167,"end":false},{"code":"пұ·","page":167,"end":false},{"code":"пұё","page":167,"end":false},{"code":"пұ№","page":167,"end":false},{"code":"пұә","page":167,"end":false},{"code":"пұ»пұј","page":167,"end":false},{"code":"пұҪ","page":167,"end":false},{"code":"пұҫ","page":167,"end":false},{"code":"пұҝ","page":167,"end":false},{"code":"пІҖ","page":167,"end":false},{"code":"пІҒ","page":167,"end":false},{"code":"пІӮ","page":167,"end":false},{"code":"пІғ","page":167,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ШЈЩҺЩҶШ¬ЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ ШЎЩҺШ§Щ„Щҗ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ЩҠЩҺШіЩҸЩҲЩ…ЩҸЩҲЩҶЩҺЩғЩҸЩ…Щ’ ШіЩҸЩҲЩ“ШЎЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ Ы– ЩҠЩҸЩӮЩҺШӘЩ‘ЩҗЩ„ЩҸЩҲЩҶЩҺ ШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҺШіЩ’ШӘЩҺШӯЩ’ЩҠЩҸЩҲЩҶЩҺ ЩҶЩҗШіЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ… ШЁЩҺЩ„ЩҺШ§Щ“ШЎЩҢЫӯ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"7:142","surah":7,"ayah":142,"num":1096,"page":167,"words":[{"code":"пІ„ пІ…","page":167,"end":false},{"code":"пІҶ","page":167,"end":false},{"code":"пІҮ","page":167,"end":false},{"code":"пІҲ","page":167,"end":false},{"code":"пІү","page":167,"end":false},{"code":"пІҠ","page":167,"end":false},{"code":"пІӢ","page":167,"end":false},{"code":"пІҢ","page":167,"end":false},{"code":"пІҚ","page":167,"end":false},{"code":"пІҺ","page":167,"end":false},{"code":"пІҸпІҗ","page":167,"end":false},{"code":"пІ‘","page":167,"end":false},{"code":"пІ’","page":167,"end":false},{"code":"пІ“","page":167,"end":false},{"code":"пІ”","page":167,"end":false},{"code":"пІ•","page":167,"end":false},{"code":"пІ–","page":167,"end":false},{"code":"пІ—","page":167,"end":false},{"code":"пІҳ","page":167,"end":false},{"code":"пІҷ","page":167,"end":false},{"code":"пІҡ","page":167,"end":false},{"code":"пІӣ","page":167,"end":false},{"code":"пІң","page":167,"end":false},{"code":"пІқ","page":167,"end":true}],"text":"Ыһ ЩҲЩҺЩҲЩҺЩ°Ш№ЩҺШҜЩ’ЩҶЩҺШ§ Щ…ЩҸЩҲШіЩҺЩүЩ° Ш«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҗЩҠЩҶЩҺ Щ„ЩҺЩҠЩ’Щ„ЩҺШ©ЩӢЫӯ ЩҲЩҺШЈЩҺШӘЩ’Щ…ЩҺЩ…Щ’ЩҶЩҺЩҖЩ°ЩҮЩҺШ§ ШЁЩҗШ№ЩҺШҙЩ’ШұЩҚЫў ЩҒЩҺШӘЩҺЩ…Щ‘ЩҺ Щ…ЩҗЩҠЩӮЩҺЩҖЩ°ШӘЩҸ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЫҰЩ“ ШЈЩҺШұЩ’ШЁЩҺШ№ЩҗЩҠЩҶЩҺ Щ„ЩҺЩҠЩ’Щ„ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ Щ…ЩҸЩҲШіЩҺЩүЩ° Щ„ЩҗШЈЩҺШ®ЩҗЩҠЩҮЩҗ ЩҮЩҺЩҖЩ°ШұЩҸЩҲЩҶЩҺ ЩұШ®Щ’Щ„ЩҸЩҒЩ’ЩҶЩҗЩү ЩҒЩҗЩү ЩӮЩҺЩҲЩ’Щ…ЩҗЩү ЩҲЩҺШЈЩҺШөЩ’Щ„ЩҗШӯЩ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШЁЩҗШ№Щ’ ШіЩҺШЁЩҗЩҠЩ„ЩҺ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’ШіЩҗШҜЩҗЩҠЩҶЩҺ"},{"key":"7:143","surah":7,"ayah":143,"num":1097,"page":167,"words":[{"code":"пІһ","page":167,"end":false},{"code":"пІҹ","page":167,"end":false},{"code":"пІ ","page":167,"end":false},{"code":"пІЎ","page":167,"end":false},{"code":"пІў","page":167,"end":false},{"code":"пІЈ","page":167,"end":false},{"code":"пІӨ","page":167,"end":false},{"code":"пІҘ","page":167,"end":false},{"code":"пІҰ","page":167,"end":false},{"code":"пІ§","page":167,"end":false},{"code":"пІЁпІ©","page":167,"end":false},{"code":"пІӘ","page":167,"end":false},{"code":"пІ«","page":167,"end":false},{"code":"пІ¬","page":167,"end":false},{"code":"пІӯ","page":167,"end":false},{"code":"пІ®","page":167,"end":false},{"code":"пІҜ","page":167,"end":false},{"code":"пІ°","page":167,"end":false},{"code":"пІұ","page":167,"end":false},{"code":"пІІ","page":167,"end":false},{"code":"пІі","page":167,"end":false},{"code":"пІҙ","page":167,"end":false},{"code":"пІөпІ¶","page":167,"end":false},{"code":"пІ·","page":167,"end":false},{"code":"пІё","page":167,"end":false},{"code":"пІ№","page":167,"end":false},{"code":"пІә","page":167,"end":false},{"code":"пІ»","page":167,"end":false},{"code":"пІј","page":167,"end":false},{"code":"пІҪ","page":167,"end":false},{"code":"пІҫ","page":167,"end":false},{"code":"пІҝпіҖ","page":167,"end":false},{"code":"піҒ","page":167,"end":false},{"code":"піӮ","page":167,"end":false},{"code":"піғ","page":167,"end":false},{"code":"пі„","page":167,"end":false},{"code":"пі…","page":167,"end":false},{"code":"піҶ","page":167,"end":false},{"code":"піҮ","page":167,"end":false},{"code":"піҲ","page":167,"end":false},{"code":"піү","page":167,"end":false},{"code":"піҠ","page":167,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ Щ…ЩҸЩҲШіЩҺЩүЩ° Щ„ЩҗЩ…ЩҗЩҠЩӮЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҲЩҺЩғЩҺЩ„Щ‘ЩҺЩ…ЩҺЩҮЩҸЫҘ ШұЩҺШЁЩ‘ЩҸЩҮЩҸЫҘ ЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘Щҗ ШЈЩҺШұЩҗЩҶЩҗЩүЩ“ ШЈЩҺЩҶШёЩҸШұЩ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ Ыҡ ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҺЩҶ ШӘЩҺШұЩҺЩүЩ°ЩҶЩҗЩү ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩҗ ЩұЩҶШёЩҸШұЩ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Ш¬ЩҺШЁЩҺЩ„Щҗ ЩҒЩҺШҘЩҗЩҶЩҗ ЩұШіЩ’ШӘЩҺЩӮЩҺШұЩ‘ЩҺ Щ…ЩҺЩғЩҺШ§ЩҶЩҺЩҮЩҸЫҘ ЩҒЩҺШіЩҺЩҲЩ’ЩҒЩҺ ШӘЩҺШұЩҺЩүЩ°ЩҶЩҗЩү Ыҡ ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШӘЩҺШ¬ЩҺЩ„Щ‘ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҸЩҮЩҸЫҘ Щ„ЩҗЩ„Щ’Ш¬ЩҺШЁЩҺЩ„Щҗ Ш¬ЩҺШ№ЩҺЩ„ЩҺЩҮЩҸЫҘ ШҜЩҺЩғЩ‘ЩӢЫӯШ§ ЩҲЩҺШ®ЩҺШұЩ‘ЩҺ Щ…ЩҸЩҲШіЩҺЩүЩ° ШөЩҺШ№ЩҗЩӮЩӢЫӯШ§ Ыҡ ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЈЩҺЩҒЩҺШ§ЩӮЩҺ ЩӮЩҺШ§Щ„ЩҺ ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺЩғЩҺ ШӘЩҸШЁЩ’ШӘЩҸ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ ЩҲЩҺШЈЩҺЩҶЩҺШ§Ы  ШЈЩҺЩҲЩ‘ЩҺЩ„ЩҸ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"}]}
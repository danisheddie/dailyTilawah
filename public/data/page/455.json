пұң","page":455,"end":false},{"code":"пұқ","page":455,"end":false},{"code":"пұһ","page":455,"end":false},{"code":"пұҹ","page":455,"end":false},{"code":"пұ ","page":455,"end":false},{"code":"пұЎ","page":455,"end":true}],"text":"ШЈЩҺЩ…Щ’ ЩҶЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ЩғЩҺЩұЩ„Щ’Щ…ЩҸЩҒЩ’ШіЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҺЩ…Щ’ ЩҶЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸ ЩұЩ„Щ’Щ…ЩҸШӘЩ‘ЩҺЩӮЩҗЩҠЩҶЩҺ ЩғЩҺЩұЩ„Щ’ЩҒЩҸШ¬Щ‘ЩҺШ§ШұЩҗ"},{"key":"38:29","surah":38,"ayah":29,"num":3999,"page":455,"words":[{"code":"пұў","page":455,"end":false},{"code":"пұЈ","page":455,"end":false},{"code":"пұӨ","page":455,"end":false},{"code":"пұҘ","page":455,"end":false},{"code":"пұҰ","page":455,"end":false},{"code":"пұ§","page":455,"end":false},{"code":"пұЁ","page":455,"end":false},{"code":"пұ©","page":455,"end":false},{"code":"пұӘ","page":455,"end":false},{"code":"пұ«","page":455,"end":true}],"text":"ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҢ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ Щ…ЩҸШЁЩҺЩҖЩ°ШұЩҺЩғЩҢЫӯ Щ„Щ‘ЩҗЩҠЩҺШҜЩ‘ЩҺШЁЩ‘ЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҮЩҗЫҰ ЩҲЩҺЩ„ЩҗЩҠЩҺШӘЩҺШ°ЩҺЩғЩ‘ЩҺШұЩҺ ШЈЩҸЩҲЫҹЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЈЩҺЩ„Щ’ШЁЩҺЩҖЩ°ШЁЩҗ"},{"key":"38:30","surah":38,"ayah":30,"num":4000,"page":455,"words":[{"code":"пұ¬","page":455,"end":false},{"code":"пұӯ","page":455,"end":false},{"code":"пұ®пұҜ","page":455,"end":false},{"code":"пұ°","page":455,"end":false},{"code":"пұұ","page":455,"end":false},{"code":"пұІ","page":455,"end":false},{"code":"пұі","page":455,"end":false},{"code":"пұҙ","page":455,"end":true}],"text":"ЩҲЩҺЩҲЩҺЩҮЩҺШЁЩ’ЩҶЩҺШ§ Щ„ЩҗШҜЩҺШ§ЩҲЩҸЫҘШҜЩҺ ШіЩҸЩ„ЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҺ Ыҡ ЩҶЩҗШ№Щ’Щ…ЩҺ ЩұЩ„Щ’Ш№ЩҺШЁЩ’ШҜЩҸ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘЩ“ ШЈЩҺЩҲЩ‘ЩҺШ§ШЁЩҢ"},{"key":"38:31","surah":38,"ayah":31,"num":4001,"page":455,"words":[{"code":"пұө","page":455,"end":false},{"code":"пұ¶","page":455,"end":false},{"code":"пұ·","page":455,"end":false},{"code":"пұё","page":455,"end":false},{"code":"пұ№","page":455,"end":false},{"code":"пұә","page":455,"end":false},{"code":"пұ»
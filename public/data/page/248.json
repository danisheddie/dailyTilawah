Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ"},{"key":"12:109","surah":12,"ayah":109,"num":1705,"page":248,"words":[{"code":"пІ„","page":248,"end":false},{"code":"пІ…","page":248,"end":false},{"code":"пІҶ","page":248,"end":false},{"code":"пІҮ","page":248,"end":false},{"code":"пІҲ","page":248,"end":false},{"code":"пІү","page":248,"end":false},{"code":"пІҠ","page":248,"end":false},{"code":"пІӢ","page":248,"end":false},{"code":"пІҢ","page":248,"end":false},{"code":"пІҚ","page":248,"end":false},{"code":"пІҺпІҸ","page":248,"end":false},{"code":"пІҗ","page":248,"end":false},{"code":"пІ‘","page":248,"end":false},{"code":"пІ’","page":248,"end":false},{"code":"пІ“","page":248,"end":false},{"code":"пІ”","page":248,"end":false},{"code":"пІ•","page":248,"end":false},{"code":"пІ–","page":248,"end":false},{"code":"пІ—","page":248,"end":false},{"code":"пІҳ","page":248,"end":false},{"code":"пІҷ","page":248,"end":false},{"code":"пІҡпІӣ","page":248,"end":false},{"code":"пІң","page":248,"end":false},{"code":"пІқ","page":248,"end":false},{"code":"пІһ","page":248,"end":false},{"code":"пІҹ","page":248,"end":false},{"code":"пІ пІЎ","page":248,"end":false},{"code":"пІў","page":248,"end":false},{"code":"пІЈ","page":248,"end":false},{"code":"пІӨ","page":248,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ШұЩҗШ¬ЩҺШ§Щ„ЩӢЫӯШ§ ЩҶЩ‘ЩҸЩҲШӯЩҗЩүЩ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’ЩӮЩҸШұЩҺЩүЩ°Щ“ Ы— ШЈЩҺЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШіЩҗЩҠШұЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҒЩҺЩҠЩҺЩҶШёЩҸШұЩҸЩҲШ§Ыҹ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШ©ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩҮЩҗЩ…Щ’ Ы— ЩҲЩҺЩ„ЩҺШҜЩҺШ§ШұЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШӘЩ‘ЩҺЩӮЩҺЩҲЩ’Ш§Ыҹ Ы— ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"12:110","surah":12,"ayah":110,"num":1706,"page":248,"words":[{"code":"пІҘ","page":248,"end":false},{"code":"пІҰ","page":248,"end":false},{"code":"пІ§","page":248,"end":false},{"code":"пІЁ","page":248,"end":false},{"code":"пІ©","page"
nd":false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":true}]}],"verses":[{"key":"12:104","surah":12,"ayah":104,"num":1700,"page":248,"words":[{"code":"пұҒ","page":248,"end":false},{"code":"пұӮ","page":248,"end":false},{"code":"пұғ","page":248,"end":false},{"code":"пұ„","page":248,"end":false},{"code":"пұ…пұҶ","page":248,"end":false},{"code":"пұҮ","page":248,"end":false},{"code":"пұҲ","page":248,"end":false},{"code":"пұү","page":248,"end":false},{"code":"пұҠ","page":248,"end":false},{"code":"пұӢ","page":248,"end":false},{"code":"пұҢ","page":248,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ШӘЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҮЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ Щ…ЩҗЩҶЩ’ ШЈЩҺШ¬Щ’ШұЩҚ Ыҡ ШҘЩҗЩҶЩ’ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш°ЩҗЩғЩ’ШұЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"12:105","surah":12,"ayah":105,"num":1701,"page":248,"words":[{"code":"пұҚ","page":248,"end":false},{"code":"пұҺ","page":248,"end":false},{"code":"пұҸ","page":248,"end":false},{"code":"пұҗ","page":248,"end":false},{"code":"пұ‘","page":248,"end":false},{"code":"пұ’","page":248,"end":false},{"code":"пұ“","page":248,"end":false},{"code":"пұ”","page":248,"end":false},{"code":"пұ•","page":248,"end":false},{"code":"пұ–","page":248,"end":false},{"code":"пұ—","page":248,"end":false},{"code":"пұҳ","page":248,"end":true}],"text":"ЩҲЩҺЩғЩҺШЈЩҺЩҠЩ‘ЩҗЩҶ Щ…Щ‘ЩҗЩҶЩ’ ШЎЩҺШ§ЩҠЩҺШ©ЩҚЫў ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҠЩҺЩ…ЩҸШұЩ‘ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ ЩҲЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺЩҶЩ’ЩҮЩҺШ§ Щ…ЩҸШ№Щ’ШұЩҗШ¶ЩҸЩҲЩҶЩҺ"},{"key":"12:106","surah":12,"ayah":106,"num":1702,"page":248,"words":[{"code":"пұҷ","page":248,"end":false},{"code":"пұҡ","page":248,"end":false},{"code":"пұӣ","page":248,"end":false},{"code":"пұң","page":248,"end":false},{"code":"пұқ","page":248,"end":false},{"code":"пұһ","page":248,"end":false},{"code":"пұҹ","page":248,"end":false},{"code":"пұ ","page":248,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ШЈЩҺЩғЩ’Ш«ЩҺШ
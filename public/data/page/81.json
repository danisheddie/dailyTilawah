:"пІӮ","end":false},{"code":"пІғ","end":false},{"code":"пІ„","end":false},{"code":"пІ…","end":false}]},{"lineNumber":11,"words":[{"code":"пІҶ","end":false},{"code":"пІҮ","end":false},{"code":"пІҲ","end":false},{"code":"пІү","end":false},{"code":"пІҠ","end":false},{"code":"пІӢ","end":false}]},{"lineNumber":12,"words":[{"code":"пІҢ","end":false},{"code":"пІҚ","end":false},{"code":"пІҺ","end":false},{"code":"пІҸ","end":false},{"code":"пІҗ","end":false},{"code":"пІ‘","end":false},{"code":"пІ’","end":false},{"code":"пІ“","end":false},{"code":"пІ”","end":false}]},{"lineNumber":13,"words":[{"code":"пІ•","end":false},{"code":"пІ–","end":false},{"code":"пІ—","end":false},{"code":"пІҳ","end":false},{"code":"пІҷ","end":false},{"code":"пІҡ","end":false}]},{"lineNumber":14,"words":[{"code":"пІӣ","end":false},{"code":"пІң","end":false},{"code":"пІқ","end":false},{"code":"пІһ","end":false},{"code":"пІҹ","end":false},{"code":"пІ ","end":false}]},{"lineNumber":15,"words":[{"code":"пІЎ","end":false},{"code":"пІў","end":false},{"code":"пІЈпІӨ","end":false},{"code":"пІҘ","end":false},{"code":"пІҰ","end":false},{"code":"пІ§","end":false},{"code":"пІЁ","end":false},{"code":"пІ©","end":false},{"code":"пІӘ","end":true}]}],"verses":[{"key":"4:20","surah":4,"ayah":20,"num":513,"page":81,"words":[{"code":"пұҒ","page":81,"end":false},{"code":"пұӮ","page":81,"end":false},{"code":"пұғ","page":81,"end":false},{"code":"пұ„","page":81,"end":false},{"code":"пұ…","page":81,"end":false},{"code":"пұҶ","page":81,"end":false},{"code":"пұҮ","page":81,"end":false},{"code":"пұҲ","page":81,"end":false},{"code":"пұү","page":81,"end":false},{"code":"пұҠ","page":81,"end":false},{"code":"пұӢ","page":81,"end":false},{"code":"пұҢ","page":81,"end":false},{"code":"пұҚпұҺ","page":81,"end":false},{"code":"пұҸ","page":81,"end":false},{"code":"пұҗ","page":81,"end":false},{"code":"пұ‘","page":81,"end":false},{"code":"пұ’","page":81,"end":false},{"code":"пұ“","page":81,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШҜШӘЩ‘ЩҸЩ…ЩҸ ЩұШіЩ’ШӘЩҗШЁЩ’ШҜЩҺШ§Щ„ЩҺ ШІЩҺЩҲЩ’Ш¬ЩҚЫў Щ…Щ‘ЩҺЩғЩҺШ§ЩҶЩҺ ШІЩҺЩҲЩ’Ш¬ЩҚЫў ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ШҘЩҗШӯЩ’ШҜЩҺЩүЩ°ЩҮЩҸЩҶЩ‘ЩҺ ЩӮЩҗЩҶШ·ЩҺШ§ШұЩӢЫӯШ§ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҸ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢШ§ Ыҡ ШЈЩҺШӘЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲЩҶЩҺЩҮЩҸЫҘ ШЁЩҸЩҮЩ’ШӘЩҺЩҖЩ°ЩҶЩӢЫӯШ§ ЩҲЩҺШҘЩҗШ«Щ’Щ…ЩӢЫӯШ§ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩӢЫӯШ§"},{"key":"4:21","surah":4,"ayah":21,"num":514,"page":81,"words":[{"code":"пұ”","page":81,"end":false},{"code":"пұ•","page":81,"end":false},{"code":"пұ–","page":81,"end":false},{"code":"пұ—","page":81,"end":false},{"code":"пұҳ","page":81,"end":false},{"code":"пұҷ","page":81,"end":false},{"code":"пұҡ","page":81,"end":false},{"code":"пұӣ","page":81,"end":false},{"code":"пұң","page":81,"end":false},{"code":"пұқ","page":81,"end":false},{"code":"пұһ","page":81,"end":false},{"code":"пұҹ","page":81,"end":true}],"text":"ЩҲЩҺЩғЩҺЩҠЩ’ЩҒЩҺ ШӘЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲЩҶЩҺЩҮЩҸЫҘ ЩҲЩҺЩӮЩҺШҜЩ’ ШЈЩҺЩҒЩ’Ш¶ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҸЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў ЩҲЩҺШЈЩҺШ®ЩҺШ°Щ’ЩҶЩҺ Щ…ЩҗЩҶЩғЩҸЩ… Щ…Щ‘ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩӢШ§ ШәЩҺЩ„ЩҗЩҠШёЩӢЫӯШ§"},{"key":"4:22","surah":4,"ayah":22,"num":515,"page":81,"words":[{"code":"пұ ","page":81,"end":false},{"code":"пұЎ","page":81,"end":false},{"code":"пұў","page":81,"end":false},{"code":"пұЈ","page":81,"end":false},{"code":"пұӨ","page":81,"end":false},{"code":"пұҘ","page":81,"end":false},{"code":"пұҰ","page":81,"end":false},{"code":"пұ§","page":81,"end":false},{"code":"пұЁ","page":81,"end":false},{"code":"пұ©","page":81,"end":false},{"code":"пұӘпұ«","page":81,"end":false},{"code":"пұ¬","page":81,"end":false},{"code":"пұӯ","page":81,"end":false},{"code":"пұ®","page":81,"end":false},{"code":"пұҜ","page":81,"end":false},{"code":"пұ°","page":81,"end":false},{"code":"пұұ","page":81,"end":false},{"code":"пұІ","page":81,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩҶЩғЩҗШӯЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩҶЩҺЩғЩҺШӯЩҺ ШЎЩҺШ§ШЁЩҺШ§Щ“ШӨЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ЩӮЩҺШҜЩ’ ШіЩҺЩ„ЩҺЩҒЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩғЩҺШ§ЩҶЩҺ ЩҒЩҺЩҖЩ°ШӯЩҗШҙЩҺШ©ЩӢЫӯ ЩҲЩҺЩ…ЩҺЩӮЩ’ШӘЩӢЫӯШ§ ЩҲЩҺШіЩҺШ§Щ“ШЎЩҺ ШіЩҺШЁЩҗЩҠЩ„ЩӢШ§"},{"key":"4:23","surah":4,"ayah":23,"num":516,"page":81,"words":[{"code":"пұі","page":81,"end":false},{"code":"пұҙ","page":81,"end":false},{"code":"пұө","page":81,"end":false},{"code":"пұ¶","page":81,"end":false},{"code":"пұ·","page":81,"end":false},{"code":"пұё","page":81,"end":false},{"code":"пұ№","page":81,"end":false},{"code":"пұә","page":81,"end":false},{"code":"пұ»","page":81,"end":false},{"code":"пұј","page":81,"end":false},{"code":"пұҪ","page":81,"end":false},{"code":"пұҫ","page":81,"end":false},{"code":"пұҝ","page":81,"end":false},{"code":"пІҖ","page":81,"end":false},{"code":"пІҒ","page":81,"end":false},{"code":"пІӮ","page":81,"end":false},{"code":"пІғ","page":81,"end":false},{"code":"пІ„","page":81,"end":false},{"code":"пІ…","page":81,"end":false},{"code":"пІҶ","page":81,"end":false},{"code":"пІҮ","page":81,"end":false},{"code":"пІҲ","page":81,"end":false},{"code":"пІү","page":81,"end":false},{"code":"пІҠ","page":81,"end":false},{"code":"пІӢ","page":81,"end":false},{"code":"пІҢ","page":81,"end":false},{"code":"пІҚ","page":81,"end":false},{"code":"пІҺ","page":81,"end":false},{"code":"пІҸ","page":81,"end":false},{"code":"пІҗ","page":81,"end":false},{"code":"пІ‘","page":81,"end":false},{"code":"пІ’","page":81,"end":false},{"code":"пІ“","page":81,"end":false},{"code":"пІ”","page":81,"end":false},{"code":"пІ•","page":81,"end":false},{"code":"пІ–","page":81,"end":false},{"code":"пІ—","page":81,"end":false},{"code":"пІҳ","page":81,"end":false},{"code":"пІҷ","page":81,"end":false},{"code":"пІҡ","page":81,"end":false},{"code":"пІӣ","page":81,"end":false},{"code":"пІң","page":81,"end":false},{"code":"пІқ","page":81,"end":false},{"code":"пІһ","page":81,"end":false},{"code":"пІҹ","page":81,"end":false},{"code":"пІ ","page":81,"end":false},{"code":"пІЎ","page":81,"end":false},{"code":"пІў","page":81,"end":false},{"code":"пІЈпІӨ","page":81,"end":false},{"code":"пІҘ","page":81,"end":false},{"code":"пІҰ","page":81,"end":false},{"code":"пІ§","page":81,"end":false},{"code":"пІЁ","page":81,"end":false},{"code":"пІ©","page":81,"end":false},{"code":"пІӘ","page":81,"end":true}],"text":"ШӯЩҸШұЩ‘ЩҗЩ…ЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЈЩҸЩ…Щ‘ЩҺЩҮЩҺЩҖЩ°ШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЁЩҺЩҶЩҺШ§ШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШ®ЩҺЩҲЩҺЩ°ШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШ№ЩҺЩ…Щ‘ЩҺЩҖЩ°ШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШ®ЩҺЩҖЩ°Щ„ЩҺЩҖЩ°ШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЁЩҺЩҶЩҺШ§ШӘЩҸ ЩұЩ„Щ’ШЈЩҺШ®Щҗ ЩҲЩҺШЁЩҺЩҶЩҺШ§ШӘЩҸ ЩұЩ„Щ’ШЈЩҸШ®Щ’ШӘЩҗ ЩҲЩҺШЈЩҸЩ…Щ‘ЩҺЩҮЩҺЩҖЩ°ШӘЩҸЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺЩҖЩ°ШӘЩҗЩүЩ“ ШЈЩҺШұЩ’Ш¶ЩҺШ№Щ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШ®ЩҺЩҲЩҺЩ°ШӘЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺШ¶ЩҺЩҖЩ°Ш№ЩҺШ©Щҗ ЩҲЩҺШЈЩҸЩ…Щ‘ЩҺЩҮЩҺЩҖЩ°ШӘЩҸ ЩҶЩҗШіЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШұЩҺШЁЩҺЩҖЩ°Щ“ШҰЩҗШЁЩҸЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺЩҖЩ°ШӘЩҗЩү ЩҒЩҗЩү ШӯЩҸШ¬ЩҸЩҲШұЩҗЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺЩҖЩ°ШӘЩҗЩү ШҜЩҺШ®ЩҺЩ„Щ’ШӘЩҸЩ… ШЁЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҒЩҺШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ШҜЩҺШ®ЩҺЩ„Щ’ШӘЩҸЩ… ШЁЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҒЩҺЩ„ЩҺШ§ Ш¬ЩҸЩҶЩҺШ§ШӯЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺШӯЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩ„ЩҸ ШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺШөЩ’Щ„ЩҺЩҖЩ°ШЁЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶ ШӘЩҺШ¬Щ’Щ…ЩҺШ№ЩҸЩҲШ§Ыҹ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„Щ’ШЈЩҸШ®Щ’ШӘЩҺЩҠЩ’ЩҶЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ЩӮЩҺШҜЩ’ ШіЩҺЩ„ЩҺЩҒЩҺ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ ШәЩҺЩҒЩҸЩҲШұЩӢЫӯШ§ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩӢЫӯШ§"}]}
e":"піҠ","end":false},{"code":"піӢ","end":false}]},{"lineNumber":15,"words":[{"code":"піҢ","end":false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗпі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":true}]}],"verses":[{"key":"25:44","surah":25,"ayah":44,"num":2899,"page":364,"words":[{"code":"пұҒ","page":364,"end":false},{"code":"пұӮ","page":364,"end":false},{"code":"пұғ","page":364,"end":false},{"code":"пұ„","page":364,"end":false},{"code":"пұ…","page":364,"end":false},{"code":"пұҶ","page":364,"end":false},{"code":"пұҮпұҲ","page":364,"end":false},{"code":"пұү","page":364,"end":false},{"code":"пұҠ","page":364,"end":false},{"code":"пұӢ","page":364,"end":false},{"code":"пұҢ","page":364,"end":false},{"code":"пұҚ","page":364,"end":false},{"code":"пұҺ","page":364,"end":false},{"code":"пұҸ","page":364,"end":false},{"code":"пұҗ","page":364,"end":false},{"code":"пұ‘","page":364,"end":true}],"text":"ШЈЩҺЩ…Щ’ ШӘЩҺШӯЩ’ШіЩҺШЁЩҸ ШЈЩҺЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҸЩҲЩҶЩҺ ШЈЩҺЩҲЩ’ ЩҠЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ Ыҡ ШҘЩҗЩҶЩ’ ЩҮЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҺЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ Ы– ШЁЩҺЩ„Щ’ ЩҮЩҸЩ…Щ’ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҸ ШіЩҺШЁЩҗЩҠЩ„ЩӢШ§"},{"key":"25:45","surah":25,"ayah":45,"num":2900,"page":364,"words":[{"code":"пұ’","page":364,"end":false},{"code":"пұ“","page":364,"end":false},{"code":"пұ”","page":364,"end":false},{"code":"пұ•","page":364,"end":false},{"code":"пұ–","page":364,"end":false},{"code":"пұ—","page":364,"end":false},{"code":"пұҳ","page":364,"end":false},{"code":"пұҷ","page":364,"end":false},{"code":"пұҡ","page":364,"end":false},{"code":"пұӣ","page":364,"end":false},{"code":"пұң","page":364,"end":false},{"code":"пұқ","page":364,"end":false},{"code":"пұһ","page":364,"end":false},{"code":"пұҹ","page":364,"end":false},{"code":"пұ ","page":364,"end":false},{"code":"пұЎ","page":364,"end":false},{"code":"пұў","page":364,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺ ШҘЩҗЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩғЩҺ ЩғЩҺЩҠЩ’ЩҒЩҺ Щ…ЩҺШҜЩ‘ЩҺ ЩұЩ„ШёЩ‘ЩҗЩ„Щ‘ЩҺ ЩҲЩҺЩ„ЩҺЩҲЩ’ ШҙЩҺШ§Щ“ШЎЩҺ Щ„ЩҺШ¬ЩҺШ№ЩҺЩ„ЩҺЩҮЩҸЫҘ ШіЩҺШ§ЩғЩҗЩҶЩӢЫӯШ§ Ш«ЩҸЩ…Щ‘ЩҺ Ш¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩұЩ„ШҙЩ‘ЩҺЩ…Щ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШҜЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"25:46","surah":25,"ayah":46,"num":2901,"page":364,"words":[{"code":"пұЈ","page":364,"end":false},{"code":"пұӨ","page":364,"end":false},{"code":"пұҘ","page":364,"end":false},{"code":"пұҰ","page":364,"end":false},{"code":"пұ§","page":364,"end":false},{"code":"пұЁ","page":364,"end":true}],"text":"Ш«ЩҸЩ…Щ‘ЩҺ ЩӮЩҺШЁЩҺШ¶Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ ЩӮЩҺШЁЩ’Ш¶ЩӢЫӯШ§ ЩҠЩҺШіЩҗЩҠШұЩӢЫӯШ§"},{"key":"25:47","surah":25,"ayah":47,"num":2902,"page":364,"words":[{"code":"пұ©","page":364,"end":false},{"code":"пұӘ","page":364,"end":false},{"code":"пұ«","page":364,"end":false},{"code":"пұ¬","page":364,"end":false},{"code":"пұӯ","page":364,"end":false},{"code":"пұ®","page":364,"end":false},{"code":"пұҜ","page":364,"end":false},{"code":"пұ°","page":364,"end":false},{"code":"пұұ","page":364,"end":false},{"code":"пұІ","page":364,"end":false},{"code":"пұі","page":364,"end":false},{"code":"пұҙ","page":364,"end":true}],"text":"ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш¬ЩҺШ№ЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„ЩҺ Щ„ЩҗШЁЩҺШ§ШіЩӢЫӯШ§ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҲЩ’Щ…ЩҺ ШіЩҸШЁЩҺШ§ШӘЩӢЫӯШ§ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„ЩҺ ЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҺ ЩҶЩҸШҙЩҸЩҲШұЩӢЫӯШ§"},{"key":"25:48","surah":25,"ayah":48,"num":2903,"page":364,"words":[{"code":"пұө","page":364,"end":false},{"code":"пұ¶","page":364,"end":false},{"code":"пұ·","page":364,"end":false},{"code":"пұё","page":364,"end":false},{"code":"пұ№","page":364,"end":false},{"code":"пұә","page":364,"end":false},{"code":"пұ»","page":364,"end":false},{"code":"пұјпұҪ","page":364,"end":false},{"code":"пұҫ","page":364,"end":false},{"code":"пұҝ","page":364,"end":false},{"code":"пІҖ","page":364,"end":false},{"code":"пІҒ","page":364,"end":false},{"code":"пІӮ","page":364,"end":false},{"code":"пІғ","page":364,"end":true}],"text":"ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШұЩ’ШіЩҺЩ„ЩҺ ЩұЩ„ШұЩ‘ЩҗЩҠЩҺЩҖЩ°ШӯЩҺ ШЁЩҸШҙЩ’ШұЩӢЫўШ§ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩҠЩҺШҜЩҺЩүЩ’ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ Щ…ЩҺШ§Щ“ШЎЩӢЫӯ Ш·ЩҺЩҮЩҸЩҲШұЩӢЫӯШ§"},{"key":"25:49","surah":25,"ayah":49,"num":2904,"page":364,"words":[{"code":"пІ„","page":364,"end":false},{"code":"пІ…","page":364,"end":false},{"code":"пІҶ","page":364,"end":false},{"code":"пІҮ","page":364,"end":false},{"code":"пІҲ","page":364,"end":false},{"code":"пІү","page":364,"end":false},{"code":"пІҠ","page":364,"end":false},{"code":"пІӢ","page":364,"end":false},{"code":"пІҢ","page":364,"end":false},{"code":"пІҚ","page":364,"end":false},{"code":"пІҺ","page":364,"end":true}],"text":"Щ„Щ‘ЩҗЩҶЩҸШӯЩ’ЩҖЫ§ЩҗЩүЩҺ ШЁЩҗЩҮЩҗЫҰ ШЁЩҺЩ„Щ’ШҜЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҺЩҠЩ’ШӘЩӢЫӯШ§ ЩҲЩҺЩҶЩҸШіЩ’ЩӮЩҗЩҠЩҺЩҮЩҸЫҘ Щ…ЩҗЩ…Щ‘ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺШ§Щ“ ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…ЩӢЫӯШ§ ЩҲЩҺШЈЩҺЩҶЩҺШ§ШіЩҗЩүЩ‘ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§"},{"key":"25:50","surah":25,"ayah":50,"num":2905,"page":364,"words":[{"code":"пІҸ","page":364,"end":false},{"code":"пІҗ","page":364,"end":false},{"code":"пІ‘","page":364,"end":false},{"code":"пІ’","page":364,"end":false},{"code":"пІ“","page":364,"end":false},{"code":"пІ”","page":364,"end":false},{"code":"пІ•","page":364,"end":false},{"code":"пІ–","page":364,"end":false},{"code":"пІ—","page":364,"end":false},{"code":"пІҳ","page":364,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШөЩҺШұЩ‘ЩҺЩҒЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…Щ’ Щ„ЩҗЩҠЩҺШ°Щ‘ЩҺЩғЩ‘ЩҺШұЩҸЩҲШ§Ыҹ ЩҒЩҺШЈЩҺШЁЩҺЩүЩ°Щ“ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҸЩҒЩҸЩҲШұЩӢЫӯШ§"},{"key":"25:51","surah":25,"ayah":51,"num":2906,"page":364,"words":[{"code":"пІҷ","page":364,"end":false},{"code":"пІҡ","page":364,"end":false},{"code":"пІӣ","page":364,"end":false},{"code":"пІң","page":364,"end":false},{"code":"пІқ","page":364,"end":false},{"code":"пІһ","page":364,"end":false},{"code":"пІҹ","page":364,"end":false},{"code":"пІ ","page":364,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ШҙЩҗШҰЩ’ЩҶЩҺШ§ Щ„ЩҺШЁЩҺШ№ЩҺШ«Щ’ЩҶЩҺШ§ ЩҒЩҗЩү ЩғЩҸЩ„Щ‘Щҗ ЩӮЩҺШұЩ’ЩҠЩҺШ©ЩҚЫў ЩҶЩ‘ЩҺШ°ЩҗЩҠШұЩӢЫӯШ§"},{"key":"25:52","surah":25,"ayah":52,"num":2907,"page":364,"words":[{"code":"пІЎ","page":364,"end":false},{"code":"пІў","page":364,"end":false},{"code":"пІЈ","page":364,"end":false},{"code":"пІӨ","page":364,"end":false},{"code":"пІҘ","page":364,"end":false},{"code":"пІҰ","page":364,"end":false},{"code":"пІ§","page":364,"end":false},{"code":"пІЁ","page":364,"end":true}],"text":"ЩҒЩҺЩ„ЩҺШ§ ШӘЩҸШ·ЩҗШ№Щҗ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩ’ЩҮЩҸЩ… ШЁЩҗЩҮЩҗЫҰ Ш¬ЩҗЩҮЩҺШ§ШҜЩӢЫӯШ§ ЩғЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"25:53","surah":25,"ayah":53,"num":2908,"page":364,"words":[{"code":"пІ© пІӘ","page":364,"end":false},{"code":"пІ«","page":364,"end":false},{"code":"пІ¬","page":364,"end":false},{"code":"пІӯ","page":364,"end":false},{"code":"пІ®","page":364,"end":false},{"code":"пІҜ","page":364,"end":false},{"code":"пІ°","page":364,"end":false},{"code":"пІұ","page":364,"end":false},{"code":"пІІ","page":364,"end":false},{"code":"пІі","page":364,"end":false},{"code":"пІҙ","page":364,"end":false},{"code":"пІө","page":364,"end":false},{"code":"пІ¶","page":364,"end":false},{"code":"пІ·","page":364,"end":false},{"code":"пІё","page":364,"end":false},{"code":"пІ№","page":364,"end":true}],"text":"Ыһ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Щ…ЩҺШұЩҺШ¬ЩҺ ЩұЩ„Щ’ШЁЩҺШӯЩ’ШұЩҺЩҠЩ’ЩҶЩҗ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Ш№ЩҺШ°Щ’ШЁЩҢЫӯ ЩҒЩҸШұЩҺШ§ШӘЩҢЫӯ ЩҲЩҺЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҗЩ„Щ’ШӯЩҢ ШЈЩҸШ¬ЩҺШ§Ш¬ЩҢЫӯ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„ЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§ ШЁЩҺШұЩ’ШІЩҺШ®ЩӢЫӯШ§ ЩҲЩҺШӯЩҗШ¬Щ’ШұЩӢЫӯШ§ Щ…Щ‘ЩҺШӯЩ’Ш¬ЩҸЩҲШұЩӢЫӯШ§"},{"key":"25:54","surah":25,"ayah":54,"num":2909,"page":364,"words":[{"code":"пІә","page":364,"end":false},{"code":"пІ»","page":364,"end":false},{"code":"пІј","page":364,"end":false},{"code":"пІҪ","page":364,"end":false},{"code":"пІҫ","page":364,"end":false},{"code":"пІҝ","page":364,"end":false},{"code":"піҖ","page":364,"end":false},{"code":"піҒ","page":364,"end":false},{"code":"піӮпіғ","page":364,"end":false},{"code":"пі„","page":364,"end":false},{"code":"пі…","page":364,"end":false},{"code":"піҶ","page":364,"end":false},{"code":"піҮ","page":364,"end":true}],"text":"ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺШ§Щ“ШЎЩҗ ШЁЩҺШҙЩҺШұЩӢЫӯШ§ ЩҒЩҺШ¬ЩҺШ№ЩҺЩ„ЩҺЩҮЩҸЫҘ ЩҶЩҺШіЩҺШЁЩӢЫӯШ§ ЩҲЩҺШөЩҗЩҮЩ’ШұЩӢЫӯШ§ Ы— ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ШұЩҺШЁЩ‘ЩҸЩғЩҺ ЩӮЩҺШҜЩҗЩҠШұЩӢЫӯШ§"},{"key":"25:55","surah":25,"ayah":55,"num":2910,"page":364,"words":[{"code":"піҲ","page":364,"end":false},{"code":"піү","page":364,"end":false},{"code":"піҠ","page":364,"end":false},{"code":"піӢ","page":364,"end":false},{"code":"піҢ","page":364,"end":false},{"code":"піҚ","page":364,"end":false},{"code":"піҺ","page":364,"end":false},{"code":"піҸ","page":364,"end":false},{"code":"піҗпі‘","page":364,"end":false},{"code":"пі’","page":364,"end":false},{"code":"пі“","page":364,"end":false},{"code":"пі”","page":364,"end":false},{"code":"пі•","page":364,"end":false},{"code":"пі–","page":364,"end":false},{"code":"пі—","page":364,"end":true}],"text":"ЩҲЩҺЩҠЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ Щ„ЩҺШ§ ЩҠЩҺЩҶЩҒЩҺШ№ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ¶ЩҸШұЩ‘ЩҸЩҮЩҸЩ…Щ’ Ы— ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ’ЩғЩҺШ§ЩҒЩҗШұЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ ШёЩҺЩҮЩҗЩҠШұЩӢЫӯШ§"}]}
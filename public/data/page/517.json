Щ‘ЩҺШіЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШәЩ’ШӘЩҺШЁ ШЁЩ‘ЩҺШ№Щ’Ш¶ЩҸЩғЩҸЩ… ШЁЩҺШ№Щ’Ш¶ЩӢШ§ Ыҡ ШЈЩҺЩҠЩҸШӯЩҗШЁЩ‘ЩҸ ШЈЩҺШӯЩҺШҜЩҸЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ЩҠЩҺШЈЩ’ЩғЩҸЩ„ЩҺ Щ„ЩҺШӯЩ’Щ…ЩҺ ШЈЩҺШ®ЩҗЩҠЩҮЩҗ Щ…ЩҺЩҠЩ’ШӘЩӢЫӯШ§ ЩҒЩҺЩғЩҺШұЩҗЩҮЩ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҸ Ыҡ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШӘЩҺЩҲЩ‘ЩҺШ§ШЁЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"49:13","surah":49,"ayah":13,"num":4625,"page":517,"words":[{"code":"пұҘ","page":517,"end":false},{"code":"пұҰ","page":517,"end":false},{"code":"пұ§","page":517,"end":false},{"code":"пұЁ","page":517,"end":false},{"code":"пұ©","page":517,"end":false},{"code":"пұӘ","page":517,"end":false},{"code":"пұ«","page":517,"end":false},{"code":"пұ¬","page":517,"end":false},{"code":"пұӯ","page":517,"end":false},{"code":"пұ®","page":517,"end":false},{"code":"пұҜпұ°","page":517,"end":false},{"code":"пұұ","page":517,"end":false},{"code":"пұІ","page":517,"end":false},{"code":"пұі","page":517,"end":false},{"code":"пұҙ","page":517,"end":false},{"code":"пұөпұ¶","page":517,"end":false},{"code":"пұ·","page":517,"end":false},{"code":"пұё","page":517,"end":false},{"code":"пұ№","page":517,"end":false},{"code":"пұә","page":517,"end":false},{"code":"пұ»","page":517,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ШҘЩҗЩҶЩ‘ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ Ш°ЩҺЩғЩҺШұЩҚЫў ЩҲЩҺШЈЩҸЩҶШ«ЩҺЩүЩ° ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ…Щ’ ШҙЩҸШ№ЩҸЩҲШЁЩӢЫӯШ§ ЩҲЩҺЩӮЩҺШЁЩҺШ§Щ“ШҰЩҗЩ„ЩҺ Щ„ЩҗШӘЩҺШ№ЩҺШ§ШұЩҺЩҒЩҸЩҲЩ“Ш§Ыҹ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’ШұЩҺЩ…ЩҺЩғЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺШӘЩ’ЩӮЩҺЩүЩ°ЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ Ш®ЩҺШЁЩҗЩҠШұЩҢЫӯ"},{"key":"49:14","surah":49,"ayah":14,"num":4626,"page":517,"words":[{"code":"пұј пұҪ","page":517,"end":false},{"code":"пұҫ","page":517,"end":false},{"code":"пұҝпІҖ","page":517,"end":false},{"code":"пІҒ","page":517,"end":false},{"code":"пІӮ","page":517,"end":false},{"code":"пІғ","page":517,"end":false},{"code":"пІ„","page":517,"end":false},{"code":"пІ…","page":517,"end":false},{"code":"пІҶ","page":517,
de":"пұ—","page":316,"end":false},{"code":"пұҳ","page":316,"end":false},{"code":"пұҷ","page":316,"end":false},{"code":"пұҡ","page":316,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШЁЩҺЩ„Щ’ ШЈЩҺЩ„Щ’ЩӮЩҸЩҲШ§Ыҹ Ы– ЩҒЩҺШҘЩҗШ°ЩҺШ§ ШӯЩҗШЁЩҺШ§Щ„ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШ№ЩҗШөЩҗЩҠЩ‘ЩҸЩҮЩҸЩ…Щ’ ЩҠЩҸШ®ЩҺЩҠЩ‘ЩҺЩ„ЩҸ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ Щ…ЩҗЩҶ ШіЩҗШӯЩ’ШұЩҗЩҮЩҗЩ…Щ’ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҺШ§ ШӘЩҺШіЩ’Ш№ЩҺЩүЩ°"},{"key":"20:67","surah":20,"ayah":67,"num":2415,"page":316,"words":[{"code":"пұӣ","page":316,"end":false},{"code":"пұң","page":316,"end":false},{"code":"пұқ","page":316,"end":false},{"code":"пұһ","page":316,"end":false},{"code":"пұҹ","page":316,"end":false},{"code":"пұ ","page":316,"end":true}],"text":"ЩҒЩҺШЈЩҺЩҲЩ’Ш¬ЩҺШіЩҺ ЩҒЩҗЩү ЩҶЩҺЩҒЩ’ШіЩҗЩҮЩҗЫҰ Ш®ЩҗЩҠЩҒЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҸЩҲШіЩҺЩүЩ°"},{"key":"20:68","surah":20,"ayah":68,"num":2416,"page":316,"words":[{"code":"пұЎ","page":316,"end":false},{"code":"пұў","page":316,"end":false},{"code":"пұЈ","page":316,"end":false},{"code":"пұӨ","page":316,"end":false},{"code":"пұҘ","page":316,"end":false},{"code":"пұҰ","page":316,"end":false},{"code":"пұ§","page":316,"end":true}],"text":"ЩӮЩҸЩ„Щ’ЩҶЩҺШ§ Щ„ЩҺШ§ ШӘЩҺШ®ЩҺЩҒЩ’ ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ ШЈЩҺЩҶШӘЩҺ ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ„ЩҺЩүЩ°"},{"key":"20:69","surah":20,"ayah":69,"num":2417,"page":316,"words":[{"code":"пұЁ","page":316,"end":false},{"code":"пұ©","page":316,"end":false},{"code":"пұӘ","page":316,"end":false},{"code":"пұ«","page":316,"end":false},{"code":"пұ¬","page":316,"end":false},{"code":"пұӯ","page":316,"end":false},{"code":"пұ®пұҜ","page":316,"end":false},{"code":"пұ°","page":316,"end":false},{"code":"пұұ","page":316,"end":false},{"code":"пұІ","page":316,"end":false},{"code":"пұіпұҙ","page":316,"end":false},{"code":"пұө","page":316,"end":false},{"code":"пұ¶","page":316,"end":false},{"code":"пұ·","page":316,"end":false},{"code":"пұё","page":316,"end":false},{"code":"пұ№","page":316,"end":false},{"code":"пұә","page":316,"end":true}],"text":"ЩҲЩҺШЈЩҺЩ„Щ’ЩӮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩҠЩҺЩ…ЩҗЩҠЩҶЩҗЩғЩҺ ШӘЩҺЩ„Щ’ЩӮЩҺЩҒЩ’ Щ…ЩҺШ§ ШөЩҺЩҶЩҺШ№ЩҸЩҲЩ“Ш§Ыҹ Ы–
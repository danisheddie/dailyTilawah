":14,"words":[{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":true},{"code":"піҷ","end":false},{"code":"піҡ","end":false}]},{"lineNumber":15,"words":[{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹпі ","end":false},{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈ","end":false},{"code":"піӨ","end":false},{"code":"піҘ","end":true}]}],"verses":[{"key":"31:20","surah":31,"ayah":20,"num":3489,"page":413,"words":[{"code":"пұҒ","page":413,"end":false},{"code":"пұӮ","page":413,"end":false},{"code":"пұғ","page":413,"end":false},{"code":"пұ„","page":413,"end":false},{"code":"пұ…","page":413,"end":false},{"code":"пұҶ","page":413,"end":false},{"code":"пұҮ","page":413,"end":false},{"code":"пұҲ","page":413,"end":false},{"code":"пұү","page":413,"end":false},{"code":"пұҠ","page":413,"end":false},{"code":"пұӢ","page":413,"end":false},{"code":"пұҢ","page":413,"end":false},{"code":"пұҚ","page":413,"end":false},{"code":"пұҺ","page":413,"end":false},{"code":"пұҸ","page":413,"end":false},{"code":"пұҗ","page":413,"end":false},{"code":"пұ‘пұ’","page":413,"end":false},{"code":"пұ“","page":413,"end":false},{"code":"пұ”","page":413,"end":false},{"code":"пұ•","page":413,"end":false},{"code":"пұ–","page":413,"end":false},{"code":"пұ—","page":413,"end":false},{"code":"пұҳ","page":413,"end":false},{"code":"пұҷ","page":413,"end":false},{"code":"пұҡ","page":413,"end":false},{"code":"пұӣ","page":413,"end":false},{"code":"пұң","page":413,"end":false},{"code":"пұқ","page":413,"end":false},{"code":"пұһ","page":413,"end":false},{"code":"пұҹ","page":413,"end":false},{"code":"пұ ","page":413,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШіЩҺШ®Щ‘ЩҺШұЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺШЈЩҺШіЩ’ШЁЩҺШәЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҶЩҗШ№ЩҺЩ…ЩҺЩҮЩҸЫҘ ШёЩҺЩҖЩ°ЩҮЩҗШұЩҺШ©ЩӢЫӯ ЩҲЩҺШЁЩҺШ§Ш·ЩҗЩҶЩҺШ©ЩӢЫӯ Ы— ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ…ЩҺЩҶ ЩҠЩҸШ¬ЩҺЩҖЩ°ШҜЩҗЩ„ЩҸ ЩҒЩҗЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ Ш№ЩҗЩ„Щ’Щ…ЩҚЫў ЩҲЩҺЩ„ЩҺШ§ ЩҮЩҸШҜЩӢЫӯЩү ЩҲЩҺЩ„ЩҺШ§ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҚЫў Щ…Щ‘ЩҸЩҶЩҗЩҠШұЩҚЫў"},{"key":"31:21","surah":31,"ayah":21,"num":3490,"page":413,"words":[{"code":"пұЎ","page":413,"end":false},{"code":"пұў","page":413,"end":false},{"code":"пұЈ","page":413,"end":false},{"code":"пұӨ","page":413,"end":false},{"code":"пұҘ","page":413,"end":false},{"code":"пұҰ","page":413,"end":false},{"code":"пұ§","page":413,"end":false},{"code":"пұЁ","page":413,"end":false},{"code":"пұ©","page":413,"end":false},{"code":"пұӘ","page":413,"end":false},{"code":"пұ«","page":413,"end":false},{"code":"пұ¬","page":413,"end":false},{"code":"пұӯ","page":413,"end":false},{"code":"пұ®пұҜ","page":413,"end":false},{"code":"пұ°","page":413,"end":false},{"code":"пұұ","page":413,"end":false},{"code":"пұІ","page":413,"end":false},{"code":"пұі","page":413,"end":false},{"code":"пұҙ","page":413,"end":false},{"code":"пұө","page":413,"end":false},{"code":"пұ¶","page":413,"end":false},{"code":"пұ·","page":413,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШЁЩҺЩ„Щ’ ЩҶЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸ Щ…ЩҺШ§ ЩҲЩҺШ¬ЩҺШҜЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЎЩҺШ§ШЁЩҺШ§Щ“ШЎЩҺЩҶЩҺШ§Щ“ Ыҡ ШЈЩҺЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ ЩҠЩҺШҜЩ’Ш№ЩҸЩҲЩҮЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„ШіЩ‘ЩҺШ№ЩҗЩҠШұЩҗ"},{"key":"31:22","surah":31,"ayah":22,"num":3491,"page":413,"words":[{"code":"пұё пұ№","page":413,"end":false},{"code":"пұә","page":413,"end":false},{"code":"пұ»","page":413,"end":false},{"code":"пұј","page":413,"end":false},{"code":"пұҪ","page":413,"end":false},{"code":"пұҫ","page":413,"end":false},{"code":"пұҝ","page":413,"end":false},{"code":"пІҖ","page":413,"end":false},{"code":"пІҒ","page":413,"end":false},{"code":"пІӮ","page":413,"end":false},{"code":"пІғпІ„","page":413,"end":false},{"code":"пІ…","page":413,"end":false},{"code":"пІҶ","page":413,"end":false},{"code":"пІҮ","page":413,"end":false},{"code":"пІҲ","page":413,"end":false},{"code":"пІү","page":413,"end":true}],"text":"Ыһ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШіЩ’Щ„ЩҗЩ…Щ’ ЩҲЩҺШ¬Щ’ЩҮЩҺЩҮЩҸЫҘЩ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩҮЩҸЩҲЩҺ Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҢЫӯ ЩҒЩҺЩӮЩҺШҜЩҗ ЩұШіЩ’ШӘЩҺЩ…Щ’ШіЩҺЩғЩҺ ШЁЩҗЩұЩ„Щ’Ш№ЩҸШұЩ’ЩҲЩҺШ©Щҗ ЩұЩ„Щ’ЩҲЩҸШ«Щ’ЩӮЩҺЩүЩ° Ы— ЩҲЩҺШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШ©ЩҸ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҗ"},{"key":"31:23","surah":31,"ayah":23,"num":3492,"page":413,"words":[{"code":"пІҠ","page":413,"end":false},{"code":"пІӢ","page":413,"end":false},{"code":"пІҢ","page":413,"end":false},{"code":"пІҚ","page":413,"end":false},{"code":"пІҺпІҸ","page":413,"end":false},{"code":"пІҗ","page":413,"end":false},{"code":"пІ‘","page":413,"end":false},{"code":"пІ’","page":413,"end":false},{"code":"пІ“","page":413,"end":false},{"code":"пІ”пІ•","page":413,"end":false},{"code":"пІ–","page":413,"end":false},{"code":"пІ—","page":413,"end":false},{"code":"пІҳ","page":413,"end":false},{"code":"пІҷ","page":413,"end":false},{"code":"пІҡ","page":413,"end":false},{"code":"пІӣ","page":413,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩғЩҺЩҒЩҺШұЩҺ ЩҒЩҺЩ„ЩҺШ§ ЩҠЩҺШӯЩ’ШІЩҸЩҶЩғЩҺ ЩғЩҸЩҒЩ’ШұЩҸЩҮЩҸЫҘЩ“ Ыҡ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҮЩҸЩ…Щ’ ЩҒЩҺЩҶЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҸЩҲЩ“Ш§Ыҹ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗШ°ЩҺШ§ШӘЩҗ ЩұЩ„ШөЩ‘ЩҸШҜЩҸЩҲШұЩҗ"},{"key":"31:24","surah":31,"ayah":24,"num":3493,"page":413,"words":[{"code":"пІң","page":413,"end":false},{"code":"пІқ","page":413,"end":false},{"code":"пІһ","page":413,"end":false},{"code":"пІҹ","page":413,"end":false},{"code":"пІ ","page":413,"end":false},{"code":"пІЎ","page":413,"end":false},{"code":"пІў","page":413,"end":false},{"code":"пІЈ","page":413,"end":true}],"text":"ЩҶЩҸЩ…ЩҺШӘЩ‘ЩҗШ№ЩҸЩҮЩҸЩ…Щ’ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ Ш«ЩҸЩ…Щ‘ЩҺ ЩҶЩҺШ¶Щ’Ш·ЩҺШұЩ‘ЩҸЩҮЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° Ш№ЩҺШ°ЩҺШ§ШЁЩҚ ШәЩҺЩ„ЩҗЩҠШёЩҚЫў"},{"key":"31:25","surah":31,"ayah":25,"num":3494,"page":413,"words":[{"code":"пІӨ","page":413,"end":false},{"code":"пІҘ","page":413,"end":false},{"code":"пІҰ","page":413,"end":false},{"code":"пІ§","page":413,"end":false},{"code":"пІЁ","page":413,"end":false},{"code":"пІ©","page":413,"end":false},{"code":"пІӘ","page":413,"end":false},{"code":"пІ«пІ¬","page":413,"end":false},{"code":"пІӯ","page":413,"end":false},{"code":"пІ®","page":413,"end":false},{"code":"пІҜпІ°","page":413,"end":false},{"code":"пІұ","page":413,"end":false},{"code":"пІІ","page":413,"end":false},{"code":"пІі","page":413,"end":false},{"code":"пІҙ","page":413,"end":false},{"code":"пІө","page":413,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШҰЩҗЩҶ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶЩ’ Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ Щ„ЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩӮЩҸЩ„Щҗ ЩұЩ„Щ’ШӯЩҺЩ…Щ’ШҜЩҸ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Ыҡ ШЁЩҺЩ„Щ’ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҸЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"31:26","surah":31,"ayah":26,"num":3495,"page":413,"words":[{"code":"пІ¶","page":413,"end":false},{"code":"пІ·","page":413,"end":false},{"code":"пІё","page":413,"end":false},{"code":"пІ№","page":413,"end":false},{"code":"пІәпІ»","page":413,"end":false},{"code":"пІј","page":413,"end":false},{"code":"пІҪ","page":413,"end":false},{"code":"пІҫ","page":413,"end":false},{"code":"пІҝ","page":413,"end":false},{"code":"піҖ","page":413,"end":false},{"code":"піҒ","page":413,"end":true}],"text":"Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ШәЩҺЩҶЩҗЩүЩ‘ЩҸ ЩұЩ„Щ’ШӯЩҺЩ…ЩҗЩҠШҜЩҸ"},{"key":"31:27","surah":31,"ayah":27,"num":3496,"page":413,"words":[{"code":"піӮ","page":413,"end":false},{"code":"піғ","page":413,"end":false},{"code":"пі„","page":413,"end":false},{"code":"пі…","page":413,"end":false},{"code":"піҶ","page":413,"end":false},{"code":"піҮ","page":413,"end":false},{"code":"піҲ","page":413,"end":false},{"code":"піү",
‘","page":144,"end":false},{"code":"пІ’","page":144,"end":false},{"code":"пІ“","page":144,"end":false},{"code":"пІ”","page":144,"end":false},{"code":"пІ•","page":144,"end":false},{"code":"пІ–","page":144,"end":false},{"code":"пІ—","page":144,"end":false},{"code":"пІҳпІҷ","page":144,"end":false},{"code":"пІҡ","page":144,"end":false},{"code":"пІӣ","page":144,"end":false},{"code":"пІң","page":144,"end":false},{"code":"пІқ","page":144,"end":false},{"code":"пІһ","page":144,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШӯЩ’ШҙЩҸШұЩҸЩҮЩҸЩ…Щ’ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ ЩҠЩҺЩҖЩ°Щ…ЩҺШ№Щ’ШҙЩҺШұЩҺ ЩұЩ„Щ’Ш¬ЩҗЩҶЩ‘Щҗ ЩӮЩҺШҜЩҗ ЩұШіЩ’ШӘЩҺЩғЩ’Ш«ЩҺШұЩ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҗ Ы– ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШӨЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҗ ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§ ЩұШіЩ’ШӘЩҺЩ…Щ’ШӘЩҺШ№ЩҺ ШЁЩҺШ№Щ’Ш¶ЩҸЩҶЩҺШ§ ШЁЩҗШЁЩҺШ№Щ’Ш¶ЩҚЫў ЩҲЩҺШЁЩҺЩ„ЩҺШәЩ’ЩҶЩҺШ§Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҺЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШ¬Щ‘ЩҺЩ„Щ’ШӘЩҺ Щ„ЩҺЩҶЩҺШ§ Ыҡ ЩӮЩҺШ§Щ„ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҸ Щ…ЩҺШ«Щ’ЩҲЩҺЩүЩ°ЩғЩҸЩ…Щ’ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы— ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ШӯЩҺЩғЩҗЩҠЩ…ЩҢ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"6:129","surah":6,"ayah":129,"num":918,"page":144,"words":[{"code":"пІҹ","page":144,"end":false},{"code":"пІ ","page":144,"end":false},{"code":"пІЎ","page":144,"end":false},{"code":"пІў","page":144,"end":false},{"code":"пІЈ","page":144,"end":false},{"code":"пІӨ","page":144,"end":false},{"code":"пІҘ","page":144,"end":false},{"code":"пІҰ","page":144,"end":false},{"code":"пІ§","page":144,"end":true}],"text":"ЩҲЩҺЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҶЩҸЩҲЩҺЩ„Щ‘ЩҗЩү ШЁЩҺШ№Щ’Ш¶ЩҺ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ ШЁЩҺШ№Щ’Ш¶ЩӢЫўШ§ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"6:130","surah":6,"ayah":130,"num":919,"page":144,"words":[{"code":"пІЁ","page":144,"end":false},{"code":"пІ©","page":144,"end":false},{"code":"пІӘ","page":144,"end":false},{"code":"пІ«","page":144,"end":false},{"code":"пІ¬","page":144,"end":false},{"code":"пІӯ","page":144,"end":false},{"code":"пІ®","page":144
e":"пІІ","page":357,"end":false},{"code":"пІі","page":357,"end":false},{"code":"пІҙ","page":357,"end":false},{"code":"пІө","page":357,"end":false},{"code":"пІ¶","page":357,"end":false},{"code":"пІ·пІё","page":357,"end":false},{"code":"пІ№","page":357,"end":false},{"code":"пІә","page":357,"end":false},{"code":"пІ»пІј","page":357,"end":false},{"code":"пІҪ","page":357,"end":false},{"code":"пІҫ","page":357,"end":false},{"code":"пІҝ","page":357,"end":false},{"code":"піҖ","page":357,"end":false},{"code":"піҒ","page":357,"end":false},{"code":"піӮпіғ","page":357,"end":false},{"code":"пі„","page":357,"end":false},{"code":"пі…","page":357,"end":false},{"code":"піҶ","page":357,"end":false},{"code":"піҮ","page":357,"end":false},{"code":"піҲпіү","page":357,"end":false},{"code":"піҠ","page":357,"end":false},{"code":"піӢ","page":357,"end":false},{"code":"піҢ","page":357,"end":false},{"code":"піҚ","page":357,"end":false},{"code":"піҺпіҸ","page":357,"end":false},{"code":"піҗ","page":357,"end":false},{"code":"пі‘","page":357,"end":false},{"code":"пі’","page":357,"end":false},{"code":"пі“","page":357,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҗЩҠЩҺШіЩ’ШӘЩҺЩҖЩ”Щ’Ш°ЩҗЩҶЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҺЩ„ЩҺЩғЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ…Щ’ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ„ЩҺЩ…Щ’ ЩҠЩҺШЁЩ’Щ„ЩҸШәЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШӯЩҸЩ„ЩҸЩ…ЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ш«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҺ Щ…ЩҺШұЩ‘ЩҺЩ°ШӘЩҚЫў Ыҡ Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШөЩҺЩ„ЩҺЩҲЩ°Ш©Щҗ ЩұЩ„Щ’ЩҒЩҺШ¬Щ’ШұЩҗ ЩҲЩҺШӯЩҗЩҠЩҶЩҺ ШӘЩҺШ¶ЩҺШ№ЩҸЩҲЩҶЩҺ Ш«ЩҗЩҠЩҺШ§ШЁЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШёЩ‘ЩҺЩҮЩҗЩҠШұЩҺШ©Щҗ ЩҲЩҺЩ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ ШөЩҺЩ„ЩҺЩҲЩ°Ш©Щҗ ЩұЩ„Щ’Ш№ЩҗШҙЩҺШ§Щ“ШЎЩҗ Ыҡ Ш«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҸ Ш№ЩҺЩҲЩ’ШұЩҺЩ°ШӘЩҚЫў Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ыҡ Щ„ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ш¬ЩҸЩҶЩҺШ§ШӯЩҢЫў ШЁЩҺШ№Щ’ШҜЩҺЩҮЩҸЩҶЩ‘ЩҺ Ыҡ Ш·ЩҺЩҲЩ‘ЩҺЩ°ЩҒЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… ШЁЩҺШ№Щ’Ш¶ЩҸЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"}]}
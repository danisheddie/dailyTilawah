Ә","page":439,"end":false},{"code":"пІ«","page":439,"end":true}],"text":"ЩҲЩҺШЈЩҺЩӮЩ’ШіЩҺЩ…ЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш¬ЩҺЩҮЩ’ШҜЩҺ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺШҰЩҗЩҶ Ш¬ЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ЩҶЩҺШ°ЩҗЩҠШұЩҢЫӯ Щ„Щ‘ЩҺЩҠЩҺЩғЩҸЩҲЩҶЩҸЩҶЩ‘ЩҺ ШЈЩҺЩҮЩ’ШҜЩҺЩүЩ° Щ…ЩҗЩҶЩ’ ШҘЩҗШӯЩ’ШҜЩҺЩү ЩұЩ„Щ’ШЈЩҸЩ…ЩҺЩ…Щҗ Ы– ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ЩҶЩҺШ°ЩҗЩҠШұЩҢЫӯ Щ…Щ‘ЩҺШ§ ШІЩҺШ§ШҜЩҺЩҮЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҶЩҸЩҒЩҸЩҲШұЩӢШ§"},{"key":"35:43","surah":35,"ayah":43,"num":3703,"page":439,"words":[{"code":"пІ¬","page":439,"end":false},{"code":"пІӯ","page":439,"end":false},{"code":"пІ®","page":439,"end":false},{"code":"пІҜ","page":439,"end":false},{"code":"пІ°пІұ","page":439,"end":false},{"code":"пІІ","page":439,"end":false},{"code":"пІі","page":439,"end":false},{"code":"пІҙ","page":439,"end":false},{"code":"пІө","page":439,"end":false},{"code":"пІ¶","page":439,"end":false},{"code":"пІ·пІё","page":439,"end":false},{"code":"пІ№","page":439,"end":false},{"code":"пІә","page":439,"end":false},{"code":"пІ»","page":439,"end":false},{"code":"пІј","page":439,"end":false},{"code":"пІҪпІҫ","page":439,"end":false},{"code":"пІҝ","page":439,"end":false},{"code":"піҖ","page":439,"end":false},{"code":"піҒ","page":439,"end":false},{"code":"піӮ","page":439,"end":false},{"code":"піғпі„","page":439,"end":false},{"code":"пі…","page":439,"end":false},{"code":"піҶ","page":439,"end":false},{"code":"піҮ","page":439,"end":false},{"code":"піҲ","page":439,"end":false},{"code":"піү","page":439,"end":false},{"code":"піҠ","page":439,"end":true}],"text":"ЩұШіЩ’ШӘЩҗЩғЩ’ШЁЩҺШ§ШұЩӢЫӯШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ…ЩҺЩғЩ’ШұЩҺ ЩұЩ„ШіЩ‘ЩҺЩҠЩ‘ЩҗШҰЩҗ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШӯЩҗЩҠЩӮЩҸ ЩұЩ„Щ’Щ…ЩҺЩғЩ’ШұЩҸ ЩұЩ„ШіЩ‘ЩҺЩҠЩ‘ЩҗШҰЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҗШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЫҰ Ыҡ ЩҒЩҺЩҮЩҺЩ„Щ’ ЩҠЩҺЩҶШёЩҸШұЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ШіЩҸЩҶЩ‘ЩҺШӘЩҺ ЩұЩ„Щ’ШЈЩҺЩҲЩ‘ЩҺЩ„ЩҗЩҠЩҶЩҺ Ыҡ ЩҒЩҺЩ„ЩҺЩҶ ШӘЩҺШ¬ЩҗШҜЩҺ Щ„ЩҗШіЩҸЩҶЩ‘ЩҺШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҺШЁЩ’ШҜЩҗЩҠЩ„ЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺЩҶ ШӘЩҺШ¬ЩҗШҜЩҺ Щ„ЩҗШіЩҸЩҶЩ‘ЩҺШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҺШӯЩ’ЩҲЩҗЩҠЩ„ЩӢШ§"},{"key":"35:44"
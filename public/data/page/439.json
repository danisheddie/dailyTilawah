ode":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false}]},{"lineNumber":14,"words":[{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷпіҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":false}]},{"lineNumber":15,"words":[{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈ","end":false},{"code":"піӨ","end":false},{"code":"піҘпіҰ","end":false},{"code":"пі§","end":false},{"code":"піЁ","end":false},{"code":"пі©","end":false},{"code":"піӘ","end":false},{"code":"пі«","end":true}]}],"verses":[{"key":"35:39","surah":35,"ayah":39,"num":3699,"page":439,"words":[{"code":"пұҒ","page":439,"end":false},{"code":"пұӮ","page":439,"end":false},{"code":"пұғ","page":439,"end":false},{"code":"пұ„","page":439,"end":false},{"code":"пұ…","page":439,"end":false},{"code":"пұҶпұҮ","page":439,"end":false},{"code":"пұҲ","page":439,"end":false},{"code":"пұү","page":439,"end":false},{"code":"пұҠ","page":439,"end":false},{"code":"пұӢпұҢ","page":439,"end":false},{"code":"пұҚ","page":439,"end":false},{"code":"пұҺ","page":439,"end":false},{"code":"пұҸ","page":439,"end":false},{"code":"пұҗ","page":439,"end":false},{"code":"пұ‘","page":439,"end":false},{"code":"пұ’","page":439,"end":false},{"code":"пұ“","page":439,"end":false},{"code":"пұ”пұ•","page":439,"end":false},{"code":"пұ–","page":439,"end":false},{"code":"пұ—","page":439,"end":false},{"code":"пұҳ","page":439,"end":false},{"code":"пұҷ","page":439,"end":false},{"code":"пұҡ","page":439,"end":false},{"code":"пұӣ","page":439,"end":false},{"code":"пұң","page":439,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш¬ЩҺШ№ЩҺЩ„ЩҺЩғЩҸЩ…Щ’ Ш®ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩҒЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ЩҒЩҺЩ…ЩҺЩҶ ЩғЩҺЩҒЩҺШұЩҺ ЩҒЩҺШ№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩғЩҸЩҒЩ’ШұЩҸЩҮЩҸЫҘ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШІЩҗЩҠШҜЩҸ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ЩғЩҸЩҒЩ’ШұЩҸЩҮЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩӮЩ’ШӘЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШІЩҗЩҠШҜЩҸ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ЩғЩҸЩҒЩ’ШұЩҸЩҮЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш®ЩҺШіЩҺШ§ШұЩӢЫӯШ§"},{"key":"35:40","surah":35,"ayah":40,"num":3700,"page":439,"words":[{"code":"пұқ","page":439,"end":false},{"code":"пұһ","page":439,"end":false},{"code":"пұҹ","page":439,"end":false},{"code":"пұ ","page":439,"end":false},{"code":"пұЎ","page":439,"end":false},{"code":"пұў","page":439,"end":false},{"code":"пұЈ","page":439,"end":false},{"code":"пұӨ","page":439,"end":false},{"code":"пұҘ","page":439,"end":false},{"code":"пұҰ","page":439,"end":false},{"code":"пұ§","page":439,"end":false},{"code":"пұЁ","page":439,"end":false},{"code":"пұ©","page":439,"end":false},{"code":"пұӘ","page":439,"end":false},{"code":"пұ«","page":439,"end":false},{"code":"пұ¬","page":439,"end":false},{"code":"пұӯ","page":439,"end":false},{"code":"пұ®","page":439,"end":false},{"code":"пұҜ","page":439,"end":false},{"code":"пұ°","page":439,"end":false},{"code":"пұұ","page":439,"end":false},{"code":"пұІ","page":439,"end":false},{"code":"пұі","page":439,"end":false},{"code":"пұҙ","page":439,"end":false},{"code":"пұөпұ¶","page":439,"end":false},{"code":"пұ·","page":439,"end":false},{"code":"пұё","page":439,"end":false},{"code":"пұ№","page":439,"end":false},{"code":"пұә","page":439,"end":false},{"code":"пұ»","page":439,"end":false},{"code":"пұј","page":439,"end":false},{"code":"пұҪ","page":439,"end":false},{"code":"пұҫ","page":439,"end":false},{"code":"пұҝ","page":439,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШЈЩҺШұЩҺШЎЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ШҙЩҸШұЩҺЩғЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺШұЩҸЩҲЩҶЩҗЩү Щ…ЩҺШ§Ш°ЩҺШ§ Ш®ЩҺЩ„ЩҺЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҺЩ…Щ’ Щ„ЩҺЩҮЩҸЩ…Щ’ ШҙЩҗШұЩ’ЩғЩҢЫӯ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ШЈЩҺЩ…Щ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩӢЫӯШ§ ЩҒЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺШӘЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ Ыҡ ШЁЩҺЩ„Щ’ ШҘЩҗЩҶ ЩҠЩҺШ№ЩҗШҜЩҸ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩ
,{"code":"пұҚ","page":110,"end":false},{"code":"пұҺ","page":110,"end":false},{"code":"пұҸ","page":110,"end":false},{"code":"пұҗ","page":110,"end":false},{"code":"пұ‘","page":110,"end":false},{"code":"пұ’","page":110,"end":false},{"code":"пұ“пұ”","page":110,"end":false},{"code":"пұ•","page":110,"end":false},{"code":"пұ–","page":110,"end":false},{"code":"пұ—","page":110,"end":false},{"code":"пұҳ","page":110,"end":false},{"code":"пұҷ","page":110,"end":false},{"code":"пұҡ","page":110,"end":false},{"code":"пұӣ","page":110,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩҶЩҺШөЩҺЩҖЩ°ШұЩҺЩүЩ°Щ“ ШЈЩҺШ®ЩҺШ°Щ’ЩҶЩҺШ§ Щ…ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩҶЩҺШіЩҸЩҲШ§Ыҹ ШӯЩҺШёЩ‘ЩӢЫӯШ§ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ Ш°ЩҸЩғЩ‘ЩҗШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ЩҒЩҺШЈЩҺШәЩ’ШұЩҺЩҠЩ’ЩҶЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШҜЩҺШ§ЩҲЩҺШ©ЩҺ ЩҲЩҺЩұЩ„Щ’ШЁЩҺШәЩ’Ш¶ЩҺШ§Щ“ШЎЩҺ ШҘЩҗЩ„ЩҺЩүЩ° ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Ыҡ ЩҲЩҺШіЩҺЩҲЩ’ЩҒЩҺ ЩҠЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШөЩ’ЩҶЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"5:15","surah":5,"ayah":15,"num":684,"page":110,"words":[{"code":"пұң","page":110,"end":false},{"code":"пұқ","page":110,"end":false},{"code":"пұһ","page":110,"end":false},{"code":"пұҹ","page":110,"end":false},{"code":"пұ ","page":110,"end":false},{"code":"пұЎ","page":110,"end":false},{"code":"пұў","page":110,"end":false},{"code":"пұЈ","page":110,"end":false},{"code":"пұӨ","page":110,"end":false},{"code":"пұҘ","page":110,"end":false},{"code":"пұҰ","page":110,"end":false},{"code":"пұ§","page":110,"end":false},{"code":"пұЁ","page":110,"end":false},{"code":"пұ©","page":110,"end":false},{"code":"пұӘ","page":110,"end":false},{"code":"пұ«пұ¬","page":110,"end":false},{"code":"пұӯ","page":110,"end":false},{"code":"пұ®","page":110,"end":false},{"code":"пұҜ","page":110,"end":false},{"code":"пұ°","page":110,"end":false},{"code":"пұұ","page":110,"end":false},{"code":"пұІ","page":110,"end":false},{"code":"пұі","page":110,"end":false},{"code":"пұҙ","page":110,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҮЩ’Щ„ЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ ШұЩҺШіЩҸЩҲЩ„ЩҸЩҶЩҺШ§ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҸШ®Щ’ЩҒЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҲЩҺЩҠЩҺШ№Щ’ЩҒЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶ ЩғЩҺШ«ЩҗЩҠШұЩҚЫў Ыҡ ЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҶЩҸЩҲШұЩҢЫӯ ЩҲЩҺЩғЩҗШӘЩҺЩҖЩ°ШЁЩҢЫӯ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҢЫӯ"},{"key":"5:16","surah":5,"ayah":16,"num":685,"page":110,"words":[{"code":"пұө","page":110,"end":false},{"code":"пұ¶","page":110,"end":false},{"code":"пұ·","page":110,"end":false},{"code":"пұё","page":110,"end":false},{"code":"пұ№","page":110,"end":false},{"code":"пұә","page":110,"end":false},{"code":"пұ»","page":110,"end":false},{"code":"пұј","page":110,"end":false},{"code":"пұҪ","page":110,"end":false},{"code":"пұҫ","page":110,"end":false},{"code":"пұҝ","page":110,"end":false},{"code":"пІҖ","page":110,"end":false},{"code":"пІҒ","page":110,"end":false},{"code":"пІӮ","page":110,"end":false},{"code":"пІғ","page":110,"end":false},{"code":"пІ„","page":110,"end":false},{"code":"пІ…","page":110,"end":false},{"code":"пІҶ","page":110,"end":false},{"code":"пІҮ","page":110,"end":true}],"text":"ЩҠЩҺЩҮЩ’ШҜЩҗЩү ШЁЩҗЩҮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺЩҶЩҗ ЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҺ ШұЩҗШ¶Щ’ЩҲЩҺЩ°ЩҶЩҺЩҮЩҸЫҘ ШіЩҸШЁЩҸЩ„ЩҺ ЩұЩ„ШіЩ‘ЩҺЩ„ЩҺЩҖЩ°Щ…Щҗ ЩҲЩҺЩҠЩҸШ®Щ’ШұЩҗШ¬ЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШёЩ‘ЩҸЩ„ЩҸЩ…ЩҺЩҖЩ°ШӘЩҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҸЩҲШұЩҗ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° ШөЩҗШұЩҺЩ°Ш·ЩҚЫў Щ…Щ‘ЩҸШіЩ’ШӘЩҺЩӮЩҗЩҠЩ…ЩҚЫў"},{"key":"5:17","surah":5,"ayah":17,"num":686,"page":110,"words":[{"code":"пІҲ","page":110,"end":false},{"code":"пІү","page":110,"end":false},{"code":"пІҠ","page":110,"end":false},{"code":"пІӢ","page":110,"end":false},{"code":"пІҢ","page":110,"end":false},{"code":"пІҚ","page":110,"end":false},{"code":"пІҺ","page":110,"end":false},{"code":"пІҸ","page":110,"end":false},{"code":"пІҗ","page":110,"end":false},{"code":"пІ‘пІ’","page":110,"end":false},{"code":"пІ“","page":110,"end":false},{"code":"пІ”","page":110,"end":false},{"code":"пІ•","page":110,"end":false},{"code":"пІ–","page":110,"end":false},{"code":"пІ—","page":110,"end":false},{"code":"пІҳ","page":110,"end":false},{"code":"пІҷ","page":110,"end":false},{"code":"пІҡ","page":110,"end":false},{"code":"пІӣ","page":110,"end":false},{"code":"пІң","page":110,"end":false},{"code":"пІқ","page":110,"end":false},{"code":"пІһ","page":110,"end":false},{"code":"пІҹ","page":110,"end":false},{"code":"пІ ","page":110,"end":false},{"code":"пІЎ","page":110,"end":false},{"code":"пІў","page":110,"end":false},{"code":"пІЈ","page":110,"end":false},{"code":"пІӨпІҘ","page":110,"end":false},{"code":"пІҰ","page":110,"end":false},{"code":"пІ§","page":110,"end":false},{"code":"пІЁ","page":110,"end":false},{"code":"пІ©","page":110,"end":false},{"code":"пІӘ","page":110,"end":false},{"code":"пІ«пІ¬","page":110,"end":false},{"code":"пІӯ","page":110,"end":false},{"code":"пІ®","page":110,"end":false},{"code":"пІҜпІ°","page":110,"end":false},{"code":"пІұ","page":110,"end":false},{"code":"пІІ","page":110,"end":false},{"code":"пІі","page":110,"end":false},{"code":"пІҙ","page":110,"end":false},{"code":"пІө","page":110,"end":false},{"code":"пІ¶","page":110,"end":true}],"text":"Щ„Щ‘ЩҺЩӮЩҺШҜЩ’ ЩғЩҺЩҒЩҺШұЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Щ…ЩҺШіЩҗЩҠШӯЩҸ ЩұШЁЩ’ЩҶЩҸ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ Ыҡ ЩӮЩҸЩ„Щ’ ЩҒЩҺЩ…ЩҺЩҶ ЩҠЩҺЩ…Щ’Щ„ЩҗЩғЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢШ§ ШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺ ШЈЩҺЩҶ ЩҠЩҸЩҮЩ’Щ„ЩҗЩғЩҺ ЩұЩ„Щ’Щ…ЩҺШіЩҗЩҠШӯЩҺ ЩұШЁЩ’ЩҶЩҺ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ ЩҲЩҺШЈЩҸЩ…Щ‘ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ Ы— ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҸЩ„Щ’ЩғЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§ Ыҡ ЩҠЩҺШ®Щ’Щ„ЩҸЩӮЩҸ Щ…ЩҺШ§ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢЫӯ"}]}
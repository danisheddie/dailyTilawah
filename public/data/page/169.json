ЩҺШ§Щ„ЩҺ ШЁЩҗШҰЩ’ШіЩҺЩ…ЩҺШ§ Ш®ЩҺЩ„ЩҺЩҒЩ’ШӘЩҸЩ…ЩҸЩҲЩҶЩҗЩү Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗЩүЩ“ Ы– ШЈЩҺШ№ЩҺШ¬ЩҗЩ„Щ’ШӘЩҸЩ…Щ’ ШЈЩҺЩ…Щ’ШұЩҺ ШұЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ Ы– ЩҲЩҺШЈЩҺЩ„Щ’ЩӮЩҺЩү ЩұЩ„Щ’ШЈЩҺЩ„Щ’ЩҲЩҺШ§ШӯЩҺ ЩҲЩҺШЈЩҺШ®ЩҺШ°ЩҺ ШЁЩҗШұЩҺШЈЩ’ШіЩҗ ШЈЩҺШ®ЩҗЩҠЩҮЩҗ ЩҠЩҺШ¬ЩҸШұЩ‘ЩҸЩҮЩҸЫҘЩ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ Ыҡ ЩӮЩҺШ§Щ„ЩҺ ЩұШЁЩ’ЩҶЩҺ ШЈЩҸЩ…Щ‘ЩҺ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…ЩҺ ЩұШіЩ’ШӘЩҺШ¶Щ’Ш№ЩҺЩҒЩҸЩҲЩҶЩҗЩү ЩҲЩҺЩғЩҺШ§ШҜЩҸЩҲШ§Ыҹ ЩҠЩҺЩӮЩ’ШӘЩҸЩ„ЩҸЩҲЩҶЩҺЩҶЩҗЩү ЩҒЩҺЩ„ЩҺШ§ ШӘЩҸШҙЩ’Щ…ЩҗШӘЩ’ ШЁЩҗЩүЩҺ ЩұЩ„Щ’ШЈЩҺШ№Щ’ШҜЩҺШ§Щ“ШЎЩҺ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ¬Щ’Ш№ЩҺЩ„Щ’ЩҶЩҗЩү Щ…ЩҺШ№ЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"7:151","surah":7,"ayah":151,"num":1105,"page":169,"words":[{"code":"пұ¬","page":169,"end":false},{"code":"пұӯ","page":169,"end":false},{"code":"пұ®","page":169,"end":false},{"code":"пұҜ","page":169,"end":false},{"code":"пұ°","page":169,"end":false},{"code":"пұұ","page":169,"end":false},{"code":"пұІ","page":169,"end":false},{"code":"пұіпұҙ","page":169,"end":false},{"code":"пұө","page":169,"end":false},{"code":"пұ¶","page":169,"end":false},{"code":"пұ·","page":169,"end":false},{"code":"пұё","page":169,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘Щҗ ЩұШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҗЩү ЩҲЩҺЩ„ЩҗШЈЩҺШ®ЩҗЩү ЩҲЩҺШЈЩҺШҜЩ’Ш®ЩҗЩ„Щ’ЩҶЩҺШ§ ЩҒЩҗЩү ШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩғЩҺ Ы– ЩҲЩҺШЈЩҺЩҶШӘЩҺ ШЈЩҺШұЩ’ШӯЩҺЩ…ЩҸ ЩұЩ„ШұЩ‘ЩҺЩ°ШӯЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"7:152","surah":7,"ayah":152,"num":1106,"page":169,"words":[{"code":"пұ№","page":169,"end":false},{"code":"пұә","page":169,"end":false},{"code":"пұ»","page":169,"end":false},{"code":"пұј","page":169,"end":false},{"code":"пұҪ","page":169,"end":false},{"code":"пұҫ","page":169,"end":false},{"code":"пұҝ","page":169,"end":false},{"code":"пІҖ","page":169,"end":false},{"code":"пІҒ","page":169,"end":false},{"code":"пІӮ","page":169,"end":false},{"code":"пІғ","page":169,"end":false},{"code":"пІ„пІ…","page":169,"end":false},{"code":"пІҶ","page":169,"end":false},{"code":"пІҮ","page":169,"end":false},{"code":"пІҲ","page":169,"end":false},{"code":"пІү","page":169,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„
e},{"code":"пұҜ","page":37,"end":false},{"code":"пұ°","page":37,"end":false},{"code":"пұұ","page":37,"end":false},{"code":"пұІ","page":37,"end":false},{"code":"пұі","page":37,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ Ш·ЩҺЩ„Щ‘ЩҺЩӮЩ’ШӘЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҺ ЩҒЩҺШЁЩҺЩ„ЩҺШәЩ’ЩҶЩҺ ШЈЩҺШ¬ЩҺЩ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҺШЈЩҺЩ…Щ’ШіЩҗЩғЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗЩ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҚ ШЈЩҺЩҲЩ’ ШіЩҺШұЩ‘ЩҗШӯЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗЩ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҚЫў Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸЩ…Щ’ШіЩҗЩғЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Ш¶ЩҗШұЩҺШ§ШұЩӢЫӯШ§ Щ„Щ‘ЩҗШӘЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„Щ’ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҒЩҺЩӮЩҺШҜЩ’ ШёЩҺЩ„ЩҺЩ…ЩҺ ЩҶЩҺЩҒЩ’ШіЩҺЩҮЩҸЫҘ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҮЩҸШІЩҸЩҲЩӢЫӯШ§ Ыҡ ЩҲЩҺЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҶЩҗШ№Щ’Щ…ЩҺШӘЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҲЩҺЩұЩ„Щ’ШӯЩҗЩғЩ’Щ…ЩҺШ©Щҗ ЩҠЩҺШ№ЩҗШёЩҸЩғЩҸЩ… ШЁЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:232","surah":2,"ayah":232,"num":239,"page":37,"words":[{"code":"пұҙ","page":37,"end":false},{"code":"пұө","page":37,"end":false},{"code":"пұ¶","page":37,"end":false},{"code":"пұ·","page":37,"end":false},{"code":"пұё","page":37,"end":false},{"code":"пұ№","page":37,"end":false},{"code":"пұә","page":37,"end":false},{"code":"пұ»","page":37,"end":false},{"code":"пұј","page":37,"end":false},{"code":"пұҪ","page":37,"end":false},{"code":"пұҫ","page":37,"end":false},{"code":"пұҝ","page":37,"end":false},{"code":"пІҖ","page":37,"end":false},{"code":"пІҒпІӮ","page":37,"end":false},{"code":"пІғ","page":37,"end":false},{"code":"пІ„","page":37,"end":false},{"code":"пІ…","page":37,"end":false},{"code":"пІҶ","page":37,"end":false},{"code":"пІҮ","page":37,"end":false},{"code":"пІҲ","page":37,"end":false},{"code":"пІү","page":37,"end":false},{"code":"пІҠ","page":37,"end":false},{"code":"пІӢ","page":37,"end":false},{"code":"пІҢпІҚ","page":37,"e
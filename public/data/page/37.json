},{"code":"пІ·","page":37,"end":false},{"code":"пІё","page":37,"end":false},{"code":"пІ№","page":37,"end":false},{"code":"пІәпІ»","page":37,"end":false},{"code":"пІј","page":37,"end":false},{"code":"пІҪ","page":37,"end":false},{"code":"пІҫ","page":37,"end":false},{"code":"пІҝпіҖ","page":37,"end":false},{"code":"піҒ","page":37,"end":false},{"code":"піӮ","page":37,"end":false},{"code":"піғ","page":37,"end":false},{"code":"пі„","page":37,"end":false},{"code":"пі…","page":37,"end":false},{"code":"піҶ","page":37,"end":false},{"code":"піҮ","page":37,"end":false},{"code":"піҲ","page":37,"end":false},{"code":"піү","page":37,"end":false},{"code":"піҠпіӢ","page":37,"end":false},{"code":"піҢ","page":37,"end":false},{"code":"піҚ","page":37,"end":false},{"code":"піҺ","page":37,"end":false},{"code":"піҸ","page":37,"end":false},{"code":"піҗ","page":37,"end":false},{"code":"пі‘","page":37,"end":false},{"code":"пі’","page":37,"end":false},{"code":"пі“","page":37,"end":false},{"code":"пі”","page":37,"end":false},{"code":"пі•","page":37,"end":false},{"code":"пі–","page":37,"end":false},{"code":"пі—","page":37,"end":false},{"code":"піҳпіҷ","page":37,"end":false},{"code":"піҡ","page":37,"end":false},{"code":"піӣ","page":37,"end":false},{"code":"пің","page":37,"end":false},{"code":"піқ","page":37,"end":false},{"code":"піһ","page":37,"end":false},{"code":"піҹ","page":37,"end":false},{"code":"пі ","page":37,"end":false},{"code":"піЎ","page":37,"end":false},{"code":"піў","page":37,"end":true}],"text":"Ыһ ЩҲЩҺЩұЩ„Щ’ЩҲЩҺЩ°Щ„ЩҗШҜЩҺЩ°ШӘЩҸ ЩҠЩҸШұЩ’Ш¶ЩҗШ№Щ’ЩҶЩҺ ШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҺЩҮЩҸЩҶЩ‘ЩҺ ШӯЩҺЩҲЩ’Щ„ЩҺЩҠЩ’ЩҶЩҗ ЩғЩҺШ§Щ…ЩҗЩ„ЩҺЩҠЩ’ЩҶЩҗ Ы– Щ„ЩҗЩ…ЩҺЩҶЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺ ШЈЩҺЩҶ ЩҠЩҸШӘЩҗЩ…Щ‘ЩҺ ЩұЩ„ШұЩ‘ЩҺШ¶ЩҺШ§Ш№ЩҺШ©ЩҺ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺЩҲЩ’Щ„ЩҸЩҲШҜЩҗ Щ„ЩҺЩҮЩҸЫҘ ШұЩҗШІЩ’ЩӮЩҸЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩғЩҗШіЩ’ЩҲЩҺШӘЩҸЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ Ыҡ Щ„ЩҺШ§ ШӘЩҸЩғЩҺЩ„Щ‘ЩҺЩҒЩҸ ЩҶЩҺЩҒЩ’ШіЩҢ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҲЩҸШіЩ’Ш№ЩҺЩҮЩҺШ§ Ыҡ Щ„ЩҺШ§ ШӘЩҸШ¶ЩҺШ§Щ“ШұЩ‘ЩҺ ЩҲЩҺЩ°Щ„ЩҗШҜЩҺШ©ЩҢЫў ШЁЩҗЩҲЩҺЩ„ЩҺШҜЩҗЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺШ§ Щ…ЩҺЩҲЩ’Щ„ЩҸЩҲШҜЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЫҘ ШЁЩҗЩҲЩҺЩ„ЩҺШҜЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩҲЩҺШ§ШұЩҗШ«Щҗ Щ…ЩҗШ«Щ’Щ„ЩҸ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ы— ЩҒЩҺШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺШ§ ЩҒЩҗШөЩҺШ§Щ„ЩӢШ§ Ш№ЩҺЩҶ ШӘЩҺШұЩҺШ§Ш¶ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ ЩҲЩҺШӘЩҺШҙЩҺШ§ЩҲЩҸШұЩҚЫў ЩҒЩҺЩ„ЩҺШ§ Ш¬ЩҸЩҶЩҺШ§ШӯЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҺШ§ Ы— ЩҲЩҺШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШҜШӘЩ‘ЩҸЩ…Щ’ ШЈЩҺЩҶ ШӘЩҺШіЩ’ШӘЩҺШұЩ’Ш¶ЩҗШ№ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺШ§ Ш¬ЩҸЩҶЩҺШ§ШӯЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШҘЩҗШ°ЩҺШ§ ШіЩҺЩ„Щ‘ЩҺЩ…Щ’ШӘЩҸЩ… Щ…Щ‘ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҠЩ’ШӘЩҸЩ… ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ Ы— ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫӯ"}]}
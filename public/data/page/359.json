end":false},{"code":"пІ¶","page":359,"end":false},{"code":"пІ·","page":359,"end":false},{"code":"пІё","page":359,"end":false},{"code":"пІ№","page":359,"end":false},{"code":"пІә","page":359,"end":false},{"code":"пІ»","page":359,"end":false},{"code":"пІј","page":359,"end":false},{"code":"пІҪ","page":359,"end":false},{"code":"пІҫ","page":359,"end":false},{"code":"пІҝ","page":359,"end":false},{"code":"піҖ","page":359,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҸЩ„Щ’ЩғЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°Щ’ ЩҲЩҺЩ„ЩҺШҜЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҶ Щ„Щ‘ЩҺЩҮЩҸЫҘ ШҙЩҺШұЩҗЩҠЩғЩҢЫӯ ЩҒЩҗЩү ЩұЩ„Щ’Щ…ЩҸЩ„Щ’ЩғЩҗ ЩҲЩҺШ®ЩҺЩ„ЩҺЩӮЩҺ ЩғЩҸЩ„Щ‘ЩҺ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩҒЩҺЩӮЩҺШҜЩ‘ЩҺШұЩҺЩҮЩҸЫҘ ШӘЩҺЩӮЩ’ШҜЩҗЩҠШұЩӢЫӯШ§"}]}
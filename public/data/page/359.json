ЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"24:63","surah":24,"ayah":63,"num":2854,"page":359,"words":[{"code":"пұ¬","page":359,"end":false},{"code":"пұӯ","page":359,"end":false},{"code":"пұ®","page":359,"end":false},{"code":"пұҜ","page":359,"end":false},{"code":"пұ°","page":359,"end":false},{"code":"пұұ","page":359,"end":false},{"code":"пұІ","page":359,"end":false},{"code":"пұіпұҙ","page":359,"end":false},{"code":"пұө","page":359,"end":false},{"code":"пұ¶","page":359,"end":false},{"code":"пұ·","page":359,"end":false},{"code":"пұё","page":359,"end":false},{"code":"пұ№","page":359,"end":false},{"code":"пұә","page":359,"end":false},{"code":"пұ»пұј","page":359,"end":false},{"code":"пұҪ","page":359,"end":false},{"code":"пұҫ","page":359,"end":false},{"code":"пұҝ","page":359,"end":false},{"code":"пІҖ","page":359,"end":false},{"code":"пІҒ","page":359,"end":false},{"code":"пІӮ","page":359,"end":false},{"code":"пІғ","page":359,"end":false},{"code":"пІ„","page":359,"end":false},{"code":"пІ…","page":359,"end":false},{"code":"пІҶ","page":359,"end":false},{"code":"пІҮ","page":359,"end":false},{"code":"пІҲ","page":359,"end":false},{"code":"пІү","page":359,"end":true}],"text":"Щ„Щ‘ЩҺШ§ ШӘЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸЩҲШ§Ыҹ ШҜЩҸШ№ЩҺШ§Щ“ШЎЩҺ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩғЩҺШҜЩҸШ№ЩҺШ§Щ“ШЎЩҗ ШЁЩҺШ№Щ’Ш¶ЩҗЩғЩҸЩ… ШЁЩҺШ№Щ’Ш¶ЩӢЫӯШ§ Ыҡ ЩӮЩҺШҜЩ’ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШӘЩҺШіЩҺЩ„Щ‘ЩҺЩ„ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Щ„ЩҗЩҲЩҺШ§Ш°ЩӢЫӯШ§ Ыҡ ЩҒЩҺЩ„Щ’ЩҠЩҺШӯЩ’Ш°ЩҺШұЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸШ®ЩҺШ§Щ„ЩҗЩҒЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ’ ШЈЩҺЩ…Щ’ШұЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҶ ШӘЩҸШөЩҗЩҠШЁЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢ ШЈЩҺЩҲЩ’ ЩҠЩҸШөЩҗЩҠШЁЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢ"},{"key":"24:64","surah":24,"ayah":64,"num":2855,"page":359,"words":[{"code":"пІҠ","page":359,"end":false},{"code":"пІӢ","page":359,"end":false},{"code":"пІҢ","page":359,"end":false},{"code":"пІҚ","page":359,"end":false},{"code":"пІҺ","page":359,"end":false},{"code":"пІҸ","page":359,"end":false},{"code":"пІҗпІ‘","page":359,"end":false},{"
se},{"code":"піҢ","end":false},{"code":"піҚ","end":false}]},{"lineNumber":15,"words":[{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":true}]}],"verses":[{"key":"39:48","surah":39,"ayah":48,"num":4106,"page":464,"words":[{"code":"пұҒ","page":464,"end":false},{"code":"пұӮ","page":464,"end":false},{"code":"пұғ","page":464,"end":false},{"code":"пұ„","page":464,"end":false},{"code":"пұ…","page":464,"end":false},{"code":"пұҶ","page":464,"end":false},{"code":"пұҮ","page":464,"end":false},{"code":"пұҲ","page":464,"end":false},{"code":"пұү","page":464,"end":false},{"code":"пұҠ","page":464,"end":false},{"code":"пұӢ","page":464,"end":false},{"code":"пұҢ","page":464,"end":true}],"text":"ЩҲЩҺШЁЩҺШҜЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҸ Щ…ЩҺШ§ ЩғЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ ЩҲЩҺШӯЩҺШ§ЩӮЩҺ ШЁЩҗЩҮЩҗЩ… Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ЩҠЩҺШіЩ’ШӘЩҺЩҮЩ’ШІЩҗШЎЩҸЩҲЩҶЩҺ"},{"key":"39:49","surah":39,"ayah":49,"num":4107,"page":464,"words":[{"code":"пұҚ","page":464,"end":false},{"code":"пұҺ","page":464,"end":false},{"code":"пұҸ","page":464,"end":false},{"code":"пұҗ","page":464,"end":false},{"code":"пұ‘","page":464,"end":false},{"code":"пұ’","page":464,"end":false},{"code":"пұ“","page":464,"end":false},{"code":"пұ”","page":464,"end":false},{"code":"пұ•","page":464,"end":false},{"code":"пұ–","page":464,"end":false},{"code":"пұ—","page":464,"end":false},{"code":"пұҳ","page":464,"end":false},{"code":"пұҷ","page":464,"end":false},{"code":"пұҡ","page":464,"end":false},{"code":"пұӣпұң","page":464,"end":false},{"code":"пұқ","page":464,"end":false},{"code":"пұһ","page":464,"end":false},{"code":"пұҹ","page":464,"end":false},{"code":"пұ ","page":464,"end":false},{"code":"пұЎ","page":464,"end":false},{"code":"пұў","page":464,"end":false},{"code":"пұЈ","page":464,"end":false},{"code":"пұӨ","page":464,"end":true}],"text":"ЩҒЩҺШҘЩҗШ°ЩҺШ§ Щ…ЩҺШіЩ‘ЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҺ Ш¶ЩҸШұЩ‘ЩҢЫӯ ШҜЩҺШ№ЩҺШ§ЩҶЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗШ°ЩҺШ§ Ш®ЩҺЩҲЩ‘ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩҶЩҗШ№Щ’Щ…ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩ‘ЩҺШ§ ЩӮЩҺШ§Щ„ЩҺ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҲШӘЩҗЩҠШӘЩҸЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩүЩ° Ш№ЩҗЩ„Щ’Щ…ЩҚЫӯ Ыҡ ШЁЩҺЩ„Щ’ ЩҮЩҗЩүЩҺ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢЫӯ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"39:50","surah":39,"ayah":50,"num":4108,"page":464,"words":[{"code":"пұҘ","page":464,"end":false},{"code":"пұҰ","page":464,"end":false},{"code":"пұ§","page":464,"end":false},{"code":"пұЁ","page":464,"end":false},{"code":"пұ©","page":464,"end":false},{"code":"пұӘ","page":464,"end":false},{"code":"пұ«","page":464,"end":false},{"code":"пұ¬","page":464,"end":false},{"code":"пұӯ","page":464,"end":false},{"code":"пұ®","page":464,"end":false},{"code":"пұҜ","page":464,"end":false},{"code":"пұ°","page":464,"end":true}],"text":"ЩӮЩҺШҜЩ’ ЩӮЩҺШ§Щ„ЩҺЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩҮЩҗЩ…Щ’ ЩҒЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШәЩ’ЩҶЩҺЩүЩ° Ш№ЩҺЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"39:51","surah":39,"ayah":51,"num":4109,"page":464,"words":[{"code":"пұұ","page":464,"end":false},{"code":"пұІ","page":464,"end":false},{"code":"пұі","page":464,"end":false},{"code":"пұҙпұө","page":464,"end":false},{"code":"пұ¶","page":464,"end":false},{"code":"пұ·","page":464,"end":false},{"code":"пұё","page":464,"end":false},{"code":"пұ№","page":464,"end":false},{"code":"пұә","page":464,"end":false},{"code":"пұ»","page":464,"end":false},{"code":"пұј","page":464,"end":false},{"code":"пұҪ","page":464,"end":false},{"code":"пұҫ","page":464,"end":false},{"code":"пұҝ","page":464,"end":false},{"code":"пІҖ","page":464,"end":false},{"code":"пІҒ","page":464,"end":true}],"text":"ЩҒЩҺШЈЩҺШөЩҺШ§ШЁЩҺЩҮЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҸ Щ…ЩҺШ§ ЩғЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ ШіЩҺЩҠЩҸШөЩҗЩҠШЁЩҸЩҮЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҸ Щ…ЩҺШ§ ЩғЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩ… ШЁЩҗЩ…ЩҸШ№Щ’Ш¬ЩҗШІЩҗЩҠЩҶЩҺ"},{"key":"39:52","surah":39,"ayah":52,"num":4110,"page":464,"words":[{"code":"пІӮ","page":464,"end":false},{"code":"пІғ","page":464,"end":false},{"code":"пІ„","page":464,"end":false},{"code":"пІ…","page":464,"end":false},{"code":"пІҶ","page":464,"end":false},{"code":"пІҮ","page":464,"end":false},{"code":"пІҲ","page":464,"end":false},{"code":"пІү","page":464,"end":false},{"code":"пІҠпІӢ","page":464,"end":false},{"code":"пІҢ","page":464,"end":false},{"code":"пІҚ","page":464,"end":false},{"code":"пІҺ","page":464,"end":false},{"code":"пІҸ","page":464,"end":false},{"code":"пІҗ","page":464,"end":false},{"code":"пІ‘","page":464,"end":false},{"code":"пІ’","page":464,"end":true}],"text":"ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШЁЩ’ШіЩҸШ·ЩҸ ЩұЩ„ШұЩ‘ЩҗШІЩ’ЩӮЩҺ Щ„ЩҗЩ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩҠЩҺЩӮЩ’ШҜЩҗШұЩҸ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"39:53","surah":39,"ayah":53,"num":4111,"page":464,"words":[{"code":"пІ“ пІ”","page":464,"end":false},{"code":"пІ•","page":464,"end":false},{"code":"пІ–","page":464,"end":false},{"code":"пІ—","page":464,"end":false},{"code":"пІҳ","page":464,"end":false},{"code":"пІҷ","page":464,"end":false},{"code":"пІҡ","page":464,"end":false},{"code":"пІӣ","page":464,"end":false},{"code":"пІң","page":464,"end":false},{"code":"пІқ","page":464,"end":false},{"code":"пІһпІҹ","page":464,"end":false},{"code":"пІ ","page":464,"end":false},{"code":"пІЎ","page":464,"end":false},{"code":"пІў","page":464,"end":false},{"code":"пІЈ","page":464,"end":false},{"code":"пІӨпІҘ","page":464,"end":false},{"code":"пІҰ","page":464,"end":false},{"code":"пІ§","page":464,"end":false},{"code":"пІЁ","page":464,"end":false},{"code":"пІ©","page":464,"end":false},{"code":"пІӘ","page":464,"end":true}],"text":"Ыһ ЩӮЩҸЩ„Щ’ ЩҠЩҺЩҖЩ°Ш№ЩҗШЁЩҺШ§ШҜЩҗЩүЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҺШіЩ’ШұЩҺЩҒЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺШ§ ШӘЩҺЩӮЩ’ЩҶЩҺШ·ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ШұЩ‘ЩҺШӯЩ’Щ…ЩҺШ©Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ ЩұЩ„Ш°Щ‘ЩҸЩҶЩҸЩҲШЁЩҺ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ШәЩҺЩҒЩҸЩҲШұЩҸ ЩұЩ„ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҸ"},{"key":"39:54","surah":39,"ayah":54,"num":4112,"page":464,"words":[{"code":"пІ«","page":464,"end":false},{"code":"пІ¬","page":464,"end":false},{"code":"пІӯ","page":464,"end":false},{"code":"пІ®","page":464,"end":false},{"code":"пІҜ","page":464,"end":false},{"code":"пІ°","page":464,"end":false},{"code":"пІұ","page":464,"end":false},{"code":"пІІ","page":464,"end":false},{"code":"пІі","page":464,"end":false},{"code":"пІҙ","page":464,"end":false},{"code":"пІө","page":464,"end":false},{"code":"пІ¶","page":464,"end":false},{"code":"пІ·","page":464,"end":false},{"code":"пІё","page":464,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶЩҗЩҠШЁЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШіЩ’Щ„ЩҗЩ…ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШЈЩҺЩҶ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҸ Ш«ЩҸЩ…Щ‘ЩҺ Щ„ЩҺШ§ ШӘЩҸЩҶШөЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"39:55","surah":39,"ayah":55,"num":4113,"page":464,"words":[{"code":"пІ№","page":464,"end":false},{"code":"пІә","page":464,"end":false},{"code":"пІ»","page":464,"end":false},{"code":"пІј","page":464,"end":false},{"code":"пІҪ","page":464,"end":false},{"code":"пІҫ","page":464,"end":false},{"code":"пІҝ","page":464,"end":false},{"code":"піҖ","page":464,"end":false},{"code":"піҒ","page":464,"end":false},{"code":"піӮ","page":464,"end":false},{"code":"піғ","page":464,"end":false},{"code":"пі„","page":464,"end":false},{"code":"пі…","page":464,"end":false},{"code":"піҶ","page":464,"end":false},{"code":"піҮ","page":464,"end":false},{"code":"піҲ","page":464,"end":false},{"code":"піү","page":464,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШӯЩ’ШіЩҺЩҶЩҺ Щ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШЈЩҺЩҶ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ШЁЩҺШәЩ’Ш
ge":42,"end":false},{"code":"пұ«","page":42,"end":false},{"code":"пұ¬","page":42,"end":false},{"code":"пұӯ","page":42,"end":false},{"code":"пұ®","page":42,"end":false},{"code":"пұҜпұ°","page":42,"end":false},{"code":"пұұ","page":42,"end":false},{"code":"пұІ","page":42,"end":false},{"code":"пұі","page":42,"end":false},{"code":"пұҙ","page":42,"end":false},{"code":"пұө","page":42,"end":false},{"code":"пұ¶","page":42,"end":false},{"code":"пұ·","page":42,"end":false},{"code":"пұё","page":42,"end":false},{"code":"пұ№","page":42,"end":false},{"code":"пұә","page":42,"end":false},{"code":"пұ»","page":42,"end":true}],"text":"Ыһ ШӘЩҗЩ„Щ’ЩғЩҺ ЩұЩ„ШұЩ‘ЩҸШіЩҸЩ„ЩҸ ЩҒЩҺШ¶Щ‘ЩҺЩ„Щ’ЩҶЩҺШ§ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҳ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶ ЩғЩҺЩ„Щ‘ЩҺЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ЩҲЩҺШұЩҺЩҒЩҺШ№ЩҺ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЩ…Щ’ ШҜЩҺШұЩҺШ¬ЩҺЩҖЩ°ШӘЩҚЫў Ыҡ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ Ш№ЩҗЩҠШіЩҺЩү ЩұШЁЩ’ЩҶЩҺ Щ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ ЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺШЈЩҺЩҠЩ‘ЩҺШҜЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ШЁЩҗШұЩҸЩҲШӯЩҗ ЩұЩ„Щ’ЩӮЩҸШҜЩҸШіЩҗ Ы— ЩҲЩҺЩ„ЩҺЩҲЩ’ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ§ ЩұЩӮЩ’ШӘЩҺШӘЩҺЩ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Щ…ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҸ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩҗ ЩұШ®Щ’ШӘЩҺЩ„ЩҺЩҒЩҸЩҲШ§Ыҹ ЩҒЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶ ЩғЩҺЩҒЩҺШұЩҺ Ыҡ ЩҲЩҺЩ„ЩҺЩҲЩ’ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ§ ЩұЩӮЩ’ШӘЩҺШӘЩҺЩ„ЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸ Щ…ЩҺШ§ ЩҠЩҸШұЩҗЩҠШҜЩҸ"},{"key":"2:254","surah":2,"ayah":254,"num":261,"page":42,"words":[{"code":"пұј","page":42,"end":false},{"code":"пұҪ","page":42,"end":false},{"code":"пұҫ","page":42,"end":false},{"code":"пұҝ","page":42,"end":false},{"code":"пІҖ","page":42,"end":false},{"code":"пІҒ","page":42,"end":false},{"code":"пІӮ","page":42,"end":false},{"code":"пІғ","page":42,"end":false},{"code":"пІ„","page":42,"end":false},{"code":"пІ…","page":42,"end":false},{"code":"пІҶ","page":42,"end":false},{"code":"пІҮ","page":42,"
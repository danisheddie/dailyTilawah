ЩҺШӘЩҺЩҮЩҸЩ…Щ’ Ы— ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺ ЩҮЩҸШҜЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° Ы— ЩҲЩҺЩ„ЩҺШҰЩҗЩҶЩҗ ЩұШӘЩ‘ЩҺШЁЩҺШ№Щ’ШӘЩҺ ШЈЩҺЩҮЩ’ЩҲЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ… ШЁЩҺШ№Щ’ШҜЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш¬ЩҺШ§Щ“ШЎЩҺЩғЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҗЩ„Щ’Щ…Щҗ Ыҷ Щ…ЩҺШ§ Щ„ЩҺЩғЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҗЩҶ ЩҲЩҺЩ„ЩҗЩүЩ‘ЩҚЫў ЩҲЩҺЩ„ЩҺШ§ ЩҶЩҺШөЩҗЩҠШұЩҚ"},{"key":"2:121","surah":2,"ayah":121,"num":128,"page":19,"words":[{"code":"пұЈ","page":19,"end":false},{"code":"пұӨ","page":19,"end":false},{"code":"пұҘ","page":19,"end":false},{"code":"пұҰ","page":19,"end":false},{"code":"пұ§","page":19,"end":false},{"code":"пұЁ","page":19,"end":false},{"code":"пұ©","page":19,"end":false},{"code":"пұӘ","page":19,"end":false},{"code":"пұ«пұ¬","page":19,"end":false},{"code":"пұӯ","page":19,"end":false},{"code":"пұ®","page":19,"end":false},{"code":"пұҜ","page":19,"end":false},{"code":"пұ°","page":19,"end":false},{"code":"пұұ","page":19,"end":false},{"code":"пұІ","page":19,"end":false},{"code":"пұі","page":19,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҠЩҺШӘЩ’Щ„ЩҸЩҲЩҶЩҺЩҮЩҸЫҘ ШӯЩҺЩӮЩ‘ЩҺ ШӘЩҗЩ„ЩҺШ§ЩҲЩҺШӘЩҗЩҮЩҗЫҰЩ“ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩғЩ’ЩҒЩҸШұЩ’ ШЁЩҗЩҮЩҗЫҰ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш®ЩҺЩҖЩ°ШіЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"2:122","surah":2,"ayah":122,"num":129,"page":19,"words":[{"code":"пұҙ","page":19,"end":false},{"code":"пұө","page":19,"end":false},{"code":"пұ¶","page":19,"end":false},{"code":"пұ·","page":19,"end":false},{"code":"пұё","page":19,"end":false},{"code":"пұ№","page":19,"end":false},{"code":"пұә","page":19,"end":false},{"code":"пұ»","page":19,"end":false},{"code":"пұј","page":19,"end":false},{"code":"пұҪ","page":19,"end":false},{"code":"пұҫ","page":19,"end":false},{"code":"пұҝ","page":19,"end":true}],"text":"ЩҠЩҺЩҖЩ°ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҶЩҗШ№Щ’Щ…ЩҺШӘЩҗЩүЩҺ ЩұЩ„Щ‘ЩҺШӘЩҗЩүЩ“ ШЈЩҺЩҶЩ’Ш№ЩҺЩ…Щ’ШӘЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҗЩү ЩҒЩҺШ¶Щ‘ЩҺЩ
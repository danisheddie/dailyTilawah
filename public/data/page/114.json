","surah":5,"ayah":37,"num":706,"page":114,"words":[{"code":"пұҒ","page":114,"end":false},{"code":"пұӮ","page":114,"end":false},{"code":"пұғ","page":114,"end":false},{"code":"пұ„","page":114,"end":false},{"code":"пұ…","page":114,"end":false},{"code":"пұҶ","page":114,"end":false},{"code":"пұҮ","page":114,"end":false},{"code":"пұҲ","page":114,"end":false},{"code":"пұүпұҠ","page":114,"end":false},{"code":"пұӢ","page":114,"end":false},{"code":"пұҢ","page":114,"end":false},{"code":"пұҚ","page":114,"end":false},{"code":"пұҺ","page":114,"end":true}],"text":"ЩҠЩҸШұЩҗЩҠШҜЩҸЩҲЩҶЩҺ ШЈЩҺЩҶ ЩҠЩҺШ®Щ’ШұЩҸШ¬ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩ… ШЁЩҗШ®ЩҺЩҖЩ°ШұЩҗШ¬ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ Щ…Щ‘ЩҸЩӮЩҗЩҠЩ…ЩҢЫӯ"},{"key":"5:38","surah":5,"ayah":38,"num":707,"page":114,"words":[{"code":"пұҸ","page":114,"end":false},{"code":"пұҗ","page":114,"end":false},{"code":"пұ‘","page":114,"end":false},{"code":"пұ’","page":114,"end":false},{"code":"пұ“","page":114,"end":false},{"code":"пұ”","page":114,"end":false},{"code":"пұ•","page":114,"end":false},{"code":"пұ–","page":114,"end":false},{"code":"пұ—","page":114,"end":false},{"code":"пұҳпұҷ","page":114,"end":false},{"code":"пұҡ","page":114,"end":false},{"code":"пұӣ","page":114,"end":false},{"code":"пұң","page":114,"end":false},{"code":"пұқ","page":114,"end":true}],"text":"ЩҲЩҺЩұЩ„ШіЩ‘ЩҺШ§ШұЩҗЩӮЩҸ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺШ§ШұЩҗЩӮЩҺШ©ЩҸ ЩҒЩҺЩұЩӮЩ’Ш·ЩҺШ№ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩ…ЩҺШ§ Ш¬ЩҺШІЩҺШ§Щ“ШЎЩӢЫў ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШіЩҺШЁЩҺШ§ ЩҶЩҺЩғЩҺЩҖЩ°Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺШІЩҗЩҠШІЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"},{"key":"5:39","surah":5,"ayah":39,"num":708,"page":114,"words":[{"code":"пұһ","page":114,"end":false},{"code":"пұҹ","page":114,"end":false},{"code":"пұ ","page":114,"end":false},{"code":"пұЎ","page":114,"end":false},{"code":"пұў","page":114,"end":false},{"code":"пұЈ","page":114,"end":false},{"code":"пұӨ","page":114,"end":false},{"code":"пұҘ","page":114,"end":false},{"code":"пұҰ","pa
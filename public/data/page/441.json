пұқ","page":441,"end":false},{"code":"пұһ","page":441,"end":false},{"code":"пұҹ","page":441,"end":false},{"code":"пұ ","page":441,"end":false},{"code":"пұЎ","page":441,"end":false},{"code":"пұў","page":441,"end":false},{"code":"пұЈ","page":441,"end":false},{"code":"пұӨ","page":441,"end":false},{"code":"пұҘ","page":441,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§Щ“ ШЈЩҺЩҶШӘЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҺШҙЩҺШұЩҢЫӯ Щ…Щ‘ЩҗШ«Щ’Щ„ЩҸЩҶЩҺШ§ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„ШұЩ‘ЩҺШӯЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸ Щ…ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚ ШҘЩҗЩҶЩ’ ШЈЩҺЩҶШӘЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺЩғЩ’Ш°ЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"36:16","surah":36,"ayah":16,"num":3721,"page":441,"words":[{"code":"пұҰ","page":441,"end":false},{"code":"пұ§","page":441,"end":false},{"code":"пұЁ","page":441,"end":false},{"code":"пұ©","page":441,"end":false},{"code":"пұӘ","page":441,"end":false},{"code":"пұ«","page":441,"end":false},{"code":"пұ¬","page":441,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҸЩҶЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШҘЩҗЩҶЩ‘ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Щ„ЩҺЩ…ЩҸШұЩ’ШіЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"36:17","surah":36,"ayah":17,"num":3722,"page":441,"words":[{"code":"пұӯ","page":441,"end":false},{"code":"пұ®","page":441,"end":false},{"code":"пұҜ","page":441,"end":false},{"code":"пұ°","page":441,"end":false},{"code":"пұұ","page":441,"end":false},{"code":"пұІ","page":441,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ’ШЁЩҺЩ„ЩҺЩҖЩ°ШәЩҸ ЩұЩ„Щ’Щ…ЩҸШЁЩҗЩҠЩҶЩҸ"},{"key":"36:18","surah":36,"ayah":18,"num":3723,"page":441,"words":[{"code":"пұі","page":441,"end":false},{"code":"пұҙ","page":441,"end":false},{"code":"пұө","page":441,"end":false},{"code":"пұ¶пұ·","page":441,"end":false},{"code":"пұё","page":441,"end":false},{"code":"пұ№","page":441,"end":false},{"code":"пұә","page":441,"end":false},{"code":"пұ»","page":441,"end":false},{"code":"пұј","page":441,"end":false},{"code":"пұҪ","page":441,"end":false},{"code":"пұҫ","page":441,"end":false},{"code":"пұҝ","page":441,"end":false},{"code":"пІҖ","page":441,"end":true}],"text":"ЩӮЩҺШ§Щ„Щ
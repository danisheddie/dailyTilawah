alse},{"code":"пұӢ","page":170,"end":false},{"code":"пұҢпұҚ","page":170,"end":false},{"code":"пұҺ","page":170,"end":false},{"code":"пұҸ","page":170,"end":false},{"code":"пұҗ","page":170,"end":false},{"code":"пұ‘","page":170,"end":false},{"code":"пұ’","page":170,"end":false},{"code":"пұ“пұ”","page":170,"end":false},{"code":"пұ•","page":170,"end":false},{"code":"пұ–","page":170,"end":false},{"code":"пұ—","page":170,"end":false},{"code":"пұҳпұҷ","page":170,"end":false},{"code":"пұҡ","page":170,"end":false},{"code":"пұӣ","page":170,"end":false},{"code":"пұң","page":170,"end":false},{"code":"пұқ","page":170,"end":false},{"code":"пұһ","page":170,"end":false},{"code":"пұҹ","page":170,"end":false},{"code":"пұ ","page":170,"end":false},{"code":"пұЎ","page":170,"end":false},{"code":"пұў","page":170,"end":false},{"code":"пұЈ","page":170,"end":true}],"text":"Ыһ ЩҲЩҺЩұЩғЩ’ШӘЩҸШЁЩ’ Щ„ЩҺЩҶЩҺШ§ ЩҒЩҗЩү ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ШӯЩҺШіЩҺЩҶЩҺШ©ЩӢЫӯ ЩҲЩҺЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩҮЩҸШҜЩ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ Ыҡ ЩӮЩҺШ§Щ„ЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩҗЩүЩ“ ШЈЩҸШөЩҗЩҠШЁЩҸ ШЁЩҗЩҮЩҗЫҰ Щ…ЩҺЩҶЩ’ ШЈЩҺШҙЩҺШ§Щ“ШЎЩҸ Ы– ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩү ЩҲЩҺШіЩҗШ№ЩҺШӘЩ’ ЩғЩҸЩ„Щ‘ЩҺ ШҙЩҺЩүЩ’ШЎЩҚЫў Ыҡ ЩҒЩҺШіЩҺШЈЩҺЩғЩ’ШӘЩҸШЁЩҸЩҮЩҺШ§ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ ЩҲЩҺЩҠЩҸШӨЩ’ШӘЩҸЩҲЩҶЩҺ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҮЩҸЩ… ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"7:157","surah":7,"ayah":157,"num":1111,"page":170,"words":[{"code":"пұӨ","page":170,"end":false},{"code":"пұҘ","page":170,"end":false},{"code":"пұҰ","page":170,"end":false},{"code":"пұ§","page":170,"end":false},{"code":"пұЁ","page":170,"end":false},{"code":"пұ©","page":170,"end":false},{"code":"пұӘ","page":170,"end":false},{"code":"пұ«","page":170,"end":false},{"code":"пұ¬","page":170,"end":false},{"code":"пұӯ","page":170,"end":false},{"code":"пұ®","page":170,"end":false},{"code":"пұҜ","page":170,"end":false},{"code":"пұ°","page":170,"end":false},{"code":"пұұ","page":170,"end":false},{"code":"пұІ","page":170,"end":false},{"code":"пұі","page":170,"end":false},{"code":"пұҙ","page":170,"end":false},{"code":"пұө","page":170,"end":false},{"code":"пұ¶","page":170,"end":false},{"code":"пұ·","page":170,"end":false},{"code":"пұё","page":170,"end":false},{"code":"пұ№","page":170,"end":false},{"code":"пұә","page":170,"end":false},{"code":"пұ»","page":170,"end":false},{"code":"пұј","page":170,"end":false},{"code":"пұҪ","page":170,"end":false},{"code":"пұҫ","page":170,"end":false},{"code":"пұҝ","page":170,"end":false},{"code":"пІҖ","page":170,"end":false},{"code":"пІҒпІӮ","page":170,"end":false},{"code":"пІғ","page":170,"end":false},{"code":"пІ„","page":170,"end":false},{"code":"пІ…","page":170,"end":false},{"code":"пІҶ","page":170,"end":false},{"code":"пІҮ","page":170,"end":false},{"code":"пІҲ","page":170,"end":false},{"code":"пІү","page":170,"end":false},{"code":"пІҠ","page":170,"end":false},{"code":"пІӢ","page":170,"end":false},{"code":"пІҢ","page":170,"end":false},{"code":"пІҚ","page":170,"end":false},{"code":"пІҺ","page":170,"end":false},{"code":"пІҸ","page":170,"end":false},{"code":"пІҗ","page":170,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘ЩҺ ЩұЩ„Щ’ШЈЩҸЩ…Щ‘ЩҗЩүЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҺШ¬ЩҗШҜЩҸЩҲЩҶЩҺЩҮЩҸЫҘ Щ…ЩҺЩғЩ’ШӘЩҸЩҲШЁЩӢШ§ Ш№ЩҗЩҶШҜЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ШӘЩ‘ЩҺЩҲЩ’ШұЩҺЩүЩ°Ш©Щҗ ЩҲЩҺЩұЩ„Щ’ШҘЩҗЩҶШ¬ЩҗЩҠЩ„Щҗ ЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺЩҠЩҺЩҶЩ’ЩҮЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ ЩҲЩҺЩҠЩҸШӯЩҗЩ„Щ‘ЩҸ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Ш·Щ‘ЩҺЩҠЩ‘ЩҗШЁЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺЩҠЩҸШӯЩҺШұЩ‘ЩҗЩ…ЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’Ш®ЩҺШЁЩҺЩҖЩ°Щ“ШҰЩҗШ«ЩҺ ЩҲЩҺЩҠЩҺШ¶ЩҺШ№ЩҸ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ШҘЩҗШөЩ’ШұЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШәЩ’Щ„ЩҺЩҖЩ°Щ„ЩҺ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ЩғЩҺШ§ЩҶЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ыҡ ЩҒЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺШ№ЩҺШІЩ‘ЩҺШұЩҸЩҲЩҮЩҸ ЩҲЩҺЩҶЩҺШөЩҺШұЩҸЩҲЩҮЩҸ ЩҲЩҺЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҸЩҲШ§Ыҹ ЩұЩ„ЩҶЩ‘ЩҸЩҲШұЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ Щ…ЩҺШ№ЩҺЩҮЩҸЫҘЩ“ Ыҷ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"7:158","surah":7,"ayah":158,"num":1112,"page":170,"words":[{"code":"пІ‘","page":170,"end":false},{"code":"пІ’","page":170,"end":false},{"code":"пІ“","page":170,"end":false},{"code":"пІ”","page":170,"end":false},{"code":"пІ•","page":170,"end":false},{"code":"пІ–","page":170,"end":false},{"code":"пІ—","page":170,"end":false},{"code":"пІҳ","page":170,"end":false},{"code":"пІҷ","page":170,"end":false},{"code":"пІҡ","page":170,"end":false},{"code":"пІӣ","page":170,"end":false},{"code":"пІң","page":170,"end":false},{"code":"пІқпІһ","page":170,"end":false},{"code":"пІҹ","page":170,"end":false},{"code":"пІ ","page":170,"end":false},{"code":"пІЎ","page":170,"end":false},{"code":"пІў","page":170,"end":false},{"code":"пІЈ","page":170,"end":false},{"code":"пІӨпІҘ","page":170,"end":false},{"code":"пІҰ","page":170,"end":false},{"code":"пІ§","page":170,"end":false},{"code":"пІЁ","page":170,"end":false},{"code":"пІ©","page":170,"end":false},{"code":"пІӘ","page":170,"end":false},{"code":"пІ«","page":170,"end":false},{"code":"пІ¬","page":170,"end":false},{"code":"пІӯ","page":170,"end":false},{"code":"пІ®","page":170,"end":false},{"code":"пІҜ","page":170,"end":false},{"code":"пІ°","page":170,"end":false},{"code":"пІұ","page":170,"end":false},{"code":"пІІ","page":170,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ШҘЩҗЩҶЩ‘ЩҗЩү ШұЩҺШіЩҸЩҲЩ„ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҸЩ„Щ’ЩғЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы– Щ„ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ ЩҠЩҸШӯЩ’ЩүЩҗЫҰ ЩҲЩҺЩҠЩҸЩ…ЩҗЩҠШӘЩҸ Ы– ЩҒЩҺЩҖЩ”ЩҺШ§Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘Щҗ ЩұЩ„Щ’ШЈЩҸЩ…Щ‘ЩҗЩүЩ‘Щҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩғЩҺЩ„ЩҗЩ…ЩҺЩҖЩ°ШӘЩҗЩҮЩҗЫҰ ЩҲЩҺЩұШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩҮЩҸ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺЩҮЩ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"7:159","surah":7,"ayah":159,"num":1113,"page":170,"words":[{"code":"пІі","page":170,"end":false},{"code":"пІҙ","page":170,"end":false},{"code":"пІө","page":170,"end":false},{"code":"пІ¶","page":170,"end":false},{"code":"пІ·","page":170,"end":false},{"code":"пІё","page":170,"end":false},{"code":"пІ№","page":170,"end":false},{"code":"пІә","page":170,"end":false},{"code":"пІ»","page":170,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶ ЩӮЩҺЩҲЩ’Щ…Щҗ Щ…ЩҸЩҲШіЩҺЩүЩ°Щ“ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҢЫӯ ЩҠЩҺЩҮЩ’ШҜЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺШЁЩҗЩҮЩҗЫҰ ЩҠЩҺШ№Щ’ШҜЩҗЩ„ЩҸЩҲЩҶЩҺ"}]}
ЩҺЩ„ЩҺШ§ ШӘЩҺШ№Щ’ШІЩҗЩ…ЩҸЩҲШ§Ыҹ Ш№ЩҸЩӮЩ’ШҜЩҺШ©ЩҺ ЩұЩ„ЩҶЩ‘ЩҗЩғЩҺШ§ШӯЩҗ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШЁЩ’Щ„ЩҸШәЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҸ ШЈЩҺШ¬ЩҺЩ„ЩҺЩҮЩҸЫҘ Ыҡ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Щ…ЩҺШ§ ЩҒЩҗЩүЩ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ЩҒЩҺЩұШӯЩ’Ш°ЩҺШұЩҸЩҲЩҮЩҸ Ыҡ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢ ШӯЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:236","surah":2,"ayah":236,"num":243,"page":38,"words":[{"code":"пІ‘","page":38,"end":false},{"code":"пІ’","page":38,"end":false},{"code":"пІ“","page":38,"end":false},{"code":"пІ”","page":38,"end":false},{"code":"пІ•","page":38,"end":false},{"code":"пІ–","page":38,"end":false},{"code":"пІ—","page":38,"end":false},{"code":"пІҳ","page":38,"end":false},{"code":"пІҷ","page":38,"end":false},{"code":"пІҡ","page":38,"end":false},{"code":"пІӣ","page":38,"end":false},{"code":"пІң","page":38,"end":false},{"code":"пІқпІһ","page":38,"end":false},{"code":"пІҹ","page":38,"end":false},{"code":"пІ ","page":38,"end":false},{"code":"пІЎ","page":38,"end":false},{"code":"пІў","page":38,"end":false},{"code":"пІЈ","page":38,"end":false},{"code":"пІӨ","page":38,"end":false},{"code":"пІҘ","page":38,"end":false},{"code":"пІҰ","page":38,"end":false},{"code":"пІ§пІЁ","page":38,"end":false},{"code":"пІ©","page":38,"end":false},{"code":"пІӘ","page":38,"end":false},{"code":"пІ«","page":38,"end":false},{"code":"пІ¬","page":38,"end":true}],"text":"Щ„Щ‘ЩҺШ§ Ш¬ЩҸЩҶЩҺШ§ШӯЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШҘЩҗЩҶ Ш·ЩҺЩ„Щ‘ЩҺЩӮЩ’ШӘЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҺ Щ…ЩҺШ§ Щ„ЩҺЩ…Щ’ ШӘЩҺЩ…ЩҺШіЩ‘ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЈЩҺЩҲЩ’ ШӘЩҺЩҒЩ’ШұЩҗШ¶ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҺШұЩҗЩҠШ¶ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩ…ЩҺШӘЩ‘ЩҗШ№ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸЩҲШіЩҗШ№Щҗ ЩӮЩҺШҜЩҺШұЩҸЩҮЩҸЫҘ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸЩӮЩ’ШӘЩҗШұЩҗ ЩӮЩҺШҜЩҺШұЩҸЩҮЩҸЫҘ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩӢЫўШ§ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ Ы– ШӯЩҺЩӮЩ‘ЩӢШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"2:237","surah":2,"ayah":237,"num":244,"page":38,"words":[{"code":"пІӯ","page":38,"end":false},{"code":"пІ®","page":38,"en
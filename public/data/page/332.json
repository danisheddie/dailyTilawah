e":332,"end":false},{"code":"пұғ","page":332,"end":false},{"code":"пұ„пұ…","page":332,"end":false},{"code":"пұҶ","page":332,"end":false},{"code":"пұҮ","page":332,"end":false},{"code":"пұҲ","page":332,"end":false},{"code":"пұү","page":332,"end":false},{"code":"пұҠ","page":332,"end":false},{"code":"пұӢ","page":332,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҺЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ШІЩҺЩ„Щ’ШІЩҺЩ„ЩҺШ©ЩҺ ЩұЩ„ШіЩ‘ЩҺШ§Ш№ЩҺШ©Щҗ ШҙЩҺЩүЩ’ШЎЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"22:2","surah":22,"ayah":2,"num":2597,"page":332,"words":[{"code":"пұҢ","page":332,"end":false},{"code":"пұҚ","page":332,"end":false},{"code":"пұҺ","page":332,"end":false},{"code":"пұҸ","page":332,"end":false},{"code":"пұҗ","page":332,"end":false},{"code":"пұ‘","page":332,"end":false},{"code":"пұ’","page":332,"end":false},{"code":"пұ“","page":332,"end":false},{"code":"пұ”","page":332,"end":false},{"code":"пұ•","page":332,"end":false},{"code":"пұ–","page":332,"end":false},{"code":"пұ—","page":332,"end":false},{"code":"пұҳ","page":332,"end":false},{"code":"пұҷ","page":332,"end":false},{"code":"пұҡ","page":332,"end":false},{"code":"пұӣ","page":332,"end":false},{"code":"пұң","page":332,"end":false},{"code":"пұқ","page":332,"end":false},{"code":"пұһ","page":332,"end":false},{"code":"пұҹ","page":332,"end":false},{"code":"пұ ","page":332,"end":false},{"code":"пұЎ","page":332,"end":false},{"code":"пұў","page":332,"end":true}],"text":"ЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҺШұЩҺЩҲЩ’ЩҶЩҺЩҮЩҺШ§ ШӘЩҺШ°Щ’ЩҮЩҺЩ„ЩҸ ЩғЩҸЩ„Щ‘ЩҸ Щ…ЩҸШұЩ’Ш¶ЩҗШ№ЩҺШ©ЩҚ Ш№ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЈЩҺШұЩ’Ш¶ЩҺШ№ЩҺШӘЩ’ ЩҲЩҺШӘЩҺШ¶ЩҺШ№ЩҸ ЩғЩҸЩ„Щ‘ЩҸ Ш°ЩҺШ§ШӘЩҗ ШӯЩҺЩ…Щ’Щ„ЩҚ ШӯЩҺЩ…Щ’Щ„ЩҺЩҮЩҺШ§ ЩҲЩҺШӘЩҺШұЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ШіЩҸЩғЩҺЩҖЩ°ШұЩҺЩүЩ° ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩ… ШЁЩҗШіЩҸЩғЩҺЩҖЩ°ШұЩҺЩүЩ° ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҙЩҺШҜЩҗЩҠШҜЩҢЫӯ"},{"key":"22:3","surah":22,"ayah":3,"num":2598,"page":332,"words":[{"code":"пұЈ","page":332,"end":false},{"code":"пұӨ","page":332,"end":false},{"code":"пұҘ","page":332,"end":false},{"code":"пұҰ","page":332,"end":false},{"code":"пұ§","page":332,"end":false},{"code":"пұЁ","page":332,"end":false},{"code":"пұ©","page":332,"end":false},{"code":"пұӘ","page":332,"end":false},{"code":"пұ«","page":332,"end":false},{"code":"пұ¬","page":332,"end":false},{"code":"пұӯ","page":332,"end":false},{"code":"пұ®","page":332,"end":false},{"code":"пұҜ","page":332,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ…ЩҺЩҶ ЩҠЩҸШ¬ЩҺЩҖЩ°ШҜЩҗЩ„ЩҸ ЩҒЩҗЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ Ш№ЩҗЩ„Щ’Щ…ЩҚЫў ЩҲЩҺЩҠЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸ ЩғЩҸЩ„Щ‘ЩҺ ШҙЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҚЫў Щ…Щ‘ЩҺШұЩҗЩҠШҜЩҚЫў"},{"key":"22:4","surah":22,"ayah":4,"num":2599,"page":332,"words":[{"code":"пұ°","page":332,"end":false},{"code":"пұұ","page":332,"end":false},{"code":"пұІ","page":332,"end":false},{"code":"пұі","page":332,"end":false},{"code":"пұҙ","page":332,"end":false},{"code":"пұө","page":332,"end":false},{"code":"пұ¶","page":332,"end":false},{"code":"пұ·","page":332,"end":false},{"code":"пұё","page":332,"end":false},{"code":"пұ№","page":332,"end":false},{"code":"пұә","page":332,"end":false},{"code":"пұ»","page":332,"end":true}],"text":"ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ…ЩҺЩҶ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺШ§ЩҮЩҸ ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҸЩҮЩҸЫҘ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩҠЩҮЩҗ ШҘЩҗЩ„ЩҺЩүЩ° Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„ШіЩ‘ЩҺШ№ЩҗЩҠШұЩҗ"},{"key":"22:5","surah":22,"ayah":5,"num":2600,"page":332,"words":[{"code":"пұј","page":332,"end":false},{"code":"пұҪ","page":332,"end":false},{"code":"пұҫ","page":332,"end":false},{"code":"пұҝ","page":332,"end":false},{"code":"пІҖ","page":332,"end":false},{"code":"пІҒ","page":332,"end":false},{"code":"пІӮ","page":332,"end":false},{"code":"пІғ","page":332,"end":false},{"code":"пІ„","page":332,"end":false},{"code":"пІ…","page":332,"end":false},{"code":"пІҶ","page":332,"end":false},{"code":"пІҮ","page":332,"end":false},{"code":"пІҲ","page":332,"end":false},{"code":"пІү","page":332,"end":false},{"code":"пІҠ","page":332,"end":false},{"code":"пІӢ","page":332,"end":false},{"code":"пІҢ","page":332,"end":false},
e},{"code":"пұқ","page":356,"end":false},{"code":"пұһ","page":356,"end":false},{"code":"пұҹ","page":356,"end":false},{"code":"пұ ","page":356,"end":false},{"code":"пұЎ","page":356,"end":false},{"code":"пұўпұЈ","page":356,"end":false},{"code":"пұӨ","page":356,"end":false},{"code":"пұҘ","page":356,"end":false},{"code":"пұҰ","page":356,"end":false},{"code":"пұ§пұЁ","page":356,"end":false},{"code":"пұ©","page":356,"end":false},{"code":"пұӘ","page":356,"end":false},{"code":"пұ«","page":356,"end":false},{"code":"пұ¬","page":356,"end":false},{"code":"пұӯ","page":356,"end":false},{"code":"пұ®","page":356,"end":false},{"code":"пұҜ","page":356,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩғЩҸЩ„Щ‘ЩҺ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶ Щ…Щ‘ЩҺШ§Щ“ШЎЩҚЫў Ы– ЩҒЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶ ЩҠЩҺЩ…Щ’ШҙЩҗЩү Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ·Щ’ЩҶЩҗЩҮЩҗЫҰ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶ ЩҠЩҺЩ…Щ’ШҙЩҗЩү Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҗШ¬Щ’Щ„ЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶ ЩҠЩҺЩ…Щ’ШҙЩҗЩү Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШұЩ’ШЁЩҺШ№ЩҚЫў Ыҡ ЩҠЩҺШ®Щ’Щ„ЩҸЩӮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ§ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢЫӯ"},{"key":"24:46","surah":24,"ayah":46,"num":2837,"page":356,"words":[{"code":"пұ°","page":356,"end":false},{"code":"пұұ","page":356,"end":false},{"code":"пұІ","page":356,"end":false},{"code":"пұіпұҙ","page":356,"end":false},{"code":"пұө","page":356,"end":false},{"code":"пұ¶","page":356,"end":false},{"code":"пұ·","page":356,"end":false},{"code":"пұё","page":356,"end":false},{"code":"пұ№","page":356,"end":false},{"code":"пұә","page":356,"end":false},{"code":"пұ»","page":356,"end":false},{"code":"пұј","page":356,"end":true}],"text":"Щ„Щ‘ЩҺЩӮЩҺШҜЩ’ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§Щ“ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚЫў Щ…Щ‘ЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҚЫў Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҺЩҮЩ’ШҜЩҗЩү Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ШҘЩҗЩ„ЩҺЩүЩ° ШөЩҗШұЩҺЩ°Ш·ЩҚЫў Щ…Щ‘ЩҸШіЩ’ШӘЩҺЩӮЩҗЩҠЩ…ЩҚЫў"},{"key":"24:47","surah":24,"ayah":47,"num":2838,"page":356,"words":[{"code":"пұҪ","page":356,"end":false},{"code":"пұҫ","page"
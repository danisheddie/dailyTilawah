ode":"пІ‘","page":206,"end":false},{"code":"пІ’","page":206,"end":false},{"code":"пІ“","page":206,"end":false},{"code":"пІ”","page":206,"end":false},{"code":"пІ•","page":206,"end":false},{"code":"пІ–","page":206,"end":false},{"code":"пІ—","page":206,"end":false},{"code":"пІҳ","page":206,"end":false},{"code":"пІҷпІҡ","page":206,"end":false},{"code":"пІӣ","page":206,"end":false},{"code":"пІң","page":206,"end":false},{"code":"пІқ","page":206,"end":false},{"code":"пІһ","page":206,"end":false},{"code":"пІҹ","page":206,"end":false},{"code":"пІ ","page":206,"end":false},{"code":"пІЎ","page":206,"end":true}],"text":"Щ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҗШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’Щ…ЩҺШҜЩҗЩҠЩҶЩҺШ©Щҗ ЩҲЩҺЩ…ЩҺЩҶЩ’ ШӯЩҺЩҲЩ’Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ§ШЁЩҗ ШЈЩҺЩҶ ЩҠЩҺШӘЩҺШ®ЩҺЩ„Щ‘ЩҺЩҒЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶ ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШұЩ’ШәЩҺШЁЩҸЩҲШ§Ыҹ ШЁЩҗШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ Ш№ЩҺЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҗЩҮЩҗЫҰ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШөЩҗЩҠШЁЩҸЩҮЩҸЩ…Щ’ ШёЩҺЩ…ЩҺШЈЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ ЩҶЩҺШөЩҺШЁЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Щ…ЩҺШ®Щ’Щ…ЩҺШөЩҺШ©ЩҢЫӯ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ·ЩҺЩҖЩ”ЩҸЩҲЩҶЩҺ Щ…ЩҺЩҲЩ’Ш·ЩҗШҰЩӢЫӯШ§ ЩҠЩҺШәЩҗЩҠШёЩҸ ЩұЩ„Щ’ЩғЩҸЩҒЩ‘ЩҺШ§ШұЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩҶЩҺШ§Щ„ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩ’ Ш№ЩҺШҜЩҸЩҲЩ‘ЩҚЫў ЩҶЩ‘ЩҺЩҠЩ’Щ„ЩӢШ§ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҸШӘЩҗШЁЩҺ Щ„ЩҺЩҮЩҸЩ… ШЁЩҗЩҮЩҗЫҰ Ш№ЩҺЩ…ЩҺЩ„ЩҢЫӯ ШөЩҺЩҖЩ°Щ„ЩҗШӯЩҢ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҸШ¶ЩҗЩҠШ№ЩҸ ШЈЩҺШ¬Щ’ШұЩҺ ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"9:121","surah":9,"ayah":121,"num":1356,"page":206,"words":[{"code":"пІў","page":206,"end":false},{"code":"пІЈ","page":206,"end":false},{"code":"пІӨ","page":206,"end":false},{"code":"пІҘ","page":206,"end":false},{"code":"пІҰ","page":206,"end":false},{"code":"пІ§","page":206,"end":false},{"code":"пІЁ","page":206,"end":false},{"code":"пІ©","page":206,"end":false},{"code":"пІӘ","page":206,"end":false},{"code":"пІ«","page":206,"end":false},{"code":"пІ¬","page":206,"end":false},{"code":"пІӯ","page":206,"end":false},{"code":"пІ®","page":206,"end":false},{"code":"пІҜ","page":206,"end":false},{"code":"пІ°","page":206,"end":false},{"code":"пІұ","page":206,"end":false},{"code":"пІІ","page":206,"end":false},{"code":"пІі","page":206,"end":false},{"code":"пІҙ","page":206,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ЩҶЩҺЩҒЩҺЩӮЩҺШ©ЩӢЫӯ ШөЩҺШәЩҗЩҠШұЩҺШ©ЩӢЫӯ ЩҲЩҺЩ„ЩҺШ§ ЩғЩҺШЁЩҗЩҠШұЩҺШ©ЩӢЫӯ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩӮЩ’Ш·ЩҺШ№ЩҸЩҲЩҶЩҺ ЩҲЩҺШ§ШҜЩҗЩҠЩӢШ§ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҸШӘЩҗШЁЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҗЩҠЩҺШ¬Щ’ШІЩҗЩҠЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺШӯЩ’ШіЩҺЩҶЩҺ Щ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"9:122","surah":9,"ayah":122,"num":1357,"page":206,"words":[{"code":"пІө пІ¶","page":206,"end":false},{"code":"пІ·","page":206,"end":false},{"code":"пІё","page":206,"end":false},{"code":"пІ№","page":206,"end":false},{"code":"пІәпІ»","page":206,"end":false},{"code":"пІј","page":206,"end":false},{"code":"пІҪ","page":206,"end":false},{"code":"пІҫ","page":206,"end":false},{"code":"пІҝ","page":206,"end":false},{"code":"піҖ","page":206,"end":false},{"code":"піҒ","page":206,"end":false},{"code":"піӮ","page":206,"end":false},{"code":"піғ","page":206,"end":false},{"code":"пі„","page":206,"end":false},{"code":"пі…","page":206,"end":false},{"code":"піҶ","page":206,"end":false},{"code":"піҮ","page":206,"end":false},{"code":"піҲ","page":206,"end":false},{"code":"піү","page":206,"end":false},{"code":"піҠ","page":206,"end":false},{"code":"піӢ","page":206,"end":false},{"code":"піҢ","page":206,"end":false},{"code":"піҚ","page":206,"end":true}],"text":"Ыһ ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ Щ„ЩҗЩҠЩҺЩҶЩҒЩҗШұЩҸЩҲШ§Ыҹ ЩғЩҺШ§Щ“ЩҒЩ‘ЩҺШ©ЩӢЫӯ Ыҡ ЩҒЩҺЩ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩҶЩҺЩҒЩҺШұЩҺ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ЩҒЩҗШұЩ’ЩӮЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ш·ЩҺШ§Щ“ШҰЩҗЩҒЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҗЩҠЩҺШӘЩҺЩҒЩҺЩӮЩ‘ЩҺЩҮЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҗ ЩҲЩҺЩ„ЩҗЩҠЩҸЩҶШ°ЩҗШұЩҸЩҲШ§Ыҹ ЩӮЩҺЩҲЩ’Щ…ЩҺЩҮЩҸЩ…Щ’ ШҘЩҗШ°ЩҺШ§ ШұЩҺШ¬ЩҺШ№ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШӯЩ’Ш°ЩҺШұЩҸЩҲЩҶЩҺ"}]}
ЁЩ‘ЩҗШұЩҸ Ыҡ ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩ…Щ‘ЩҺШ§ ЩҠЩҸШҙЩ’ШұЩҗЩғЩҸЩҲЩҶЩҺ"},{"key":"59:24","surah":59,"ayah":24,"num":5150,"page":548,"words":[{"code":"пІІ","page":548,"end":false},{"code":"пІі","page":548,"end":false},{"code":"пІҙ","page":548,"end":false},{"code":"пІө","page":548,"end":false},{"code":"пІ¶пІ·","page":548,"end":false},{"code":"пІё","page":548,"end":false},{"code":"пІ№","page":548,"end":false},{"code":"пІәпІ»","page":548,"end":false},{"code":"пІј","page":548,"end":false},{"code":"пІҪ","page":548,"end":false},{"code":"пІҫ","page":548,"end":false},{"code":"пІҝ","page":548,"end":false},{"code":"піҖ","page":548,"end":false},{"code":"піҒпіӮ","page":548,"end":false},{"code":"піғ","page":548,"end":false},{"code":"пі„","page":548,"end":false},{"code":"пі…","page":548,"end":false},{"code":"піҶ","page":548,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Ш®ЩҺЩҖЩ°Щ„ЩҗЩӮЩҸ ЩұЩ„Щ’ШЁЩҺШ§ШұЩҗШҰЩҸ ЩұЩ„Щ’Щ…ЩҸШөЩҺЩҲЩ‘ЩҗШұЩҸ Ы– Щ„ЩҺЩҮЩҸ ЩұЩ„Щ’ШЈЩҺШіЩ’Щ…ЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ’ШӯЩҸШіЩ’ЩҶЩҺЩүЩ° Ыҡ ЩҠЩҸШіЩҺШЁЩ‘ЩҗШӯЩҸ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы– ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"}]}
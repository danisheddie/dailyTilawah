":"пұҶ","page":548,"end":false},{"code":"пұҮпұҲ","page":548,"end":false},{"code":"пұү","page":548,"end":false},{"code":"пұҠ","page":548,"end":false},{"code":"пұӢ","page":548,"end":false},{"code":"пұҢ","page":548,"end":true}],"text":"ЩҒЩҺЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШӘЩҺЩҮЩҸЩ…ЩҺШ§Щ“ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҺЩҠЩ’ЩҶЩҗ ЩҒЩҗЩҠЩҮЩҺШ§ Ыҡ ЩҲЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш¬ЩҺШІЩҺЩ°Щ“ШӨЩҸШ§Ыҹ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"59:18","surah":59,"ayah":18,"num":5144,"page":548,"words":[{"code":"пұҚ","page":548,"end":false},{"code":"пұҺ","page":548,"end":false},{"code":"пұҸ","page":548,"end":false},{"code":"пұҗ","page":548,"end":false},{"code":"пұ‘","page":548,"end":false},{"code":"пұ’","page":548,"end":false},{"code":"пұ“","page":548,"end":false},{"code":"пұ”","page":548,"end":false},{"code":"пұ•","page":548,"end":false},{"code":"пұ–пұ—","page":548,"end":false},{"code":"пұҳ","page":548,"end":false},{"code":"пұҷпұҡ","page":548,"end":false},{"code":"пұӣ","page":548,"end":false},{"code":"пұң","page":548,"end":false},{"code":"пұқ","page":548,"end":false},{"code":"пұһ","page":548,"end":false},{"code":"пұҹ","page":548,"end":false},{"code":"пұ ","page":548,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩ„Щ’ШӘЩҺЩҶШёЩҸШұЩ’ ЩҶЩҺЩҒЩ’ШіЩҢЫӯ Щ…Щ‘ЩҺШ§ ЩӮЩҺШҜЩ‘ЩҺЩ…ЩҺШӘЩ’ Щ„ЩҗШәЩҺШҜЩҚЫў Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш®ЩҺШЁЩҗЩҠШұЩҢЫў ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"59:19","surah":59,"ayah":19,"num":5145,"page":548,"words":[{"code":"пұЎ","page":548,"end":false},{"code":"пұў","page":548,"end":false},{"code":"пұЈ","page":548,"end":false},{"code":"пұӨ","page":548,"end":false},{"code":"пұҘ","page":548,"end":false},{"code":"пұҰ","page":548,"end":false},{"code":"пұ§пұЁ","page":548,"end":false},{"code":"пұ©","page":548,"end":false},{"code":"пұӘ","page":548,"end":false},{"code":"пұ«","page":548,"end":false},{"code":"пұ¬","page":548,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ЩғЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҶЩҺШіЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҒЩҺШЈЩҺЩҶШіЩҺЩүЩ°ЩҮЩҸЩ…Щ’ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"59:20","surah":59,"ayah":20,"num":5146,"page":548,"words":[{"code":"пұӯ","page":548,"end":false},{"code":"пұ®","page":548,"end":false},{"code":"пұҜ","page":548,"end":false},{"code":"пұ°","page":548,"end":false},{"code":"пұұ","page":548,"end":false},{"code":"пұІпұі","page":548,"end":false},{"code":"пұҙ","page":548,"end":false},{"code":"пұө","page":548,"end":false},{"code":"пұ¶","page":548,"end":false},{"code":"пұ·","page":548,"end":false},{"code":"пұё","page":548,"end":true}],"text":"Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺЩҲЩҗЩүЩ“ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҲЩҺШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„Щ’Ш¬ЩҺЩҶЩ‘ЩҺШ©Щҗ Ыҡ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„Щ’Ш¬ЩҺЩҶЩ‘ЩҺШ©Щҗ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҒЩҺШ§Щ“ШҰЩҗШІЩҸЩҲЩҶЩҺ"},{"key":"59:21","surah":59,"ayah":21,"num":5147,"page":548,"words":[{"code":"пұ№","page":548,"end":false},{"code":"пұә","page":548,"end":false},{"code":"пұ»","page":548,"end":false},{"code":"пұј","page":548,"end":false},{"code":"пұҪ","page":548,"end":false},{"code":"пұҫ","page":548,"end":false},{"code":"пұҝ","page":548,"end":false},{"code":"пІҖ","page":548,"end":false},{"code":"пІҒ","page":548,"end":false},{"code":"пІӮ","page":548,"end":false},{"code":"пІғ","page":548,"end":false},{"code":"пІ„пІ…","page":548,"end":false},{"code":"пІҶ","page":548,"end":false},{"code":"пІҮ","page":548,"end":false},{"code":"пІҲ","page":548,"end":false},{"code":"пІү","page":548,"end":false},{"code":"пІҠ","page":548,"end":false},{"code":"пІӢ","page":548,"end":false},{"code":"пІҢ","page":548,"end":true}],"text":"Щ„ЩҺЩҲЩ’ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° Ш¬ЩҺШЁЩҺЩ„ЩҚЫў Щ„Щ‘ЩҺШұЩҺШЈЩҺЩҠЩ’ШӘЩҺЩҮЩҸЫҘ Ш®ЩҺЩҖЩ°ШҙЩҗШ№ЩӢЫӯШ§ Щ…Щ‘ЩҸШӘЩҺШөЩҺШҜЩ‘ЩҗШ№ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ Ш®ЩҺШҙЩ’ЩҠЩҺШ©Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺШӘЩҗЩ„Щ’ЩғЩҺ ЩұЩ„Щ’ШЈЩҺЩ…Щ’Ш«ЩҺЩҖЩ°Щ„ЩҸ ЩҶЩҺШ¶Щ’ШұЩҗШЁЩҸЩҮЩҺШ§ Щ„ЩҗЩ„ЩҶ
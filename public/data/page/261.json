e":261,"end":false},{"code":"пұғ","page":261,"end":false},{"code":"пұ„","page":261,"end":false},{"code":"пұ…","page":261,"end":false},{"code":"пұҶ","page":261,"end":false},{"code":"пұҮпұҲ","page":261,"end":false},{"code":"пұү","page":261,"end":false},{"code":"пұҠ","page":261,"end":false},{"code":"пұӢ","page":261,"end":true}],"text":"Щ…ЩҸЩҮЩ’Ш·ЩҗШ№ЩҗЩҠЩҶЩҺ Щ…ЩҸЩӮЩ’ЩҶЩҗШ№ЩҗЩү ШұЩҸШЎЩҸЩҲШіЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШұЩ’ШӘЩҺШҜЩ‘ЩҸ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ш·ЩҺШұЩ’ЩҒЩҸЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺШЈЩҺЩҒЩ’ЩҖЩ”ЩҗШҜЩҺШӘЩҸЩҮЩҸЩ…Щ’ ЩҮЩҺЩҲЩҺШ§Щ“ШЎЩҢЫӯ"},{"key":"14:44","surah":14,"ayah":44,"num":1794,"page":261,"words":[{"code":"пұҢ","page":261,"end":false},{"code":"пұҚ","page":261,"end":false},{"code":"пұҺ","page":261,"end":false},{"code":"пұҸ","page":261,"end":false},{"code":"пұҗ","page":261,"end":false},{"code":"пұ‘","page":261,"end":false},{"code":"пұ’","page":261,"end":false},{"code":"пұ“","page":261,"end":false},{"code":"пұ”","page":261,"end":false},{"code":"пұ•","page":261,"end":false},{"code":"пұ–","page":261,"end":false},{"code":"пұ—","page":261,"end":false},{"code":"пұҳ","page":261,"end":false},{"code":"пұҷ","page":261,"end":false},{"code":"пұҡ","page":261,"end":false},{"code":"пұӣ","page":261,"end":false},{"code":"пұңпұқ","page":261,"end":false},{"code":"пұһ","page":261,"end":false},{"code":"пұҹ","page":261,"end":false},{"code":"пұ ","page":261,"end":false},{"code":"пұЎ","page":261,"end":false},{"code":"пұў","page":261,"end":false},{"code":"пұЈ","page":261,"end":false},{"code":"пұӨ","page":261,"end":false},{"code":"пұҘ","page":261,"end":false},{"code":"пұҰ","page":261,"end":false},{"code":"пұ§","page":261,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶШ°ЩҗШұЩҗ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ЩҒЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§Щ“ ШЈЩҺШ®Щ‘ЩҗШұЩ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҚЫў ЩӮЩҺШұЩҗЩҠШЁЩҚЫў ЩҶЩ‘ЩҸШ¬ЩҗШЁЩ’ ШҜЩҺШ№Щ’ЩҲЩҺШӘЩҺЩғЩҺ ЩҲЩҺЩҶЩҺШӘЩ‘ЩҺШЁЩҗШ№Щҗ ЩұЩ„ШұЩ‘ЩҸШіЩҸЩ„ЩҺ Ы— ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩӮЩ’ШіЩҺЩ…Щ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Щ…ЩҺШ§ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШІЩҺЩҲЩҺШ§Щ„ЩҚЫў"},{"key":"14:45","surah":14,"ayah":45,"num":1795,"page":261,"words":[{"code":"пұЁ","page":261,"end":false},{"code":"пұ©","page":261,"end":false},{"code":"пұӘ","page":261,"end":false},{"code":"пұ«","page":261,"end":false},{"code":"пұ¬","page":261,"end":false},{"code":"пұӯ","page":261,"end":false},{"code":"пұ®","page":261,"end":false},{"code":"пұҜ","page":261,"end":false},{"code":"пұ°","page":261,"end":false},{"code":"пұұ","page":261,"end":false},{"code":"пұІ","page":261,"end":false},{"code":"пұі","page":261,"end":false},{"code":"пұҙ","page":261,"end":false},{"code":"пұө","page":261,"end":false},{"code":"пұ¶","page":261,"end":true}],"text":"ЩҲЩҺШіЩҺЩғЩҺЩҶШӘЩҸЩ…Щ’ ЩҒЩҗЩү Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҶЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩҒЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ШЁЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШ¶ЩҺШұЩҺШЁЩ’ЩҶЩҺШ§ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺЩ…Щ’Ш«ЩҺШ§Щ„ЩҺ"},{"key":"14:46","surah":14,"ayah":46,"num":1796,"page":261,"words":[{"code":"пұ·","page":261,"end":false},{"code":"пұё","page":261,"end":false},{"code":"пұ№","page":261,"end":false},{"code":"пұә","page":261,"end":false},{"code":"пұ»","page":261,"end":false},{"code":"пұј","page":261,"end":false},{"code":"пұҪ","page":261,"end":false},{"code":"пұҫ","page":261,"end":false},{"code":"пұҝ","page":261,"end":false},{"code":"пІҖ","page":261,"end":false},{"code":"пІҒ","page":261,"end":false},{"code":"пІӮ","page":261,"end":false},{"code":"пІғ","page":261,"end":true}],"text":"ЩҲЩҺЩӮЩҺШҜЩ’ Щ…ЩҺЩғЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҺЩғЩ’ШұЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШ№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺЩғЩ’ШұЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҺЩғЩ’ШұЩҸЩҮЩҸЩ…Щ’ Щ„ЩҗШӘЩҺШІЩҸЩҲЩ„ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸ ЩұЩ„Щ’Ш¬ЩҗШЁЩҺШ§Щ„ЩҸ"},{"key":"14:47","surah":14,"ayah":47,"num":1797,"page":261,"words":[{"code":"пІ„","page":261,"end":false},{"code":"пІ…","page":261,"end":false},{"code":"пІҶ","page":261,"end":false},{"code":"пІҮ","page":261,"end":false},{"code":"пІҲ","page":261,"end":false},{"code":"пІүпІҠ","page":261,"end":false},{"code":"пІӢ","page":261,"end":false},{"code":"пІҢ","page":261,"end":false},{"code":"пІҚ","page":261,"end":false},{"code":"пІҺ","page":261,"end":false},{"code":"пІҸ","page":261,"end":false},{"code":"пІҗ","page":261,"end":true}],"text":"ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШӯЩ’ШіЩҺШЁЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҸШ®Щ’Щ„ЩҗЩҒЩҺ ЩҲЩҺШ№Щ’ШҜЩҗЩҮЩҗЫҰ ШұЩҸШіЩҸЩ„ЩҺЩҮЩҸЫҘЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺШІЩҗЩҠШІЩҢЫӯ Ш°ЩҸЩҲ ЩұЩҶШӘЩҗЩӮЩҺШ§Щ…ЩҚЫў"},{"key":"14:48","surah":14,"ayah":48,"num":1798,"page":261,"words":[{"code":"пІ‘","page":261,"end":false},{"code":"пІ’","page":261,"end":false},{"code":"пІ“","page":261,"end":false},{"code":"пІ”","page":261,"end":false},{"code":"пІ•","page":261,"end":false},{"code":"пІ–пІ—","page":261,"end":false},{"code":"пІҳ","page":261,"end":false},{"code":"пІҷ","page":261,"end":false},{"code":"пІҡ","page":261,"end":false},{"code":"пІӣ","page":261,"end":false},{"code":"пІң","page":261,"end":true}],"text":"ЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҸШЁЩҺШҜЩ‘ЩҺЩ„ЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ ШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҸ Ы– ЩҲЩҺШЁЩҺШұЩҺШІЩҸЩҲШ§Ыҹ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ЩҲЩҺЩ°ШӯЩҗШҜЩҗ ЩұЩ„Щ’ЩӮЩҺЩҮЩ‘ЩҺШ§ШұЩҗ"},{"key":"14:49","surah":14,"ayah":49,"num":1799,"page":261,"words":[{"code":"пІқ","page":261,"end":false},{"code":"пІһ","page":261,"end":false},{"code":"пІҹ","page":261,"end":false},{"code":"пІ ","page":261,"end":false},{"code":"пІЎ","page":261,"end":false},{"code":"пІў","page":261,"end":false},{"code":"пІЈ","page":261,"end":true}],"text":"ЩҲЩҺШӘЩҺШұЩҺЩү ЩұЩ„Щ’Щ…ЩҸШ¬Щ’ШұЩҗЩ…ЩҗЩҠЩҶЩҺ ЩҠЩҺЩҲЩ’Щ…ЩҺШҰЩҗШ°ЩҚЫў Щ…Щ‘ЩҸЩӮЩҺШұЩ‘ЩҺЩҶЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШөЩ’ЩҒЩҺШ§ШҜЩҗ"},{"key":"14:50","surah":14,"ayah":50,"num":1800,"page":261,"words":[{"code":"пІӨ","page":261,"end":false},{"code":"пІҘ","page":261,"end":false},{"code":"пІҰ","page":261,"end":false},{"code":"пІ§","page":261,"end":false},{"code":"пІЁ","page":261,"end":false},{"code":"пІ©","page":261,"end":false},{"code":"пІӘ","page":261,"end":true}],"text":"ШіЩҺШұЩҺШ§ШЁЩҗЩҠЩ„ЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШ·ЩҗШұЩҺШ§ЩҶЩҚЫў ЩҲЩҺШӘЩҺШәЩ’ШҙЩҺЩүЩ° ЩҲЩҸШ¬ЩҸЩҲЩҮЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҸ"},{"key":"14:51","surah":14,"ayah":51,"num":1801,"page":261,"words":[{"code":"пІ«","page":261,"end":false},{"code":"пІ¬","page":261,"end":false},{"code":"пІӯ","page":261,"end":false},{"code":"пІ®","page":261,"end":false},{"code":"пІҜ","page":261,"end":false},{"code":"пІ°пІұ","page":261,"end":false},{"code":"пІІ","page":261,"end":false},{"code":"пІі","page":261,"end":false},{"code":"пІҙ","page":261,"end":false},{"code":"пІө","page":261,"end":false},{"code":"пІ¶","page":261,"end":true}],"text":"Щ„ЩҗЩҠЩҺШ¬Щ’ШІЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩғЩҸЩ„Щ‘ЩҺ ЩҶЩҺЩҒЩ’ШіЩҚЫў Щ…Щ‘ЩҺШ§ ЩғЩҺШіЩҺШЁЩҺШӘЩ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШіЩҺШұЩҗЩҠШ№ЩҸ ЩұЩ„Щ’ШӯЩҗШіЩҺШ§ШЁЩҗ"},{"key":"14:52","surah":14,"ayah":52,"num":1802,"page":261,"words":[{"code":"пІ·","page":261,"end":false},{"code":"пІё","page":261,"end":false},{"code":"пІ№","page":261,"end":false},{"code":"пІә","page":261,"end":false},{"code":"пІ»","page":261,"end":false},{"code":"пІј","page":261,"end":false},{"code":"пІҪ","page":261,"end":false},{"code":"пІҫ","page":261,"end":false},{"code":"пІҝ","page":261,"end":false},{"code":"піҖ","page":261,"end":false},{"code":"піҒ","page":261,"end":false},{"code":"піӮ","page":261,"end":false},{"code":"піғ","page":261,"end":false},{"code":"пі„","page":261,"end":true}],"text":"ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ШЁЩҺЩ„ЩҺЩҖЩ°ШәЩҢЫӯ Щ„Щ‘ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺЩ„ЩҗЩҠЩҸЩҶШ°ЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩ„ЩҗЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҢЫӯ ЩҲЩҺЩ°ШӯЩҗШҜЩҢЫӯ ЩҲЩҺЩ„ЩҗЩҠЩҺШ°Щ‘ЩҺЩғЩ‘ЩҺШұЩҺ ШЈЩҸЩҲЫҹЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЈЩҺЩ„Щ’ШЁЩҺЩҖЩ°ШЁЩҗ"}]}
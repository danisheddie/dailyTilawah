","page":28,"end":false},{"code":"пұӮ","page":28,"end":false},{"code":"пұғ","page":28,"end":false},{"code":"пұ„","page":28,"end":false},{"code":"пұ…","page":28,"end":false},{"code":"пұҶ","page":28,"end":false},{"code":"пұҮ","page":28,"end":false},{"code":"пұҲ","page":28,"end":false},{"code":"пұү","page":28,"end":false},{"code":"пұҠ","page":28,"end":false},{"code":"пұӢ","page":28,"end":false},{"code":"пұҢпұҚ","page":28,"end":false},{"code":"пұҺ","page":28,"end":false},{"code":"пұҸ","page":28,"end":false},{"code":"пұҗ","page":28,"end":false},{"code":"пұ‘","page":28,"end":false},{"code":"пұ’","page":28,"end":true}],"text":"ЩҒЩҺЩ…ЩҺЩҶЩ’ Ш®ЩҺШ§ЩҒЩҺ Щ…ЩҗЩҶ Щ…Щ‘ЩҸЩҲШөЩҚЫў Ш¬ЩҺЩҶЩҺЩҒЩӢШ§ ШЈЩҺЩҲЩ’ ШҘЩҗШ«Щ’Щ…ЩӢЫӯШ§ ЩҒЩҺШЈЩҺШөЩ’Щ„ЩҺШӯЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺШ§Щ“ ШҘЩҗШ«Щ’Щ…ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:183","surah":2,"ayah":183,"num":190,"page":28,"words":[{"code":"пұ“","page":28,"end":false},{"code":"пұ”","page":28,"end":false},{"code":"пұ•","page":28,"end":false},{"code":"пұ–","page":28,"end":false},{"code":"пұ—","page":28,"end":false},{"code":"пұҳ","page":28,"end":false},{"code":"пұҷ","page":28,"end":false},{"code":"пұҡ","page":28,"end":false},{"code":"пұӣ","page":28,"end":false},{"code":"пұң","page":28,"end":false},{"code":"пұқ","page":28,"end":false},{"code":"пұһ","page":28,"end":false},{"code":"пұҹ","page":28,"end":false},{"code":"пұ ","page":28,"end":false},{"code":"пұЎ","page":28,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„ШөЩ‘ЩҗЩҠЩҺШ§Щ…ЩҸ ЩғЩҺЩ…ЩҺШ§ ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҸЩ…Щ’ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"2:184","surah":2,"ayah":184,"num":191,"page":28,"words":[{"code":"пұў","page":28,"end":false},{"code":"пұЈпұӨ","page":28,"end":false},{"code":"пұҘ","page":28,"end":false},{"code":"пұҰ","page":28,"end":false},{"code":"пұ§","page":28,"end":false},{"code":"пұЁ","page":28,"end":false},{"code":"пұ©","page":28,"end":false},{"code":"пұӘ","page":28,"end":false},{"code":"пұ«","page":28,"end":false},{"code":"пұ¬","page":28,"end":false},{"code":"пұӯ","page":28,"end":false},{"code":"пұ®","page":28,"end":false},{"code":"пұҜпұ°","page":28,"end":false},{"code":"пұұ","page":28,"end":false},{"code":"пұІ","page":28,"end":false},{"code":"пұі","page":28,"end":false},{"code":"пұҙ","page":28,"end":false},{"code":"пұө","page":28,"end":false},{"code":"пұ¶пұ·","page":28,"end":false},{"code":"пұё","page":28,"end":false},{"code":"пұ№","page":28,"end":false},{"code":"пұә","page":28,"end":false},{"code":"пұ»","page":28,"end":false},{"code":"пұј","page":28,"end":false},{"code":"пұҪпұҫ","page":28,"end":false},{"code":"пұҝ","page":28,"end":false},{"code":"пІҖ","page":28,"end":false},{"code":"пІҒ","page":28,"end":false},{"code":"пІӮ","page":28,"end":false},{"code":"пІғ","page":28,"end":false},{"code":"пІ„","page":28,"end":false},{"code":"пІ…","page":28,"end":false},{"code":"пІҶ","page":28,"end":true}],"text":"ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩӢЫӯШ§ Щ…Щ‘ЩҺШ№Щ’ШҜЩҸЩҲШҜЩҺЩ°ШӘЩҚЫў Ыҡ ЩҒЩҺЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҗЩҶЩғЩҸЩ… Щ…Щ‘ЩҺШұЩҗЩҠШ¶ЩӢШ§ ШЈЩҺЩҲЩ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШіЩҺЩҒЩҺШұЩҚЫў ЩҒЩҺШ№ЩҗШҜЩ‘ЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚ ШЈЩҸШ®ЩҺШұЩҺ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸШ·ЩҗЩҠЩӮЩҸЩҲЩҶЩҺЩҮЩҸЫҘ ЩҒЩҗШҜЩ’ЩҠЩҺШ©ЩҢЫӯ Ш·ЩҺШ№ЩҺШ§Щ…ЩҸ Щ…ЩҗШіЩ’ЩғЩҗЩҠЩҶЩҚЫў Ы– ЩҒЩҺЩ…ЩҺЩҶ ШӘЩҺШ·ЩҺЩҲЩ‘ЩҺШ№ЩҺ Ш®ЩҺЩҠЩ’ШұЩӢЫӯШ§ ЩҒЩҺЩҮЩҸЩҲЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЫҘ Ыҡ ЩҲЩҺШЈЩҺЩҶ ШӘЩҺШөЩҸЩҲЩ…ЩҸЩҲШ§Ыҹ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы– ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:185","surah":2,"ayah":185,"num":192,"page":28,"words":[{"code":"пІҮ","page":28,"end":false},{"code":"пІҲ","page":28,"end":false},{"code":"пІү","page":28,"end":false},{"code":"пІҠ","page":28,"end":false},{"code":"пІӢ","page":28,"end":false},{"code":"пІҢ","page":28,"end":false},{"code":"пІҚ","page":28,"end":false},{"code":"пІҺ","page":28,"end":false},{"code":"пІҸ","page":28,"end":false},{"code":"пІҗ","page":28,"end":false},{"code":"пІ‘","page":28,"end":false},{"code":"пІ’пІ“","page":28,"end":false},{"code":"пІ”","page":28,"end":false},{"code":"пІ•","page":28,"end":false},{"code":"пІ–","page":28,"end":false},{"code":"пІ—","page":28,"end":false},{"code":"пІҳпІҷ","page":28,"end":false},{"code":"пІҡ","page":28,"end":false},{"code":"пІӣ","page":28,"end":false},{"code":"пІң","page":28,"end":false},{"code":"пІқ","page":28,"end":false},{"code":"пІһ","page":28,"end":false},{"code":"пІҹ","page":28,"end":false},{"code":"пІ ","page":28,"end":false},{"code":"пІЎ","page":28,"end":false},{"code":"пІў","page":28,"end":false},{"code":"пІЈпІӨ","page":28,"end":false},{"code":"пІҘ","page":28,"end":false},{"code":"пІҰ","page":28,"end":false},{"code":"пІ§","page":28,"end":false},{"code":"пІЁ","page":28,"end":false},{"code":"пІ©","page":28,"end":false},{"code":"пІӘ","page":28,"end":false},{"code":"пІ«","page":28,"end":false},{"code":"пІ¬","page":28,"end":false},{"code":"пІӯ","page":28,"end":false},{"code":"пІ®","page":28,"end":false},{"code":"пІҜ","page":28,"end":false},{"code":"пІ°","page":28,"end":false},{"code":"пІұ","page":28,"end":false},{"code":"пІІ","page":28,"end":false},{"code":"пІі","page":28,"end":false},{"code":"пІҙ","page":28,"end":false},{"code":"пІө","page":28,"end":false},{"code":"пІ¶","page":28,"end":true}],"text":"ШҙЩҺЩҮЩ’ШұЩҸ ШұЩҺЩ…ЩҺШ¶ЩҺШ§ЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ЩҒЩҗЩҠЩҮЩҗ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҸ ЩҮЩҸШҜЩӢЫӯЩү Щ„Щ‘ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’ЩҒЩҸШұЩ’ЩӮЩҺШ§ЩҶЩҗ Ыҡ ЩҒЩҺЩ…ЩҺЩҶ ШҙЩҺЩҮЩҗШҜЩҺ Щ…ЩҗЩҶЩғЩҸЩ…ЩҸ ЩұЩ„ШҙЩ‘ЩҺЩҮЩ’ШұЩҺ ЩҒЩҺЩ„Щ’ЩҠЩҺШөЩҸЩ…Щ’ЩҮЩҸ Ы– ЩҲЩҺЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҺШұЩҗЩҠШ¶ЩӢШ§ ШЈЩҺЩҲЩ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШіЩҺЩҒЩҺШұЩҚЫў ЩҒЩҺШ№ЩҗШҜЩ‘ЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚ ШЈЩҸШ®ЩҺШұЩҺ Ы— ЩҠЩҸШұЩҗЩҠШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҠЩҸШіЩ’ШұЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸШұЩҗЩҠШҜЩҸ ШЁЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҸШіЩ’ШұЩҺ ЩҲЩҺЩ„ЩҗШӘЩҸЩғЩ’Щ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҗШҜЩ‘ЩҺШ©ЩҺ ЩҲЩҺЩ„ЩҗШӘЩҸЩғЩҺШЁЩ‘ЩҗШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺШ§ ЩҮЩҺШҜЩҺЩүЩ°ЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШҙЩ’ЩғЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"2:186","surah":2,"ayah":186,"num":193,"page":28,"words":[{"code":"пІ·","page":28,"end":false},{"code":"пІё","page":28,"end":false},{"code":"пІ№","page":28,"end":false},{"code":"пІә","page":28,"end":false},{"code":"пІ»","page":28,"end":false},{"code":"пІјпІҪ","page":28,"end":false},{"code":"пІҫ","page":28,"end":false},{"code":"пІҝ","page":28,"end":false},{"code":"піҖ","page":28,"end":false},{"code":"піҒ","page":28,"end":false},{"code":"піӮпіғ","page":28,"end":false},{"code":"пі„","page":28,"end":false},{"code":"пі…","page":28,"end":false},{"code":"піҶ","page":28,"end":false},{"code":"піҮ","page":28,"end":false},{"code":"піҲ","page":28,"end":false},{"code":"піү","page":28,"end":false},{"code":"піҠ","page":28,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШіЩҺШЈЩҺЩ„ЩҺЩғЩҺ Ш№ЩҗШЁЩҺШ§ШҜЩҗЩү Ш№ЩҺЩҶЩ‘ЩҗЩү ЩҒЩҺШҘЩҗЩҶЩ‘ЩҗЩү ЩӮЩҺШұЩҗЩҠШЁЩҢ Ы– ШЈЩҸШ¬ЩҗЩҠШЁЩҸ ШҜЩҺШ№Щ’ЩҲЩҺШ©ЩҺ ЩұЩ„ШҜЩ‘ЩҺШ§Ш№Щҗ ШҘЩҗШ°ЩҺШ§ ШҜЩҺШ№ЩҺШ§ЩҶЩҗ Ы– ЩҒЩҺЩ„Щ’ЩҠЩҺШіЩ’ШӘЩҺШ¬ЩҗЩҠШЁЩҸЩҲШ§Ыҹ Щ„ЩҗЩү ЩҲЩҺЩ„Щ’ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩү Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШұЩ’ШҙЩҸШҜЩҸЩҲЩҶЩҺ"}]}
:9,"words":[{"code":"пұҒ","page":9,"end":false},{"code":"пұӮ","page":9,"end":false},{"code":"пұғ","page":9,"end":false},{"code":"пұ„","page":9,"end":false},{"code":"пұ…","page":9,"end":false},{"code":"пұҶ","page":9,"end":false},{"code":"пұҮ","page":9,"end":false},{"code":"пұҲ","page":9,"end":false},{"code":"пұү","page":9,"end":false},{"code":"пұҠ","page":9,"end":false},{"code":"пұӢ","page":9,"end":false},{"code":"пұҢ","page":9,"end":false},{"code":"пұҚ","page":9,"end":false},{"code":"пұҺ","page":9,"end":false},{"code":"пұҸ","page":9,"end":false},{"code":"пұҗ","page":9,"end":false},{"code":"пұ‘","page":9,"end":false},{"code":"пұ’пұ“","page":9,"end":false},{"code":"пұ”","page":9,"end":false},{"code":"пұ•","page":9,"end":false},{"code":"пұ–","page":9,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ЩӮЩҸЩ„Щ’ЩҶЩҺШ§ ЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗ ЩұЩ„Щ’ЩӮЩҺШұЩ’ЩҠЩҺШ©ЩҺ ЩҒЩҺЩғЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШӯЩҺЩҠЩ’Ш«ЩҸ ШҙЩҗШҰЩ’ШӘЩҸЩ…Щ’ ШұЩҺШәЩҺШҜЩӢЫӯШ§ ЩҲЩҺЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЁЩҺШ§ШЁЩҺ ШіЩҸШ¬Щ‘ЩҺШҜЩӢЫӯШ§ ЩҲЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ШӯЩҗШ·Щ‘ЩҺШ©ЩҢЫӯ ЩҶЩ‘ЩҺШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩғЩҸЩ…Щ’ Ш®ЩҺШ·ЩҺЩҖЩ°ЩҠЩҺЩҖЩ°ЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШіЩҺЩҶЩҺШІЩҗЩҠШҜЩҸ ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"2:59","surah":2,"ayah":59,"num":66,"page":9,"words":[{"code":"пұ—","page":9,"end":false},{"code":"пұҳ","page":9,"end":false},{"code":"пұҷ","page":9,"end":false},{"code":"пұҡ","page":9,"end":false},{"code":"пұӣ","page":9,"end":false},{"code":"пұң","page":9,"end":false},{"code":"пұқ","page":9,"end":false},{"code":"пұһ","page":9,"end":false},{"code":"пұҹ","page":9,"end":false},{"code":"пұ ","page":9,"end":false},{"code":"пұЎ","page":9,"end":false},{"code":"пұў","page":9,"end":false},{"code":"пұЈ","page":9,"end":false},{"code":"пұӨ","page":9,"end":false},{"code":"пұҘ","page":9,"end":false},{"code":"пұҰ","page":9,"end":false},{"code":"пұ§","page":9,"end":false},{"code":"пұЁ","page":9,"end":false},{"code":"пұ©","page":9,"end":true}],"text":"ЩҒЩҺШЁЩҺШҜЩ‘ЩҺЩ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ЩӮЩҺЩҲЩ’Щ„ЩӢШ§ ШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ШұЩҗШ¬Щ’ШІЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩҒЩ’ШіЩҸЩӮЩҸЩҲЩҶЩҺ"},{"key":"2:60","surah":2,"ayah":60,"num":67,"page":9,"words":[{"code":"пұӘ пұ«","page":9,"end":false},{"code":"пұ¬","page":9,"end":false},{"code":"пұӯ","page":9,"end":false},{"code":"пұ®","page":9,"end":false},{"code":"пұҜ","page":9,"end":false},{"code":"пұ°","page":9,"end":false},{"code":"пұұ","page":9,"end":false},{"code":"пұІпұі","page":9,"end":false},{"code":"пұҙ","page":9,"end":false},{"code":"пұө","page":9,"end":false},{"code":"пұ¶","page":9,"end":false},{"code":"пұ·","page":9,"end":false},{"code":"пұёпұ№","page":9,"end":false},{"code":"пұә","page":9,"end":false},{"code":"пұ»","page":9,"end":false},{"code":"пұј","page":9,"end":false},{"code":"пұҪ","page":9,"end":false},{"code":"пұҫпұҝ","page":9,"end":false},{"code":"пІҖ","page":9,"end":false},{"code":"пІҒ","page":9,"end":false},{"code":"пІӮ","page":9,"end":false},{"code":"пІғ","page":9,"end":false},{"code":"пІ„","page":9,"end":false},{"code":"пІ…","page":9,"end":false},{"code":"пІҶ","page":9,"end":false},{"code":"пІҮ","page":9,"end":false},{"code":"пІҲ","page":9,"end":false},{"code":"пІү","page":9,"end":false},{"code":"пІҠ","page":9,"end":true}],"text":"Ыһ ЩҲЩҺШҘЩҗШ°Щҗ ЩұШіЩ’ШӘЩҺШіЩ’ЩӮЩҺЩүЩ° Щ…ЩҸЩҲШіЩҺЩүЩ° Щ„ЩҗЩӮЩҺЩҲЩ’Щ…ЩҗЩҮЩҗЫҰ ЩҒЩҺЩӮЩҸЩ„Щ’ЩҶЩҺШ§ ЩұШ¶Щ’ШұЩҗШЁ ШЁЩ‘ЩҗШ№ЩҺШөЩҺШ§ЩғЩҺ ЩұЩ„Щ’ШӯЩҺШ¬ЩҺШұЩҺ Ы– ЩҒЩҺЩұЩҶЩҒЩҺШ¬ЩҺШұЩҺШӘЩ’ Щ…ЩҗЩҶЩ’ЩҮЩҸ ЩұШ«Щ’ЩҶЩҺШӘЩҺШ§ Ш№ЩҺШҙЩ’ШұЩҺШ©ЩҺ Ш№ЩҺЩҠЩ’ЩҶЩӢЫӯШ§ Ы– ЩӮЩҺШҜЩ’ Ш№ЩҺЩ„ЩҗЩ…ЩҺ ЩғЩҸЩ„Щ‘ЩҸ ШЈЩҸЩҶЩҺШ§ШіЩҚЫў Щ…Щ‘ЩҺШҙЩ’ШұЩҺШЁЩҺЩҮЩҸЩ…Щ’ Ы– ЩғЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҲЩҺЩұШҙЩ’ШұЩҺШЁЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ШұЩ‘ЩҗШІЩ’ЩӮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ№Щ’Ш«ЩҺЩҲЩ’Ш§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ…ЩҸЩҒЩ’ШіЩҗШҜЩҗЩҠЩҶЩҺ"},{"key":"2:61","surah":2,"ayah":61,"num":68,"page":9,"words":[{"code":"пІӢ","page":9,"end":false},{"code":"пІҢ","page":9,"end":false},{"code":"пІҚ","page":9,"end":false},{"code":"пІҺ","page":9,"end":false},{"code":"пІҸ","page":9,"end":false},{"code":"пІҗ","page":9,"end":false},{"code":"пІ‘","page":9,"end":false},{"code":"пІ’","page":9,"end":false},{"code":"пІ“","page":9,"end":false},{"code":"пІ”","page":9,"end":false},{"code":"пІ•","page":9,"end":false},{"code":"пІ–","page":9,"end":false},{"code":"пІ—","page":9,"end":false},{"code":"пІҳ","page":9,"end":false},{"code":"пІҷ","page":9,"end":false},{"code":"пІҡ","page":9,"end":false},{"code":"пІӣ","page":9,"end":false},{"code":"пІң","page":9,"end":false},{"code":"пІқ","page":9,"end":false},{"code":"пІһ","page":9,"end":false},{"code":"пІҹ","page":9,"end":false},{"code":"пІ пІЎ","page":9,"end":false},{"code":"пІў","page":9,"end":false},{"code":"пІЈ","page":9,"end":false},{"code":"пІӨ","page":9,"end":false},{"code":"пІҘ","page":9,"end":false},{"code":"пІҰ","page":9,"end":false},{"code":"пІ§","page":9,"end":false},{"code":"пІЁ","page":9,"end":false},{"code":"пІ©пІӘ","page":9,"end":false},{"code":"пІ«","page":9,"end":false},{"code":"пІ¬","page":9,"end":false},{"code":"пІӯ","page":9,"end":false},{"code":"пІ®","page":9,"end":false},{"code":"пІҜ","page":9,"end":false},{"code":"пІ°пІұ","page":9,"end":false},{"code":"пІІ","page":9,"end":false},{"code":"пІі","page":9,"end":false},{"code":"пІҙ","page":9,"end":false},{"code":"пІө","page":9,"end":false},{"code":"пІ¶","page":9,"end":false},{"code":"пІ·","page":9,"end":false},{"code":"пІё","page":9,"end":false},{"code":"пІ№пІә","page":9,"end":false},{"code":"пІ»","page":9,"end":false},{"code":"пІј","page":9,"end":false},{"code":"пІҪ","page":9,"end":false},{"code":"пІҫ","page":9,"end":false},{"code":"пІҝ","page":9,"end":false},{"code":"піҖ","page":9,"end":false},{"code":"піҒ","page":9,"end":false},{"code":"піӮ","page":9,"end":false},{"code":"піғ","page":9,"end":false},{"code":"пі„пі…","page":9,"end":false},{"code":"піҶ","page":9,"end":false},{"code":"піҮ","page":9,"end":false},{"code":"піҲ","page":9,"end":false},{"code":"піү","page":9,"end":false},{"code":"піҠ","page":9,"end":false},{"code":"піӢ","page":9,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ЩӮЩҸЩ„Щ’ШӘЩҸЩ…Щ’ ЩҠЩҺЩҖЩ°Щ…ЩҸЩҲШіЩҺЩүЩ° Щ„ЩҺЩҶ ЩҶЩ‘ЩҺШөЩ’ШЁЩҗШұЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° Ш·ЩҺШ№ЩҺШ§Щ…ЩҚЫў ЩҲЩҺЩ°ШӯЩҗШҜЩҚЫў ЩҒЩҺЩұШҜЩ’Ш№ЩҸ Щ„ЩҺЩҶЩҺШ§ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ЩҠЩҸШ®Щ’ШұЩҗШ¬Щ’ Щ„ЩҺЩҶЩҺШ§ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҸЩҶЫўШЁЩҗШӘЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ Щ…ЩҗЩҶЫў ШЁЩҺЩӮЩ’Щ„ЩҗЩҮЩҺШ§ ЩҲЩҺЩӮЩҗШ«Щ‘ЩҺШ§Щ“ШҰЩҗЩҮЩҺШ§ ЩҲЩҺЩҒЩҸЩҲЩ…ЩҗЩҮЩҺШ§ ЩҲЩҺШ№ЩҺШҜЩҺШіЩҗЩҮЩҺШ§ ЩҲЩҺШЁЩҺШөЩҺЩ„ЩҗЩҮЩҺШ§ Ы– ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺШӘЩҺШіЩ’ШӘЩҺШЁЩ’ШҜЩҗЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҮЩҸЩҲЩҺ ШЈЩҺШҜЩ’ЩҶЩҺЩүЩ° ШЁЩҗЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҮЩҸЩҲЩҺ Ш®ЩҺЩҠЩ’ШұЩҢ Ыҡ ЩұЩҮЩ’ШЁЩҗШ·ЩҸЩҲШ§Ыҹ Щ…ЩҗШөЩ’ШұЩӢЫӯШ§ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҺШ§ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҸЩ…Щ’ Ы— ЩҲЩҺШ¶ЩҸШұЩҗШЁЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Ш°Щ‘ЩҗЩ„Щ‘ЩҺШ©ЩҸ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШіЩ’ЩғЩҺЩҶЩҺШ©ЩҸ ЩҲЩҺШЁЩҺШ§Щ“ШЎЩҸЩҲ ШЁЩҗШәЩҺШ¶ЩҺШЁЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩҠЩҺЩӮЩ’ШӘЩҸЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩҗЩҖЫ§ЩҶЩҺ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Ы— Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺШөЩҺЩҲШ§Ыҹ ЩҲЩ‘ЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"}]}
","end":true}]},{"lineNumber":14,"words":[{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false}]},{"lineNumber":15,"words":[{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"піңпіқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":false},{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈ","end":true}]}],"verses":[{"key":"33:16","surah":33,"ayah":16,"num":3549,"page":420,"words":[{"code":"пұҒ","page":420,"end":false},{"code":"пұӮ","page":420,"end":false},{"code":"пұғ","page":420,"end":false},{"code":"пұ„","page":420,"end":false},{"code":"пұ…","page":420,"end":false},{"code":"пұҶ","page":420,"end":false},{"code":"пұҮ","page":420,"end":false},{"code":"пұҲ","page":420,"end":false},{"code":"пұү","page":420,"end":false},{"code":"пұҠ","page":420,"end":false},{"code":"пұӢ","page":420,"end":false},{"code":"пұҢ","page":420,"end":false},{"code":"пұҚ","page":420,"end":false},{"code":"пұҺ","page":420,"end":false},{"code":"пұҸ","page":420,"end":false},{"code":"пұҗ","page":420,"end":true}],"text":"ЩӮЩҸЩ„ Щ„Щ‘ЩҺЩҶ ЩҠЩҺЩҶЩҒЩҺШ№ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҒЩҗШұЩҺШ§ШұЩҸ ШҘЩҗЩҶ ЩҒЩҺШұЩҺШұЩ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҗ ШЈЩҺЩҲЩҗ ЩұЩ„Щ’ЩӮЩҺШӘЩ’Щ„Щҗ ЩҲЩҺШҘЩҗШ°ЩӢЫӯШ§ Щ„Щ‘ЩҺШ§ ШӘЩҸЩ…ЩҺШӘЩ‘ЩҺШ№ЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"33:17","surah":33,"ayah":17,"num":3550,"page":420,"words":[{"code":"пұ‘","page":420,"end":false},{"code":"пұ’","page":420,"end":false},{"code":"пұ“","page":420,"end":false},{"code":"пұ”","page":420,"end":false},{"code":"пұ•","page":420,"end":false},{"code":"пұ–","page":420,"end":false},{"code":"пұ—","page":420,"end":false},{"code":"пұҳ","page":420,"end":false},{"code":"пұҷ","page":420,"end":false},{"code":"пұҡ","page":420,"end":false},{"code":"пұӣ","page":420,"end":false},{"code":"пұң","page":420,"end":false},{"code":"пұқ","page":420,"end":false},{"code":"пұһ","page":420,"end":false},{"code":"пұҹпұ ","page":420,"end":false},{"code":"пұЎ","page":420,"end":false},{"code":"пұў","page":420,"end":false},{"code":"пұЈ","page":420,"end":false},{"code":"пұӨ","page":420,"end":false},{"code":"пұҘ","page":420,"end":false},{"code":"пұҰ","page":420,"end":false},{"code":"пұ§","page":420,"end":false},{"code":"пұЁ","page":420,"end":false},{"code":"пұ©","page":420,"end":false},{"code":"пұӘ","page":420,"end":true}],"text":"ЩӮЩҸЩ„Щ’ Щ…ЩҺЩҶ Ш°ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҺШ№Щ’ШөЩҗЩ…ЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺ ШЁЩҗЩғЩҸЩ…Щ’ ШіЩҸЩҲЩ“ШЎЩӢШ§ ШЈЩҺЩҲЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺ ШЁЩҗЩғЩҸЩ…Щ’ ШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ¬ЩҗШҜЩҸЩҲЩҶЩҺ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҶЩҺШөЩҗЩҠШұЩӢЫӯШ§"},{"key":"33:18","surah":33,"ayah":18,"num":3551,"page":420,"words":[{"code":"пұ« пұ¬","page":420,"end":false},{"code":"пұӯ","page":420,"end":false},{"code":"пұ®","page":420,"end":false},{"code":"пұҜ","page":420,"end":false},{"code":"пұ°","page":420,"end":false},{"code":"пұұ","page":420,"end":false},{"code":"пұІ","page":420,"end":false},{"code":"пұі","page":420,"end":false},{"code":"пұҙпұө","page":420,"end":false},{"code":"пұ¶","page":420,"end":false},{"code":"пұ·","page":420,"end":false},{"code":"пұё","page":420,"end":false},{"code":"пұ№","page":420,"end":false},{"code":"пұә","page":420,"end":false},{"code":"пұ»","page":420,"end":true}],"text":"Ыһ ЩӮЩҺШҜЩ’ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸШ№ЩҺЩҲЩ‘ЩҗЩӮЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ ЩҲЩҺЩұЩ„Щ’ЩӮЩҺШ§Щ“ШҰЩҗЩ„ЩҗЩҠЩҶЩҺ Щ„ЩҗШҘЩҗШ®Щ’ЩҲЩҺЩ°ЩҶЩҗЩҮЩҗЩ…Щ’ ЩҮЩҺЩ„ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШЈЩ’ШӘЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ШЁЩҺШЈЩ’ШіЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢШ§"},{"key":"33:19","surah":33,"ayah":19,"num":3552,"page":420,"words":[{"code":"пұј","page":420,"end":false},{"code":"пұҪпұҫ","page":420,"end":false},{"code":"пұҝ","page":420,"end":false},{"code":"пІҖ","page":420,"end":false},{"code":"пІҒ","page":420,"end":false},{"code":"пІӮ","page":420,"end":false},{"code":"пІғ","page":420,"end":false},{"code":"пІ„","page":420,"end":false},{"code":"пІ…","page":420,"end":false},{"code":"пІҶ","page":420,"end":false},{"code":"пІҮ","page":420,"end":false},{"code":"пІҲ","page":420,"end":false},{"code":"пІү","page":420,"end":false},{"code":"пІҠ","page":420,"end":false},{"code":"пІӢпІҢ","page":420,"end":false},{"code":"пІҚ","page":420,"end":false},{"code":"пІҺ","page":420,"end":false},{"code":"пІҸ","page":420,"end":false},{"code":"пІҗ","page":420,"end":false},{"code":"пІ‘","page":420,"end":false},{"code":"пІ’","page":420,"end":false},{"code":"пІ“","page":420,"end":false},{"code":"пІ”","page":420,"end":false},{"code":"пІ•пІ–","page":420,"end":false},{"code":"пІ—","page":420,"end":false},{"code":"пІҳ","page":420,"end":false},{"code":"пІҷ","page":420,"end":false},{"code":"пІҡ","page":420,"end":false},{"code":"пІӣ","page":420,"end":false},{"code":"пІңпІқ","page":420,"end":false},{"code":"пІһ","page":420,"end":false},{"code":"пІҹ","page":420,"end":false},{"code":"пІ ","page":420,"end":false},{"code":"пІЎ","page":420,"end":false},{"code":"пІў","page":420,"end":false},{"code":"пІЈ","page":420,"end":true}],"text":"ШЈЩҺШҙЩҗШӯЩ‘ЩҺШ©ЩӢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ы– ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ’Ш®ЩҺЩҲЩ’ЩҒЩҸ ШұЩҺШЈЩҺЩҠЩ’ШӘЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺЩҶШёЩҸШұЩҸЩҲЩҶЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ ШӘЩҺШҜЩҸЩҲШұЩҸ ШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҸЩҮЩҸЩ…Щ’ ЩғЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҸШәЩ’ШҙЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҗ Ы– ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш°ЩҺЩҮЩҺШЁЩҺ ЩұЩ„Щ’Ш®ЩҺЩҲЩ’ЩҒЩҸ ШіЩҺЩ„ЩҺЩӮЩҸЩҲЩғЩҸЩ… ШЁЩҗШЈЩҺЩ„Щ’ШіЩҗЩҶЩҺШ©ЩҚ ШӯЩҗШҜЩҺШ§ШҜЩҚ ШЈЩҺШҙЩҗШӯЩ‘ЩҺШ©ЩӢ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Ш®ЩҺЩҠЩ’ШұЩҗ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ„ЩҺЩ…Щ’ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ЩҒЩҺШЈЩҺШӯЩ’ШЁЩҺШ·ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺШіЩҗЩҠШұЩӢЫӯШ§"},{"key":"33:20","surah":33,"ayah":20,"num":3553,"page":420,"words":[{"code":"пІӨ","page":420,"end":false},{"code":"пІҘ","page":420,"end":false},{"code":"пІҰ","page":420,"end":false},{"code":"пІ§пІЁ","page":420,"end":false},{"code":"пІ©","page":420,"end":false},{"code":"пІӘ","page":420,"end":false},{"code":"пІ«","page":420,"end":false},{"code":"пІ¬","page":420,"end":false},{"code":"пІӯ","page":420,"end":false},{"code":"пІ®","page":420,"end":false},{"code":"пІҜ","page":420,"end":false},{"code":"пІ°","page":420,"end":false},{"code":"пІұ","page":420,"end":false},{"code":"пІІ","page":420,"end":false},{"code":"пІі","page":420,"end":false},{"code":"пІҙпІө","page":420,"end":false},{"code":"пІ¶","page":420,"end":false},{"code":"пІ·","page":420,"end":false},{"code":"пІё","page":420,"end":false},{"code":"пІ№","page":420,"end":false},{"code":"пІә","page":420,"end":false},{"code":"пІ»","page":420,"end":false},{"code":"пІј","page":420,"end":false},{"code":"пІҪ","page":420,"end":true}],"text":"ЩҠЩҺШӯЩ’ШіЩҺШЁЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШӯЩ’ШІЩҺШ§ШЁЩҺ Щ„ЩҺЩ…Щ’ ЩҠЩҺШ°Щ’ЩҮЩҺШЁЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺШҘЩҗЩҶ ЩҠЩҺШЈЩ’ШӘЩҗ ЩұЩ„Щ’ШЈЩҺШӯЩ’ШІЩҺШ§ШЁЩҸ ЩҠЩҺЩҲЩҺШҜЩ‘ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ… ШЁЩҺШ§ШҜЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ§ШЁЩҗ ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ’ ШЈЩҺЩҶЫўШЁЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩғЩҸЩ… Щ…Щ‘ЩҺШ§ ЩӮЩҺЩҖЩ°ШӘЩҺЩ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"33:21","surah":33,"ayah":21,"num":3554,"page":420,"words":[{"code":"пІҫ","page":420,"end":false},{"code":"пІҝ","page":420,"end":false},{"code":"піҖ","page":420,"end":false},{"code":"піҒ","page":420,"end":false},{"code":"піӮ","page":420,"end":false},{"code":"піғ","page":420,"end":false},{"code":"пі„","page":420,"end":false},{"code":"пі…","page":420,"end":false},{"code":"піҶ","page":420,"end":false},{"code":"піҮ","page":420,"end":false},{"code":"піҲ","page":420,"end":false},{"code":"піү","page":420,"end":false},{"code":"піҠ","page":420,"end":false},{"code":"піӢ","page":420,"end":false},{"code":"піҢ","page":420,"end":false},{"code":"піҚ","page":420,"end":false},{"code":"піҺ","page":420,"end":false},{"code":"піҸ","page":420,"end":true}],"text":"Щ„Щ‘ЩҺЩӮЩҺШҜЩ’ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҒЩҗЩү ШұЩҺШіЩҸЩҲЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҸШіЩ’ЩҲЩҺШ©ЩҢ ШӯЩҺШіЩҺЩҶЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҗЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ ЩҠЩҺШұЩ’Ш¬ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺ ЩҲЩҺШ°ЩҺЩғЩҺШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§"},{"key":"33:22","surah":33,"ayah":22,"num":3555,"page":420,"words":[{"code":"піҗ","page":420,"end":false},{"code":"пі‘","page":420,"end":false},{"code":"пі’","page":420,"end":false},{"code":"пі“","page":420,"end":false},{"code":"пі”","page":420,"end":false},{"code":"пі•","page":420,"end":false},{"code":"пі–","page":420,"end":false},{"code":"пі—","page":420,"end":false},{"code":"піҳ","page":420,"end":false},{"code":"піҷ","page":420,"end":false},{"code":"піҡ","page":420,"end":false},{"code":"піӣ","page":420,"end":false},{"code":"піңпіқ","page":420,"end":false},{"code":"піһ","page":420,"end":false},{"code":"піҹ","page":420,"end":false},{"code":"пі ","page":420,"end":false},{"code":"піЎ","page":420,"end":false},{"code":"піў","page":420,"end":false},{"code":"піЈ","page":420,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШұЩҺШЎЩҺШ§ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШӯЩ’ШІЩҺШ§ШЁЩҺ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҺШ§ ЩҲЩҺШ№ЩҺШҜЩҺЩҶЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҸЩҮЩҸЫҘ ЩҲЩҺШөЩҺШҜЩҺЩӮЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҸЩҮЩҸЫҘ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ШІЩҺШ§ШҜЩҺЩҮЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩӢЫӯШ§ ЩҲЩҺШӘЩҺШіЩ’Щ„ЩҗЩҠЩ…ЩӢЫӯШ§"}]}
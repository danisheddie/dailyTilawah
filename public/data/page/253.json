":253,"end":false},{"code":"пІғ","page":253,"end":false},{"code":"пІ„","page":253,"end":false},{"code":"пІ…","page":253,"end":false},{"code":"пІҶпІҮ","page":253,"end":false},{"code":"пІҲ","page":253,"end":false},{"code":"пІү","page":253,"end":false},{"code":"пІҠ","page":253,"end":false},{"code":"пІӢ","page":253,"end":false},{"code":"пІҢ","page":253,"end":false},{"code":"пІҚ","page":253,"end":false},{"code":"пІҺ","page":253,"end":false},{"code":"пІҸ","page":253,"end":false},{"code":"пІҗ","page":253,"end":false},{"code":"пІ‘","page":253,"end":false},{"code":"пІ’","page":253,"end":false},{"code":"пІ“","page":253,"end":false},{"code":"пІ”","page":253,"end":false},{"code":"пІ•","page":253,"end":false},{"code":"пІ–","page":253,"end":false},{"code":"пІ—","page":253,"end":false},{"code":"пІҳпІҷ","page":253,"end":false},{"code":"пІҡ","page":253,"end":false},{"code":"пІӣ","page":253,"end":false},{"code":"пІң","page":253,"end":false},{"code":"пІқ","page":253,"end":false},{"code":"пІһ","page":253,"end":false},{"code":"пІҹ","page":253,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ШЈЩҺЩҶЩ‘ЩҺ ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩӢЫӯШ§ ШіЩҸЩҠЩ‘ЩҗШұЩҺШӘЩ’ ШЁЩҗЩҮЩҗ ЩұЩ„Щ’Ш¬ЩҗШЁЩҺШ§Щ„ЩҸ ШЈЩҺЩҲЩ’ ЩӮЩҸШ·Щ‘ЩҗШ№ЩҺШӘЩ’ ШЁЩҗЩҮЩҗ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ ШЈЩҺЩҲЩ’ ЩғЩҸЩ„Щ‘ЩҗЩ…ЩҺ ШЁЩҗЩҮЩҗ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҺЩүЩ° Ы— ШЁЩҺЩ„ Щ„Щ‘ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ШЈЩҺЩ…Щ’ШұЩҸ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢШ§ Ы— ШЈЩҺЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШ§ЫҹЩҠЩ’ЩҖЩ”ЩҺШіЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶ Щ„Щ‘ЩҺЩҲЩ’ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩҮЩҺШҜЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ Ы— ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШІЩҺШ§Щ„ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШӘЩҸШөЩҗЩҠШЁЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ШөЩҺЩҶЩҺШ№ЩҸЩҲШ§Ыҹ ЩӮЩҺШ§ШұЩҗШ№ЩҺШ©ЩҢ ШЈЩҺЩҲЩ’ ШӘЩҺШӯЩҸЩ„Щ‘ЩҸ ЩӮЩҺШұЩҗЩҠШЁЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶ ШҜЩҺШ§ШұЩҗЩҮЩҗЩ…Щ’ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШЈЩ’ШӘЩҗЩүЩҺ ЩҲЩҺШ№Щ’ШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҸШ®Щ’Щ„ЩҗЩҒЩҸ ЩұЩ„Щ’Щ…ЩҗЩҠШ№ЩҺШ§ШҜЩҺ"},{"key":"13:32","surah":13,"ayah":32,"num":1739,"page":253,"words":[{"code":"пІ ","page":253,"end":false},{"code":"пІЎ","page":253,"end":fa
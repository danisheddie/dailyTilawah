":false},{"code":"пұң","page":230,"end":false},{"code":"пұқ","page":230,"end":false},{"code":"пұһ","page":230,"end":false},{"code":"пұҹ","page":230,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШӘЩҺШ№Щ’Ш¬ЩҺШЁЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺЩ…Щ’ШұЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ШұЩҺШӯЩ’Щ…ЩҺШӘЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЁЩҺШұЩҺЩғЩҺЩҖЩ°ШӘЩҸЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЈЩҺЩҮЩ’Щ„ЩҺ ЩұЩ„Щ’ШЁЩҺЩҠЩ’ШӘЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ШӯЩҺЩ…ЩҗЩҠШҜЩҢЫӯ Щ…Щ‘ЩҺШ¬ЩҗЩҠШҜЩҢЫӯ"},{"key":"11:74","surah":11,"ayah":74,"num":1547,"page":230,"words":[{"code":"пұ ","page":230,"end":false},{"code":"пұЎ","page":230,"end":false},{"code":"пұў","page":230,"end":false},{"code":"пұЈ","page":230,"end":false},{"code":"пұӨ","page":230,"end":false},{"code":"пұҘ","page":230,"end":false},{"code":"пұҰ","page":230,"end":false},{"code":"пұ§","page":230,"end":false},{"code":"пұЁ","page":230,"end":false},{"code":"пұ©","page":230,"end":false},{"code":"пұӘ","page":230,"end":false},{"code":"пұ«","page":230,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ Ш°ЩҺЩҮЩҺШЁЩҺ Ш№ЩҺЩҶЩ’ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҺ ЩұЩ„ШұЩ‘ЩҺЩҲЩ’Ш№ЩҸ ЩҲЩҺШ¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ЩҮЩҸ ЩұЩ„Щ’ШЁЩҸШҙЩ’ШұЩҺЩүЩ° ЩҠЩҸШ¬ЩҺЩҖЩ°ШҜЩҗЩ„ЩҸЩҶЩҺШ§ ЩҒЩҗЩү ЩӮЩҺЩҲЩ’Щ…Щҗ Щ„ЩҸЩҲШ·ЩҚ"},{"key":"11:75","surah":11,"ayah":75,"num":1548,"page":230,"words":[{"code":"пұ¬","page":230,"end":false},{"code":"пұӯ","page":230,"end":false},{"code":"пұ®","page":230,"end":false},{"code":"пұҜ","page":230,"end":false},{"code":"пұ°","page":230,"end":false},{"code":"пұұ","page":230,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҺ Щ„ЩҺШӯЩҺЩ„ЩҗЩҠЩ…ЩҢ ШЈЩҺЩҲЩ‘ЩҺЩ°ЩҮЩҢЫӯ Щ…Щ‘ЩҸЩҶЩҗЩҠШЁЩҢЫӯ"},{"key":"11:76","surah":11,"ayah":76,"num":1549,"page":230,"words":[{"code":"пұІ","page":230,"end":false},{"code":"пұі","page":230,"end":false},{"code":"пұҙ","page":230,"end":false},{"code":"пұөпұ¶","page":230,"end":false},{"code":"пұ·","page":230,"end":false},{"code":"пұё","page":230,"end":false},{"code":"пұ№","page":230,"end":false},{"code":"пұә","page":230,"end":false},{"code":"пұ»пұј","page":230,"end":false},{"code":"пұҪ","page":230,"end":false
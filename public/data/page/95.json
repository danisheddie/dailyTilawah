":95,"end":false},{"code":"пІҖ","page":95,"end":false},{"code":"пІҒ","page":95,"end":false},{"code":"пІӮ","page":95,"end":false},{"code":"пІғ","page":95,"end":false},{"code":"пІ„","page":95,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ЩғЩҸЩҶШӘЩҺ ЩҒЩҗЩҠЩҮЩҗЩ…Щ’ ЩҒЩҺШЈЩҺЩӮЩҺЩ…Щ’ШӘЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҒЩҺЩ„Щ’ШӘЩҺЩӮЩҸЩ…Щ’ Ш·ЩҺШ§Щ“ШҰЩҗЩҒЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺШ№ЩҺЩғЩҺ ЩҲЩҺЩ„Щ’ЩҠЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШіЩ’Щ„ЩҗШӯЩҺШӘЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺШҘЩҗШ°ЩҺШ§ ШіЩҺШ¬ЩҺШҜЩҸЩҲШ§Ыҹ ЩҒЩҺЩ„Щ’ЩҠЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ЩҲЩҺШұЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„Щ’ШӘЩҺШЈЩ’ШӘЩҗ Ш·ЩҺШ§Щ“ШҰЩҗЩҒЩҺШ©ЩҢ ШЈЩҸШ®Щ’ШұЩҺЩүЩ° Щ„ЩҺЩ…Щ’ ЩҠЩҸШөЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ЩҒЩҺЩ„Щ’ЩҠЩҸШөЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ Щ…ЩҺШ№ЩҺЩғЩҺ ЩҲЩҺЩ„Щ’ЩҠЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲШ§Ыҹ ШӯЩҗШ°Щ’ШұЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШіЩ’Щ„ЩҗШӯЩҺШӘЩҺЩҮЩҸЩ…Щ’ Ы— ЩҲЩҺШҜЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’ ШӘЩҺШәЩ’ЩҒЩҸЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ’ ШЈЩҺШіЩ’Щ„ЩҗШӯЩҺШӘЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩ…Щ’ШӘЩҗШ№ЩҺШӘЩҗЩғЩҸЩ…Щ’ ЩҒЩҺЩҠЩҺЩ…ЩҗЩҠЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҺЩҠЩ’Щ„ЩҺШ©ЩӢЫӯ ЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩ„ЩҺШ§ Ш¬ЩҸЩҶЩҺШ§ШӯЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ ШЁЩҗЩғЩҸЩ…Щ’ ШЈЩҺШ°ЩӢЫӯЩү Щ…Щ‘ЩҗЩҶ Щ…Щ‘ЩҺШ·ЩҺШұЩҚ ШЈЩҺЩҲЩ’ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҺШұЩ’Ш¶ЩҺЩүЩ°Щ“ ШЈЩҺЩҶ ШӘЩҺШ¶ЩҺШ№ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШіЩ’Щ„ЩҗШӯЩҺШӘЩҺЩғЩҸЩ…Щ’ Ы– ЩҲЩҺШ®ЩҸШ°ЩҸЩҲШ§Ыҹ ШӯЩҗШ°Щ’ШұЩҺЩғЩҸЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЈЩҺШ№ЩҺШҜЩ‘ЩҺ Щ„ЩҗЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩӢЫӯШ§ Щ…Щ‘ЩҸЩҮЩҗЩҠЩҶЩӢЫӯШ§"},{"key":"4:103","surah":4,"ayah":103,"num":596,"page":95,"words":[{"code":"пІ…","page":95,"end":false},{"code":"пІҶ","page":95,"end":false},{"code":"пІҮ","page":95,"end":false},{"code":"пІҲ","page":95,"end":false},{"code":"пІү","page":95,"end":false},{"code":"пІҠ","page":95,"end":false},{"code":"пІӢ","page":95,"end":false},{"code":"пІҢ","page":95,"end":false},{"code":"пІҚпІҺ","page":95,"end":false},{"code":"пІҸ","page":95,"end":false},{"code":"пІҗ","page":95,"end":false},{"code":"пІ‘","page":95,"end":false},{"code":"пІ’пІ“","page":95,"end":false},{"code":"пІ”","page":95,"end":false},{"code":"пІ•","page":95,"end":false},{"code":"пІ–","page":95,"end":false},{"code":"пІ—","page":95,"end":false},{"code":"пІҳ","page":95,"end":false},{"code":"пІҷ","page":95,"end":false},{"code":"пІҡ","page":95,"end":false},{"code":"пІӣ","page":95,"end":true}],"text":"ЩҒЩҺШҘЩҗШ°ЩҺШ§ ЩӮЩҺШ¶ЩҺЩҠЩ’ШӘЩҸЩ…ЩҸ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҒЩҺЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩӢЫӯШ§ ЩҲЩҺЩӮЩҸШ№ЩҸЩҲШҜЩӢЫӯШ§ ЩҲЩҺШ№ЩҺЩ„ЩҺЩүЩ° Ш¬ЩҸЩҶЩҸЩҲШЁЩҗЩғЩҸЩ…Щ’ Ыҡ ЩҒЩҺШҘЩҗШ°ЩҺШ§ ЩұШ·Щ’Щ…ЩҺШЈЩ’ЩҶЩҺЩҶШӘЩҸЩ…Щ’ ЩҒЩҺШЈЩҺЩӮЩҗЩҠЩ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩғЩҺШ§ЩҶЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩӢЫӯШ§ Щ…Щ‘ЩҺЩҲЩ’ЩӮЩҸЩҲШӘЩӢЫӯШ§"},{"key":"4:104","surah":4,"ayah":104,"num":597,"page":95,"words":[{"code":"пІң","page":95,"end":false},{"code":"пІқ","page":95,"end":false},{"code":"пІһ","page":95,"end":false},{"code":"пІҹ","page":95,"end":false},{"code":"пІ пІЎ","page":95,"end":false},{"code":"пІў","page":95,"end":false},{"code":"пІЈ","page":95,"end":false},{"code":"пІӨ","page":95,"end":false},{"code":"пІҘ","page":95,"end":false},{"code":"пІҰ","page":95,"end":false},{"code":"пІ§","page":95,"end":false},{"code":"пІЁпІ©","page":95,"end":false},{"code":"пІӘ","page":95,"end":false},{"code":"пІ«","page":95,"end":false},{"code":"пІ¬","page":95,"end":false},{"code":"пІӯ","page":95,"end":false},{"code":"пІ®","page":95,"end":false},{"code":"пІҜпІ°","page":95,"end":false},{"code":"пІұ","page":95,"end":false},{"code":"пІІ","page":95,"end":false},{"code":"пІі","page":95,"end":false},{"code":"пІҙ","page":95,"end":false},{"code":"пІө","page":95,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩҮЩҗЩҶЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҗ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ Ы– ШҘЩҗЩҶ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ШӘЩҺШЈЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШЈЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ЩғЩҺЩ…ЩҺШ§ ШӘЩҺШЈЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ Ы– ЩҲЩҺШӘЩҺШұЩ’Ш¬ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ Щ„ЩҺШ§ ЩҠЩҺШұЩ’Ш¬ЩҸЩҲЩҶЩҺ Ы— ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢШ§"},{"key":"4:105","surah":4,"ayah":105,"num":598,"page":95,"words":[{"code":"пІ¶","page":95,"end":false},{"code":"пІ·","page":95,"end":false},{"code":"пІё","page":95,"end":false},{"code":"пІ№","page":95,"end":false},{"code":"пІә","page":95,"end":false},{"code":"пІ»","page":95,"end":false},{"code":"пІј","page":95,"end":false},{"code":"пІҪ","page":95,"end":false},{"code":"пІҫ","page":95,"end":false},{"code":"пІҝ","page":95,"end":false},{"code":"піҖпіҒ","page":95,"end":false},{"code":"піӮ","page":95,"end":false},{"code":"піғ","page":95,"end":false},{"code":"пі„","page":95,"end":false},{"code":"пі…","page":95,"end":false},{"code":"піҶ","page":95,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Щ„ЩҗШӘЩҺШӯЩ’ЩғЩҸЩ…ЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҺШұЩҺЩүЩ°ЩғЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩғЩҸЩҶ Щ„Щ‘ЩҗЩ„Щ’Ш®ЩҺШ§Щ“ШҰЩҗЩҶЩҗЩҠЩҶЩҺ Ш®ЩҺШөЩҗЩҠЩ…ЩӢЫӯШ§"}]}
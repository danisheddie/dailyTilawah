alse},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false}]},{"lineNumber":14,"words":[{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":false},{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈпіӨ","end":false}]},{"lineNumber":15,"words":[{"code":"піҘ","end":false},{"code":"піҰ","end":false},{"code":"пі§","end":false},{"code":"піЁ","end":false},{"code":"пі©","end":false},{"code":"піӘпі«","end":false},{"code":"пі¬","end":false},{"code":"піӯ","end":false},{"code":"пі®","end":true}]}],"verses":[{"key":"13:14","surah":13,"ayah":14,"num":1721,"page":251,"words":[{"code":"пұҒ","page":251,"end":false},{"code":"пұӮ","page":251,"end":false},{"code":"пұғпұ„","page":251,"end":false},{"code":"пұ…","page":251,"end":false},{"code":"пұҶ","page":251,"end":false},{"code":"пұҮ","page":251,"end":false},{"code":"пұҲ","page":251,"end":false},{"code":"пұү","page":251,"end":false},{"code":"пұҠ","page":251,"end":false},{"code":"пұӢ","page":251,"end":false},{"code":"пұҢ","page":251,"end":false},{"code":"пұҚ","page":251,"end":false},{"code":"пұҺ","page":251,"end":false},{"code":"пұҸ","page":251,"end":false},{"code":"пұҗ","page":251,"end":false},{"code":"пұ‘","page":251,"end":false},{"code":"пұ’","page":251,"end":false},{"code":"пұ“","page":251,"end":false},{"code":"пұ”","page":251,"end":false},{"code":"пұ•","page":251,"end":false},{"code":"пұ–пұ—","page":251,"end":false},{"code":"пұҳ","page":251,"end":false},{"code":"пұҷ","page":251,"end":false},{"code":"пұҡ","page":251,"end":false},{"code":"пұӣ","page":251,"end":false},{"code":"пұң","page":251,"end":false},{"code":"пұқ","page":251,"end":false},{"code":"пұһ","page":251,"end":true}],"text":"Щ„ЩҺЩҮЩҸЫҘ ШҜЩҺШ№Щ’ЩҲЩҺШ©ЩҸ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Ы– ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЫҰ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШ¬ЩҗЩҠШЁЩҸЩҲЩҶЩҺ Щ„ЩҺЩҮЩҸЩ… ШЁЩҗШҙЩҺЩүЩ’ШЎЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҺШЁЩҺЩҖЩ°ШіЩҗШ·Щҗ ЩғЩҺЩҒЩ‘ЩҺЩҠЩ’ЩҮЩҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺШ§Щ“ШЎЩҗ Щ„ЩҗЩҠЩҺШЁЩ’Щ„ЩҸШәЩҺ ЩҒЩҺШ§ЩҮЩҸ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩҲЩҺ ШЁЩҗШЁЩҺЩҖЩ°Щ„ЩҗШәЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ШҜЩҸШ№ЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҒЩҗЩү Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҚЫў"},{"key":"13:15","surah":13,"ayah":15,"num":1722,"page":251,"words":[{"code":"пұҹпұ ","page":251,"end":false},{"code":"пұЎпұў","page":251,"end":false},{"code":"пұЈ","page":251,"end":false},{"code":"пұӨ","page":251,"end":false},{"code":"пұҘ","page":251,"end":false},{"code":"пұҰ","page":251,"end":false},{"code":"пұ§","page":251,"end":false},{"code":"пұЁ","page":251,"end":false},{"code":"пұ©","page":251,"end":false},{"code":"пұӘ","page":251,"end":false},{"code":"пұ«пұ¬","page":251,"end":false},{"code":"пұӯ","page":251,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺШіЩ’Ш¬ЩҸШҜЩҸ Щ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ш·ЩҺЩҲЩ’Ш№ЩӢЫӯШ§ ЩҲЩҺЩғЩҺШұЩ’ЩҮЩӢЫӯШ§ ЩҲЩҺШёЩҗЩ„ЩҺЩҖЩ°Щ„ЩҸЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ШәЩҸШҜЩҸЩҲЩ‘Щҗ ЩҲЩҺЩұЩ„Щ’ЩҖЩ”ЩҺШ§ШөЩҺШ§Щ„Щҗ Ы©"},{"key":"13:16","surah":13,"ayah":16,"num":1723,"page":251,"words":[{"code":"пұ®","page":251,"end":false},{"code":"пұҜ","page":251,"end":false},{"code":"пұ°","page":251,"end":false},{"code":"пұұ","page":251,"end":false},{"code":"пұІ","page":251,"end":false},{"code":"пұі","page":251,"end":false},{"code":"пұҙпұө","page":251,"end":false},{"code":"пұ¶","page":251,"end":false},{"code":"пұ·","page":251,"end":false},{"code":"пұё","page":251,"end":false},{"code":"пұ№","page":251,"end":false},{"code":"пұә","page":251,"end":false},{"code":"пұ»","page":251,"end":false},{"code":"пұј","page":251,"end":false},{"code":"пұҪ","page":251,"end":false},{"code":"пұҫ","page":251,"end":false},{"code":"пұҝ","page":251,"end":false},{"code":"пІҖпІҒ","page":251,"end":false},{"code":"пІӮ","page":251,"end":false},{"code":"пІғ","page":251,"end":false},{"code":"пІ„","page":251,"end":false},{"code":"пІ…","page":251,"end":false},{"code":"пІ
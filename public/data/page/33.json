","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false}]},{"lineNumber":15,"words":[{"code":"пі‘","end":false},{"code":"пі’пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":true}]}],"verses":[{"key":"2:211","surah":2,"ayah":211,"num":218,"page":33,"words":[{"code":"пұҒ","page":33,"end":false},{"code":"пұӮ","page":33,"end":false},{"code":"пұғ","page":33,"end":false},{"code":"пұ„","page":33,"end":false},{"code":"пұ…","page":33,"end":false},{"code":"пұҶ","page":33,"end":false},{"code":"пұҮ","page":33,"end":false},{"code":"пұҲпұү","page":33,"end":false},{"code":"пұҠ","page":33,"end":false},{"code":"пұӢ","page":33,"end":false},{"code":"пұҢ","page":33,"end":false},{"code":"пұҚ","page":33,"end":false},{"code":"пұҺ","page":33,"end":false},{"code":"пұҸ","page":33,"end":false},{"code":"пұҗ","page":33,"end":false},{"code":"пұ‘","page":33,"end":false},{"code":"пұ’","page":33,"end":false},{"code":"пұ“","page":33,"end":false},{"code":"пұ”","page":33,"end":false},{"code":"пұ•","page":33,"end":false},{"code":"пұ–","page":33,"end":true}],"text":"ШіЩҺЩ„Щ’ ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩғЩҺЩ…Щ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ ШЎЩҺШ§ЩҠЩҺШ©ЩҚЫӯ ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺШ©ЩҚЫў Ы— ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШЁЩҺШҜЩ‘ЩҗЩ„Щ’ ЩҶЩҗШ№Щ’Щ…ЩҺШ©ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Щ…ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ЩҮЩҸ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШҙЩҺШҜЩҗЩҠШҜЩҸ ЩұЩ„Щ’Ш№ЩҗЩӮЩҺШ§ШЁЩҗ"},{"key":"2:212","surah":2,"ayah":212,"num":219,"page":33,"words":[{"code":"пұ—","page":33,"end":false},{"code":"пұҳ","page":33,"end":false},{"code":"пұҷ","page":33,"end":false},{"code":"пұҡ","page":33,"end":false},{"code":"пұӣ","page":33,"end":false},{"code":"пұң","page":33,"end":false},{"code":"пұқ","page":33,"end":false},{"code":"пұһ","page":33,"end":false},{"code":"пұҹпұ ","page":33,"end":false},{"code":"пұЎ","page":33,"end":false},{"code":"пұў","page":33,"end":false},{"code":"пұЈ","page":33,"end":false},{"code":"пұӨ","page":33,"end":false},{"code":"пұҘпұҰ","page":33,"end":false},{"code":"пұ§","page":33,"end":false},{"code":"пұЁ","page":33,"end":false},{"code":"пұ©","page":33,"end":false},{"code":"пұӘ","page":33,"end":false},{"code":"пұ«","page":33,"end":false},{"code":"пұ¬","page":33,"end":false},{"code":"пұӯ","page":33,"end":true}],"text":"ШІЩҸЩҠЩ‘ЩҗЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©ЩҸ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҲЩҺЩҠЩҺШіЩ’Ш®ЩҺШұЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Ыҳ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШӘЩ‘ЩҺЩӮЩҺЩҲЩ’Ш§Ыҹ ЩҒЩҺЩҲЩ’ЩӮЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҺШұЩ’ШІЩҸЩӮЩҸ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ШӯЩҗШіЩҺШ§ШЁЩҚЫў"},{"key":"2:213","surah":2,"ayah":213,"num":220,"page":33,"words":[{"code":"пұ®","page":33,"end":false},{"code":"пұҜ","page":33,"end":false},{"code":"пұ°","page":33,"end":false},{"code":"пұұ","page":33,"end":false},{"code":"пұІ","page":33,"end":false},{"code":"пұі","page":33,"end":false},{"code":"пұҙ","page":33,"end":false},{"code":"пұө","page":33,"end":false},{"code":"пұ¶","page":33,"end":false},{"code":"пұ·","page":33,"end":false},{"code":"пұё","page":33,"end":false},{"code":"пұ№","page":33,"end":false},{"code":"пұә","page":33,"end":false},{"code":"пұ»","page":33,"end":false},{"code":"пұј","page":33,"end":false},{"code":"пұҪ","page":33,"end":false},{"code":"пұҫ","page":33,"end":false},{"code":"пұҝ","page":33,"end":false},{"code":"пІҖпІҒ","page":33,"end":false},{"code":"пІӮ","page":33,"end":false},{"code":"пІғ","page":33,"end":false},{"code":"пІ„","page":33,"end":false},{"code":"пІ…","page":33,"end":false},{"code":"пІҶ","page":33,"end":false},{"code":"пІҮ","page":33,"end":false},{"code":"пІҲ","page":33,"end":false},{"code":"пІү","page":33,"end":false},{"code":"пІҠ","page":33,"end":false},{"code":"пІӢ","page":33,"end":false},{"code":"пІҢ","page":33,"end":false},{"c
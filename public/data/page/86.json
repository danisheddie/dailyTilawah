se},{"code":"піҢ","end":false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false}]},{"lineNumber":15,"words":[{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":true}]}],"verses":[{"key":"4:45","surah":4,"ayah":45,"num":538,"page":86,"words":[{"code":"пұҒ","page":86,"end":false},{"code":"пұӮ","page":86,"end":false},{"code":"пұғпұ„","page":86,"end":false},{"code":"пұ…","page":86,"end":false},{"code":"пұҶ","page":86,"end":false},{"code":"пұҮ","page":86,"end":false},{"code":"пұҲ","page":86,"end":false},{"code":"пұү","page":86,"end":false},{"code":"пұҠ","page":86,"end":false},{"code":"пұӢ","page":86,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗШЈЩҺШ№Щ’ШҜЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§ ЩҲЩҺЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҶЩҺШөЩҗЩҠШұЩӢЫӯШ§"},{"key":"4:46","surah":4,"ayah":46,"num":539,"page":86,"words":[{"code":"пұҢ","page":86,"end":false},{"code":"пұҚ","page":86,"end":false},{"code":"пұҺ","page":86,"end":false},{"code":"пұҸ","page":86,"end":false},{"code":"пұҗ","page":86,"end":false},{"code":"пұ‘","page":86,"end":false},{"code":"пұ’","page":86,"end":false},{"code":"пұ“","page":86,"end":false},{"code":"пұ”","page":86,"end":false},{"code":"пұ•","page":86,"end":false},{"code":"пұ–","page":86,"end":false},{"code":"пұ—","page":86,"end":false},{"code":"пұҳ","page":86,"end":false},{"code":"пұҷ","page":86,"end":false},{"code":"пұҡ","page":86,"end":false},{"code":"пұӣ","page":86,"end":false},{"code":"пұң","page":86,"end":false},{"code":"пұқ","page":86,"end":false},{"code":"пұһпұҹ","page":86,"end":false},{"code":"пұ ","page":86,"end":false},{"code":"пұЎ","page":86,"end":false},{"code":"пұў","page":86,"end":false},{"code":"пұЈ","page":86,"end":false},{"code":"пұӨ","page":86,"end":false},{"code":"пұҘ","page":86,"end":false},{"code":"пұҰ","page":86,"end":false},{"code":"пұ§","page":86,"end":false},{"code":"пұЁ","page":86,"end":false},{"code":"пұ©","page":86,"end":false},{"code":"пұӘ","page":86,"end":false},{"code":"пұ«","page":86,"end":false},{"code":"пұ¬","page":86,"end":false},{"code":"пұӯ","page":86,"end":false},{"code":"пұ®","page":86,"end":false},{"code":"пұҜ","page":86,"end":false},{"code":"пұ°","page":86,"end":false},{"code":"пұұ","page":86,"end":false},{"code":"пұІ","page":86,"end":false},{"code":"пұі","page":86,"end":true}],"text":"Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҮЩҺШ§ШҜЩҸЩҲШ§Ыҹ ЩҠЩҸШӯЩҺШұЩ‘ЩҗЩҒЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ЩғЩҺЩ„ЩҗЩ…ЩҺ Ш№ЩҺЩҶ Щ…Щ‘ЩҺЩҲЩҺШ§Ш¶ЩҗШ№ЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ШіЩҺЩ…ЩҗШ№Щ’ЩҶЩҺШ§ ЩҲЩҺШ№ЩҺШөЩҺЩҠЩ’ЩҶЩҺШ§ ЩҲЩҺЩұШіЩ’Щ…ЩҺШ№Щ’ ШәЩҺЩҠЩ’ШұЩҺ Щ…ЩҸШіЩ’Щ…ЩҺШ№ЩҚЫў ЩҲЩҺШұЩҺЩ°Ш№ЩҗЩҶЩҺШ§ Щ„ЩҺЩҠЩ‘ЩӢЫўШ§ ШЁЩҗШЈЩҺЩ„Щ’ШіЩҗЩҶЩҺШӘЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШ·ЩҺШ№Щ’ЩҶЩӢЫӯШ§ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҗ Ыҡ ЩҲЩҺЩ„ЩҺЩҲЩ’ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШіЩҺЩ…ЩҗШ№Щ’ЩҶЩҺШ§ ЩҲЩҺШЈЩҺШ·ЩҺШ№Щ’ЩҶЩҺШ§ ЩҲЩҺЩұШіЩ’Щ…ЩҺШ№Щ’ ЩҲЩҺЩұЩҶШёЩҸШұЩ’ЩҶЩҺШ§ Щ„ЩҺЩғЩҺШ§ЩҶЩҺ Ш®ЩҺЩҠЩ’ШұЩӢЫӯШ§ Щ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩӮЩ’ЩҲЩҺЩ…ЩҺ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ Щ„Щ‘ЩҺШ№ЩҺЩҶЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩғЩҸЩҒЩ’ШұЩҗЩҮЩҗЩ…Щ’ ЩҒЩҺЩ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"4:47","surah":4,"ayah":47,"num":540,"page":86,"words":[{"code":"пұҙ","page":86,"end":false},{"code":"пұө","page":86,"end":false},{"code":"пұ¶","page":86,"end":false},{"code":"пұ·","page":86,"end":false},{"code":"пұё","page":86,"end":false},{"code":"пұ№","page":86,"end":false},{"code":"пұә","page":86,"end":false},{"code":"пұ»","page":86,"end":false},{"code":"пұј","page":86,"end":false},{"code":"пұҪ","page":86,"end":false},{"code":"пұҫ","page":86,"end":false},{"code":"пұҝ","page":86,"end":false},{"code":"пІҖ","page":86,"end":false},{"code":"пІҒ","page":86,"end":false},{"code":"пІӮ","page":86,"end":false},{"code":"пІғ","page":86,"end":false},{"code":"пІ„","page":86,"end":false},{"code":"пІ…","page":86,"end":false},{"code":"пІҶ","page":86,"end":false},{"code":"пІҮ","page":86,"end":false},{"code":"пІҲ","page":86,"end":false},{"code":"пІү","page":86,"end":false},{"code":"пІҠ","page":86,"end":false},{"code":"пІӢпІҢ","page":86,"end":false},{"code":"пІҚ","page":86,"end":false},{"code":"пІҺ","page":86,"end":false},{"code":"пІҸ","page":86,"end":false},{"code":"пІҗ","page":86,"end":false},{"code":"пІ‘","page":86,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸЩҲШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ШЎЩҺШ§Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҺШ§ ЩҶЩҺШІЩ‘ЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҸШөЩҺШҜЩ‘ЩҗЩӮЩӢЫӯШ§ Щ„Щ‘ЩҗЩ…ЩҺШ§ Щ…ЩҺШ№ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШЈЩҺЩҶ ЩҶЩ‘ЩҺШ·Щ’Щ…ЩҗШіЩҺ ЩҲЩҸШ¬ЩҸЩҲЩҮЩӢЫӯШ§ ЩҒЩҺЩҶЩҺШұЩҸШҜЩ‘ЩҺЩҮЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШҜЩ’ШЁЩҺШ§ШұЩҗЩҮЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ЩҶЩҺЩ„Щ’Ш№ЩҺЩҶЩҺЩҮЩҸЩ…Щ’ ЩғЩҺЩ…ЩҺШ§ Щ„ЩҺШ№ЩҺЩҶЩ‘ЩҺШ§Щ“ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҺ ЩұЩ„ШіЩ‘ЩҺШЁЩ’ШӘЩҗ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ШЈЩҺЩ…Щ’ШұЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺЩҒЩ’Ш№ЩҸЩҲЩ„ЩӢШ§"},{"key":"4:48","surah":4,"ayah":48,"num":541,"page":86,"words":[{"code":"пІ’","page":86,"end":false},{"code":"пІ“","page":86,"end":false},{"code":"пІ”","page":86,"end":false},{"code":"пІ•","page":86,"end":false},{"code":"пІ–","page":86,"end":false},{"code":"пІ—","page":86,"end":false},{"code":"пІҳ","page":86,"end":false},{"code":"пІҷ","page":86,"end":false},{"code":"пІҡ","page":86,"end":false},{"code":"пІӣ","page":86,"end":false},{"code":"пІң","page":86,"end":false},{"code":"пІқ","page":86,"end":false},{"code":"пІһпІҹ","page":86,"end":false},{"code":"пІ ","page":86,"end":false},{"code":"пІЎ","page":86,"end":false},{"code":"пІў","page":86,"end":false},{"code":"пІЈ","page":86,"end":false},{"code":"пІӨ","page":86,"end":false},{"code":"пІҘ","page":86,"end":false},{"code":"пІҰ","page":86,"end":false},{"code":"пІ§","page":86,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ ШЈЩҺЩҶ ЩҠЩҸШҙЩ’ШұЩҺЩғЩҺ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ Щ…ЩҺШ§ ШҜЩҸЩҲЩҶЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҗЩ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШҙЩ’ШұЩҗЩғЩ’ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩӮЩҺШҜЩҗ ЩұЩҒЩ’ШӘЩҺШұЩҺЩүЩ°Щ“ ШҘЩҗШ«Щ’Щ…ЩӢШ§ Ш№ЩҺШёЩҗЩҠЩ…ЩӢШ§"},{"key":"4:49","surah":4,"ayah":49,"num":542,"page":86,"words":[{"code":"пІЁ","page":86,"end":false},{"code":"пІ©","page":86,"end":false},{"code":"пІӘ","page":86,"end":false},{"code":"пІ«","page":86,"end":false},{"code":"пІ¬","page":86,"end":false},{"code":"пІӯпІ®","page":86,"end":false},{"code":"пІҜ","page":86,"end":false},{"code":"пІ°","page":86,"end":false},{"code":"пІұ","page":86,"end":false},{"code":"пІІ","page":86,"end":false},{"code":"пІі","page":86,"end":false},{"code":"пІҙ","page":86,"end":false},{"code":"пІө","page":86,"end":false},{"code":"пІ¶","page":86,"end":false},{"code":"пІ·","page":86,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸШІЩҺЩғЩ‘ЩҸЩҲЩҶЩҺ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ… Ыҡ ШЁЩҺЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҸШІЩҺЩғЩ‘ЩҗЩү Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ЩҒЩҺШӘЩҗЩҠЩ„ЩӢШ§"},{"key":"4:50","surah":4,"ayah":50,"num":543,"page":86,"words":[{"code":"пІё","page":86,"end":false},{"code":"пІ№","page":86,"end":false},{"code":"пІә","page":86,"end":false},{"code":"пІ»","page":86,"end":false},{"code":"пІј","page":86,"end":false},{"code":"пІҪпІҫ","page":86,"end":false},{"code":"пІҝ","page":86,"end":false},{"code":"піҖ","page":86,"end":false},{"code":"піҒ","page":86,"end":false},{"code":"піӮ","page":86,"end":false},{"code":"піғ","page":86,"end":true}],"text":"ЩұЩҶШёЩҸШұЩ’ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩҠЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ Ы– ЩҲЩҺЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩҮЩҗЫҰЩ“ ШҘЩҗШ«Щ’Щ…ЩӢЫӯШ§ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩӢШ§"},{"key":"4:51","surah":4,"ayah":51,"num":544,"page":86,"words":[{"code":"пі„","page":86,"end":false},{"code":"пі…","page":86,"end":false},{"code":"піҶ","page":86,"end":false},{"code":"піҮ","page":86,"end":false},{"code":"піҲ","page":86,"end":false},{"code":"піү","page":86,"end":false},{"code":"піҠ","page":86,"end":false},{"code":"піӢ","page":86,"end":false},{"code":"піҢ","page":86,"end":false},{"code":"піҚ","page":86,"end":false},{"code":"піҺ","page":86,"end":false},{"code":"піҸ","page":86,"end":false},{"code":"піҗ","page":86,"end":false},{"code":"пі‘","page":86,"end":false},{"code":"пі’","page":86,"end":false},{"code":"пі“","page":86,"end":false},{"code":"пі”","page":86,"end":false},{"code":"пі•","page":86,"end":false},{"code":"пі–","page":86,"end":false},{"code":"пі—","page":86,"end":false},{"code":"піҳ","page":86,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸЩҲШӘЩҸЩҲШ§Ыҹ ЩҶЩҺШөЩҗЩҠШЁЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’Ш¬ЩҗШЁЩ’ШӘЩҗ ЩҲЩҺЩұЩ„Ш·Щ‘ЩҺЩҖЩ°ШәЩҸЩҲШӘЩҗ ЩҲЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ ШЈЩҺЩҮЩ’ШҜЩҺЩүЩ° Щ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ШіЩҺШЁЩҗЩҠЩ„ЩӢШ§"}]}
,"end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷпіҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false}]},{"lineNumber":15,"words":[{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":true},{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈ","end":false},{"code":"піӨ","end":false},{"code":"піҘ","end":false},{"code":"піҰ","end":false},{"code":"пі§","end":false},{"code":"піЁ","end":true}]}],"verses":[{"key":"34:40","surah":34,"ayah":40,"num":3646,"page":433,"words":[{"code":"пұҒ","page":433,"end":false},{"code":"пұӮ","page":433,"end":false},{"code":"пұғ","page":433,"end":false},{"code":"пұ„","page":433,"end":false},{"code":"пұ…","page":433,"end":false},{"code":"пұҶ","page":433,"end":false},{"code":"пұҮ","page":433,"end":false},{"code":"пұҲ","page":433,"end":false},{"code":"пұү","page":433,"end":false},{"code":"пұҠ","page":433,"end":false},{"code":"пұӢ","page":433,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШӯЩ’ШҙЩҸШұЩҸЩҮЩҸЩ…Щ’ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҗЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©Щҗ ШЈЩҺЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ ШҘЩҗЩҠЩ‘ЩҺШ§ЩғЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ"},{"key":"34:41","surah":34,"ayah":41,"num":3647,"page":433,"words":[{"code":"пұҢ","page":433,"end":false},{"code":"пұҚ","page":433,"end":false},{"code":"пұҺ","page":433,"end":false},{"code":"пұҸ","page":433,"end":false},{"code":"пұҗ","page":433,"end":false},{"code":"пұ‘пұ’","page":433,"end":false},{"code":"пұ“","page":433,"end":false},{"code":"пұ”","page":433,"end":false},{"code":"пұ•","page":433,"end":false},{"code":"пұ–пұ—","page":433,"end":false},{"code":"пұҳ","page":433,"end":false},{"code":"пұҷ","page":433,"end":false},{"code":"пұҡ","page":433,"end":false},{"code":"пұӣ","page":433,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺЩғЩҺ ШЈЩҺЩҶШӘЩҺ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩҸЩҶЩҺШ§ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЩ… Ы– ШЁЩҺЩ„Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ ЩұЩ„Щ’Ш¬ЩҗЩҶЩ‘ЩҺ Ы– ШЈЩҺЩғЩ’Ш«ЩҺШұЩҸЩҮЩҸЩ… ШЁЩҗЩҮЩҗЩ… Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"34:42","surah":34,"ayah":42,"num":3648,"page":433,"words":[{"code":"пұң","page":433,"end":false},{"code":"пұқ","page":433,"end":false},{"code":"пұһ","page":433,"end":false},{"code":"пұҹ","page":433,"end":false},{"code":"пұ ","page":433,"end":false},{"code":"пұЎ","page":433,"end":false},{"code":"пұў","page":433,"end":false},{"code":"пұЈ","page":433,"end":false},{"code":"пұӨ","page":433,"end":false},{"code":"пұҘ","page":433,"end":false},{"code":"пұҰ","page":433,"end":false},{"code":"пұ§","page":433,"end":false},{"code":"пұЁ","page":433,"end":false},{"code":"пұ©","page":433,"end":false},{"code":"пұӘ","page":433,"end":false},{"code":"пұ«","page":433,"end":false},{"code":"пұ¬","page":433,"end":false},{"code":"пұӯ","page":433,"end":false},{"code":"пұ®","page":433,"end":true}],"text":"ЩҒЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ Щ„ЩҺШ§ ЩҠЩҺЩ…Щ’Щ„ЩҗЩғЩҸ ШЁЩҺШ№Щ’Ш¶ЩҸЩғЩҸЩ…Щ’ Щ„ЩҗШЁЩҺШ№Щ’Ш¶ЩҚЫў ЩҶЩ‘ЩҺЩҒЩ’Ш№ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ Ш¶ЩҺШұЩ‘ЩӢЫӯШ§ ЩҲЩҺЩҶЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Ш°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ЩғЩҸЩҶШӘЩҸЩ… ШЁЩҗЩҮЩҺШ§ ШӘЩҸЩғЩҺШ°Щ‘ЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"34:43","surah":34,"ayah":43,"num":3649,"page":433,"words":[{"code":"пұҜ","page":433,"end":false},{"code":"пұ°","page":433,"end":false},{"code":"пұұ","page":433,"end":false},{"code":"пұІ","page":433,"end":false},{"code":"пұі","page":433,"end":false},{"code":"пұҙ","page":433,"end":false},{"code":"пұө","page":433,"end":false},{"code":"пұ¶","page":433,"end":false},{"code":"пұ·","page":433,"end":false},{"code":"пұё","page":433,"end":false},{"code":"пұ№","page":433,"end":false},{"code":"пұә","page":433,"end":false},{"code":"пұ»","page":433,"end":false},{"code":"пұј","page":433,"end":false},{"code":"пұҪ","page":433,"end":false},{"code":"пұҫ","page":433,"end":false},{"code":"пұҝ","page":433,"end":false},{"code":"пІҖ","page":433,"end":false},{"code":"пІҒ","page":433,"end":false},{"code":"пІӮ","page":433,"end":false},{"code":"пІғ","page":433,"end":false},{"code":"пІ„","page":433,"end":false},{"code":"пІ…пІҶ","page":433,"end":false},{"code":"пІҮ","page":433,"end":false},{"code":"пІҲ","page":433,"end":false},{"code":"пІү","page":433,"end":false},{"code":"пІҠ","page":433,"end":false},{"code":"пІӢ","page":433,"end":false},{"code":"пІҢ","page":433,"end":false},{"code":"пІҚ","page":433,"end":false},{"code":"пІҺ","page":433,"end":false},{"code":"пІҸ","page":433,"end":false},{"code":"пІҗ","page":433,"end":false},{"code":"пІ‘","page":433,"end":false},{"code":"пІ’","page":433,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШӘЩҸШӘЩ’Щ„ЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҸЩҶЩҺШ§ ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҚЫў ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ШұЩҺШ¬ЩҸЩ„ЩҢЫӯ ЩҠЩҸШұЩҗЩҠШҜЩҸ ШЈЩҺЩҶ ЩҠЩҺШөЩҸШҜЩ‘ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ ЩҠЩҺШ№Щ’ШЁЩҸШҜЩҸ ШЎЩҺШ§ШЁЩҺШ§Щ“ШӨЩҸЩғЩҸЩ…Щ’ ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШҘЩҗЩҒЩ’ЩғЩҢЫӯ Щ…Щ‘ЩҸЩҒЩ’ШӘЩҺШұЩӢЫӯЩү Ыҡ ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ„ЩҗЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Щ„ЩҺЩ…Щ‘ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ШҘЩҗЩҶЩ’ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ШіЩҗШӯЩ’ШұЩҢЫӯ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҢЫӯ"},{"key":"34:44","surah":34,"ayah":44,"num":3650,"page":433,"words":[{"code":"пІ“","page":433,"end":false},{"code":"пІ”","page":433,"end":false},{"code":"пІ•","page":433,"end":false},{"code":"пІ–","page":433,"end":false},{"code":"пІ—пІҳ","page":433,"end":false},{"code":"пІҷ","page":433,"end":false},{"code":"пІҡ","page":433,"end":false},{"code":"пІӣ","page":433,"end":false},{"code":"пІң","page":433,"end":false},{"code":"пІқ","page":433,"end":false},{"code":"пІһ","page":433,"end":false},{"code":"пІҹ","page":433,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩғЩҸШӘЩҸШЁЩҚЫў ЩҠЩҺШҜЩ’ШұЩҸШіЩҸЩҲЩҶЩҺЩҮЩҺШ§ Ы– ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩӮЩҺШЁЩ’Щ„ЩҺЩғЩҺ Щ…ЩҗЩҶ ЩҶЩ‘ЩҺШ°ЩҗЩҠШұЩҚЫў"},{"key":"34:45","surah":34,"ayah":45,"num":3651,"page":433,"words":[{"code":"пІ ","page":433,"end":false},{"code":"пІЎ","page":433,"end":false},{"code":"пІў","page":433,"end":false},{"code":"пІЈ","page":433,"end":false},{"code":"пІӨ","page":433,"end":false},{"code":"пІҘ","page":433,"end":false},{"code":"пІҰ","page":433,"end":false},{"code":"пІ§","page":433,"end":false},{"code":"пІЁ","page":433,"end":false},{"code":"пІ©","page":433,"end":false},{"code":"пІӘпІ«","page":433,"end":false},{"code":"пІ¬","page":433,"end":false},{"code":"пІӯ","page":433,"end":false},{"code":"пІ®","page":433,"end":false},{"code":"пІҜ","page":433,"end":true}],"text":"ЩҲЩҺЩғЩҺШ°Щ‘ЩҺШЁЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩ„ЩҺШәЩҸЩҲШ§Ыҹ Щ…ЩҗШ№Щ’ШҙЩҺШ§ШұЩҺ Щ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҒЩҺЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲШ§Ыҹ ШұЩҸШіЩҸЩ„ЩҗЩү Ы– ЩҒЩҺЩғЩҺЩҠЩ’ЩҒЩҺ ЩғЩҺШ§ЩҶЩҺ ЩҶЩҺЩғЩҗЩҠШұЩҗ"},{"key":"34:46","surah":34,"ayah":46,"num":3652,"page":433,"words":[{"code":"пІ° пІұ","page":433,"end":false},{"code":"пІІ","page":433,"end":false},{"code":"пІі","page":433,"end":false},{"code":"пІҙпІө","page":433,"end":false},{"code":"пІ¶","page":433,"end":false},{"code":"пІ·","page":433,"end":false},{"code":"пІё","page":433,"end":false},{"code":"пІ№","page":433,"end":false},{"code":"пІә","page":433,"end":false},{"code":"пІ»","page":433,"end":false},{"code":"пІјпІҪ","page":433,"end":false},{"code":"пІҫ","page":433,"end":false},{"code":"пІҝ","page":433,"end":false},{"code":"піҖ","page":433,"end":false},{"code":"піҒпіӮ","page":433,"end":false},{"code":"піғ","page":433,"end":false},{"code":"пі„","page":433,"end":false},{"code":"пі…","page":433,"end":false},{"code":"піҶ","page":433,"end":false},{"code":"піҮ","page":433,"end":false},{"code":"піҲ","page":433,"end":false},{"code":"піү","page":433,"end":false},{"code":"піҠ","page":433,"end":false},{"code":"піӢ","page":433,"end":false},{"code":"піҢ","page":433,"end":true}],"text":"Ыһ ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШ№ЩҗШёЩҸЩғЩҸЩ… ШЁЩҗЩҲЩҺЩ°ШӯЩҗШҜЩҺШ©ЩҚ Ы– ШЈЩҺЩҶ ШӘЩҺЩӮЩҸЩҲЩ…ЩҸЩҲШ§Ыҹ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ«Щ’ЩҶЩҺЩүЩ° ЩҲЩҺЩҒЩҸШұЩҺЩ°ШҜЩҺЩүЩ° Ш«ЩҸЩ…Щ‘ЩҺ ШӘЩҺШӘЩҺЩҒЩҺЩғЩ‘ЩҺШұЩҸЩҲШ§Ыҹ Ыҡ Щ…ЩҺШ§ ШЁЩҗШөЩҺШ§ШӯЩҗШЁЩҗЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ Ш¬ЩҗЩҶЩ‘ЩҺШ©ЩҚ Ыҡ ШҘЩҗЩҶЩ’ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҶЩҺШ°ЩҗЩҠШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺ ЩҠЩҺШҜЩҺЩүЩ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҚЫў ШҙЩҺШҜЩҗЩҠШҜЩҚЫў"},{"key":"34:47","surah":34,"ayah":47,"num":3653,"page":433,"words":[{"code":"піҚ","page":433,"end":false},{"code":"піҺ","page":433,"end":false},{"code":"піҸ","page":433,"end":false},{"code":"піҗ","page":433,"end":false},{"code":"пі‘","page":433,"end":false},{"code":"пі’","page":433,"end":false},{"code":"пі“пі”","page":433,"end":false},{"code":"пі•","page":433,"end":false},{"code":"пі–","page":433,"end":false},{"code":"пі—","page":433,"end":false},{"code":"піҳ","page":433,"end":false},{"code":"піҷпіҡ","page":433,"end":false},{"code":"піӣ","page":433,"end":false},{"code":"пің","page":433,"end":false},{"code":"піқ","page":433,"end":false},{"code":"піһ","page":433,"end":false},{"code":"піҹ","page":433,"end":false},{"code":"пі ","page":433,"end":true}],"text":"ЩӮЩҸЩ„Щ’ Щ…ЩҺШ§ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺШ¬Щ’ШұЩҚЫў ЩҒЩҺЩҮЩҸЩҲЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Ы– ШҘЩҗЩҶЩ’ ШЈЩҺШ¬Щ’ШұЩҗЩүЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺЩҮЩҸЩҲЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ШҙЩҺЩҮЩҗЩҠШҜЩҢЫӯ"},{"key":"34:48","surah":34,"ayah":48,"num":3654,"page":433,"words":[{"code":"піЎ","page":433,"end":false},{"code":"піў","page":433,"end":false},{"code":"піЈ","page":433,"end":false},{"code":"піӨ","page":433,"end":false},{"code":"піҘ","page":433,"end":false},{"code":"піҰ","page":433,"end":false},{"code":"пі§","page":433,"end":false},{"code":"піЁ","page":433,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҗЩү ЩҠЩҺЩӮЩ’Ш°ЩҗЩҒЩҸ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Ш№ЩҺЩ„Щ‘ЩҺЩҖЩ°Щ…ЩҸ ЩұЩ„Щ’ШәЩҸЩҠЩҸЩҲШЁЩҗ"}]}
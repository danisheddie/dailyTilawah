{"code":"пұҒ","page":113,"end":false},{"code":"пұӮ","page":113,"end":false},{"code":"пұғ","page":113,"end":false},{"code":"пұ„","page":113,"end":false},{"code":"пұ…","page":113,"end":false},{"code":"пұҶ","page":113,"end":false},{"code":"пұҮ","page":113,"end":false},{"code":"пұҲ","page":113,"end":false},{"code":"пұү","page":113,"end":false},{"code":"пұҠ","page":113,"end":false},{"code":"пұӢ","page":113,"end":false},{"code":"пұҢ","page":113,"end":false},{"code":"пұҚ","page":113,"end":false},{"code":"пұҺ","page":113,"end":false},{"code":"пұҸ","page":113,"end":false},{"code":"пұҗ","page":113,"end":false},{"code":"пұ‘","page":113,"end":false},{"code":"пұ’","page":113,"end":false},{"code":"пұ“","page":113,"end":false},{"code":"пұ”","page":113,"end":false},{"code":"пұ•","page":113,"end":false},{"code":"пұ–","page":113,"end":false},{"code":"пұ—","page":113,"end":false},{"code":"пұҳ","page":113,"end":false},{"code":"пұҷ","page":113,"end":false},{"code":"пұҡ","page":113,"end":false},{"code":"пұӣпұң","page":113,"end":false},{"code":"пұқ","page":113,"end":false},{"code":"пұһ","page":113,"end":false},{"code":"пұҹ","page":113,"end":false},{"code":"пұ ","page":113,"end":false},{"code":"пұЎ","page":113,"end":false},{"code":"пұў","page":113,"end":false},{"code":"пұЈ","page":113,"end":false},{"code":"пұӨ","page":113,"end":false},{"code":"пұҘ","page":113,"end":false},{"code":"пұҰ","page":113,"end":false},{"code":"пұ§","page":113,"end":false},{"code":"пұЁ","page":113,"end":false},{"code":"пұ©","page":113,"end":false},{"code":"пұӘ","page":113,"end":true}],"text":"Щ…ЩҗЩҶЩ’ ШЈЩҺШ¬Щ’Щ„Щҗ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩғЩҺШӘЩҺШЁЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ…ЩҺЩҶ ЩӮЩҺШӘЩҺЩ„ЩҺ ЩҶЩҺЩҒЩ’ШіЩӢЫўШ§ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ЩҶЩҺЩҒЩ’ШіЩҚ ШЈЩҺЩҲЩ’ ЩҒЩҺШіЩҺШ§ШҜЩҚЫў ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҒЩҺЩғЩҺШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩӮЩҺШӘЩҺЩ„ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ ЩҲЩҺЩ…ЩҺЩҶЩ’ ШЈЩҺШӯЩ’ЩҠЩҺШ§ЩҮЩҺШ§ ЩҒЩҺЩғЩҺШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШӯЩ’ЩҠЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ Ыҡ ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ЩҮЩҸЩ…Щ’ ШұЩҸШіЩҸЩ„ЩҸЩҶЩҺШ§ ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩҶЩ‘ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ… ШЁЩҺШ№Щ’ШҜЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ„ЩҺЩ…ЩҸШіЩ’ШұЩҗЩҒЩҸЩҲЩҶЩҺ"},{"key":"5:33","surah":5,"ayah":33,"num":702,"page":113,"words":[{"code":"пұ«","page":113,"end":false},{"code":"пұ¬","page":113,"end":false},{"code":"пұӯ","page":113,"end":false},{"code":"пұ®","page":113,"end":false},{"code":"пұҜ","page":113,"end":false},{"code":"пұ°","page":113,"end":false},{"code":"пұұ","page":113,"end":false},{"code":"пұІ","page":113,"end":false},{"code":"пұі","page":113,"end":false},{"code":"пұҙ","page":113,"end":false},{"code":"пұө","page":113,"end":false},{"code":"пұ¶","page":113,"end":false},{"code":"пұ·","page":113,"end":false},{"code":"пұё","page":113,"end":false},{"code":"пұ№","page":113,"end":false},{"code":"пұә","page":113,"end":false},{"code":"пұ»","page":113,"end":false},{"code":"пұј","page":113,"end":false},{"code":"пұҪ","page":113,"end":false},{"code":"пұҫ","page":113,"end":false},{"code":"пұҝ","page":113,"end":false},{"code":"пІҖ","page":113,"end":false},{"code":"пІҒ","page":113,"end":false},{"code":"пІӮпІғ","page":113,"end":false},{"code":"пІ„","page":113,"end":false},{"code":"пІ…","page":113,"end":false},{"code":"пІҶ","page":113,"end":false},{"code":"пІҮ","page":113,"end":false},{"code":"пІҲпІү","page":113,"end":false},{"code":"пІҠ","page":113,"end":false},{"code":"пІӢ","page":113,"end":false},{"code":"пІҢ","page":113,"end":false},{"code":"пІҚ","page":113,"end":false},{"code":"пІҺ","page":113,"end":false},{"code":"пІҸ","page":113,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ Ш¬ЩҺШІЩҺЩ°Щ“ШӨЩҸШ§Ыҹ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸШӯЩҺШ§ШұЩҗШЁЩҸЩҲЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ЩҲЩҺЩҠЩҺШіЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҒЩҺШіЩҺШ§ШҜЩӢШ§ ШЈЩҺЩҶ ЩҠЩҸЩӮЩҺШӘЩ‘ЩҺЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҲЩ’ ЩҠЩҸШөЩҺЩ„Щ‘ЩҺШЁЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҲЩ’ ШӘЩҸЩӮЩҺШ·Щ‘ЩҺШ№ЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺШұЩ’Ш¬ЩҸЩ„ЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ Ш®ЩҗЩ„ЩҺЩҖЩ°ЩҒЩҚ ШЈЩҺЩҲЩ’ ЩҠЩҸЩҶЩҒЩҺЩҲЩ’Ш§Ыҹ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш®ЩҗШІЩ’ЩүЩҢЫӯ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢ"},{"key":"5:34","surah":5,"ayah":34,"num":703,"page":113,"words":[{"code":"пІҗ","page":113,"end":false},{"code":"пІ‘","page":113,"end":false},{"code":"пІ’","page":113,"end":false},{"code":"пІ“","page":113,"end":false},{"code":"пІ”","page":113,"end":false},{"code":"пІ•","page":113,"end":false},{"code":"пІ–","page":113,"end":false},{"code":"пІ—пІҳ","page":113,"end":false},{"code":"пІҷ","page":113,"end":false},{"code":"пІҡ","page":113,"end":false},{"code":"пІӣ","page":113,"end":false},{"code":"пІң","page":113,"end":false},{"code":"пІқ","page":113,"end":false},{"code":"пІһ","page":113,"end":true}],"text":"ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺШ§ШЁЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШЈЩҺЩҶ ШӘЩҺЩӮЩ’ШҜЩҗШұЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ы– ЩҒЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"5:35","surah":5,"ayah":35,"num":704,"page":113,"words":[{"code":"пІҹ","page":113,"end":false},{"code":"пІ ","page":113,"end":false},{"code":"пІЎ","page":113,"end":false},{"code":"пІў","page":113,"end":false},{"code":"пІЈ","page":113,"end":false},{"code":"пІӨ","page":113,"end":false},{"code":"пІҘ","page":113,"end":false},{"code":"пІҰ","page":113,"end":false},{"code":"пІ§","page":113,"end":false},{"code":"пІЁ","page":113,"end":false},{"code":"пІ©","page":113,"end":false},{"code":"пІӘ","page":113,"end":false},{"code":"пІ«","page":113,"end":false},{"code":"пІ¬","page":113,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩұШЁЩ’ШӘЩҺШәЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩұЩ„Щ’ЩҲЩҺШіЩҗЩҠЩ„ЩҺШ©ЩҺ ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„ЩҗЩҮЩҗЫҰ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"5:36","surah":5,"ayah":36,"num":705,"page":113,"words":[{"code":"пІӯ","page":113,"end":false},{"code":"пІ®","page":113,"end":false},{"code":"пІҜ","page":113,"end":false},{"code":"пІ°","page":113,"end":false},{"code":"пІұ","page":113,"end":false},{"code":"пІІ","page":113,"end":false},{"code":"пІі","page":113,"end":false},{"code":"пІҙ","page":113,"end":false},{"code":"пІө","page":113,"end":false},{"code":"пІ¶","page":113,"end":false},{"code":"пІ·","page":113,"end":false},{"code":"пІё","page":113,"end":false},{"code":"пІ№","page":113,"end":false},{"code":"пІә","page":113,"end":false},{"code":"пІ»","page":113,"end":false},{"code":"пІј","page":113,"end":false},{"code":"пІҪ","page":113,"end":false},{"code":"пІҫ","page":113,"end":false},{"code":"пІҝ","page":113,"end":false},{"code":"піҖ","page":113,"end":false},{"code":"піҒпіӮ","page":113,"end":false},{"code":"піғ","page":113,"end":false},{"code":"пі„","page":113,"end":false},{"code":"пі…","page":113,"end":false},{"code":"піҶ","page":113,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’ ШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ ЩҲЩҺЩ…ЩҗШ«Щ’Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ№ЩҺЩҮЩҸЫҘ Щ„ЩҗЩҠЩҺЩҒЩ’ШӘЩҺШҜЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Щ…ЩҺШ§ ШӘЩҸЩӮЩҸШЁЩ‘ЩҗЩ„ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"}]}
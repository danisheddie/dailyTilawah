,"page":12,"end":false},{"code":"пұ®","page":12,"end":false},{"code":"пұҜ","page":12,"end":false},{"code":"пұ°","page":12,"end":true}],"text":"ЩҒЩҺЩҲЩҺЩҠЩ’Щ„ЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩғЩ’ШӘЩҸШЁЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ШЁЩҗШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҗЩҠЩҺШҙЩ’ШӘЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ Ш«ЩҺЩ…ЩҺЩҶЩӢЫӯШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ Ы– ЩҒЩҺЩҲЩҺЩҠЩ’Щ„ЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩғЩҺШӘЩҺШЁЩҺШӘЩ’ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺЩҲЩҺЩҠЩ’Щ„ЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"2:80","surah":2,"ayah":80,"num":87,"page":12,"words":[{"code":"пұұ","page":12,"end":false},{"code":"пұІ","page":12,"end":false},{"code":"пұі","page":12,"end":false},{"code":"пұҙ","page":12,"end":false},{"code":"пұө","page":12,"end":false},{"code":"пұ¶","page":12,"end":false},{"code":"пұ·пұё","page":12,"end":false},{"code":"пұ№","page":12,"end":false},{"code":"пұә","page":12,"end":false},{"code":"пұ»","page":12,"end":false},{"code":"пұј","page":12,"end":false},{"code":"пұҪ","page":12,"end":false},{"code":"пұҫ","page":12,"end":false},{"code":"пұҝ","page":12,"end":false},{"code":"пІҖ","page":12,"end":false},{"code":"пІҒпІӮ","page":12,"end":false},{"code":"пІғ","page":12,"end":false},{"code":"пІ„","page":12,"end":false},{"code":"пІ…","page":12,"end":false},{"code":"пІҶ","page":12,"end":false},{"code":"пІҮ","page":12,"end":false},{"code":"пІҲ","page":12,"end":false},{"code":"пІү","page":12,"end":false},{"code":"пІҠ","page":12,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҶ ШӘЩҺЩ…ЩҺШіЩ‘ЩҺЩҶЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩӢЫӯШ§ Щ…Щ‘ЩҺШ№Щ’ШҜЩҸЩҲШҜЩҺШ©ЩӢЫӯ Ыҡ ЩӮЩҸЩ„Щ’ ШЈЩҺШӘЩ‘ЩҺШ®ЩҺШ°Щ’ШӘЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩҮЩ’ШҜЩӢЫӯШ§ ЩҒЩҺЩ„ЩҺЩҶ ЩҠЩҸШ®Щ’Щ„ЩҗЩҒЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩҮЩ’ШҜЩҺЩҮЩҸЫҘЩ“ Ы– ШЈЩҺЩ…Щ’ ШӘЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ Щ„ЩҺШ§ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:81","surah":2,"ayah":81,"num":88,"page":12,"words":[{"code":"пІӢпІҢ","page":12,"end":false},{"code":"пІҚ","page":12,"end":false},{"code":"пІҺ","page":12,"end":false},{"code":"пІҸ","page":12,"end":false},{"code":"пІҗ","page":12,"end":false},{"code":"пІ‘","page":12,"end":false},{"code":"пІ’","page":12,"end":false},{"code":"пІ“","page":12,"end":false},{"code":"пІ”","page":12,"end":false},{"code":"пІ•пІ–","page":12,"end":false},{"code":"пІ—","page":12,"end":false},{"code":"пІҳ","page":12,"end":false},{"code":"пІҷ","page":12,"end":false},{"code":"пІҡ","page":12,"end":true}],"text":"ШЁЩҺЩ„ЩҺЩүЩ° Щ…ЩҺЩҶ ЩғЩҺШіЩҺШЁЩҺ ШіЩҺЩҠЩ‘ЩҗШҰЩҺШ©ЩӢЫӯ ЩҲЩҺШЈЩҺШӯЩҺЩҖЩ°Ш·ЩҺШӘЩ’ ШЁЩҗЩҮЩҗЫҰ Ш®ЩҺШ·ЩҗЩҠЩ“ЩҖЩ”ЩҺШӘЩҸЩҮЩҸЫҘ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ы– ЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҸЩҲЩҶЩҺ"},{"key":"2:82","surah":2,"ayah":82,"num":89,"page":12,"words":[{"code":"пІӣ","page":12,"end":false},{"code":"пІң","page":12,"end":false},{"code":"пІқ","page":12,"end":false},{"code":"пІһ","page":12,"end":false},{"code":"пІҹ","page":12,"end":false},{"code":"пІ ","page":12,"end":false},{"code":"пІЎпІў","page":12,"end":false},{"code":"пІЈ","page":12,"end":false},{"code":"пІӨ","page":12,"end":false},{"code":"пІҘ","page":12,"end":false},{"code":"пІҰ","page":12,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„Щ’Ш¬ЩҺЩҶЩ‘ЩҺШ©Щҗ Ы– ЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҸЩҲЩҶЩҺ"},{"key":"2:83","surah":2,"ayah":83,"num":90,"page":12,"words":[{"code":"пІ§","page":12,"end":false},{"code":"пІЁ","page":12,"end":false},{"code":"пІ©","page":12,"end":false},{"code":"пІӘ","page":12,"end":false},{"code":"пІ«","page":12,"end":false},{"code":"пІ¬","page":12,"end":false},{"code":"пІӯ","page":12,"end":false},{"code":"пІ®","page":12,"end":false},{"code":"пІҜ","page":12,"end":false},{"code":"пІ°","page":12,"end":false},{"code":"пІұ","page":12,"end":false},{"code":"пІІ","page":12,"end":false},{"code":"пІі","page":12,"end":false},{"code":"пІҙ","
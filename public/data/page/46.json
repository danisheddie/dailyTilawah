lse},{"code":"пұӢпұҢ","page":46,"end":false},{"code":"пұҚ","page":46,"end":false},{"code":"пұҺ","page":46,"end":false},{"code":"пұҸ","page":46,"end":false},{"code":"пұҗ","page":46,"end":false},{"code":"пұ‘","page":46,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶЩҒЩҺЩӮЩ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺЩҒЩҺЩӮЩҺШ©ЩҚ ШЈЩҺЩҲЩ’ ЩҶЩҺШ°ЩҺШұЩ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺШ°Щ’ШұЩҚЫў ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҮЩҸЫҘ Ы— ЩҲЩҺЩ…ЩҺШ§ Щ„ЩҗЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺЩҶШөЩҺШ§ШұЩҚ"},{"key":"2:271","surah":2,"ayah":271,"num":278,"page":46,"words":[{"code":"пұ’","page":46,"end":false},{"code":"пұ“","page":46,"end":false},{"code":"пұ”","page":46,"end":false},{"code":"пұ•","page":46,"end":false},{"code":"пұ–пұ—","page":46,"end":false},{"code":"пұҳ","page":46,"end":false},{"code":"пұҷ","page":46,"end":false},{"code":"пұҡ","page":46,"end":false},{"code":"пұӣ","page":46,"end":false},{"code":"пұң","page":46,"end":false},{"code":"пұқ","page":46,"end":false},{"code":"пұһпұҹ","page":46,"end":false},{"code":"пұ ","page":46,"end":false},{"code":"пұЎ","page":46,"end":false},{"code":"пұў","page":46,"end":false},{"code":"пұЈпұӨ","page":46,"end":false},{"code":"пұҘ","page":46,"end":false},{"code":"пұҰ","page":46,"end":false},{"code":"пұ§","page":46,"end":false},{"code":"пұЁ","page":46,"end":false},{"code":"пұ©","page":46,"end":true}],"text":"ШҘЩҗЩҶ ШӘЩҸШЁЩ’ШҜЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺШҜЩҺЩӮЩҺЩҖЩ°ШӘЩҗ ЩҒЩҺЩҶЩҗШ№ЩҗЩ…Щ‘ЩҺШ§ ЩҮЩҗЩүЩҺ Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШ®Щ’ЩҒЩҸЩҲЩҮЩҺШ§ ЩҲЩҺШӘЩҸШӨЩ’ШӘЩҸЩҲЩҮЩҺШ§ ЩұЩ„Щ’ЩҒЩҸЩӮЩҺШұЩҺШ§Щ“ШЎЩҺ ЩҒЩҺЩҮЩҸЩҲЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩҠЩҸЩғЩҺЩҒЩ‘ЩҗШұЩҸ Ш№ЩҺЩҶЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш®ЩҺШЁЩҗЩҠШұЩҢЫӯ"},{"key":"2:272","surah":2,"ayah":272,"num":279,"page":46,"words":[{"code":"пұӘ пұ«","page":46,"end":false},{"code":"пұ¬","page":46,"end":false},{"code":"пұӯ","page":46,"end":false},{"code":"пұ®","page":46,"end":false},{"code":"пұҜ","page":46,"end":false},{"code":"пұ°","page":46,"end":false},{"code":"пұұ","page":46,"end":false},{"code":"пұІпұі","page":46,"end":false},{"code":"пұҙ","page":46,"end":false},{"code":"пұө","page":46,"end":false},{"code":"пұ¶","page":46,"end":false},{"code":"пұ·","page":46,"end":false},{"code":"пұёпұ№","page":46,"end":false},{"code":"пұә","page":46,"end":false},{"code":"пұ»","page":46,"end":false},{"code":"пұј","page":46,"end":false},{"code":"пұҪ","page":46,"end":false},{"code":"пұҫ","page":46,"end":false},{"code":"пұҝпІҖ","page":46,"end":false},{"code":"пІҒ","page":46,"end":false},{"code":"пІӮ","page":46,"end":false},{"code":"пІғ","page":46,"end":false},{"code":"пІ„","page":46,"end":false},{"code":"пІ…","page":46,"end":false},{"code":"пІҶ","page":46,"end":false},{"code":"пІҮ","page":46,"end":false},{"code":"пІҲ","page":46,"end":false},{"code":"пІү","page":46,"end":false},{"code":"пІҠ","page":46,"end":true}],"text":"Ыһ Щ„Щ‘ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ ЩҮЩҸШҜЩҺЩүЩ°ЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺЩҮЩ’ШҜЩҗЩү Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ы— ЩҲЩҺЩ…ЩҺШ§ ШӘЩҸЩҶЩҒЩҗЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў ЩҒЩҺЩ„ЩҗШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ШӘЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ ЩҲЩҺШ¬Щ’ЩҮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ШӘЩҸЩҶЩҒЩҗЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў ЩҠЩҸЩҲЩҺЩҒЩ‘ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ Щ„ЩҺШ§ ШӘЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:273","surah":2,"ayah":273,"num":280,"page":46,"words":[{"code":"пІӢ","page":46,"end":false},{"code":"пІҢ","page":46,"end":false},{"code":"пІҚ","page":46,"end":false},{"code":"пІҺ","page":46,"end":false},{"code":"пІҸ","page":46,"end":false},{"code":"пІҗ","page":46,"end":false},{"code":"пІ‘","page":46,"end":false},{"code":"пІ’","page":46,"end":false},{"code":"пІ“","page":46,"end":false},{"code":"пІ”","page":46,"end":false},{"code":"пІ•","page":46,"end":false},{"code":"пІ–","page":46,"end":false},{"code":"пІ—","page":46,"end":false},{"code":"пІҳ","page":46,"end":false},{"code":"пІҷ","page":46,"end":false},{"code":"пІҡ","page":46,"end":false},{"code":"пІӣ","page":46,"end":false},{"code":"пІң","page":46,"end":false},{"code":"пІқ","page":46,"end":false},{"code":"пІһ","page":46,"end":false},{"code":"пІҹ","page":46,"end":false},{"code":"пІ пІЎ","page":46,"end":false},{"code":"пІў","page":46,"end":false},{"code":"пІЈ","page":46,"end":false},{"code":"пІӨ","page":46,"end":false},{"code":"пІҘ","page":46,"end":false},{"code":"пІҰ","page":46,"end":false},{"code":"пІ§","page":46,"end":false},{"code":"пІЁ","page":46,"end":false},{"code":"пІ©","page":46,"end":false},{"code":"пІӘ","page":46,"end":true}],"text":"Щ„ЩҗЩ„Щ’ЩҒЩҸЩӮЩҺШұЩҺШ§Щ“ШЎЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸШӯЩ’ШөЩҗШұЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШ·ЩҗЩҠШ№ЩҸЩҲЩҶЩҺ Ш¶ЩҺШұЩ’ШЁЩӢЫӯШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҠЩҺШӯЩ’ШіЩҺШЁЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш¬ЩҺШ§ЩҮЩҗЩ„ЩҸ ШЈЩҺШәЩ’ЩҶЩҗЩҠЩҺШ§Щ“ШЎЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШӘЩ‘ЩҺШ№ЩҺЩҒЩ‘ЩҸЩҒЩҗ ШӘЩҺШ№Щ’ШұЩҗЩҒЩҸЩҮЩҸЩ… ШЁЩҗШіЩҗЩҠЩ…ЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ШҘЩҗЩ„Щ’ШӯЩҺШ§ЩҒЩӢЫӯШ§ Ы— ЩҲЩҺЩ…ЩҺШ§ ШӘЩҸЩҶЩҒЩҗЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҗЩҮЩҗЫҰ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ"},{"key":"2:274","surah":2,"ayah":274,"num":281,"page":46,"words":[{"code":"пІ«","page":46,"end":false},{"code":"пІ¬","page":46,"end":false},{"code":"пІӯ","page":46,"end":false},{"code":"пІ®","page":46,"end":false},{"code":"пІҜ","page":46,"end":false},{"code":"пІ°","page":46,"end":false},{"code":"пІұ","page":46,"end":false},{"code":"пІІ","page":46,"end":false},{"code":"пІі","page":46,"end":false},{"code":"пІҙ","page":46,"end":false},{"code":"пІө","page":46,"end":false},{"code":"пІ¶","page":46,"end":false},{"code":"пІ·","page":46,"end":false},{"code":"пІё","page":46,"end":false},{"code":"пІ№","page":46,"end":false},{"code":"пІә","page":46,"end":false},{"code":"пІ»","page":46,"end":false},{"code":"пІј","page":46,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҗ ШіЩҗШұЩ‘ЩӢЫӯШ§ ЩҲЩҺШ№ЩҺЩ„ЩҺШ§ЩҶЩҗЩҠЩҺШ©ЩӢЫӯ ЩҒЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩҸЩҮЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ Ш®ЩҺЩҲЩ’ЩҒЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҠЩҺШӯЩ’ШІЩҺЩҶЩҸЩҲЩҶЩҺ"}]}
age":130,"end":false},{"code":"пұ ","page":130,"end":false},{"code":"пұЎпұў","page":130,"end":false},{"code":"пұЈ","page":130,"end":false},{"code":"пұӨ","page":130,"end":false},{"code":"пұҘ","page":130,"end":false},{"code":"пұҰ","page":130,"end":false},{"code":"пұ§","page":130,"end":false},{"code":"пұЁ","page":130,"end":false},{"code":"пұ©","page":130,"end":false},{"code":"пұӘ","page":130,"end":false},{"code":"пұ«","page":130,"end":false},{"code":"пұ¬","page":130,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШЈЩҺЩүЩ‘ЩҸ ШҙЩҺЩүЩ’ШЎЩҚ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ ШҙЩҺЩҮЩҺЩҖЩ°ШҜЩҺШ©ЩӢЫӯ Ы– ЩӮЩҸЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ШҙЩҺЩҮЩҗЩҠШҜЩҢЫў ШЁЩҺЩҠЩ’ЩҶЩҗЩү ЩҲЩҺШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШЈЩҸЩҲШӯЩҗЩүЩҺ ШҘЩҗЩ„ЩҺЩүЩ‘ЩҺ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҸ Щ„ЩҗШЈЩҸЩҶШ°ЩҗШұЩҺЩғЩҸЩ… ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩ…ЩҺЩҶЫў ШЁЩҺЩ„ЩҺШәЩҺ Ыҡ ШЈЩҺШҰЩҗЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ Щ„ЩҺШӘЩҺШҙЩ’ЩҮЩҺШҜЩҸЩҲЩҶЩҺ ШЈЩҺЩҶЩ‘ЩҺ Щ…ЩҺШ№ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЎЩҺШ§Щ„ЩҗЩҮЩҺШ©ЩӢ ШЈЩҸШ®Щ’ШұЩҺЩүЩ° Ыҡ ЩӮЩҸЩ„ Щ„Щ‘ЩҺШ§Щ“ ШЈЩҺШҙЩ’ЩҮЩҺШҜЩҸ Ыҡ ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҢЫӯ ЩҲЩҺЩ°ШӯЩҗШҜЩҢЫӯ ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩҶЩҗЩү ШЁЩҺШұЩҗЩүЩ“ШЎЩҢЫӯ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҸШҙЩ’ШұЩҗЩғЩҸЩҲЩҶЩҺ"},{"key":"6:20","surah":6,"ayah":20,"num":809,"page":130,"words":[{"code":"пұӯ","page":130,"end":false},{"code":"пұ®","page":130,"end":false},{"code":"пұҜ","page":130,"end":false},{"code":"пұ°","page":130,"end":false},{"code":"пұұ","page":130,"end":false},{"code":"пұІ","page":130,"end":false},{"code":"пұіпұҙ","page":130,"end":false},{"code":"пұө","page":130,"end":false},{"code":"пұ¶","page":130,"end":false},{"code":"пұ·","page":130,"end":false},{"code":"пұё","page":130,"end":false},{"code":"пұ№","page":130,"end":false},{"code":"пұә","page":130,"end":false},{"code":"пұ»","page":130,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҠЩҺШ№Щ’ШұЩҗЩҒЩҸЩҲЩҶЩҺЩҮЩҸЫҘ ЩғЩҺЩ…ЩҺШ§ ЩҠЩҺШ№Щ’ШұЩҗЩҒЩҸЩҲЩҶЩҺ ШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…ЩҸ Ыҳ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Ш®ЩҺШіЩҗШұЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"6:21"
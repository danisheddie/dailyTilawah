se},{"code":"пІ ","page":491,"end":false},{"code":"пІЎ","page":491,"end":false},{"code":"пІў","page":491,"end":false},{"code":"пІЈ","page":491,"end":false},{"code":"пІӨ","page":491,"end":false},{"code":"пІҘ","page":491,"end":false},{"code":"пІҰ","page":491,"end":false},{"code":"пІ§","page":491,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩҶЩҸШІЩ‘ЩҗЩ„ЩҺ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҺШ¬ЩҸЩ„ЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҺШұЩ’ЩҠЩҺШӘЩҺЩҠЩ’ЩҶЩҗ Ш№ЩҺШёЩҗЩҠЩ…ЩҚ"},{"key":"43:32","surah":43,"ayah":32,"num":4357,"page":491,"words":[{"code":"пІЁ","page":491,"end":false},{"code":"пІ©","page":491,"end":false},{"code":"пІӘ","page":491,"end":false},{"code":"пІ«пІ¬","page":491,"end":false},{"code":"пІӯ","page":491,"end":false},{"code":"пІ®","page":491,"end":false},{"code":"пІҜ","page":491,"end":false},{"code":"пІ°","page":491,"end":false},{"code":"пІұ","page":491,"end":false},{"code":"пІІ","page":491,"end":false},{"code":"пІіпІҙ","page":491,"end":false},{"code":"пІө","page":491,"end":false},{"code":"пІ¶","page":491,"end":false},{"code":"пІ·","page":491,"end":false},{"code":"пІё","page":491,"end":false},{"code":"пІ№","page":491,"end":false},{"code":"пІә","page":491,"end":false},{"code":"пІ»","page":491,"end":false},{"code":"пІј","page":491,"end":false},{"code":"пІҪпІҫ","page":491,"end":false},{"code":"пІҝ","page":491,"end":false},{"code":"піҖ","page":491,"end":false},{"code":"піҒ","page":491,"end":false},{"code":"піӮ","page":491,"end":false},{"code":"піғ","page":491,"end":false},{"code":"пі„","page":491,"end":true}],"text":"ШЈЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺЩӮЩ’ШіЩҗЩ…ЩҸЩҲЩҶЩҺ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҺ ШұЩҺШЁЩ‘ЩҗЩғЩҺ Ыҡ ЩҶЩҺШӯЩ’ЩҶЩҸ ЩӮЩҺШіЩҺЩ…Щ’ЩҶЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШ№ЩҗЩҠШҙЩҺШӘЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ыҡ ЩҲЩҺШұЩҺЩҒЩҺШ№Щ’ЩҶЩҺШ§ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩҲЩ’ЩӮЩҺ ШЁЩҺШ№Щ’Ш¶ЩҚЫў ШҜЩҺШұЩҺШ¬ЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҺ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ… ШЁЩҺШ№Щ’Ш¶ЩӢЫӯШ§ ШіЩҸШ®Щ’ШұЩҗЩҠЩ‘ЩӢЫӯШ§ Ы— ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШӘЩҸ ШұЩҺШЁЩ‘ЩҗЩғЩҺ Ш®ЩҺЩҠЩ’ШұЩ
page":491,"end":false},{"code":"пұў","page":491,"end":false},{"code":"пұЈ","page":491,"end":false},{"code":"пұӨ","page":491,"end":false},{"code":"пұҘ","page":491,"end":false},{"code":"пұҰ","page":491,"end":false},{"code":"пұ§","page":491,"end":true}],"text":"Ыһ ЩӮЩҺЩҖЩ°Щ„ЩҺ ШЈЩҺЩҲЩҺЩ„ЩҺЩҲЩ’ Ш¬ЩҗШҰЩ’ШӘЩҸЩғЩҸЩ… ШЁЩҗШЈЩҺЩҮЩ’ШҜЩҺЩүЩ° Щ…ЩҗЩ…Щ‘ЩҺШ§ ЩҲЩҺШ¬ЩҺШҜШӘЩ‘ЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЎЩҺШ§ШЁЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ Ы– ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҸШұЩ’ШіЩҗЩ„Щ’ШӘЩҸЩ… ШЁЩҗЩҮЩҗЫҰ ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"43:25","surah":43,"ayah":25,"num":4350,"page":491,"words":[{"code":"пұЁ","page":491,"end":false},{"code":"пұ©пұӘ","page":491,"end":false},{"code":"пұ«","page":491,"end":false},{"code":"пұ¬","page":491,"end":false},{"code":"пұӯ","page":491,"end":false},{"code":"пұ®","page":491,"end":false},{"code":"пұҜ","page":491,"end":false},{"code":"пұ°","page":491,"end":true}],"text":"ЩҒЩҺЩұЩҶШӘЩҺЩӮЩҺЩ…Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҒЩҺЩұЩҶШёЩҸШұЩ’ ЩғЩҺЩҠЩ’ЩҒЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШ©ЩҸ ЩұЩ„Щ’Щ…ЩҸЩғЩҺШ°Щ‘ЩҗШЁЩҗЩҠЩҶЩҺ"},{"key":"43:26","surah":43,"ayah":26,"num":4351,"page":491,"words":[{"code":"пұұ","page":491,"end":false},{"code":"пұІ","page":491,"end":false},{"code":"пұі","page":491,"end":false},{"code":"пұҙ","page":491,"end":false},{"code":"пұө","page":491,"end":false},{"code":"пұ¶","page":491,"end":false},{"code":"пұ·","page":491,"end":false},{"code":"пұё","page":491,"end":false},{"code":"пұ№","page":491,"end":false},{"code":"пұә","page":491,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ЩӮЩҺШ§Щ„ЩҺ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҸ Щ„ЩҗШЈЩҺШЁЩҗЩҠЩҮЩҗ ЩҲЩҺЩӮЩҺЩҲЩ’Щ…ЩҗЩҮЩҗЫҰЩ“ ШҘЩҗЩҶЩ‘ЩҺЩҶЩҗЩү ШЁЩҺШұЩҺШ§Щ“ШЎЩҢЫӯ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ"},{"key":"43:27","surah":43,"ayah":27,"num":4352,"page":491,"words":[{"code":"пұ»","page":491,"end":false},{"code":"пұј","page":491,"end":false},{"code":"пұҪ","page":491,"end":false},{"code":"пұҫ","page":491,"end":false},{"code":"пұҝ","page":491,"end":false},{"code":"пІҖ","page":491,"end":true}],"text":"ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҒЩҺ
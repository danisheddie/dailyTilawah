ber":15,"words":[{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":true}]}],"verses":[{"key":"2:135","surah":2,"ayah":135,"num":142,"page":21,"words":[{"code":"пұҒ","page":21,"end":false},{"code":"пұӮ","page":21,"end":false},{"code":"пұғ","page":21,"end":false},{"code":"пұ„","page":21,"end":false},{"code":"пұ…","page":21,"end":false},{"code":"пұҶпұҮ","page":21,"end":false},{"code":"пұҲ","page":21,"end":false},{"code":"пұү","page":21,"end":false},{"code":"пұҠ","page":21,"end":false},{"code":"пұӢ","page":21,"end":false},{"code":"пұҢпұҚ","page":21,"end":false},{"code":"пұҺ","page":21,"end":false},{"code":"пұҸ","page":21,"end":false},{"code":"пұҗ","page":21,"end":false},{"code":"пұ‘","page":21,"end":false},{"code":"пұ’","page":21,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ЩҮЩҸЩҲШҜЩӢШ§ ШЈЩҺЩҲЩ’ ЩҶЩҺШөЩҺЩҖЩ°ШұЩҺЩүЩ° ШӘЩҺЩҮЩ’ШӘЩҺШҜЩҸЩҲШ§Ыҹ Ы— ЩӮЩҸЩ„Щ’ ШЁЩҺЩ„Щ’ Щ…ЩҗЩ„Щ‘ЩҺШ©ЩҺ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҖЫ§Щ…ЩҺ ШӯЩҺЩҶЩҗЩҠЩҒЩӢЫӯШ§ Ы– ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ"},{"key":"2:136","surah":2,"ayah":136,"num":143,"page":21,"words":[{"code":"пұ“","page":21,"end":false},{"code":"пұ”","page":21,"end":false},{"code":"пұ•","page":21,"end":false},{"code":"пұ–","page":21,"end":false},{"code":"пұ—","page":21,"end":false},{"code":"пұҳ","page":21,"end":false},{"code":"пұҷ","page":21,"end":false},{"code":"пұҡ","page":21,"end":false},{"code":"пұӣ","page":21,"end":false},{"code":"пұң","page":21,"end":false},{"code":"пұқ","page":21,"end":false},{"code":"пұһ","page":21,"end":false},{"code":"пұҹ","page":21,"end":false},{"code":"пұ ","page":21,"end":false},{"code":"пұЎ","page":21,"end":false},{"code":"пұў","page":21,"end":false},{"code":"пұЈ","page":21,"end":false},{"code":"пұӨ","page":21,"end":false},{"code":"пұҘ","page":21,"end":false},{"code":"пұҰ","page":21,"end":false},{"code":"пұ§","page":21,"end":false},{"code":"пұЁ","page":21,"end":false},{"code":"пұ©","page":21,"end":false},{"code":"пұӘ","page":21,"end":false},{"code":"пұ«","page":21,"end":false},{"code":"пұ¬","page":21,"end":false},{"code":"пұӯ","page":21,"end":false},{"code":"пұ®","page":21,"end":false},{"code":"пұҜ","page":21,"end":false},{"code":"пұ°","page":21,"end":false},{"code":"пұұ","page":21,"end":false},{"code":"пұІ","page":21,"end":true}],"text":"ЩӮЩҸЩҲЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Щ…ЩҺЩҶЩ‘ЩҺШ§ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҖЫ§Щ…ЩҺ ЩҲЩҺШҘЩҗШіЩ’Щ…ЩҺЩҖЩ°Ш№ЩҗЩҠЩ„ЩҺ ЩҲЩҺШҘЩҗШіЩ’ШӯЩҺЩҖЩ°ЩӮЩҺ ЩҲЩҺЩҠЩҺШ№Щ’ЩӮЩҸЩҲШЁЩҺ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШіЩ’ШЁЩҺШ§Ш·Щҗ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҲШӘЩҗЩүЩҺ Щ…ЩҸЩҲШіЩҺЩүЩ° ЩҲЩҺШ№ЩҗЩҠШіЩҺЩүЩ° ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҲШӘЩҗЩүЩҺ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺШ§ ЩҶЩҸЩҒЩҺШұЩ‘ЩҗЩӮЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺ ШЈЩҺШӯЩҺШҜЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҲЩҺЩҶЩҺШӯЩ’ЩҶЩҸ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҸШіЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:137","surah":2,"ayah":137,"num":144,"page":21,"words":[{"code":"пұі","page":21,"end":false},{"code":"пұҙ","page":21,"end":false},{"code":"пұө","page":21,"end":false},{"code":"пұ¶","page":21,"end":false},{"code":"пұ·","page":21,"end":false},{"code":"пұё","page":21,"end":false},{"code":"пұ№","page":21,"end":false},{"code":"пұәпұ»","page":21,"end":false},{"code":"пұј","page":21,"end":false},{"code":"пұҪ","page":21,"end":false},{"code":"пұҫ","page":21,"end":false},{"code":"пұҝ","page":21,"end":false},{"code":"пІҖ","page":21,"end":false},{"code":"пІҒпІӮ","page":21,"end":false},{"code":"пІғ","page":21,"end":false},{"code":"пІ„пІ…","page":21,"end":false},{"code":"пІҶ","page":21,"end":false},{"code":"пІҮ","page":21,"end":false},{"code":"пІҲ","page":21,"end":false},{"code":"пІү","page":21,"end":true}],"text":"ЩҒЩҺШҘЩҗЩҶЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҗШ«Щ’Щ„Щҗ Щ…ЩҺШ§Щ“ ШЎЩҺШ§Щ…ЩҺЩҶШӘЩҸЩ… ШЁЩҗЩҮЩҗЫҰ ЩҒЩҺЩӮЩҺШҜЩҗ ЩұЩҮЩ’ШӘЩҺШҜЩҺЩҲШ§Ыҹ Ы– ЩҲЩ‘ЩҺШҘЩҗЩҶ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҲЩ’Ш§Ыҹ ЩҒЩҺШҘЩҗ
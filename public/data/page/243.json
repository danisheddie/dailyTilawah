":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’пі“","end":false}]},{"lineNumber":15,"words":[{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":true}]}],"verses":[{"key":"12:64","surah":12,"ayah":64,"num":1660,"page":243,"words":[{"code":"пұҒ","page":243,"end":false},{"code":"пұӮ","page":243,"end":false},{"code":"пұғ","page":243,"end":false},{"code":"пұ„","page":243,"end":false},{"code":"пұ…","page":243,"end":false},{"code":"пұҶ","page":243,"end":false},{"code":"пұҮ","page":243,"end":false},{"code":"пұҲ","page":243,"end":false},{"code":"пұү","page":243,"end":false},{"code":"пұҠ","page":243,"end":false},{"code":"пұӢ","page":243,"end":false},{"code":"пұҢ","page":243,"end":false},{"code":"пұҚ","page":243,"end":false},{"code":"пұҺпұҸ","page":243,"end":false},{"code":"пұҗ","page":243,"end":false},{"code":"пұ‘","page":243,"end":false},{"code":"пұ’","page":243,"end":false},{"code":"пұ“","page":243,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩҮЩҺЩ„Щ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩ…ЩҗЩҶШӘЩҸЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ®ЩҗЩҠЩҮЩҗ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Ы– ЩҒЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш®ЩҺЩҠЩ’ШұЩҢ ШӯЩҺЩҖЩ°ЩҒЩҗШёЩӢЫӯШ§ Ы– ЩҲЩҺЩҮЩҸЩҲЩҺ ШЈЩҺШұЩ’ШӯЩҺЩ…ЩҸ ЩұЩ„ШұЩ‘ЩҺЩ°ШӯЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"12:65","surah":12,"ayah":65,"num":1661,"page":243,"words":[{"code":"пұ”","page":243,"end":false},{"code":"пұ•","page":243,"end":false},{"code":"пұ–","page":243,"end":false},{"code":"пұ—","page":243,"end":false},{"code":"пұҳ","page":243,"end":false},{"code":"пұҷ","page":243,"end":false},{"code":"пұҡпұӣ","page":243,"end":false},{"code":"пұң","page":243,"end":false},{"code":"пұқ","page":243,"end":false},{"code":"пұһ","page":243,"end":false},{"code":"пұҹпұ ","page":243,"end":false},{"code":"пұЎ","page":243,"end":false},{"code":"пұў","page":243,"end":false},{"code":"пұЈ","page":243,"end":false},{"code":"пұӨпұҘ","page":243,"end":false},{"code":"пұҰ","page":243,"end":false},{"code":"пұ§","page":243,"end":false},{"code":"пұЁ","page":243,"end":false},{"code":"пұ©","page":243,"end":false},{"code":"пұӘ","page":243,"end":false},{"code":"пұ«","page":243,"end":false},{"code":"пұ¬пұӯ","page":243,"end":false},{"code":"пұ®","page":243,"end":false},{"code":"пұҜ","page":243,"end":false},{"code":"пұ°","page":243,"end":false},{"code":"пұұ","page":243,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ЩҒЩҺШӘЩҺШӯЩҸЩҲШ§Ыҹ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШ¬ЩҺШҜЩҸЩҲШ§Ыҹ ШЁЩҗШ¶ЩҺЩҖЩ°Ш№ЩҺШӘЩҺЩҮЩҸЩ…Щ’ ШұЩҸШҜЩ‘ЩҺШӘЩ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ы– ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШ§ЩҶЩҺШ§ Щ…ЩҺШ§ ЩҶЩҺШЁЩ’ШәЩҗЩү Ы– ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗЫҰ ШЁЩҗШ¶ЩҺЩҖЩ°Ш№ЩҺШӘЩҸЩҶЩҺШ§ ШұЩҸШҜЩ‘ЩҺШӘЩ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Ы– ЩҲЩҺЩҶЩҺЩ…ЩҗЩҠШұЩҸ ШЈЩҺЩҮЩ’Щ„ЩҺЩҶЩҺШ§ ЩҲЩҺЩҶЩҺШӯЩ’ЩҒЩҺШёЩҸ ШЈЩҺШ®ЩҺШ§ЩҶЩҺШ§ ЩҲЩҺЩҶЩҺШІЩ’ШҜЩҺШ§ШҜЩҸ ЩғЩҺЩҠЩ’Щ„ЩҺ ШЁЩҺШ№ЩҗЩҠШұЩҚЫў Ы– Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩғЩҺЩҠЩ’Щ„ЩҢЫӯ ЩҠЩҺШіЩҗЩҠШұЩҢЫӯ"},{"key":"12:66","surah":12,"ayah":66,"num":1662,"page":243,"words":[{"code":"пұІ","page":243,"end":false},{"code":"пұі","page":243,"end":false},{"code":"пұҙ","page":243,"end":false},{"code":"пұө","page":243,"end":false},{"code":"пұ¶","page":243,"end":false},{"code":"пұ·","page":243,"end":false},{"code":"пұё","page":243,"end":false},{"code":"пұ№","page":243,"end":false},{"code":"пұә","page":243,"end":false},{"code":"пұ»","page":243,"end":false},{"code":"пұј","page":243,"end":false},{"code":"пұҪ","page":243,"end":false},{"code":"пұҫ","page":243,"end":false},{"code":"пұҝ","page":243,"end":false},{"code":"пІҖпІҒ","page":243,"end":false},{"code":"пІӮ","page":243,"end":false},{"code":"пІғ","page":243,"end":false},{"code":"пІ„","page":243,"end":false},{"code":"пІ…","page":243,"end":false},{"code":"пІҶ","page":243,"end":false},{"code":"пІҮ","page":243,"end":false},{"code":"пІҲ","page":243,"end":false},{"code":"пІү","page":243,"end":false},{"code":"пІҠ","page":243,"end":false},{"code":"пІӢ","page":243,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҺЩҶЩ’ ШЈЩҸШұЩ’ШіЩҗЩ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ№ЩҺЩғЩҸЩ…Щ’ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ШӘЩҸШӨЩ’ШӘЩҸЩҲЩҶЩҗ Щ…ЩҺЩҲЩ’Ш«ЩҗЩӮЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺШӘЩҺШЈЩ’ШӘЩҸЩҶЩ‘ЩҺЩҶЩҗЩү ШЁЩҗЩҮЩҗЫҰЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҸШӯЩҺШ§Ш·ЩҺ ШЁЩҗЩғЩҸЩ…Щ’ Ы– ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҲЩ’ЩҮЩҸ Щ…ЩҺЩҲЩ’Ш«ЩҗЩӮЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺШ§ ЩҶЩҺЩӮЩҸЩҲЩ„ЩҸ ЩҲЩҺЩғЩҗЩҠЩ„ЩҢЫӯ"},{"key":"12:67","surah":12,"ayah":67,"num":1663,"page":243,"words":[{"code":"пІҢ","page":243,"end":false},{"code":"пІҚ","page":243,"end":false},{"code":"пІҺ","page":243,"end":false},{"code":"пІҸ","page":243,"end":false},{"code":"пІҗ","page":243,"end":false},{"code":"пІ‘","page":243,"end":false},{"code":"пІ’","page":243,"end":false},{"code":"пІ“","page":243,"end":false},{"code":"пІ”","page":243,"end":false},{"code":"пІ•","page":243,"end":false},{"code":"пІ–пІ—","page":243,"end":false},{"code":"пІҳ","page":243,"end":false},{"code":"пІҷ","page":243,"end":false},{"code":"пІҡ","page":243,"end":false},{"code":"пІӣ","page":243,"end":false},{"code":"пІң","page":243,"end":false},{"code":"пІқ","page":243,"end":false},{"code":"пІһпІҹ","page":243,"end":false},{"code":"пІ ","page":243,"end":false},{"code":"пІЎ","page":243,"end":false},{"code":"пІў","page":243,"end":false},{"code":"пІЈпІӨ","page":243,"end":false},{"code":"пІҘ","page":243,"end":false},{"code":"пІҰпІ§","page":243,"end":false},{"code":"пІЁ","page":243,"end":false},{"code":"пІ©","page":243,"end":false},{"code":"пІӘ","page":243,"end":false},{"code":"пІ«","page":243,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩҠЩҺЩҖЩ°ШЁЩҺЩҶЩҗЩүЩ‘ЩҺ Щ„ЩҺШ§ ШӘЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЫў ШЁЩҺШ§ШЁЩҚЫў ЩҲЩҺЩ°ШӯЩҗШҜЩҚЫў ЩҲЩҺЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШЈЩҺШЁЩ’ЩҲЩҺЩ°ШЁЩҚЫў Щ…Щ‘ЩҸШӘЩҺЩҒЩҺШұЩ‘ЩҗЩӮЩҺШ©ЩҚЫў Ы– ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸШәЩ’ЩҶЩҗЩү Ш№ЩҺЩҶЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚ Ы– ШҘЩҗЩҶЩҗ ЩұЩ„Щ’ШӯЩҸЩғЩ’Щ…ЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Ы– Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щ’ШӘЩҸ Ы– ЩҲЩҺШ№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩҒЩҺЩ„Щ’ЩҠЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щҗ ЩұЩ„Щ’Щ…ЩҸШӘЩҺЩҲЩҺЩғЩ‘ЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"12:68","surah":12,"ayah":68,"num":1664,"page":243,"words":[{"code":"пІ¬","page":243,"end":false},{"code":"пІӯ","page":243,"end":false},{"code":"пІ®","page":243,"end":false},{"code":"пІҜ","page":243,"end":false},{"code":"пІ°","page":243,"end":false},{"code":"пІұ","page":243,"end":false},{"code":"пІІ","page":243,"end":false},{"code":"пІі","page":243,"end":false},{"code":"пІҙ","page":243,"end":false},{"code":"пІө","page":243,"end":false},{"code":"пІ¶","page":243,"end":false},{"code":"пІ·","page":243,"end":false},{"code":"пІё","page":243,"end":false},{"code":"пІ№","page":243,"end":false},{"code":"пІә","page":243,"end":false},{"code":"пІ»","page":243,"end":false},{"code":"пІј","page":243,"end":false},{"code":"пІҪ","page":243,"end":false},{"code":"пІҫ","page":243,"end":false},{"code":"пІҝпіҖ","page":243,"end":false},{"code":"піҒ","page":243,"end":false},{"code":"піӮ","page":243,"end":false},{"code":"піғ","page":243,"end":false},{"code":"пі„","page":243,"end":false},{"code":"пі…","page":243,"end":false},{"code":"піҶ","page":243,"end":false},{"code":"піҮ","page":243,"end":false},{"code":"піҲ","page":243,"end":false},{"code":"піү","page":243,"end":false},{"code":"піҠ","page":243,"end":false},{"code":"піӢ","page":243,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШҜЩҺШ®ЩҺЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШӯЩҺЩҠЩ’Ш«ЩҸ ШЈЩҺЩ…ЩҺШұЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШЁЩҸЩҲЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ ЩҠЩҸШәЩ’ЩҶЩҗЩү Ш№ЩҺЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ШӯЩҺШ§Ш¬ЩҺШ©ЩӢЫӯ ЩҒЩҗЩү ЩҶЩҺЩҒЩ’ШіЩҗ ЩҠЩҺШ№Щ’ЩӮЩҸЩҲШЁЩҺ ЩӮЩҺШ¶ЩҺЩүЩ°ЩҮЩҺШ§ Ыҡ ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺШ°ЩҸЩҲ Ш№ЩҗЩ„Щ’Щ…ЩҚЫў Щ„Щ‘ЩҗЩ…ЩҺШ§ Ш№ЩҺЩ„Щ‘ЩҺЩ…Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"12:69","surah":12,"ayah":69,"num":1665,"page":243,"words":[{"code":"піҢ","page":243,"end":false},{"code":"піҚ","page":243,"end":false},{"code":"піҺ","page":243,"end":false},{"code":"піҸ","page":243,"end":false},{"code":"піҗ","page":243,"end":false},{"code":"пі‘","page":243,"end":false},{"code":"пі’пі“","page":243,"end":false},{"code":"пі”","page":243,"end":false},{"code":"пі•","page":243,"end":false},{"code":"пі–","page":243,"end":false},{"code":"пі—","page":243,"end":false},{"code":"піҳ","page":243,"end":false},{"code":"піҷ","page":243,"end":false},{"code":"піҡ","page":243,"end":false},{"code":"піӣ","page":243,"end":false},{"code":"пің","page":243,"end":false},{"code":"піқ","page":243,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШҜЩҺШ®ЩҺЩ„ЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҠЩҸЩҲШіЩҸЩҒЩҺ ШЎЩҺШ§ЩҲЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЈЩҺШ®ЩҺШ§ЩҮЩҸ Ы– ЩӮЩҺШ§Щ„ЩҺ ШҘЩҗЩҶЩ‘ЩҗЩүЩ“ ШЈЩҺЩҶЩҺШ§Ы  ШЈЩҺШ®ЩҸЩҲЩғЩҺ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШЁЩ’ШӘЩҺШҰЩҗШіЩ’ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"}]}
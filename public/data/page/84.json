,"page":84,"end":false},{"code":"пұҚ","page":84,"end":false},{"code":"пұҺпұҸ","page":84,"end":false},{"code":"пұҗ","page":84,"end":false},{"code":"пұ‘","page":84,"end":false},{"code":"пұ’","page":84,"end":false},{"code":"пұ“","page":84,"end":false},{"code":"пұ”","page":84,"end":false},{"code":"пұ•","page":84,"end":false},{"code":"пұ–пұ—","page":84,"end":false},{"code":"пұҳ","page":84,"end":false},{"code":"пұҷ","page":84,"end":false},{"code":"пұҡ","page":84,"end":false},{"code":"пұӣ","page":84,"end":false},{"code":"пұң","page":84,"end":false},{"code":"пұқ","page":84,"end":false},{"code":"пұһ","page":84,"end":false},{"code":"пұҹпұ ","page":84,"end":false},{"code":"пұЎ","page":84,"end":false},{"code":"пұў","page":84,"end":false},{"code":"пұЈ","page":84,"end":false},{"code":"пұӨ","page":84,"end":false},{"code":"пұҘ","page":84,"end":false},{"code":"пұҰпұ§","page":84,"end":false},{"code":"пұЁ","page":84,"end":false},{"code":"пұ©","page":84,"end":false},{"code":"пұӘ","page":84,"end":false},{"code":"пұ«","page":84,"end":false},{"code":"пұ¬","page":84,"end":false},{"code":"пұӯ","page":84,"end":true}],"text":"ЩұЩ„ШұЩ‘ЩҗШ¬ЩҺШ§Щ„ЩҸ ЩӮЩҺЩҲЩ‘ЩҺЩ°Щ…ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ ШЁЩҗЩ…ЩҺШ§ ЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў ЩҲЩҺШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҺЩҶЩҒЩҺЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩҮЩҗЩ…Щ’ Ыҡ ЩҒЩҺЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҸ ЩӮЩҺЩҖЩ°ЩҶЩҗШӘЩҺЩҖЩ°ШӘЩҢ ШӯЩҺЩҖЩ°ЩҒЩҗШёЩҺЩҖЩ°ШӘЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ’ШәЩҺЩҠЩ’ШЁЩҗ ШЁЩҗЩ…ЩҺШ§ ШӯЩҺЩҒЩҗШёЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩҲЩҺЩұЩ„Щ‘ЩҺЩҖЩ°ШӘЩҗЩү ШӘЩҺШ®ЩҺШ§ЩҒЩҸЩҲЩҶЩҺ ЩҶЩҸШҙЩҸЩҲШІЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҺШ№ЩҗШёЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩұЩҮЩ’Ш¬ЩҸШұЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҗЩү ЩұЩ„Щ’Щ…ЩҺШ¶ЩҺШ§Ш¬ЩҗШ№Щҗ ЩҲЩҺЩұШ¶Щ’ШұЩҗШЁЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Ы– ЩҒЩҺШҘЩҗЩҶЩ’ ШЈЩҺШ·ЩҺШ№Щ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШЁЩ’ШәЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ ШіЩҺШЁЩҗЩҠЩ„ЩӢШ§ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§ ЩғЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"4:35","surah":4,"ayah":35,"num":528,"page":84,"words":[{"code":"пұ®","page":84,"end":false},{"code":"пұҜ","page":84,"end":false},{"code":"пұ°","page":84,"end":false},{"code":"пұұ","page":84,"end":false},{"code":"пұІ","page":84,"end":false},{"code":"пұі","page":84,"end":false},{"code":"пұҙ","page":84,"end":false},{"code":"пұө","page":84,"end":false},{"code":"пұ¶","page":84,"end":false},{"code":"пұ·","page":84,"end":false},{"code":"пұё","page":84,"end":false},{"code":"пұ№","page":84,"end":false},{"code":"пұә","page":84,"end":false},{"code":"пұ»","page":84,"end":false},{"code":"пұј","page":84,"end":false},{"code":"пұҪ","page":84,"end":false},{"code":"пұҫпұҝ","page":84,"end":false},{"code":"пІҖ","page":84,"end":false},{"code":"пІҒ","page":84,"end":false},{"code":"пІӮ","page":84,"end":false},{"code":"пІғ","page":84,"end":false},{"code":"пІ„","page":84,"end":false},{"code":"пІ…","page":84,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ’ Ш®ЩҗЩҒЩ’ШӘЩҸЩ…Щ’ ШҙЩҗЩӮЩҺШ§ЩӮЩҺ ШЁЩҺЩҠЩ’ЩҶЩҗЩҮЩҗЩ…ЩҺШ§ ЩҒЩҺЩұШЁЩ’Ш№ЩҺШ«ЩҸЩҲШ§Ыҹ ШӯЩҺЩғЩҺЩ…ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШӯЩҺЩғЩҺЩ…ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҺШ§Щ“ ШҘЩҗЩҶ ЩҠЩҸШұЩҗЩҠШҜЩҺШ§Щ“ ШҘЩҗШөЩ’Щ„ЩҺЩҖЩ°ШӯЩӢЫӯШ§ ЩҠЩҸЩҲЩҺЩҒЩ‘ЩҗЩӮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§Щ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢШ§ Ш®ЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"4:36","surah":4,"ayah":36,"num":529,"page":84,"words":[{"code":"пІҶ пІҮ","page":84,"end":false},{"code":"пІҲ","page":84,"end":false},{"code":"пІү","page":84,"end":false},{"code":"пІҠ","page":84,"end":false},{"code":"пІӢ","page":84,"end":false},{"code":"пІҢпІҚ","page":84,"end":false},{"code":"пІҺ","page":84,"end":false},{"code":"пІҸ","page":84,"end":false},{"code":"пІҗ","page":84,"end":false},{"code":"пІ‘","page":84,"end":false},{"code":"пІ’","page":84,"end":false},{"code":"пІ“","page":84,"end":false},{"code":"пІ”","page":84,"end":false},{"code":"пІ•","page":84,"end":false},{"code":"пІ–","page":84,"end":false},{"code":"пІ—","page":84,"end":false},{"code":"пІҳ","page":84,"end":false},{"code":"пІҷ","page":84,"end":false},{"code":"пІҡ","page":84,"end":false},{"code":"пІӣ","page":84,"end":false},{"code":"пІң","page":84,"end":false},{"code":"пІқ","page":84,"end":false},{"code":"пІһ","page":84,"end":false},{"code":"пІҹпІ ","page":84,"end":false},{"code":"пІЎ","page":84,"end":false},{"code":"пІў","page":84,"end":false},{"code":"пІЈ","page":84,"end":false},{"code":"пІӨ","page":84,"end":false},{"code":"пІҘ","page":84,"end":false},{"code":"пІҰ","page":84,"end":false},{"code":"пІ§","page":84,"end":false},{"code":"пІЁ","page":84,"end":false},{"code":"пІ©","page":84,"end":true}],"text":"Ыһ ЩҲЩҺЩұШ№Щ’ШЁЩҸШҜЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШҙЩ’ШұЩҗЩғЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ Ы– ЩҲЩҺШЁЩҗЩұЩ„Щ’ЩҲЩҺЩ°Щ„ЩҗШҜЩҺЩҠЩ’ЩҶЩҗ ШҘЩҗШӯЩ’ШіЩҺЩҖЩ°ЩҶЩӢЫӯШ§ ЩҲЩҺШЁЩҗШ°ЩҗЩү ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЁЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҠЩҶЩҗ ЩҲЩҺЩұЩ„Щ’Ш¬ЩҺШ§ШұЩҗ Ш°ЩҗЩү ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЁЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’Ш¬ЩҺШ§ШұЩҗ ЩұЩ„Щ’Ш¬ЩҸЩҶЩҸШЁЩҗ ЩҲЩҺЩұЩ„ШөЩ‘ЩҺШ§ШӯЩҗШЁЩҗ ШЁЩҗЩұЩ„Щ’Ш¬ЩҺЩҶЫўШЁЩҗ ЩҲЩҺЩұШЁЩ’ЩҶЩҗ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ ЩҲЩҺЩ…ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҸШӯЩҗШЁЩ‘ЩҸ Щ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҸШ®Щ’ШӘЩҺШ§Щ„ЩӢЫӯШ§ ЩҒЩҺШ®ЩҸЩҲШұЩӢШ§"},{"key":"4:37","surah":4,"ayah":37,"num":530,"page":84,"words":[{"code":"пІӘ","page":84,"end":false},{"code":"пІ«","page":84,"end":false},{"code":"пІ¬","page":84,"end":false},{"code":"пІӯ","page":84,"end":false},{"code":"пІ®","page":84,"end":false},{"code":"пІҜ","page":84,"end":false},{"code":"пІ°","page":84,"end":false},{"code":"пІұ","page":84,"end":false},{"code":"пІІ","page":84,"end":false},{"code":"пІі","page":84,"end":false},{"code":"пІҙпІө","page":84,"end":false},{"code":"пІ¶","page":84,"end":false},{"code":"пІ·","page":84,"end":false},{"code":"пІё","page":84,"end":false},{"code":"пІ№","page":84,"end":false},{"code":"пІә","page":84,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШЁЩ’Ш®ЩҺЩ„ЩҸЩҲЩҶЩҺ ЩҲЩҺЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩҲЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ШЁЩҗЩұЩ„Щ’ШЁЩҸШ®Щ’Щ„Щҗ ЩҲЩҺЩҠЩҺЩғЩ’ШӘЩҸЩ…ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩүЩ°ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҶ ЩҒЩҺШ¶Щ’Щ„ЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺШЈЩҺШ№Щ’ШӘЩҺШҜЩ’ЩҶЩҺШ§ Щ„ЩҗЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩӢЫӯШ§ Щ…Щ‘ЩҸЩҮЩҗЩҠЩҶЩӢЫӯШ§"}]}
]}],"verses":[{"key":"8:9","surah":8,"ayah":9,"num":1169,"page":178,"words":[{"code":"пұҒ","page":178,"end":false},{"code":"пұӮ","page":178,"end":false},{"code":"пұғ","page":178,"end":false},{"code":"пұ„","page":178,"end":false},{"code":"пұ…","page":178,"end":false},{"code":"пұҶ","page":178,"end":false},{"code":"пұҮ","page":178,"end":false},{"code":"пұҲ","page":178,"end":false},{"code":"пұү","page":178,"end":false},{"code":"пұҠ","page":178,"end":false},{"code":"пұӢ","page":178,"end":false},{"code":"пұҢ","page":178,"end":true}],"text":"ШҘЩҗШ°Щ’ ШӘЩҺШіЩ’ШӘЩҺШәЩҗЩҠШ«ЩҸЩҲЩҶЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩұШіЩ’ШӘЩҺШ¬ЩҺШ§ШЁЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҶЩ‘ЩҗЩү Щ…ЩҸЩ…ЩҗШҜЩ‘ЩҸЩғЩҸЩ… ШЁЩҗШЈЩҺЩ„Щ’ЩҒЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©Щҗ Щ…ЩҸШұЩ’ШҜЩҗЩҒЩҗЩҠЩҶЩҺ"},{"key":"8:10","surah":8,"ayah":10,"num":1170,"page":178,"words":[{"code":"пұҚ","page":178,"end":false},{"code":"пұҺ","page":178,"end":false},{"code":"пұҸ","page":178,"end":false},{"code":"пұҗ","page":178,"end":false},{"code":"пұ‘","page":178,"end":false},{"code":"пұ’","page":178,"end":false},{"code":"пұ“","page":178,"end":false},{"code":"пұ”пұ•","page":178,"end":false},{"code":"пұ–","page":178,"end":false},{"code":"пұ—","page":178,"end":false},{"code":"пұҳ","page":178,"end":false},{"code":"пұҷ","page":178,"end":false},{"code":"пұҡ","page":178,"end":false},{"code":"пұӣпұң","page":178,"end":false},{"code":"пұқ","page":178,"end":false},{"code":"пұһ","page":178,"end":false},{"code":"пұҹ","page":178,"end":false},{"code":"пұ ","page":178,"end":false},{"code":"пұЎ","page":178,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ Ш¬ЩҺШ№ЩҺЩ„ЩҺЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҸШҙЩ’ШұЩҺЩүЩ° ЩҲЩҺЩ„ЩҗШӘЩҺШ·Щ’Щ…ЩҺШҰЩҗЩҶЩ‘ЩҺ ШЁЩҗЩҮЩҗЫҰ ЩӮЩҸЩ„ЩҸЩҲШЁЩҸЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШөЩ’ШұЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺШІЩҗЩҠШІЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢ"},{"key":"8:11","surah":8,"ayah":11,"num":1171,"page":178,"words":[{"code":"пұў","page":178,"end":false},{"code":"пұЈ","page":178,"end":false},{"code":"пұӨ","page"
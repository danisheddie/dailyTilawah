„Щ’ШҘЩҗЩҶШіЩҸ ЩҲЩҺЩұЩ„Щ’Ш¬ЩҗЩҶЩ‘ЩҸ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҶ ЩҠЩҺШЈЩ’ШӘЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҗШ«Щ’Щ„Щҗ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҗ Щ„ЩҺШ§ ЩҠЩҺШЈЩ’ШӘЩҸЩҲЩҶЩҺ ШЁЩҗЩ…ЩҗШ«Щ’Щ„ЩҗЩҮЩҗЫҰ ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҺ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ…Щ’ Щ„ЩҗШЁЩҺШ№Щ’Ш¶ЩҚЫў ШёЩҺЩҮЩҗЩҠШұЩӢЫӯШ§"},{"key":"17:89","surah":17,"ayah":89,"num":2118,"page":291,"words":[{"code":"пұ ","page":291,"end":false},{"code":"пұЎ","page":291,"end":false},{"code":"пұў","page":291,"end":false},{"code":"пұЈ","page":291,"end":false},{"code":"пұӨ","page":291,"end":false},{"code":"пұҘ","page":291,"end":false},{"code":"пұҰ","page":291,"end":false},{"code":"пұ§","page":291,"end":false},{"code":"пұЁ","page":291,"end":false},{"code":"пұ©","page":291,"end":false},{"code":"пұӘ","page":291,"end":false},{"code":"пұ«","page":291,"end":false},{"code":"пұ¬","page":291,"end":false},{"code":"пұӯ","page":291,"end":false},{"code":"пұ®","page":291,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШөЩҺШұЩ‘ЩҺЩҒЩ’ЩҶЩҺШ§ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҒЩҗЩү ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҗ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ Щ…ЩҺШ«ЩҺЩ„ЩҚЫў ЩҒЩҺШЈЩҺШЁЩҺЩүЩ°Щ“ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҸЩҒЩҸЩҲШұЩӢЫӯШ§"},{"key":"17:90","surah":17,"ayah":90,"num":2119,"page":291,"words":[{"code":"пұҜ","page":291,"end":false},{"code":"пұ°","page":291,"end":false},{"code":"пұұ","page":291,"end":false},{"code":"пұІ","page":291,"end":false},{"code":"пұі","page":291,"end":false},{"code":"пұҙ","page":291,"end":false},{"code":"пұө","page":291,"end":false},{"code":"пұ¶","page":291,"end":false},{"code":"пұ·","page":291,"end":false},{"code":"пұё","page":291,"end":false},{"code":"пұ№","page":291,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҶ ЩҶЩ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҺ Щ„ЩҺЩғЩҺ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ШӘЩҺЩҒЩ’Ш¬ЩҸШұЩҺ Щ„ЩҺЩҶЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҠЩҺЩҶЫўШЁЩҸЩҲШ№ЩӢШ§"},{"key":"17:91","surah":17,"ayah":91,"num":2120,"page":291,"words":[{"code":"пұә","page":291,"end":false},{"code":"пұ»","page":291,"end":false},{"code":"пұј","page":291,"end":false},{"code":"пұҪ","page":291,"end":false},{"
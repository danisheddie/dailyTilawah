nd":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false}]},{"lineNumber":15,"words":[{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":true}]}],"verses":[{"key":"17:8","surah":17,"ayah":8,"num":2037,"page":283,"words":[{"code":"пұҒ","page":283,"end":false},{"code":"пұӮ","page":283,"end":false},{"code":"пұғ","page":283,"end":false},{"code":"пұ„пұ…","page":283,"end":false},{"code":"пұҶ","page":283,"end":false},{"code":"пұҮ","page":283,"end":false},{"code":"пұҲпұү","page":283,"end":false},{"code":"пұҠ","page":283,"end":false},{"code":"пұӢ","page":283,"end":false},{"code":"пұҢ","page":283,"end":false},{"code":"пұҚ","page":283,"end":false},{"code":"пұҺ","page":283,"end":true}],"text":"Ш№ЩҺШіЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ЩҠЩҺШұЩ’ШӯЩҺЩ…ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШҘЩҗЩҶЩ’ Ш№ЩҸШҜШӘЩ‘ЩҸЩ…Щ’ Ш№ЩҸШҜЩ’ЩҶЩҺШ§ Ыҳ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Щ„ЩҗЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ШӯЩҺШөЩҗЩҠШұЩӢШ§"},{"key":"17:9","surah":17,"ayah":9,"num":2038,"page":283,"words":[{"code":"пұҸ","page":283,"end":false},{"code":"пұҗ","page":283,"end":false},{"code":"пұ‘","page":283,"end":false},{"code":"пұ’","page":283,"end":false},{"code":"пұ“","page":283,"end":false},{"code":"пұ”","page":283,"end":false},{"code":"пұ•","page":283,"end":false},{"code":"пұ–","page":283,"end":false},{"code":"пұ—","page":283,"end":false},{"code":"пұҳ","page":283,"end":false},{"code":"пұҷ","page":283,"end":false},{"code":"пұҡ","page":283,"end":false},{"code":"пұӣ","page":283,"end":false},{"code":"пұң","page":283,"end":false},{"code":"пұқ","page":283,"end":false},{"code":"пұһ","page":283,"end":false},{"code":"пұҹ","page":283,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҺ ЩҠЩҺЩҮЩ’ШҜЩҗЩү Щ„ЩҗЩ„Щ‘ЩҺШӘЩҗЩү ЩҮЩҗЩүЩҺ ШЈЩҺЩӮЩ’ЩҲЩҺЩ…ЩҸ ЩҲЩҺЩҠЩҸШЁЩҺШҙЩ‘ЩҗШұЩҸ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩӢЫӯШ§ ЩғЩҺШЁЩҗЩҠШұЩӢЫӯШ§"},{"key":"17:10","surah":17,"ayah":10,"num":2039,"page":283,"words":[{"code":"пұ ","page":283,"end":false},{"code":"пұЎ","page":283,"end":false},{"code":"пұў","page":283,"end":false},{"code":"пұЈ","page":283,"end":false},{"code":"пұӨ","page":283,"end":false},{"code":"пұҘ","page":283,"end":false},{"code":"пұҰ","page":283,"end":false},{"code":"пұ§","page":283,"end":false},{"code":"пұЁ","page":283,"end":false},{"code":"пұ©","page":283,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ШЈЩҺШ№Щ’ШӘЩҺШҜЩ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩӢШ§ ШЈЩҺЩ„ЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"17:11","surah":17,"ayah":11,"num":2040,"page":283,"words":[{"code":"пұӘ","page":283,"end":false},{"code":"пұ«","page":283,"end":false},{"code":"пұ¬","page":283,"end":false},{"code":"пұӯ","page":283,"end":false},{"code":"пұ®пұҜ","page":283,"end":false},{"code":"пұ°","page":283,"end":false},{"code":"пұұ","page":283,"end":false},{"code":"пұІ","page":283,"end":false},{"code":"пұі","page":283,"end":true}],"text":"ЩҲЩҺЩҠЩҺШҜЩ’Ш№ЩҸ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҸ ШЁЩҗЩұЩ„ШҙЩ‘ЩҺШұЩ‘Щҗ ШҜЩҸШ№ЩҺШ§Щ“ШЎЩҺЩҮЩҸЫҘ ШЁЩҗЩұЩ„Щ’Ш®ЩҺЩҠЩ’ШұЩҗ Ы– ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҸ Ш№ЩҺШ¬ЩҸЩҲЩ„ЩӢЫӯШ§"},{"key":"17:12","surah":17,"ayah":12,"num":2041,"page":283,"words":[{"code":"пұҙ","page":283,"end":false},{"code":"пұө","page":283,"end":false},{"code":"пұ¶","page":283,"end":false},{"code":"пұ·пұё","page":283,"end":false},{"code":"пұ№","page":283,"end":false},{"code":"пұә","page":283,"end":false},{"code":"пұ»","page":283,"end":false},{"code":"пұј","page":283,"end":false},{"code":"пұҪ","page":283,"end":false},{"code":"пұҫ","page":283,"end":false},{"code":"пұҝ","page":283,"end":false},{"code":"пІҖ","page":283,"end":false},{"code":"пІҒ","page":283,"end":false},{"code":"пІӮ","page":283,"end":false},{"code":"пІғ","page":283,"end":false},{"code":"пІ„","page":283,"end":false},{"code":"пІ…","page":283,"end":false},{"code":"пІҶ","page":283,"end":false},{"code":"пІҮпІҲ","page":283,"end":false},{"code":"пІү","page":283,"end":false},{"code":"пІҠ","page":283,"end":false},{"code":"пІӢ","page":283,"end":false},{"code":"пІҢ","page":283,"end":false},{"code":"пІҚ","page":283,"end":true}],"text":"ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„ЩҺ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҺ ШЎЩҺШ§ЩҠЩҺШӘЩҺЩҠЩ’ЩҶЩҗ Ы– ЩҒЩҺЩ…ЩҺШӯЩҺЩҲЩ’ЩҶЩҺШ§Щ“ ШЎЩҺШ§ЩҠЩҺШ©ЩҺ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§Щ“ ШЎЩҺШ§ЩҠЩҺШ©ЩҺ ЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҗ Щ…ЩҸШЁЩ’ШөЩҗШұЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗШӘЩҺШЁЩ’ШӘЩҺШәЩҸЩҲШ§Ыҹ ЩҒЩҺШ¶Щ’Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҗШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Ш№ЩҺШҜЩҺШҜЩҺ ЩұЩ„ШіЩ‘ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺЩұЩ„Щ’ШӯЩҗШіЩҺШ§ШЁЩҺ Ыҡ ЩҲЩҺЩғЩҸЩ„Щ‘ЩҺ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩҒЩҺШөЩ‘ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ШӘЩҺЩҒЩ’ШөЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"17:13","surah":17,"ayah":13,"num":2042,"page":283,"words":[{"code":"пІҺ","page":283,"end":false},{"code":"пІҸ","page":283,"end":false},{"code":"пІҗ","page":283,"end":false},{"code":"пІ‘","page":283,"end":false},{"code":"пІ’","page":283,"end":false},{"code":"пІ“пІ”","page":283,"end":false},{"code":"пІ•","page":283,"end":false},{"code":"пІ–","page":283,"end":false},{"code":"пІ—","page":283,"end":false},{"code":"пІҳ","page":283,"end":false},{"code":"пІҷ","page":283,"end":false},{"code":"пІҡ","page":283,"end":false},{"code":"пІӣ","page":283,"end":false},{"code":"пІң","page":283,"end":true}],"text":"ЩҲЩҺЩғЩҸЩ„Щ‘ЩҺ ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҚ ШЈЩҺЩ„Щ’ШІЩҺЩ…Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ Ш·ЩҺЩҖЩ°Щ“ШҰЩҗШұЩҺЩҮЩҸЫҘ ЩҒЩҗЩү Ш№ЩҸЩҶЩҸЩӮЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺЩҶЩҸШ®Щ’ШұЩҗШ¬ЩҸ Щ„ЩҺЩҮЩҸЫҘ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩӢЫӯШ§ ЩҠЩҺЩ„Щ’ЩӮЩҺЩүЩ°ЩҮЩҸ Щ…ЩҺЩҶШҙЩҸЩҲШұЩӢШ§"},{"key":"17:14","surah":17,"ayah":14,"num":2043,"page":283,"words":[{"code":"пІқ","page":283,"end":false},{"code":"пІһ","page":283,"end":false},{"code":"пІҹ","page":283,"end":false},{"code":"пІ ","page":283,"end":false},{"code":"пІЎ","page":283,"end":false},{"code":"пІў","page":283,"end":false},{"code":"пІЈ","page":283,"end":false},{"code":"пІӨ","page":283,"end":true}],"text":"ЩұЩӮЩ’ШұЩҺШЈЩ’ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺЩғЩҺ ЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩҶЩҺЩҒЩ’ШіЩҗЩғЩҺ ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ ШӯЩҺШіЩҗЩҠШЁЩӢЫӯШ§"},{"key":"17:15","surah":17,"ayah":15,"num":2044,"page":283,"words":[{"code":"пІҘ","page":283,"end":false},{"code":"пІҰ","page":283,"end":false},{"code":"пІ§","page":283,"end":false},{"code":"пІЁ","page":283,"end":false},{"code":"пІ©пІӘ","page":283,"end":false},{"code":"пІ«","page":283,"end":false},{"code":"пІ¬","page":283,"end":false},{"code":"пІӯ","page":283,"end":false},{"code":"пІ®","page":283,"end":false},{"code":"пІҜпІ°","page":283,"end":false},{"code":"пІұ","page":283,"end":false},{"code":"пІІ","page":283,"end":false},{"code":"пІі","page":283,"end":false},{"code":"пІҙ","page":283,"end":false},{"code":"пІөпІ¶","page":283,"end":false},{"code":"пІ·","page":283,"end":false},{"code":"пІё","page":283,"end":false},{"code":"пІ№","page":283,"end":false},{"code":"пІә","page":283,"end":false},{"code":"пІ»","page":283,"end":false},{"code":"пІј","page":283,"end":false},{"code":"пІҪ","page":283,"end":true}],"text":"Щ…Щ‘ЩҺЩҶЩҗ ЩұЩҮЩ’ШӘЩҺШҜЩҺЩүЩ° ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҠЩҺЩҮЩ’ШӘЩҺШҜЩҗЩү Щ„ЩҗЩҶЩҺЩҒЩ’ШіЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺЩ…ЩҺЩҶ Ш¶ЩҺЩ„Щ‘ЩҺ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҠЩҺШ¶ЩҗЩ„Щ‘ЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШІЩҗШұЩҸ ЩҲЩҺШ§ШІЩҗШұЩҺШ©ЩҢЫӯ ЩҲЩҗШІЩ’ШұЩҺ ШЈЩҸШ®Щ’ШұЩҺЩүЩ° Ы— ЩҲЩҺЩ…ЩҺШ§ ЩғЩҸЩҶЩ‘ЩҺШ§ Щ…ЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҗЩҠЩҶЩҺ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҶЩҺШЁЩ’Ш№ЩҺШ«ЩҺ ШұЩҺШіЩҸЩҲЩ„ЩӢЫӯШ§"},{"key":"17:16","surah":17,"ayah":16,"num":2045,"page":283,"words":[{"code":"пІҫ","page":283,"end":false},{"code":"пІҝ","page":283,"end":false},{"code":"піҖ","page":283,"end":false},{"code":"піҒ","page":283,"end":false},{"code":"піӮ","page":283,"end":false},{"code":"піғ","page":283,"end":false},{"code":"пі„","page":283,"end":false},{"code":"пі…","page":283,"end":false},{"code":"піҶ","page":283,"end":false},{"code":"піҮ","page":283,"end":false},{"code":"піҲ","page":283,"end":false},{"code":"піү","page":283,"end":false},{"cod
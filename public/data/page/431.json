,{"code":"пұ§","page":431,"end":false},{"code":"пұЁ","page":431,"end":false},{"code":"пұ©","page":431,"end":false},{"code":"пұӘ","page":431,"end":false},{"code":"пұ«","page":431,"end":false},{"code":"пұ¬","page":431,"end":false},{"code":"пұӯ","page":431,"end":false},{"code":"пұ®","page":431,"end":false},{"code":"пұҜ","page":431,"end":true}],"text":"Ыһ ЩӮЩҸЩ„Щ’ Щ…ЩҺЩҶ ЩҠЩҺШұЩ’ШІЩҸЩӮЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы– ЩӮЩҸЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ШҘЩҗЩҠЩ‘ЩҺШ§ЩғЩҸЩ…Щ’ Щ„ЩҺШ№ЩҺЩ„ЩҺЩүЩ° ЩҮЩҸШҜЩӢЩү ШЈЩҺЩҲЩ’ ЩҒЩҗЩү Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҚЫў Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҚЫў"},{"key":"34:25","surah":34,"ayah":25,"num":3631,"page":431,"words":[{"code":"пұ°","page":431,"end":false},{"code":"пұұ","page":431,"end":false},{"code":"пұІ","page":431,"end":false},{"code":"пұі","page":431,"end":false},{"code":"пұҙ","page":431,"end":false},{"code":"пұө","page":431,"end":false},{"code":"пұ¶","page":431,"end":false},{"code":"пұ·","page":431,"end":false},{"code":"пұё","page":431,"end":false},{"code":"пұ№","page":431,"end":true}],"text":"ЩӮЩҸЩ„ Щ„Щ‘ЩҺШ§ ШӘЩҸШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ…Щ‘ЩҺШ§Щ“ ШЈЩҺШ¬Щ’ШұЩҺЩ…Щ’ЩҶЩҺШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҶЩҸШіЩ’ЩҖЩ”ЩҺЩ„ЩҸ Ш№ЩҺЩ…Щ‘ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"34:26","surah":34,"ayah":26,"num":3632,"page":431,"words":[{"code":"пұә","page":431,"end":false},{"code":"пұ»","page":431,"end":false},{"code":"пұј","page":431,"end":false},{"code":"пұҪ","page":431,"end":false},{"code":"пұҫ","page":431,"end":false},{"code":"пұҝ","page":431,"end":false},{"code":"пІҖ","page":431,"end":false},{"code":"пІҒ","page":431,"end":false},{"code":"пІӮ","page":431,"end":false},{"code":"пІғ","page":431,"end":false},{"code":"пІ„","page":431,"end":false},{"code":"пІ…","page":431,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ЩҠЩҺШ¬Щ’Щ…ЩҺШ№ЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҶЩҺШ§ ШұЩҺШЁЩ‘ЩҸЩҶЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҺЩҒЩ’ШӘЩҺШӯЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩҶЩҺШ§ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ЩҒЩҺШӘЩ‘ЩҺШ§ШӯЩҸ ЩұЩ„Щ’Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҸ"},{"key":"34:27","surah":34,"ayah":27,"num":3633,"page":431,"
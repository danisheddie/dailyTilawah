lse},{"code":"пұҘ","page":172,"end":false},{"code":"пұҰ","page":172,"end":false},{"code":"пұ§","page":172,"end":false},{"code":"пұЁ","page":172,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ЩҶЩҺШіЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Ш°ЩҸЩғЩ‘ЩҗШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҶШ¬ЩҺЩҠЩ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„ШіЩ‘ЩҸЩҲЩ“ШЎЩҗ ЩҲЩҺШЈЩҺШ®ЩҺШ°Щ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ШЁЩҗШ№ЩҺШ°ЩҺШ§ШЁЩҚЫӯ ШЁЩҺЩҖЩ”ЩҗЩҠШіЩҚЫӯ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩҒЩ’ШіЩҸЩӮЩҸЩҲЩҶЩҺ"},{"key":"7:166","surah":7,"ayah":166,"num":1120,"page":172,"words":[{"code":"пұ©","page":172,"end":false},{"code":"пұӘ","page":172,"end":false},{"code":"пұ«","page":172,"end":false},{"code":"пұ¬","page":172,"end":false},{"code":"пұӯ","page":172,"end":false},{"code":"пұ®","page":172,"end":false},{"code":"пұҜ","page":172,"end":false},{"code":"пұ°","page":172,"end":false},{"code":"пұұ","page":172,"end":false},{"code":"пұІ","page":172,"end":false},{"code":"пұі","page":172,"end":false},{"code":"пұҙ","page":172,"end":true}],"text":"ЩҒЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ Ш№ЩҺШӘЩҺЩҲЩ’Ш§Ыҹ Ш№ЩҺЩҶ Щ…Щ‘ЩҺШ§ ЩҶЩҸЩҮЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸ ЩӮЩҸЩ„Щ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ЩӮЩҗШұЩҺШҜЩҺШ©ЩӢ Ш®ЩҺЩҖЩ°ШіЩҗЩҖЩ”ЩҗЩҠЩҶЩҺ"},{"key":"7:167","surah":7,"ayah":167,"num":1121,"page":172,"words":[{"code":"пұө","page":172,"end":false},{"code":"пұ¶","page":172,"end":false},{"code":"пұ·","page":172,"end":false},{"code":"пұё","page":172,"end":false},{"code":"пұ№","page":172,"end":false},{"code":"пұә","page":172,"end":false},{"code":"пұ»","page":172,"end":false},{"code":"пұј","page":172,"end":false},{"code":"пұҪ","page":172,"end":false},{"code":"пұҫ","page":172,"end":false},{"code":"пұҝ","page":172,"end":false},{"code":"пІҖпІҒ","page":172,"end":false},{"code":"пІӮ","page":172,"end":false},{"code":"пІғ","page":172,"end":false},{"code":"пІ„","page":172,"end":false},{"code":"пІ…","page":172,"end":false},{"code":"пІҶ","page":172,"end":false},{"code":"пІҮ","page":172,"end":false},{"code":"пІҲ","page":172,"end":false},{"code":"пІү","page":172,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ШӘЩҺШЈЩҺШ°Щ‘ЩҺЩҶЩҺ ШұЩҺШЁЩ‘ЩҸЩғЩҺ Щ„ЩҺЩҠЩҺШЁЩ’Ш№ЩҺШ«ЩҺЩҶЩ‘ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Щ…ЩҺЩҶ ЩҠЩҺШіЩҸЩҲЩ…ЩҸЩҮЩҸЩ…Щ’ ШіЩҸЩҲЩ“ШЎЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ Ы— ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҺ Щ„ЩҺШіЩҺШұЩҗЩҠШ№ЩҸ ЩұЩ„Щ’Ш№ЩҗЩӮЩҺШ§ШЁЩҗ Ы– ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"7:168","surah":7,"ayah":168,"num":1122,"page":172,"words":[{"code":"пІҠ","page":172,"end":false},{"code":"пІӢ","page":172,"end":false},{"code":"пІҢ","page":172,"end":false},{"code":"пІҚпІҺ","page":172,"end":false},{"code":"пІҸ","page":172,"end":false},{"code":"пІҗ","page":172,"end":false},{"code":"пІ‘","page":172,"end":false},{"code":"пІ’","page":172,"end":false},{"code":"пІ“пІ”","page":172,"end":false},{"code":"пІ•","page":172,"end":false},{"code":"пІ–","page":172,"end":false},{"code":"пІ—","page":172,"end":false},{"code":"пІҳ","page":172,"end":false},{"code":"пІҷ","page":172,"end":false},{"code":"пІҡ","page":172,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ·Щ‘ЩҺШ№Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҸЩ…ЩҺЩ…ЩӢЫӯШ§ Ы– Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҸЩҲЩҶЩҺ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШҜЩҸЩҲЩҶЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ы– ЩҲЩҺШЁЩҺЩ„ЩҺЩҲЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ШӯЩҺШіЩҺЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҲЩҶЩҺ"},{"key":"7:169","surah":7,"ayah":169,"num":1123,"page":172,"words":[{"code":"пІӣ","page":172,"end":false},{"code":"пІң","page":172,"end":false},{"code":"пІқ","page":172,"end":false},{"code":"пІһ","page":172,"end":false},{"code":"пІҹ","page":172,"end":false},{"code":"пІ ","page":172,"end":false},{"code":"пІЎ","page":172,"end":false},{"code":"пІў","page":172,"end":false},{"code":"пІЈ","page":172,"end":false},{"code":"пІӨ","page":172,"end":false},{"code":"пІҘ","page":172,"end":false},{"code":"пІҰ","page":172,"end":false},{"code":"пІ§","page":172,"end":false},{"code":"пІЁ","page":172,"end":false},{"code":"пІ©","page":172,"end":false},{"code":"пІӘ","page":172,"
:"пІі","page":168,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺШ®ЩҺШ°ЩҺ ЩӮЩҺЩҲЩ’Щ…ЩҸ Щ…ЩҸЩҲШіЩҺЩүЩ° Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ ШӯЩҸЩ„ЩҗЩҠЩ‘ЩҗЩҮЩҗЩ…Щ’ Ш№ЩҗШ¬Щ’Щ„ЩӢЫӯШ§ Ш¬ЩҺШіЩҺШҜЩӢЫӯШ§ Щ„Щ‘ЩҺЩҮЩҸЫҘ Ш®ЩҸЩҲЩҺШ§ШұЩҢ Ыҡ ШЈЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺШ§ ЩҠЩҸЩғЩҺЩ„Щ‘ЩҗЩ…ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩҮЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ШіЩҺШЁЩҗЩҠЩ„ЩӢШ§ Ыҳ ЩұШӘЩ‘ЩҺШ®ЩҺШ°ЩҸЩҲЩҮЩҸ ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШёЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"7:149","surah":7,"ayah":149,"num":1103,"page":168,"words":[{"code":"пІҙ","page":168,"end":false},{"code":"пІө","page":168,"end":false},{"code":"пІ¶","page":168,"end":false},{"code":"пІ·","page":168,"end":false},{"code":"пІё","page":168,"end":false},{"code":"пІ№","page":168,"end":false},{"code":"пІә","page":168,"end":false},{"code":"пІ»","page":168,"end":false},{"code":"пІј","page":168,"end":false},{"code":"пІҪ","page":168,"end":false},{"code":"пІҫ","page":168,"end":false},{"code":"пІҝ","page":168,"end":false},{"code":"піҖ","page":168,"end":false},{"code":"піҒ","page":168,"end":false},{"code":"піӮ","page":168,"end":false},{"code":"піғ","page":168,"end":false},{"code":"пі„","page":168,"end":false},{"code":"пі…","page":168,"end":false},{"code":"піҶ","page":168,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ШіЩҸЩӮЩҗШ·ЩҺ ЩҒЩҗЩүЩ“ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺШұЩҺШЈЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺШҜЩ’ Ш¶ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺШҰЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШұЩ’ШӯЩҺЩ…Щ’ЩҶЩҺШ§ ШұЩҺШЁЩ‘ЩҸЩҶЩҺШ§ ЩҲЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩҶЩҺШ§ Щ„ЩҺЩҶЩҺЩғЩҸЩҲЩҶЩҺЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш®ЩҺЩҖЩ°ШіЩҗШұЩҗЩҠЩҶЩҺ"}]}
:[{"code":"пұҒ","page":168,"end":false},{"code":"пұӮ","page":168,"end":false},{"code":"пұғ","page":168,"end":false},{"code":"пұ„","page":168,"end":false},{"code":"пұ…","page":168,"end":false},{"code":"пұҶ","page":168,"end":false},{"code":"пұҮ","page":168,"end":false},{"code":"пұҲ","page":168,"end":false},{"code":"пұү","page":168,"end":false},{"code":"пұҠ","page":168,"end":false},{"code":"пұӢ","page":168,"end":false},{"code":"пұҢ","page":168,"end":false},{"code":"пұҚ","page":168,"end":false},{"code":"пұҺ","page":168,"end":false},{"code":"пұҸ","page":168,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩҠЩҺЩҖЩ°Щ…ЩҸЩҲШіЩҺЩүЩ°Щ“ ШҘЩҗЩҶЩ‘ЩҗЩү ЩұШөЩ’Ш·ЩҺЩҒЩҺЩҠЩ’ШӘЩҸЩғЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШЁЩҗШұЩҗШіЩҺЩҖЩ°Щ„ЩҺЩҖЩ°ШӘЩҗЩү ЩҲЩҺШЁЩҗЩғЩҺЩ„ЩҺЩҖЩ°Щ…ЩҗЩү ЩҒЩҺШ®ЩҸШ°Щ’ Щ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҠЩ’ШӘЩҸЩғЩҺ ЩҲЩҺЩғЩҸЩҶ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҖЩ°ЩғЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"7:145","surah":7,"ayah":145,"num":1099,"page":168,"words":[{"code":"пұҗ","page":168,"end":false},{"code":"пұ‘","page":168,"end":false},{"code":"пұ’","page":168,"end":false},{"code":"пұ“","page":168,"end":false},{"code":"пұ”","page":168,"end":false},{"code":"пұ•","page":168,"end":false},{"code":"пұ–","page":168,"end":false},{"code":"пұ—","page":168,"end":false},{"code":"пұҳ","page":168,"end":false},{"code":"пұҷ","page":168,"end":false},{"code":"пұҡ","page":168,"end":false},{"code":"пұӣ","page":168,"end":false},{"code":"пұң","page":168,"end":false},{"code":"пұқ","page":168,"end":false},{"code":"пұһ","page":168,"end":false},{"code":"пұҹ","page":168,"end":false},{"code":"пұ пұЎ","page":168,"end":false},{"code":"пұў","page":168,"end":false},{"code":"пұЈ","page":168,"end":false},{"code":"пұӨ","page":168,"end":false},{"code":"пұҘ","page":168,"end":true}],"text":"ЩҲЩҺЩғЩҺШӘЩҺШЁЩ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЫҘ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺЩ„Щ’ЩҲЩҺШ§ШӯЩҗ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў Щ…Щ‘ЩҺЩҲЩ’Ш№ЩҗШёЩҺШ©ЩӢЫӯ ЩҲЩҺШӘЩҺЩҒЩ’ШөЩҗЩҠЩ„ЩӢЫӯШ§ Щ„Щ‘ЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩҒЩҺШ®ЩҸШ°Щ’ЩҮЩҺШ§ ШЁЩҗЩӮЩҸЩҲЩ‘ЩҺШ©ЩҚЫў ЩҲЩҺШЈЩ’Щ…ЩҸШұЩ’ ЩӮЩҺЩҲЩ’Щ…ЩҺЩғЩҺ ЩҠЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲШ§Ыҹ ШЁЩҗ
ode":"пұү","page":341,"end":false},{"code":"пұҠ","page":341,"end":false},{"code":"пұӢ","page":341,"end":false},{"code":"пұҢ","page":341,"end":false},{"code":"пұҚ","page":341,"end":false},{"code":"пұҺ","page":341,"end":false},{"code":"пұҸ","page":341,"end":false},{"code":"пұҗ","page":341,"end":false},{"code":"пұ‘","page":341,"end":false},{"code":"пұ’","page":341,"end":false},{"code":"пұ“пұ”","page":341,"end":false},{"code":"пұ•","page":341,"end":false},{"code":"пұ–","page":341,"end":false},{"code":"пұ—","page":341,"end":false},{"code":"пұҳ","page":341,"end":false},{"code":"пұҷ","page":341,"end":false},{"code":"пұҡ","page":341,"end":false},{"code":"пұӣпұң","page":341,"end":false},{"code":"пұқ","page":341,"end":false},{"code":"пұһ","page":341,"end":false},{"code":"пұҹ","page":341,"end":false},{"code":"пұ ","page":341,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҸ Ш¶ЩҸШұЩҗШЁЩҺ Щ…ЩҺШ«ЩҺЩ„ЩҢЫӯ ЩҒЩҺЩұШіЩ’ШӘЩҺЩ…ЩҗШ№ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЫҘЩ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺЩҶ ЩҠЩҺШ®Щ’Щ„ЩҸЩӮЩҸЩҲШ§Ыҹ Ш°ЩҸШЁЩҺШ§ШЁЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺЩҲЩҗ ЩұШ¬Щ’ШӘЩҺЩ…ЩҺШ№ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЫҘ Ы– ЩҲЩҺШҘЩҗЩҶ ЩҠЩҺШіЩ’Щ„ЩҸШЁЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„Ш°Щ‘ЩҸШЁЩҺШ§ШЁЩҸ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ Щ„Щ‘ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺЩҶЩӮЩҗШ°ЩҸЩҲЩҮЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸ Ыҡ Ш¶ЩҺШ№ЩҸЩҒЩҺ ЩұЩ„Ш·Щ‘ЩҺШ§Щ„ЩҗШЁЩҸ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШ·Щ’Щ„ЩҸЩҲШЁЩҸ"},{"key":"22:74","surah":22,"ayah":74,"num":2669,"page":341,"words":[{"code":"пұЎ","page":341,"end":false},{"code":"пұў","page":341,"end":false},{"code":"пұЈ","page":341,"end":false},{"code":"пұӨ","page":341,"end":false},{"code":"пұҘпұҰ","page":341,"end":false},{"code":"пұ§","page":341,"end":false},{"code":"пұЁ","page":341,"end":false},{"code":"пұ©","page":341,"end":false},{"code":"пұӘ","page":341,"end":false},{"code":"пұ«","page":341,"end":true}],"text":"Щ…ЩҺШ§ ЩӮЩҺШҜЩҺШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШӯЩҺЩӮЩ‘ЩҺ ЩӮЩҺШҜЩ’ШұЩҗЩҮЩҗЫҰЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺЩӮЩҺЩҲЩҗЩүЩ‘ЩҢ Ш№ЩҺШІЩҗЩҠШІЩҢ"},{"key":"22:75","surah":22,"ayah":75,"num":2670,"page":341,"wor
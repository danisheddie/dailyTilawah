ШЁЩ‘ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩұЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш®ЩҺЩҠЩ’ШұЩҺ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ Ы©"},{"key":"22:78","surah":22,"ayah":78,"num":2673,"page":341,"words":[{"code":"пІ“","page":341,"end":false},{"code":"пІ”","page":341,"end":false},{"code":"пІ•","page":341,"end":false},{"code":"пІ–","page":341,"end":false},{"code":"пІ—пІҳ","page":341,"end":false},{"code":"пІҷ","page":341,"end":false},{"code":"пІҡ","page":341,"end":false},{"code":"пІӣ","page":341,"end":false},{"code":"пІң","page":341,"end":false},{"code":"пІқ","page":341,"end":false},{"code":"пІһ","page":341,"end":false},{"code":"пІҹ","page":341,"end":false},{"code":"пІ ","page":341,"end":false},{"code":"пІЎпІў","page":341,"end":false},{"code":"пІЈ","page":341,"end":false},{"code":"пІӨ","page":341,"end":false},{"code":"пІҘпІҰ","page":341,"end":false},{"code":"пІ§","page":341,"end":false},{"code":"пІЁ","page":341,"end":false},{"code":"пІ©","page":341,"end":false},{"code":"пІӘ","page":341,"end":false},{"code":"пІ«","page":341,"end":false},{"code":"пІ¬","page":341,"end":false},{"code":"пІӯ","page":341,"end":false},{"code":"пІ®","page":341,"end":false},{"code":"пІҜ","page":341,"end":false},{"code":"пІ°","page":341,"end":false},{"code":"пІұ","page":341,"end":false},{"code":"пІІ","page":341,"end":false},{"code":"пІі","page":341,"end":false},{"code":"пІҙ","page":341,"end":false},{"code":"пІөпІ¶","page":341,"end":false},{"code":"пІ·","page":341,"end":false},{"code":"пІё","page":341,"end":false},{"code":"пІ№","page":341,"end":false},{"code":"пІә","page":341,"end":false},{"code":"пІ»","page":341,"end":false},{"code":"пІј","page":341,"end":false},{"code":"пІҪ","page":341,"end":false},{"code":"пІҫпІҝ","page":341,"end":false},{"code":"піҖ","page":341,"end":false},{"code":"піҒ","page":341,"end":false},{"code":"піӮ","page":341,"end":false},{"code":"піғ","page":341,"end":false},{"code":"пі„","page":341,"end":true}],"text":"ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӯЩҺЩӮЩ‘ЩҺ Ш¬ЩҗЩҮЩҺШ§ШҜЩҗЩҮЩҗЫҰ Ыҡ ЩҮЩҸЩҲЩҺ ЩұШ¬Щ’ШӘЩҺШЁЩҺЩүЩ°ЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ Ш¬ЩҺШ№ЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҗ Щ…ЩҗЩҶЩ’ ШӯЩҺШұЩҺШ¬ЩҚЫў Ыҡ Щ…Щ‘ЩҗЩ„Щ‘ЩҺШ©ЩҺ ШЈЩҺШЁЩҗЩҠЩғЩҸЩ…Щ’ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҺ Ыҡ ЩҮЩҸЩҲЩҺ ШіЩҺЩ…Щ‘ЩҺЩүЩ°ЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸШіЩ’Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ ЩҲЩҺЩҒЩҗЩү ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ„ЩҗЩҠЩҺЩғЩҸЩҲЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҸ ШҙЩҺЩҮЩҗЩҠШҜЩӢШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ШҙЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Ыҡ ЩҒЩҺШЈЩҺЩӮЩҗЩҠЩ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҸЩҲШ§Ыҹ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩұШ№Щ’ШӘЩҺШөЩҗЩ…ЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҮЩҸЩҲЩҺ Щ…ЩҺЩҲЩ’Щ„ЩҺЩүЩ°ЩғЩҸЩ…Щ’ Ы– ЩҒЩҺЩҶЩҗШ№Щ’Щ…ЩҺ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’Щ„ЩҺЩүЩ° ЩҲЩҺЩҶЩҗШ№Щ’Щ…ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШөЩҗЩҠШұЩҸ"}]}
nd":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false}]},{"lineNumber":15,"words":[{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false},{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":true}]}],"verses":[{"key":"16:55","surah":16,"ayah":55,"num":1956,"page":273,"words":[{"code":"пұҒ","page":273,"end":false},{"code":"пұӮ","page":273,"end":false},{"code":"пұғпұ„","page":273,"end":false},{"code":"пұ…","page":273,"end":false},{"code":"пұҶ","page":273,"end":false},{"code":"пұҮ","page":273,"end":false},{"code":"пұҲ","page":273,"end":true}],"text":"Щ„ЩҗЩҠЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҺШ§Щ“ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ Ыҡ ЩҒЩҺШӘЩҺЩ…ЩҺШӘЩ‘ЩҺШ№ЩҸЩҲШ§Ыҹ Ы– ЩҒЩҺШіЩҺЩҲЩ’ЩҒЩҺ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"16:56","surah":16,"ayah":56,"num":1957,"page":273,"words":[{"code":"пұү","page":273,"end":false},{"code":"пұҠ","page":273,"end":false},{"code":"пұӢ","page":273,"end":false},{"code":"пұҢ","page":273,"end":false},{"code":"пұҚ","page":273,"end":false},{"code":"пұҺ","page":273,"end":false},{"code":"пұҸпұҗ","page":273,"end":false},{"code":"пұ‘","page":273,"end":false},{"code":"пұ’","page":273,"end":false},{"code":"пұ“","page":273,"end":false},{"code":"пұ”","page":273,"end":false},{"code":"пұ•","page":273,"end":false},{"code":"пұ–","page":273,"end":true}],"text":"ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ…ЩҺШ§ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ЩҶЩҺШөЩҗЩҠШЁЩӢЫӯШ§ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ШұЩҺШІЩҺЩӮЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ Ы— ШӘЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺШӘЩҸШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҶЩ‘ЩҺ Ш№ЩҺЩ…Щ‘ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"16:57","surah":16,"ayah":57,"num":1958,"page":273,"words":[{"code":"пұ—","page":273,"end":false},{"code":"пұҳ","page":273,"end":false},{"code":"пұҷ","page":273,"end":false},{"code":"пұҡ","page":273,"end":false},{"code":"пұӣ","page":273,"end":false},{"code":"пұң","page":273,"end":false},{"code":"пұқ","page":273,"end":false},{"code":"пұһ","page":273,"end":true}],"text":"ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ШЁЩҺЩҶЩҺЩҖЩ°ШӘЩҗ ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺЩҮЩҸЫҘ Ыҷ ЩҲЩҺЩ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩҠЩҺШҙЩ’ШӘЩҺЩҮЩҸЩҲЩҶЩҺ"},{"key":"16:58","surah":16,"ayah":58,"num":1959,"page":273,"words":[{"code":"пұҹ","page":273,"end":false},{"code":"пұ ","page":273,"end":false},{"code":"пұЎ","page":273,"end":false},{"code":"пұў","page":273,"end":false},{"code":"пұЈ","page":273,"end":false},{"code":"пұӨ","page":273,"end":false},{"code":"пұҘ","page":273,"end":false},{"code":"пұҰ","page":273,"end":false},{"code":"пұ§","page":273,"end":false},{"code":"пұЁ","page":273,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШЁЩҸШҙЩ‘ЩҗШұЩҺ ШЈЩҺШӯЩҺШҜЩҸЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ШЈЩҸЩҶШ«ЩҺЩүЩ° ШёЩҺЩ„Щ‘ЩҺ ЩҲЩҺШ¬Щ’ЩҮЩҸЩҮЩҸЫҘ Щ…ЩҸШіЩ’ЩҲЩҺШҜЩ‘ЩӢЫӯШ§ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩғЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"16:59","surah":16,"ayah":59,"num":1960,"page":273,"words":[{"code":"пұ©","page":273,"end":false},{"code":"пұӘ","page":273,"end":false},{"code":"пұ«","page":273,"end":false},{"code":"пұ¬","page":273,"end":false},{"code":"пұӯ","page":273,"end":false},{"code":"пұ®","page":273,"end":false},{"code":"пұҜ","page":273,"end":false},{"code":"пұ°пұұ","page":273,"end":false},{"code":"пұІ","page":273,"end":false},{"code":"пұі","page":273,"end":false},{"code":"пұҙ","page":273,"end":false},{"code":"пұө","page":273,"end":false},{"code":"пұ¶","page":273,"end":false},{"code":"пұ·","page":273,"end":false},{"code":"пұёпұ№","page":273,"end":false},{"code":"пұә","page":273,"end":false},{"code":"пұ»","page":273,"end":false},{"code":"пұј","page":273,"end":false},{"code":"пұҪ","page":273,"end":false},{"code":"пұҫ","page":273,"end":true}],"text":"ЩҠЩҺШӘЩҺЩҲЩҺЩ°ШұЩҺЩүЩ° Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ Щ…ЩҗЩҶ ШіЩҸЩҲЩ“ШЎЩҗ Щ…ЩҺШ§ ШЁЩҸШҙЩ‘ЩҗШұЩҺ ШЁЩҗЩҮЩҗЫҰЩ“ Ыҡ ШЈЩҺЩҠЩҸЩ…Щ’ШіЩҗЩғЩҸЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҮЩҸЩҲЩҶЩҚ ШЈЩҺЩ…Щ’ ЩҠЩҺШҜЩҸШіЩ‘ЩҸЩҮЩҸЫҘ ЩҒЩҗЩү ЩұЩ„ШӘЩ‘ЩҸШұЩҺШ§ШЁЩҗ Ы— ШЈЩҺЩ„ЩҺШ§ ШіЩҺШ§Щ“ШЎЩҺ Щ…ЩҺШ§ ЩҠЩҺШӯЩ’ЩғЩҸЩ…ЩҸЩҲЩҶЩҺ"},{"key":"16:60","surah":16,"ayah":60,"num":1961,"page":273,"words":[{"code":"пұҝ","page":273,"end":false},{"code":"пІҖ","page":273,"end":false},{"code":"пІҒ","page":273,"end":false},{"code":"пІӮ","page":273,"end":false},{"code":"пІғ","page":273,"end":false},{"code":"пІ„пІ…","page":273,"end":false},{"code":"пІҶ","page":273,"end":false},{"code":"пІҮ","page":273,"end":false},{"code":"пІҲпІү","page":273,"end":false},{"code":"пІҠ","page":273,"end":false},{"code":"пІӢ","page":273,"end":false},{"code":"пІҢ","page":273,"end":false},{"code":"пІҚ","page":273,"end":true}],"text":"Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Щ…ЩҺШ«ЩҺЩ„ЩҸ ЩұЩ„ШіЩ‘ЩҺЩҲЩ’ШЎЩҗ Ы– ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’Щ…ЩҺШ«ЩҺЩ„ЩҸ ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ„ЩҺЩүЩ° Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"},{"key":"16:61","surah":16,"ayah":61,"num":1962,"page":273,"words":[{"code":"пІҺ","page":273,"end":false},{"code":"пІҸ","page":273,"end":false},{"code":"пІҗ","page":273,"end":false},{"code":"пІ‘","page":273,"end":false},{"code":"пІ’","page":273,"end":false},{"code":"пІ“","page":273,"end":false},{"code":"пІ”","page":273,"end":false},{"code":"пІ•","page":273,"end":false},{"code":"пІ–","page":273,"end":false},{"code":"пІ—","page":273,"end":false},{"code":"пІҳ","page":273,"end":false},{"code":"пІҷ","page":273,"end":false},{"code":"пІҡ","page":273,"end":false},{"code":"пІӣ","page":273,"end":false},{"code":"пІңпІқ","page":273,"end":false},{"code":"пІһ","page":273,"end":false},{"code":"пІҹ","page":273,"end":false},{"code":"пІ ","page":273,"end":false},{"code":"пІЎ","page":273,"end":false},{"code":"пІў","page":273,"end":false},{"code":"пІЈ","page":273,"end":false},{"code":"пІӨ","page":273,"end":false},{"code":"пІҘ","page":273,"end":false},{"code":"пІҰ","page":273,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩҠЩҸШӨЩҺШ§Ш®ЩҗШ°ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ШЁЩҗШёЩҸЩ„Щ’Щ…ЩҗЩҮЩҗЩ… Щ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ Щ…ЩҗЩҶ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩҚЫў ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ ЩҠЩҸШӨЩҺШ®Щ‘ЩҗШұЩҸЩҮЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҚЫў Щ…Щ‘ЩҸШіЩҺЩ…Щ‘ЩӢЫӯЩү Ы– ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ ШЈЩҺШ¬ЩҺЩ„ЩҸЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺЩҖЩ”Щ’Ш®ЩҗШұЩҸЩҲЩҶЩҺ ШіЩҺШ§Ш№ЩҺШ©ЩӢЫӯ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺЩӮЩ’ШҜЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"16:62","surah":16,"ayah":62,"num":1963,"page":273,"words":[{"code":"пІ§","page":273,"end":false},{"code":"пІЁ","page":273,"end":false},{"code":"пІ©","page":273,"end":false},{"code":"пІӘпІ«","page":273,"end":false},{"code":"пІ¬","page":273,"end":false},{"code":"пІӯ","page":273,"end":false},{"code":"пІ®","page":273,"end":false},{"code":"пІҜ","page":273,"end":false},{"code":"пІ°","page":273,"end":false},{"code":"пІұпІІ","page":273,"end":false},{"code":"пІі","page":273,"end":false},{"code":"пІҙ","page":273,"end":false},{"code":"пІө","page":273,"end":false},{"code":"пІ¶","page":273,"end":false},{"code":"пІ·","page":273,"end":false},{"code":"пІё","page":273,"end":false},{"code":"пІ№","page":273,"end":false},{"code":"пІә","page":273,"end":true}],"text":"ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҠЩҺЩғЩ’ШұЩҺЩҮЩҸЩҲЩҶЩҺ ЩҲЩҺШӘЩҺШөЩҗЩҒЩҸ ШЈЩҺЩ„Щ’ШіЩҗЩҶЩҺШӘЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ ШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ШӯЩҸШіЩ’ЩҶЩҺЩүЩ° Ы– Щ„ЩҺШ§ Ш¬ЩҺШұЩҺЩ…ЩҺ ШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҺ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҸЩҒЩ’ШұЩҺШ·ЩҸЩҲЩҶЩҺ"},{"key":"16:63","surah":16,"ayah":63,"num":1964,"page":273,"words":[{"code":"пІ»","page":273,"end":false},{"code":"пІј","page":273,"end":false},{"code":"пІҪ","page":273,"end":false},{"code":"пІҫ","page":273,"end":false},{"code":"пІҝ","page":273,"end":false},{"code":"піҖ","page":273,"end":false},{"code":"піҒ","page":273,"end":false},{"code":"піӮ","page":273,"end":false},{"code":"піғ","page":273,"end":false},{"code":"пі„","page":273,"end":false},{"code":"пі…","page":273,"end":false},{"code":"піҶ","page":273,"end":false},{"code":"піҮ","page":273,"end":false},{"code":"піҲ","page":273,"end":false},{"code":"піү","page":273,"end":false},{"code":"піҠ","page":273,"end":false},{"code":"піӢ","page":273,"end":false},{"code":"піҢ","page":273,"end":true}],"text":"ШӘЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺЩӮЩҺШҜЩ’ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҸЩ…ЩҺЩ…ЩҚЫў Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҺ ЩҒЩҺШІЩҺЩҠЩ‘ЩҺЩҶЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩҮЩҸЩҲЩҺ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"16:64","surah":16,"ayah":64,"num":1965,"page":273,"words":[{"code":"піҚ","page":273,"end":false},{"code":"піҺ","page":273,"end":false},{"code":"піҸ","page":273,"end":false},{"code":"піҗ","page":273,"end":false},{"code":"пі‘","page":273,"end":false},{"code":"пі’","page":273,"end":false},{"code":"пі“","page":273,"end":false},{"code":"пі”","page":273,"end":false},{"code":"пі•","page":273,"end":false},{"code":"пі–","page":273,"end":false},{"code":"пі—","page":273,"end":false},{"code":"піҳ","page":273,"end":false},{"code":"піҷ","page":273,"end":false},{"code":"піҡ","page":273,"end":false},{"code":"піӣ","page":273,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ„ЩҗШӘЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҺ Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩұШ®Щ’ШӘЩҺЩ„ЩҺЩҒЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҗ Ыҷ ЩҲЩҺЩҮЩҸШҜЩӢЫӯЩү ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"}]}
"end":false},{"code":"пІҳ","page":56,"end":false},{"code":"пІҷ","page":56,"end":true}],"text":"ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩӢШ§ ШҘЩҗЩ„ЩҺЩүЩ° ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ШЈЩҺЩҶЩ‘ЩҗЩү ЩӮЩҺШҜЩ’ Ш¬ЩҗШҰЩ’ШӘЩҸЩғЩҸЩ… ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ Ы– ШЈЩҺЩҶЩ‘ЩҗЩүЩ“ ШЈЩҺШ®Щ’Щ„ЩҸЩӮЩҸ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Ш·Щ‘ЩҗЩҠЩҶЩҗ ЩғЩҺЩҮЩҺЩҠЩ’ЩҖЩ”ЩҺШ©Щҗ ЩұЩ„Ш·Щ‘ЩҺЩҠЩ’ШұЩҗ ЩҒЩҺШЈЩҺЩҶЩҒЩҸШ®ЩҸ ЩҒЩҗЩҠЩҮЩҗ ЩҒЩҺЩҠЩҺЩғЩҸЩҲЩҶЩҸ Ш·ЩҺЩҠЩ’ШұЩӢЫўШ§ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺШЈЩҸШЁЩ’ШұЩҗШҰЩҸ ЩұЩ„Щ’ШЈЩҺЩғЩ’Щ…ЩҺЩҮЩҺ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШЁЩ’ШұЩҺШөЩҺ ЩҲЩҺШЈЩҸШӯЩ’ЩүЩҗ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҺЩүЩ° ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺШЈЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ ЩҲЩҺЩ…ЩҺШ§ ШӘЩҺШҜЩ‘ЩҺШ®ЩҗШұЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ШЁЩҸЩҠЩҸЩҲШӘЩҗЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"3:50","surah":3,"ayah":50,"num":343,"page":56,"words":[{"code":"пІҡ","page":56,"end":false},{"code":"пІӣ","page":56,"end":false},{"code":"пІң","page":56,"end":false},{"code":"пІқ","page":56,"end":false},{"code":"пІһ","page":56,"end":false},{"code":"пІҹ","page":56,"end":false},{"code":"пІ ","page":56,"end":false},{"code":"пІЎ","page":56,"end":false},{"code":"пІў","page":56,"end":false},{"code":"пІЈ","page":56,"end":false},{"code":"пІӨ","page":56,"end":false},{"code":"пІҘпІҰ","page":56,"end":false},{"code":"пІ§","page":56,"end":false},{"code":"пІЁ","page":56,"end":false},{"code":"пІ©","page":56,"end":false},{"code":"пІӘ","page":56,"end":false},{"code":"пІ«","page":56,"end":false},{"code":"пІ¬","page":56,"end":false},{"code":"пІӯ","page":56,"end":false},{"code":"пІ®","page":56,"end":true}],"text":"ЩҲЩҺЩ…ЩҸШөЩҺШҜЩ‘ЩҗЩӮЩӢЫӯШ§ Щ„Щ‘ЩҗЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩҠЩҺШҜЩҺЩүЩ‘ЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШӘЩ‘ЩҺЩҲЩ’ШұЩҺЩүЩ°Ш©Щҗ ЩҲЩҺЩ„ЩҗШЈЩҸШӯЩҗЩ„Щ‘ЩҺ Щ„ЩҺЩғЩҸЩ… ШЁЩҺШ№Щ’Ш¶ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ШӯЩҸШұЩ‘ЩҗЩ…ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШ¬ЩҗШҰЩ’ШӘЩҸЩғЩҸЩ… ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ЩҒЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„
ЩҸЩҲЫҹЩ„ЩҗЩү ЩұЩ„Ш¶Щ‘ЩҺШұЩҺШұЩҗ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ Ыҡ ЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҗЩҠЩҶЩҺ ШЁЩҗШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩӮЩҺЩҖЩ°Ш№ЩҗШҜЩҗЩҠЩҶЩҺ ШҜЩҺШұЩҺШ¬ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩғЩҸЩ„Щ‘ЩӢЫӯШ§ ЩҲЩҺШ№ЩҺШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’ШӯЩҸШіЩ’ЩҶЩҺЩүЩ° Ыҡ ЩҲЩҺЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸШ¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҗЩҠЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩӮЩҺЩҖЩ°Ш№ЩҗШҜЩҗЩҠЩҶЩҺ ШЈЩҺШ¬Щ’ШұЩӢШ§ Ш№ЩҺШёЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:96","surah":4,"ayah":96,"num":589,"page":94,"words":[{"code":"пұҰ","page":94,"end":false},{"code":"пұ§","page":94,"end":false},{"code":"пұЁ","page":94,"end":false},{"code":"пұ©пұӘ","page":94,"end":false},{"code":"пұ«","page":94,"end":false},{"code":"пұ¬","page":94,"end":false},{"code":"пұӯ","page":94,"end":false},{"code":"пұ®","page":94,"end":false},{"code":"пұҜ","page":94,"end":true}],"text":"ШҜЩҺШұЩҺШ¬ЩҺЩҖЩ°ШӘЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ ЩҲЩҺЩ…ЩҺШәЩ’ЩҒЩҗШұЩҺШ©ЩӢЫӯ ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШәЩҺЩҒЩҸЩҲШұЩӢЫӯШ§ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩӢШ§"},{"key":"4:97","surah":4,"ayah":97,"num":590,"page":94,"words":[{"code":"пұ°","page":94,"end":false},{"code":"пұұ","page":94,"end":false},{"code":"пұІ","page":94,"end":false},{"code":"пұі","page":94,"end":false},{"code":"пұҙ","page":94,"end":false},{"code":"пұө","page":94,"end":false},{"code":"пұ¶","page":94,"end":false},{"code":"пұ·","page":94,"end":false},{"code":"пұёпұ№","page":94,"end":false},{"code":"пұә","page":94,"end":false},{"code":"пұ»","page":94,"end":false},{"code":"пұј","page":94,"end":false},{"code":"пұҪ","page":94,"end":false},{"code":"пұҫпұҝ","page":94,"end":false},{"code":"пІҖ","page":94,"end":false},{"code":"пІҒ","page":94,"end":false},{"code":"пІӮ","page":94,"end":false},{"code":"пІғ","page":94,"end":false},{"code":"пІ„","page":94,"end":false},{"code":"пІ…","page":94,"end":false},{"code":"пІҶ","page":94,"end":false},{"code":"пІҮпІҲ","pa
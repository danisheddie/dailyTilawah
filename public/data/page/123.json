","page":123,"end":false},{"code":"пІҫпІҝ","page":123,"end":false},{"code":"піҖ","page":123,"end":false},{"code":"піҒ","page":123,"end":false},{"code":"піӮ","page":123,"end":false},{"code":"піғпі„","page":123,"end":false},{"code":"пі…","page":123,"end":false},{"code":"піҶ","page":123,"end":false},{"code":"піҮ","page":123,"end":false},{"code":"піҲ","page":123,"end":false},{"code":"піүпіҠ","page":123,"end":false},{"code":"піӢ","page":123,"end":false},{"code":"піҢ","page":123,"end":false},{"code":"піҚ","page":123,"end":false},{"code":"піҺ","page":123,"end":false},{"code":"піҸ","page":123,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺЩӮЩ’ШӘЩҸЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҠЩ’ШҜЩҺ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ ШӯЩҸШұЩҸЩ…ЩҢЫӯ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩӮЩҺШӘЩҺЩ„ЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶЩғЩҸЩ… Щ…Щ‘ЩҸШӘЩҺШ№ЩҺЩ…Щ‘ЩҗШҜЩӢЫӯШ§ ЩҒЩҺШ¬ЩҺШІЩҺШ§Щ“ШЎЩҢЫӯ Щ…Щ‘ЩҗШ«Щ’Щ„ЩҸ Щ…ЩҺШ§ ЩӮЩҺШӘЩҺЩ„ЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ№ЩҺЩ…Щҗ ЩҠЩҺШӯЩ’ЩғЩҸЩ…ЩҸ ШЁЩҗЩҮЩҗЫҰ Ш°ЩҺЩҲЩҺШ§ Ш№ЩҺШҜЩ’Щ„ЩҚЫў Щ…Щ‘ЩҗЩҶЩғЩҸЩ…Щ’ ЩҮЩҺШҜЩ’ЩҠЩӢЫўШ§ ШЁЩҺЩҖЩ°Щ„ЩҗШәЩҺ ЩұЩ„Щ’ЩғЩҺШ№Щ’ШЁЩҺШ©Щҗ ШЈЩҺЩҲЩ’ ЩғЩҺЩҒЩ‘ЩҺЩҖЩ°ШұЩҺШ©ЩҢЫӯ Ш·ЩҺШ№ЩҺШ§Щ…ЩҸ Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҠЩҶЩҺ ШЈЩҺЩҲЩ’ Ш№ЩҺШҜЩ’Щ„ЩҸ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШөЩҗЩҠЩҺШ§Щ…ЩӢЫӯШ§ Щ„Щ‘ЩҗЩҠЩҺШ°ЩҸЩҲЩӮЩҺ ЩҲЩҺШЁЩҺШ§Щ„ЩҺ ШЈЩҺЩ…Щ’ШұЩҗЩҮЩҗЫҰ Ы— Ш№ЩҺЩҒЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ…Щ‘ЩҺШ§ ШіЩҺЩ„ЩҺЩҒЩҺ Ыҡ ЩҲЩҺЩ…ЩҺЩҶЩ’ Ш№ЩҺШ§ШҜЩҺ ЩҒЩҺЩҠЩҺЩҶШӘЩҺЩӮЩҗЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺШІЩҗЩҠШІЩҢЫӯ Ш°ЩҸЩҲ ЩұЩҶШӘЩҗЩӮЩҺШ§Щ…ЩҚ"}]}
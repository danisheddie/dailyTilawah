","page":192,"end":false},{"code":"пұҠ","page":192,"end":false},{"code":"пұӢ","page":192,"end":false},{"code":"пұҢ","page":192,"end":false},{"code":"пұҚ","page":192,"end":false},{"code":"пұҺ","page":192,"end":false},{"code":"пұҸ","page":192,"end":false},{"code":"пұҗ","page":192,"end":true}],"text":"ЩҠЩҸШұЩҗЩҠШҜЩҸЩҲЩҶЩҺ ШЈЩҺЩҶ ЩҠЩҸШ·Щ’ЩҒЩҗЩҖЩ”ЩҸЩҲШ§Ыҹ ЩҶЩҸЩҲШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШЈЩҺЩҒЩ’ЩҲЩҺЩ°ЩҮЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺЩҠЩҺШЈЩ’ШЁЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҸШӘЩҗЩ…Щ‘ЩҺ ЩҶЩҸЩҲШұЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШұЩҗЩҮЩҺ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"9:33","surah":9,"ayah":33,"num":1268,"page":192,"words":[{"code":"пұ‘","page":192,"end":false},{"code":"пұ’","page":192,"end":false},{"code":"пұ“","page":192,"end":false},{"code":"пұ”","page":192,"end":false},{"code":"пұ•","page":192,"end":false},{"code":"пұ–","page":192,"end":false},{"code":"пұ—","page":192,"end":false},{"code":"пұҳ","page":192,"end":false},{"code":"пұҷ","page":192,"end":false},{"code":"пұҡ","page":192,"end":false},{"code":"пұӣ","page":192,"end":false},{"code":"пұң","page":192,"end":false},{"code":"пұқ","page":192,"end":false},{"code":"пұһ","page":192,"end":false},{"code":"пұҹ","page":192,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШұЩ’ШіЩҺЩ„ЩҺ ШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ШЁЩҗЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° ЩҲЩҺШҜЩҗЩҠЩҶЩҗ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Щ„ЩҗЩҠЩҸШёЩ’ЩҮЩҗШұЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҗ ЩғЩҸЩ„Щ‘ЩҗЩҮЩҗЫҰ ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҺШұЩҗЩҮЩҺ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҸЩҲЩҶЩҺ"},{"key":"9:34","surah":9,"ayah":34,"num":1269,"page":192,"words":[{"code":"пұ  пұЎ","page":192,"end":false},{"code":"пұў","page":192,"end":false},{"code":"пұЈ","page":192,"end":false},{"code":"пұӨ","page":192,"end":false},{"code":"пұҘ","page":192,"end":false},{"code":"пұҰ","page":192,"end":false},{"code":"пұ§","page":192,"end":false},{"code":"пұЁ","page":192,"end":false},{"code":"пұ©","page":192,"end":false},{"code":"пұӘ","page":192,"end":false},{"code":"пұ«","page":192,"end":false},{"code":"пұ¬","page":192,"end":false},{"code":"пұӯ","page":192,"end":false},{"code":"пұ®","page":192,"end":false},{"code":"пұҜ","page":192,"end":false},{"code":"пұ°пұұ","page":192,"end":false},{"code":"пұІ","page":192,"end":false},{"code":"пұі","page":192,"end":false},{"code":"пұҙ","page":192,"end":false},{"code":"пұө","page":192,"end":false},{"code":"пұ¶","page":192,"end":false},{"code":"пұ·","page":192,"end":false},{"code":"пұё","page":192,"end":false},{"code":"пұ№","page":192,"end":false},{"code":"пұә","page":192,"end":false},{"code":"пұ»","page":192,"end":false},{"code":"пұј","page":192,"end":false},{"code":"пұҪ","page":192,"end":false},{"code":"пұҫ","page":192,"end":true}],"text":"Ыһ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШӯЩ’ШЁЩҺШ§ШұЩҗ ЩҲЩҺЩұЩ„ШұЩ‘ЩҸЩҮЩ’ШЁЩҺШ§ЩҶЩҗ Щ„ЩҺЩҠЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҖЩ°Ш·ЩҗЩ„Щҗ ЩҲЩҺЩҠЩҺШөЩҸШҜЩ‘ЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶ ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩғЩ’ЩҶЩҗШІЩҸЩҲЩҶЩҺ ЩұЩ„Ш°Щ‘ЩҺЩҮЩҺШЁЩҺ ЩҲЩҺЩұЩ„Щ’ЩҒЩҗШ¶Щ‘ЩҺШ©ЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺЩҮЩҺШ§ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺШЁЩҺШҙЩ‘ЩҗШұЩ’ЩҮЩҸЩ… ШЁЩҗШ№ЩҺШ°ЩҺШ§ШЁЩҚ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҚЫў"},{"key":"9:35","surah":9,"ayah":35,"num":1270,"page":192,"words":[{"code":"пұҝ","page":192,"end":false},{"code":"пІҖ","page":192,"end":false},{"code":"пІҒ","page":192,"end":false},{"code":"пІӮ","page":192,"end":false},{"code":"пІғ","page":192,"end":false},{"code":"пІ„","page":192,"end":false},{"code":"пІ…","page":192,"end":false},{"code":"пІҶ","page":192,"end":false},{"code":"пІҮ","page":192,"end":false},{"code":"пІҲ","page":192,"end":false},{"code":"пІүпІҠ","page":192,"end":false},{"code":"пІӢ","page":192,"end":false},{"code":"пІҢ","page":192,"end":false},{"code":"пІҚ","page":192,"end":false},{"code":"пІҺ","page":192,"end":false},{"code":"пІҸ","page":192,"end":false},{"code":"пІҗ","page":192,"end":false},{"code":"пІ‘","page":192,"end":false},{"code":"пІ’","page":192,"end":false},{"code":"пІ“","page":192,"end":true}],"text":"ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҸШӯЩ’Щ…ЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ ЩҒЩҗЩү ЩҶЩҺШ§ШұЩҗ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ ЩҒЩҺШӘЩҸЩғЩ’ЩҲЩҺЩүЩ° ШЁЩҗЩҮЩҺШ§ Ш¬ЩҗШЁЩҺШ§ЩҮЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШ¬ЩҸЩҶЩҸЩҲШЁЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШёЩҸЩҮЩҸЩҲШұЩҸЩҮЩҸЩ…Щ’ Ы– ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҺШ§ ЩғЩҺЩҶЩҺШІЩ’ШӘЩҸЩ…Щ’ Щ„ЩҗШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ЩҒЩҺШ°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺЩғЩ’ЩҶЩҗШІЩҸЩҲЩҶЩҺ"},{"key":"9:36","surah":9,"ayah":36,"num":1271,"page":192,"words":[{"code":"пІ”","page":192,"end":false},{"code":"пІ•","page":192,"end":false},{"code":"пІ–","page":192,"end":false},{"code":"пІ—","page":192,"end":false},{"code":"пІҳ","page":192,"end":false},{"code":"пІҷ","page":192,"end":false},{"code":"пІҡ","page":192,"end":false},{"code":"пІӣ","page":192,"end":false},{"code":"пІң","page":192,"end":false},{"code":"пІқ","page":192,"end":false},{"code":"пІһ","page":192,"end":false},{"code":"пІҹ","page":192,"end":false},{"code":"пІ ","page":192,"end":false},{"code":"пІЎ","page":192,"end":false},{"code":"пІў","page":192,"end":false},{"code":"пІЈ","page":192,"end":false},{"code":"пІӨ","page":192,"end":false},{"code":"пІҘпІҰ","page":192,"end":false},{"code":"пІ§","page":192,"end":false},{"code":"пІЁ","page":192,"end":false},{"code":"пІ©пІӘ","page":192,"end":false},{"code":"пІ«","page":192,"end":false},{"code":"пІ¬","page":192,"end":false},{"code":"пІӯ","page":192,"end":false},{"code":"пІ®пІҜ","page":192,"end":false},{"code":"пІ°","page":192,"end":false},{"code":"пІұ","page":192,"end":false},{"code":"пІІ","page":192,"end":false},{"code":"пІі","page":192,"end":false},{"code":"пІҙ","page":192,"end":false},{"code":"пІөпІ¶","page":192,"end":false},{"code":"пІ·","page":192,"end":false},{"code":"пІё","page":192,"end":false},{"code":"пІ№","page":192,"end":false},{"code":"пІә","page":192,"end":false},{"code":"пІ»","page":192,"end":false},{"code":"пІј","page":192,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ Ш№ЩҗШҜЩ‘ЩҺШ©ЩҺ ЩұЩ„ШҙЩ‘ЩҸЩҮЩҸЩҲШұЩҗ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұШ«Щ’ЩҶЩҺШ§ Ш№ЩҺШҙЩҺШұЩҺ ШҙЩҺЩҮЩ’ШұЩӢЫӯШ§ ЩҒЩҗЩү ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺЩҲЩ’Щ…ЩҺ Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§Щ“ ШЈЩҺШұЩ’ШЁЩҺШ№ЩҺШ©ЩҢ ШӯЩҸШұЩҸЩ…ЩҢЫӯ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҸ ЩұЩ„Щ’ЩӮЩҺЩҠЩ‘ЩҗЩ…ЩҸ Ыҡ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШёЩ’Щ„ЩҗЩ…ЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҗЩҶЩ‘ЩҺ ШЈЩҺЩҶЩҒЩҸШіЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ ЩғЩҺШ§Щ“ЩҒЩ‘ЩҺШ©ЩӢЫӯ ЩғЩҺЩ…ЩҺШ§ ЩҠЩҸЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲЩҶЩҺЩғЩҸЩ…Щ’ ЩғЩҺШ§Щ“ЩҒЩ‘ЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҺШ№ЩҺ ЩұЩ„Щ’Щ…ЩҸШӘЩ‘ЩҺЩӮЩҗЩҠЩҶЩҺ"}]}
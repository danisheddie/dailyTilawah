:368,"end":false},{"code":"пұҡ","page":368,"end":false},{"code":"пұӣ","page":368,"end":false},{"code":"пұң","page":368,"end":true}],"text":"ЩҲЩҺШӘЩҗЩ„Щ’ЩғЩҺ ЩҶЩҗШ№Щ’Щ…ЩҺШ©ЩҢЫӯ ШӘЩҺЩ…ЩҸЩҶЩ‘ЩҸЩҮЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ‘ЩҺ ШЈЩҺЩҶЩ’ Ш№ЩҺШЁЩ‘ЩҺШҜШӘЩ‘ЩҺ ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ"},{"key":"26:23","surah":26,"ayah":23,"num":2955,"page":368,"words":[{"code":"пұқ","page":368,"end":false},{"code":"пұһ","page":368,"end":false},{"code":"пұҹ","page":368,"end":false},{"code":"пұ ","page":368,"end":false},{"code":"пұЎ","page":368,"end":false},{"code":"пұў","page":368,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҸ ЩҲЩҺЩ…ЩҺШ§ ШұЩҺШЁЩ‘ЩҸ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"26:24","surah":26,"ayah":24,"num":2956,"page":368,"words":[{"code":"пұЈ","page":368,"end":false},{"code":"пұӨ","page":368,"end":false},{"code":"пұҘ","page":368,"end":false},{"code":"пұҰ","page":368,"end":false},{"code":"пұ§","page":368,"end":false},{"code":"пұЁпұ©","page":368,"end":false},{"code":"пұӘ","page":368,"end":false},{"code":"пұ«","page":368,"end":false},{"code":"пұ¬","page":368,"end":false},{"code":"пұӯ","page":368,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘ЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§Щ“ Ы– ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҸЩҲЩӮЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"26:25","surah":26,"ayah":25,"num":2957,"page":368,"words":[{"code":"пұ®","page":368,"end":false},{"code":"пұҜ","page":368,"end":false},{"code":"пұ°","page":368,"end":false},{"code":"пұұ","page":368,"end":false},{"code":"пұІ","page":368,"end":false},{"code":"пұі","page":368,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҗЩ…ЩҺЩҶЩ’ ШӯЩҺЩҲЩ’Щ„ЩҺЩҮЩҸЫҘЩ“ ШЈЩҺЩ„ЩҺШ§ ШӘЩҺШіЩ’ШӘЩҺЩ…ЩҗШ№ЩҸЩҲЩҶЩҺ"},{"key":"26:26","surah":26,"ayah":26,"num":2958,"page":368,"words":[{"code":"пұҙ","page":368,"end":false},{"code":"пұө","page":368,"end":false},{"code":"пұ¶","page":368,"end":false},{"code":"пұ·","page":368,"end":false},{"code":"пұё","page":368,"end":false},{"code":"пұ№","page":368,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘ЩҸЩғ
:97,"end":false},{"code":"пұӯ","page":97,"end":false},{"code":"пұ®","page":97,"end":false},{"code":"пұҜпұ°","page":97,"end":false},{"code":"пұұ","page":97,"end":false},{"code":"пұІ","page":97,"end":false},{"code":"пұі","page":97,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШҙЩҺШ§ЩӮЩҗЩӮЩҗ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Щ…ЩҺШ§ ШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҺ Щ„ЩҺЩҮЩҸ ЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° ЩҲЩҺЩҠЩҺШӘЩ‘ЩҺШЁЩҗШ№Щ’ ШәЩҺЩҠЩ’ШұЩҺ ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҶЩҸЩҲЩҺЩ„Щ‘ЩҗЩҮЩҗЫҰ Щ…ЩҺШ§ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩүЩ° ЩҲЩҺЩҶЩҸШөЩ’Щ„ЩҗЩҮЩҗЫҰ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Ы– ЩҲЩҺШіЩҺШ§Щ“ШЎЩҺШӘЩ’ Щ…ЩҺШөЩҗЩҠШұЩӢШ§"},{"key":"4:116","surah":4,"ayah":116,"num":609,"page":97,"words":[{"code":"пұҙ","page":97,"end":false},{"code":"пұө","page":97,"end":false},{"code":"пұ¶","page":97,"end":false},{"code":"пұ·","page":97,"end":false},{"code":"пұё","page":97,"end":false},{"code":"пұ№","page":97,"end":false},{"code":"пұә","page":97,"end":false},{"code":"пұ»","page":97,"end":false},{"code":"пұј","page":97,"end":false},{"code":"пұҪ","page":97,"end":false},{"code":"пұҫ","page":97,"end":false},{"code":"пұҝ","page":97,"end":false},{"code":"пІҖпІҒ","page":97,"end":false},{"code":"пІӮ","page":97,"end":false},{"code":"пІғ","page":97,"end":false},{"code":"пІ„","page":97,"end":false},{"code":"пІ…","page":97,"end":false},{"code":"пІҶ","page":97,"end":false},{"code":"пІҮ","page":97,"end":false},{"code":"пІҲ","page":97,"end":false},{"code":"пІү","page":97,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ ШЈЩҺЩҶ ЩҠЩҸШҙЩ’ШұЩҺЩғЩҺ ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ Щ…ЩҺШ§ ШҜЩҸЩҲЩҶЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҗЩ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШҙЩ’ШұЩҗЩғЩ’ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩӮЩҺШҜЩ’ Ш¶ЩҺЩ„Щ‘ЩҺ Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩӢЫўШ§ ШЁЩҺШ№ЩҗЩҠШҜЩӢШ§"},{"key":"4:117","surah":4,"ayah":117,"num":610,"page":97,"words":[{"code":"пІҠ","page":97,"end":false},{"code":"пІӢ","page":97,"end":false},{"code":"пІҢ","page":97,"end":false},{"code":"пІҚ","page":97,"end":false},{"code":"пІҺ","page":97,"end":false},{"code":"пІҸ","page":97,"en
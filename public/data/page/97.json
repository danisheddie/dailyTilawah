ЩҸШЁЩҺШӘЩ‘ЩҗЩғЩҸЩҶЩ‘ЩҺ ШЎЩҺШ§Ш°ЩҺШ§ЩҶЩҺ ЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ ЩҲЩҺЩ„ЩҺЩҖЩ”ЩҺШ§Щ…ЩҸШұЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩҠЩҸШәЩҺЩҠЩ‘ЩҗШұЩҸЩҶЩ‘ЩҺ Ш®ЩҺЩ„Щ’ЩӮЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШӘЩ‘ЩҺШ®ЩҗШ°Щҗ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҺ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩӮЩҺШҜЩ’ Ш®ЩҺШіЩҗШұЩҺ Ш®ЩҸШіЩ’ШұЩҺШ§ЩҶЩӢЫӯШ§ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩӢЫӯШ§"},{"key":"4:120","surah":4,"ayah":120,"num":613,"page":97,"words":[{"code":"пІ·","page":97,"end":false},{"code":"пІёпІ№","page":97,"end":false},{"code":"пІә","page":97,"end":false},{"code":"пІ»","page":97,"end":false},{"code":"пІј","page":97,"end":false},{"code":"пІҪ","page":97,"end":false},{"code":"пІҫ","page":97,"end":false},{"code":"пІҝ","page":97,"end":true}],"text":"ЩҠЩҺШ№ЩҗШҜЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩҠЩҸЩ…ЩҺЩҶЩ‘ЩҗЩҠЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ№ЩҗШҜЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ ШәЩҸШұЩҸЩҲШұЩӢШ§"},{"key":"4:121","surah":4,"ayah":121,"num":614,"page":97,"words":[{"code":"піҖ","page":97,"end":false},{"code":"піҒ","page":97,"end":false},{"code":"піӮ","page":97,"end":false},{"code":"піғ","page":97,"end":false},{"code":"пі„","page":97,"end":false},{"code":"пі…","page":97,"end":false},{"code":"піҶ","page":97,"end":false},{"code":"піҮ","page":97,"end":true}],"text":"ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ…ЩҺШЈЩ’ЩҲЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ¬ЩҗШҜЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ’ЩҮЩҺШ§ Щ…ЩҺШӯЩҗЩҠШөЩӢЫӯШ§"}]}
","page":557,"end":false},{"code":"пұҚ","page":557,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҲЩҺЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§Щ“ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ы– ЩҲЩҺШЁЩҗШҰЩ’ШіЩҺ ЩұЩ„Щ’Щ…ЩҺШөЩҗЩҠШұЩҸ"},{"key":"64:11","surah":64,"ayah":11,"num":5210,"page":557,"words":[{"code":"пұҺ","page":557,"end":false},{"code":"пұҸ","page":557,"end":false},{"code":"пұҗ","page":557,"end":false},{"code":"пұ‘","page":557,"end":false},{"code":"пұ’","page":557,"end":false},{"code":"пұ“","page":557,"end":false},{"code":"пұ”пұ•","page":557,"end":false},{"code":"пұ–","page":557,"end":false},{"code":"пұ—","page":557,"end":false},{"code":"пұҳ","page":557,"end":false},{"code":"пұҷ","page":557,"end":false},{"code":"пұҡпұӣ","page":557,"end":false},{"code":"пұң","page":557,"end":false},{"code":"пұқ","page":557,"end":false},{"code":"пұһ","page":557,"end":false},{"code":"пұҹ","page":557,"end":false},{"code":"пұ ","page":557,"end":true}],"text":"Щ…ЩҺШ§Щ“ ШЈЩҺШөЩҺШ§ШЁЩҺ Щ…ЩҗЩҶ Щ…Щ‘ЩҸШөЩҗЩҠШЁЩҺШ©ЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЫў ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺЩҮЩ’ШҜЩҗ ЩӮЩҺЩ„Щ’ШЁЩҺЩҮЩҸЫҘ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"64:12","surah":64,"ayah":12,"num":5211,"page":557,"words":[{"code":"пұЎ","page":557,"end":false},{"code":"пұў","page":557,"end":false},{"code":"пұЈ","page":557,"end":false},{"code":"пұӨпұҘ","page":557,"end":false},{"code":"пұҰ","page":557,"end":false},{"code":"пұ§","page":557,"end":false},{"code":"пұЁ","page":557,"end":false},{"code":"пұ©","page":557,"end":false},{"code":"пұӘ","page":557,"end":false},{"code":"пұ«","page":557,"end":false},{"code":"пұ¬","page":557,"end":false},{"code":"пұӯ","page":557,"end":true}],"text":"ЩҲЩҺШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ Ыҡ ЩҒЩҺШҘЩҗЩҶ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҺШіЩҸЩҲЩ„ЩҗЩҶЩҺШ§ ЩұЩ„Щ’ШЁЩҺЩ„ЩҺЩҖЩ°ШәЩҸ ЩұЩ„Щ’Щ…ЩҸШЁЩҗЩҠЩҶЩҸ"},{"key":"64:13","surah":64,"ayah":13,"num":5212,"page":557,"words":[{"code":"пұ®","page":557,"end":false},{"code":"пұҜ","page":557,"end":false},{"code":"пұ°","page":557,"end":false},{"code":"пұұ","page":557,"end":false},{"code":"пұІпұі","page":557,"end":false},{"code":"пұҙ","page":557,"end":false},{"code":"пұө","page":557,"end":false},{"code":"пұ¶","page":557,"end":false},{"code":"пұ·","page":557,"end":false},{"code":"пұё","page":557,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩ„Щ’ЩҠЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"64:14","surah":64,"ayah":14,"num":5213,"page":557,"words":[{"code":"пұ№","page":557,"end":false},{"code":"пұә","page":557,"end":false},{"code":"пұ»","page":557,"end":false},{"code":"пұј","page":557,"end":false},{"code":"пұҪ","page":557,"end":false},{"code":"пұҫ","page":557,"end":false},{"code":"пұҝ","page":557,"end":false},{"code":"пІҖ","page":557,"end":false},{"code":"пІҒ","page":557,"end":false},{"code":"пІӮпІғ","page":557,"end":false},{"code":"пІ„","page":557,"end":false},{"code":"пІ…","page":557,"end":false},{"code":"пІҶ","page":557,"end":false},{"code":"пІҮ","page":557,"end":false},{"code":"пІҲ","page":557,"end":false},{"code":"пІү","page":557,"end":false},{"code":"пІҠ","page":557,"end":false},{"code":"пІӢ","page":557,"end":false},{"code":"пІҢ","page":557,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҗЩғЩҸЩ…Щ’ Ш№ЩҺШҜЩҸЩҲЩ‘ЩӢЫӯШ§ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩұШӯЩ’Ш°ЩҺШұЩҸЩҲЩҮЩҸЩ…Щ’ Ыҡ ЩҲЩҺШҘЩҗЩҶ ШӘЩҺШ№Щ’ЩҒЩҸЩҲШ§Ыҹ ЩҲЩҺШӘЩҺШөЩ’ЩҒЩҺШӯЩҸЩҲШ§Ыҹ ЩҲЩҺШӘЩҺШәЩ’ЩҒЩҗШұЩҸЩҲШ§Ыҹ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢ"},{"key":"64:15","surah":64,"ayah":15,"num":5214,"page":557,"words":[{"code":"пІҚ","page":557,"end":false},{"code":"пІҺ","page":557,"end":false},{"code":"пІҸ","page":557,"end":false},{"code":"пІҗпІ‘","page":557,"end":false},{"code":"пІ’","page":557,"end":false},{"code":"пІ“","page":557,"end":false},{"code":"пІ”","page":557,"end":false},{"code":"пІ•","page":557,"end":false},{"code":"пІ–","page":557,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҸЩғЩҸЩ…Щ’ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢЫӯ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҗЩҶШҜЩҺЩҮЩҸЫҘЩ“ ШЈЩҺШ¬Щ’ШұЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"64:16","surah":64,"ayah":16,"num":5215,"page":557,"words":[{"code":"пІ—","page":557,"end":false},{"code":"пІҳ","page":557,"end":false},{"code":"пІҷ","page":557,"end":false},{"code":"пІҡ","page":557,"end":false},{"code":"пІӣ","page":557,"end":false},{"code":"пІң","page":557,"end":false},{"code":"пІқ","page":557,"end":false},{"code":"пІһ","page":557,"end":false},{"code":"пІҹпІ ","page":557,"end":false},{"code":"пІЎ","page":557,"end":false},{"code":"пІў","page":557,"end":false},{"code":"пІЈ","page":557,"end":false},{"code":"пІӨ","page":557,"end":false},{"code":"пІҘ","page":557,"end":false},{"code":"пІҰ","page":557,"end":false},{"code":"пІ§","page":557,"end":false},{"code":"пІЁ","page":557,"end":true}],"text":"ЩҒЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҺШ§ ЩұШіЩ’ШӘЩҺШ·ЩҺШ№Щ’ШӘЩҸЩ…Щ’ ЩҲЩҺЩұШіЩ’Щ…ЩҺШ№ЩҸЩҲШ§Ыҹ ЩҲЩҺШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩҲЩҺШЈЩҺЩҶЩҒЩҗЩӮЩҸЩҲШ§Ыҹ Ш®ЩҺЩҠЩ’ШұЩӢЫӯШ§ Щ„Щ‘ЩҗШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸЩҲЩӮЩҺ ШҙЩҸШӯЩ‘ЩҺ ЩҶЩҺЩҒЩ’ШіЩҗЩҮЩҗЫҰ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"64:17","surah":64,"ayah":17,"num":5216,"page":557,"words":[{"code":"пІ©","page":557,"end":false},{"code":"пІӘ","page":557,"end":false},{"code":"пІ«","page":557,"end":false},{"code":"пІ¬","page":557,"end":false},{"code":"пІӯ","page":557,"end":false},{"code":"пІ®","page":557,"end":false},{"code":"пІҜ","page":557,"end":false},{"code":"пІ°","page":557,"end":false},{"code":"пІұпІІ","page":557,"end":false},{"code":"пІі","page":557,"end":false},{"code":"пІҙ","page":557,"end":false},{"code":"пІө","page":557,"end":false},{"code":"пІ¶","page":557,"end":true}],"text":"ШҘЩҗЩҶ ШӘЩҸЩӮЩ’ШұЩҗШ¶ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺШұЩ’Ш¶ЩӢШ§ ШӯЩҺШіЩҺЩҶЩӢЫӯШ§ ЩҠЩҸШ¶ЩҺЩҖЩ°Ш№ЩҗЩҒЩ’ЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҙЩҺЩғЩҸЩҲШұЩҢ ШӯЩҺЩ„ЩҗЩҠЩ…ЩҢ"},{"key":"64:18","surah":64,"ayah":18,"num":5217,"page":557,"words":[{"code":"пІ·","page":557,"end":false},{"code":"пІё","page":557,"end":false},{"code":"пІ№","page":557,"end":false},{"code":"пІә","page":557,"end":false},{"code":"пІ»","page":557,"end":false},{"code":"пІј","page":557,"end":true}],"text":"Ш№ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸ ЩұЩ„Щ’ШәЩҺЩҠЩ’ШЁЩҗ ЩҲЩҺЩұЩ„ШҙЩ‘ЩҺЩҮЩҺЩҖЩ°ШҜЩҺШ©Щҗ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"}]}
{"code":"піү","end":true}]}],"verses":[{"key":"16:111","surah":16,"ayah":111,"num":2012,"page":280,"words":[{"code":"пұҒ пұӮ","page":280,"end":false},{"code":"пұғ","page":280,"end":false},{"code":"пұ„","page":280,"end":false},{"code":"пұ…","page":280,"end":false},{"code":"пұҶ","page":280,"end":false},{"code":"пұҮ","page":280,"end":false},{"code":"пұҲ","page":280,"end":false},{"code":"пұү","page":280,"end":false},{"code":"пұҠ","page":280,"end":false},{"code":"пұӢ","page":280,"end":false},{"code":"пұҢ","page":280,"end":false},{"code":"пұҚ","page":280,"end":false},{"code":"пұҺ","page":280,"end":false},{"code":"пұҸ","page":280,"end":false},{"code":"пұҗ","page":280,"end":false},{"code":"пұ‘","page":280,"end":true}],"text":"Ыһ ЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҺШЈЩ’ШӘЩҗЩү ЩғЩҸЩ„Щ‘ЩҸ ЩҶЩҺЩҒЩ’ШіЩҚЫў ШӘЩҸШ¬ЩҺЩҖЩ°ШҜЩҗЩ„ЩҸ Ш№ЩҺЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҗЩҮЩҺШ§ ЩҲЩҺШӘЩҸЩҲЩҺЩҒЩ‘ЩҺЩүЩ° ЩғЩҸЩ„Щ‘ЩҸ ЩҶЩҺЩҒЩ’ШіЩҚЫў Щ…Щ‘ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҺШӘЩ’ ЩҲЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"16:112","surah":16,"ayah":112,"num":2013,"page":280,"words":[{"code":"пұ’","page":280,"end":false},{"code":"пұ“","page":280,"end":false},{"code":"пұ”","page":280,"end":false},{"code":"пұ•","page":280,"end":false},{"code":"пұ–","page":280,"end":false},{"code":"пұ—","page":280,"end":false},{"code":"пұҳ","page":280,"end":false},{"code":"пұҷ","page":280,"end":false},{"code":"пұҡ","page":280,"end":false},{"code":"пұӣ","page":280,"end":false},{"code":"пұң","page":280,"end":false},{"code":"пұқ","page":280,"end":false},{"code":"пұһ","page":280,"end":false},{"code":"пұҹ","page":280,"end":false},{"code":"пұ ","page":280,"end":false},{"code":"пұЎ","page":280,"end":false},{"code":"пұў","page":280,"end":false},{"code":"пұЈ","page":280,"end":false},{"code":"пұӨ","page":280,"end":false},{"code":"пұҘ","page":280,"end":false},{"code":"пұҰ","page":280,"end":false},{"code":"пұ§","page":280,"end":false},{"code":"пұЁ","page":280,"end":false},{"code":"пұ©","page":280,"end":false},{"code":"пұӘ","page":280,"end":true}],"text":"ЩҲЩҺШ¶ЩҺШұЩҺШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ ЩӮЩҺШұЩ’ЩҠЩҺШ©ЩӢЫӯ ЩғЩҺШ§ЩҶЩҺШӘЩ’ ШЎЩҺШ§Щ…ЩҗЩҶЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҸШ·Щ’Щ…ЩҺШҰЩҗЩҶЩ‘ЩҺШ©ЩӢЫӯ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҺШ§ ШұЩҗШІЩ’ЩӮЩҸЩҮЩҺШ§ ШұЩҺШәЩҺШҜЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ Щ…ЩҺЩғЩҺШ§ЩҶЩҚЫў ЩҒЩҺЩғЩҺЩҒЩҺШұЩҺШӘЩ’ ШЁЩҗШЈЩҺЩҶЩ’Ш№ЩҸЩ…Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺШЈЩҺШ°ЩҺЩ°ЩӮЩҺЩҮЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҗШЁЩҺШ§ШіЩҺ ЩұЩ„Щ’Ш¬ЩҸЩҲШ№Щҗ ЩҲЩҺЩұЩ„Щ’Ш®ЩҺЩҲЩ’ЩҒЩҗ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШөЩ’ЩҶЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"16:113","surah":16,"ayah":113,"num":2014,"page":280,"words":[{"code":"пұ«","page":280,"end":false},{"code":"пұ¬","page":280,"end":false},{"code":"пұӯ","page":280,"end":false},{"code":"пұ®","page":280,"end":false},{"code":"пұҜ","page":280,"end":false},{"code":"пұ°","page":280,"end":false},{"code":"пұұ","page":280,"end":false},{"code":"пұІ","page":280,"end":false},{"code":"пұі","page":280,"end":false},{"code":"пұҙ","page":280,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ…Щ’ ШұЩҺШіЩҸЩҲЩ„ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҺЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲЩҮЩҸ ЩҒЩҺШЈЩҺШ®ЩҺШ°ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҸ ЩҲЩҺЩҮЩҸЩ…Щ’ ШёЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"16:114","surah":16,"ayah":114,"num":2015,"page":280,"words":[{"code":"пұө","page":280,"end":false},{"code":"пұ¶","page":280,"end":false},{"code":"пұ·","page":280,"end":false},{"code":"пұё","page":280,"end":false},{"code":"пұ№","page":280,"end":false},{"code":"пұә","page":280,"end":false},{"code":"пұ»","page":280,"end":false},{"code":"пұј","page":280,"end":false},{"code":"пұҪ","page":280,"end":false},{"code":"пұҫ","page":280,"end":false},{"code":"пұҝ","page":280,"end":false},{"code":"пІҖ","page":280,"end":false},{"code":"пІҒ","page":280,"end":false},{"code":"пІӮ","page":280,"end":true}],"text":"ЩҒЩҺЩғЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШұЩҺШІЩҺЩӮЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШӯЩҺЩ„ЩҺЩҖЩ°Щ„ЩӢЫӯШ§ Ш·ЩҺЩҠЩ‘ЩҗШЁЩӢЫӯШ§ ЩҲЩҺЩұШҙЩ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҶЩҗШ№Щ’Щ…ЩҺШӘЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШҘЩҗЩҠЩ‘ЩҺШ§ЩҮЩҸ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ"},{"key":"16:115","surah":16,"ayah":115,"num":2016,"page":280,"words":[{"code":"пІғ","page":280,"end":false},{"code":"пІ„","page":280,"end":false},{"code":"пІ…","page":280,"end":false},{"code":"пІҶ","page":280,"end":false},{"code":"пІҮ","page":280,"end":false},{"code":"пІҲ","page":280,"end":false},{"code":"пІү","page":280,"end":false},{"code":"пІҠ","page":280,"end":false},{"code":"пІӢ","page":280,"end":false},{"code":"пІҢ","page":280,"end":false},{"code":"пІҚ","page":280,"end":false},{"code":"пІҺпІҸ","page":280,"end":false},{"code":"пІҗ","page":280,"end":false},{"code":"пІ‘","page":280,"end":false},{"code":"пІ’","page":280,"end":false},{"code":"пІ“","page":280,"end":false},{"code":"пІ”","page":280,"end":false},{"code":"пІ•","page":280,"end":false},{"code":"пІ–","page":280,"end":false},{"code":"пІ—","page":280,"end":false},{"code":"пІҳ","page":280,"end":false},{"code":"пІҷ","page":280,"end":false},{"code":"пІҡ","page":280,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ШӯЩҺШұЩ‘ЩҺЩ…ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҺЩҠЩ’ШӘЩҺШ©ЩҺ ЩҲЩҺЩұЩ„ШҜЩ‘ЩҺЩ…ЩҺ ЩҲЩҺЩ„ЩҺШӯЩ’Щ…ЩҺ ЩұЩ„Щ’Ш®ЩҗЩҶШІЩҗЩҠШұЩҗ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҮЩҗЩ„Щ‘ЩҺ Щ„ЩҗШәЩҺЩҠЩ’ШұЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗЩҮЩҗЫҰ Ы– ЩҒЩҺЩ…ЩҺЩҶЩҗ ЩұШ¶Щ’Ш·ЩҸШұЩ‘ЩҺ ШәЩҺЩҠЩ’ШұЩҺ ШЁЩҺШ§ШәЩҚЫў ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺШ§ШҜЩҚЫў ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"16:116","surah":16,"ayah":116,"num":2017,"page":280,"words":[{"code":"пІӣ","page":280,"end":false},{"code":"пІң","page":280,"end":false},{"code":"пІқ","page":280,"end":false},{"code":"пІһ","page":280,"end":false},{"code":"пІҹ","page":280,"end":false},{"code":"пІ ","page":280,"end":false},{"code":"пІЎ","page":280,"end":false},{"code":"пІў","page":280,"end":false},{"code":"пІЈ","page":280,"end":false},{"code":"пІӨ","page":280,"end":false},{"code":"пІҘ","page":280,"end":false},{"code":"пІҰ","page":280,"end":false},{"code":"пІ§","page":280,"end":false},{"code":"пІЁпІ©","page":280,"end":false},{"code":"пІӘ","page":280,"end":false},{"code":"пІ«","page":280,"end":false},{"code":"пІ¬","page":280,"end":false},{"code":"пІӯ","page":280,"end":false},{"code":"пІ®","page":280,"end":false},{"code":"пІҜ","page":280,"end":false},{"code":"пІ°","page":280,"end":false},{"code":"пІұ","page":280,"end":false},{"code":"пІІ","page":280,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ Щ„ЩҗЩ…ЩҺШ§ ШӘЩҺШөЩҗЩҒЩҸ ШЈЩҺЩ„Щ’ШіЩҗЩҶЩҺШӘЩҸЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ШӯЩҺЩ„ЩҺЩҖЩ°Щ„ЩҢЫӯ ЩҲЩҺЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ШӯЩҺШұЩҺШ§Щ…ЩҢЫӯ Щ„Щ‘ЩҗШӘЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ Щ„ЩҺШ§ ЩҠЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"16:117","surah":16,"ayah":117,"num":2018,"page":280,"words":[{"code":"пІі","page":280,"end":false},{"code":"пІҙ","page":280,"end":false},{"code":"пІө","page":280,"end":false},{"code":"пІ¶","page":280,"end":false},{"code":"пІ·","page":280,"end":false},{"code":"пІё","page":280,"end":true}],"text":"Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҢЫӯ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩҢЫӯ ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"16:118","surah":16,"ayah":118,"num":2019,"page":280,"words":[{"code":"пІ№","page":280,"end":false},{"code":"пІә","page":280,"end":false},{"code":"пІ»","page":280,"end":false},{"code":"пІј","page":280,"end":false},{"code":"пІҪ","page":280,"end":false},{"code":"пІҫ","page":280,"end":false},{"code":"пІҝ","page":280,"end":false},{"code":"піҖ","page":280,"end":false},{"code":"піҒпіӮ","page":280,"end":false},{"code":"піғ","page":280,"end":false},{"code":"пі„","page":280,"end":false},{"code":"пі…","page":280,"end":false},{"code":"піҶ","page":280,"end":false},{"code":"піҮ","page":280,"end":false},{"code":"піҲ","page":280,"end":false},{"code":"піү","page":280,"end":true}],"text":"ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҮЩҺШ§ШҜЩҸЩҲШ§Ыҹ ШӯЩҺШұЩ‘ЩҺЩ…Щ’ЩҶЩҺШ§ Щ…ЩҺШ§ ЩӮЩҺШөЩҺШөЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Ы– ЩҲЩҺЩ…ЩҺШ§ ШёЩҺЩ„ЩҺЩ…Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ ЩғЩҺШ§ЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШёЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"}]}
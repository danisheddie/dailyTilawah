ЩғЩҺШ§ЩҶЩҺ Щ„ЩҗЩ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҚ ШЈЩҺЩҶ ЩҠЩҺЩӮЩ’ШӘЩҸЩ„ЩҺ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩӢШ§ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш®ЩҺШ·ЩҺЩҖЩ”ЩӢЫӯШ§ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩӮЩҺШӘЩҺЩ„ЩҺ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩӢШ§ Ш®ЩҺШ·ЩҺЩҖЩ”ЩӢЫӯШ§ ЩҒЩҺШӘЩҺШӯЩ’ШұЩҗЩҠШұЩҸ ШұЩҺЩӮЩҺШЁЩҺШ©ЩҚЫў Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҺШ©ЩҚЫў ЩҲЩҺШҜЩҗЩҠЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҸШіЩҺЩ„Щ‘ЩҺЩ…ЩҺШ©ЩҢ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЫҰЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҺШөЩ‘ЩҺШҜЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺЩҲЩ’Щ…ЩҚ Ш№ЩҺШҜЩҸЩҲЩ‘ЩҚЫў Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩҮЩҸЩҲЩҺ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҢЫӯ ЩҒЩҺШӘЩҺШӯЩ’ШұЩҗЩҠШұЩҸ ШұЩҺЩӮЩҺШЁЩҺШ©ЩҚЫў Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҺШ©ЩҚЫў Ы– ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺЩҲЩ’Щ…ЩҚЫӯ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҢЫӯ ЩҒЩҺШҜЩҗЩҠЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҸШіЩҺЩ„Щ‘ЩҺЩ…ЩҺШ©ЩҢ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШӘЩҺШӯЩ’ШұЩҗЩҠШұЩҸ ШұЩҺЩӮЩҺШЁЩҺШ©ЩҚЫў Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҺШ©ЩҚЫў Ы– ЩҒЩҺЩ…ЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШ¬ЩҗШҜЩ’ ЩҒЩҺШөЩҗЩҠЩҺШ§Щ…ЩҸ ШҙЩҺЩҮЩ’ШұЩҺЩҠЩ’ЩҶЩҗ Щ…ЩҸШӘЩҺШӘЩҺШ§ШЁЩҗШ№ЩҺЩҠЩ’ЩҶЩҗ ШӘЩҺЩҲЩ’ШЁЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:93","surah":4,"ayah":93,"num":586,"page":93,"words":[{"code":"пІғ","page":93,"end":false},{"code":"пІ„","page":93,"end":false},{"code":"пІ…","page":93,"end":false},{"code":"пІҶ","page":93,"end":false},{"code":"пІҮ","page":93,"end":false},{"code":"пІҲ","page":93,"end":false},{"code":"пІү","page":93,"end":false},{"code":"пІҠ","page":93,"end":false},{"code":"пІӢ","page":93,"end":false},{"code":"пІҢ","page":93,"end":false},{"code":"пІҚ","page":93,"end":false},{"code":"пІҺ","page":93,"end":false},{"code":"пІҸ","page":93,"end":false},{"code":"пІҗ","page":93,"end":false},{"code":"пІ‘","page":93,"end":false},{"code":"пІ’","page":93,"end":false},{"code":"пІ“","page":93,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩӮЩ’ШӘЩҸЩ„Щ’ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩӢЫӯШ§ Щ…Щ‘ЩҸШӘЩҺШ№ЩҺЩ…Щ‘ЩҗШҜЩӢЫӯШ§ ЩҒЩҺШ¬ЩҺШІЩҺШ§Щ“ШӨЩҸЩҮЩҸЫҘ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩӢЫӯШ§ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҲЩҺШәЩҺШ¶ЩҗШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩҲЩҺЩ„ЩҺШ№ЩҺЩҶЩҺЩҮЩҸЫҘ ЩҲЩҺШЈЩҺШ№ЩҺШҜЩ‘ЩҺ Щ„ЩҺЩҮЩҸЫҘ Ш№ЩҺШ°ЩҺШ§ШЁЩӢШ§ Ш№ЩҺШёЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:94","surah":4,"ayah":94,"num":587,"page":93,"words":[{"code":"пІ”","page":93,"end":false},{"code":"пІ•","page":93,"end":false},{"code":"пІ–","page":93,"end":false},{"code":"пІ—","page":93,"end":false},{"code":"пІҳ","page":93,"end":false},{"code":"пІҷ","page":93,"end":false},{"code":"пІҡ","page":93,"end":false},{"code":"пІӣ","page":93,"end":false},{"code":"пІң","page":93,"end":false},{"code":"пІқ","page":93,"end":false},{"code":"пІһ","page":93,"end":false},{"code":"пІҹ","page":93,"end":false},{"code":"пІ ","page":93,"end":false},{"code":"пІЎ","page":93,"end":false},{"code":"пІў","page":93,"end":false},{"code":"пІЈ","page":93,"end":false},{"code":"пІӨ","page":93,"end":false},{"code":"пІҘ","page":93,"end":false},{"code":"пІҰ","page":93,"end":false},{"code":"пІ§","page":93,"end":false},{"code":"пІЁ","page":93,"end":false},{"code":"пІ©","page":93,"end":false},{"code":"пІӘ","page":93,"end":false},{"code":"пІ«","page":93,"end":false},{"code":"пІ¬пІӯ","page":93,"end":false},{"code":"пІ®","page":93,"end":false},{"code":"пІҜ","page":93,"end":false},{"code":"пІ°","page":93,"end":false},{"code":"пІұ","page":93,"end":false},{"code":"пІІ","page":93,"end":false},{"code":"пІі","page":93,"end":false},{"code":"пІҙ","page":93,"end":false},{"code":"пІөпІ¶","page":93,"end":false},{"code":"пІ·","page":93,"end":false},{"code":"пІё","page":93,"end":false},{"code":"пІ№","page":93,"end":false},{"code":"пІә","page":93,"end":false},{"code":"пІ»","page":93,"end":false},{"code":"пІј","page":93,"end":false},{"code":"пІҪ","page":93,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ Ш¶ЩҺШұЩҺШЁЩ’ШӘЩҸЩ…Щ’ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ Щ„ЩҗЩ…ЩҺЩҶЩ’ ШЈЩҺЩ„Щ’ЩӮЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„ШіЩ‘ЩҺЩ„ЩҺЩҖЩ°Щ…ЩҺ Щ„ЩҺШіЩ’ШӘЩҺ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩӢЫӯШ§ ШӘЩҺШЁЩ’ШӘЩҺШәЩҸЩҲЩҶЩҺ Ш№ЩҺШұЩҺШ¶ЩҺ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҒЩҺШ№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШәЩҺШ§ЩҶЩҗЩ…ЩҸ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩҢЫӯ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ ЩҒЩҺЩ…ЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҒЩҺШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш®ЩҺШЁЩҗЩҠШұЩӢЫӯШ§"}]}
ұЩ„Щ’ЩғЩҺЩ„ЩҺЩҖЩ°Щ„ЩҺШ©Щҗ Ыҡ ШҘЩҗЩҶЩҗ ЩұЩ…Щ’ШұЩҸШӨЩҢШ§Ыҹ ЩҮЩҺЩ„ЩҺЩғЩҺ Щ„ЩҺЩҠЩ’ШіЩҺ Щ„ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ ЩҲЩҺЩ„ЩҺЩҮЩҸЫҘЩ“ ШЈЩҸШ®Щ’ШӘЩҢЫӯ ЩҒЩҺЩ„ЩҺЩҮЩҺШ§ ЩҶЩҗШөЩ’ЩҒЩҸ Щ…ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩҠЩҺШұЩҗШ«ЩҸЩҮЩҺШ§Щ“ ШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҶ Щ„Щ‘ЩҺЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺШҜЩҢЫӯ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺШӘЩҺШ§ ЩұШ«Щ’ЩҶЩҺШӘЩҺЩҠЩ’ЩҶЩҗ ЩҒЩҺЩ„ЩҺЩҮЩҸЩ…ЩҺШ§ ЩұЩ„Ш«Щ‘ЩҸЩ„ЩҸШ«ЩҺШ§ЩҶЩҗ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ Ыҡ ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ®Щ’ЩҲЩҺШ©ЩӢЫӯ ШұЩ‘ЩҗШ¬ЩҺШ§Щ„ЩӢЫӯШ§ ЩҲЩҺЩҶЩҗШіЩҺШ§Щ“ШЎЩӢЫӯ ЩҒЩҺЩ„ЩҗЩ„Ш°Щ‘ЩҺЩғЩҺШұЩҗ Щ…ЩҗШ«Щ’Щ„ЩҸ ШӯЩҺШёЩ‘Щҗ ЩұЩ„Щ’ШЈЩҸЩҶШ«ЩҺЩҠЩҺЩҠЩ’ЩҶЩҗ Ы— ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ШӘЩҺШ¶ЩҗЩ„Щ‘ЩҸЩҲШ§Ыҹ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў"},{"key":"5:1","surah":5,"ayah":1,"num":670,"page":106,"words":[{"code":"пұә","page":106,"end":false},{"code":"пұ»","page":106,"end":false},{"code":"пұј","page":106,"end":false},{"code":"пұҪ","page":106,"end":false},{"code":"пұҫпұҝ","page":106,"end":false},{"code":"пІҖ","page":106,"end":false},{"code":"пІҒ","page":106,"end":false},{"code":"пІӮ","page":106,"end":false},{"code":"пІғ","page":106,"end":false},{"code":"пІ„","page":106,"end":false},{"code":"пІ…","page":106,"end":false},{"code":"пІҶ","page":106,"end":false},{"code":"пІҮ","page":106,"end":false},{"code":"пІҲ","page":106,"end":false},{"code":"пІү","page":106,"end":false},{"code":"пІҠ","page":106,"end":false},{"code":"пІӢ","page":106,"end":false},{"code":"пІҢпІҚ","page":106,"end":false},{"code":"пІҺ","page":106,"end":false},{"code":"пІҸ","page":106,"end":false},{"code":"пІҗ","page":106,"end":false},{"code":"пІ‘","page":106,"end":false},{"code":"пІ’","page":106,"end":false},{"code":"пІ“","page":106,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҲЩ’ЩҒЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ’Ш№ЩҸЩӮЩҸЩҲШҜЩҗ Ыҡ ШЈЩҸШӯЩҗЩ„Щ‘ЩҺШӘЩ’ Щ„ЩҺЩғЩҸЩ… ШЁЩҺЩҮЩҗЩҠЩ…ЩҺШ©ЩҸ ЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ЩҠЩҸШӘЩ’Щ„ЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШәЩҺЩҠЩ’ШұЩҺ Щ…ЩҸШӯЩҗЩ„Щ‘ЩҗЩү ЩұЩ„ШөЩ‘ЩҺЩҠЩ’ШҜЩҗ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ ШӯЩҸШұЩҸЩ…ЩҢ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШӯЩ’ЩғЩҸЩ…ЩҸ Щ…ЩҺШ§ ЩҠЩҸШұЩҗЩҠШҜЩҸ"},{"key":"5:2","surah":5,"ayah":2,"num":671,"page":106,"words":[{"code":"пІ”","page":106,"end":false},{"code":"пІ•","page":106,"end":false},{"code":"пІ–","page":106,"end":false},{"code":"пІ—","page":106,"end":false},{"code":"пІҳ","page":106,"end":false},{"code":"пІҷ","page":106,"end":false},{"code":"пІҡ","page":106,"end":false},{"code":"пІӣ","page":106,"end":false},{"code":"пІң","page":106,"end":false},{"code":"пІқ","page":106,"end":false},{"code":"пІһ","page":106,"end":false},{"code":"пІҹ","page":106,"end":false},{"code":"пІ ","page":106,"end":false},{"code":"пІЎ","page":106,"end":false},{"code":"пІў","page":106,"end":false},{"code":"пІЈ","page":106,"end":false},{"code":"пІӨ","page":106,"end":false},{"code":"пІҘ","page":106,"end":false},{"code":"пІҰ","page":106,"end":false},{"code":"пІ§","page":106,"end":false},{"code":"пІЁ","page":106,"end":false},{"code":"пІ©","page":106,"end":false},{"code":"пІӘпІ«","page":106,"end":false},{"code":"пІ¬","page":106,"end":false},{"code":"пІӯ","page":106,"end":false},{"code":"пІ®пІҜ","page":106,"end":false},{"code":"пІ°","page":106,"end":false},{"code":"пІұ","page":106,"end":false},{"code":"пІІ","page":106,"end":false},{"code":"пІі","page":106,"end":false},{"code":"пІҙ","page":106,"end":false},{"code":"пІө","page":106,"end":false},{"code":"пІ¶","page":106,"end":false},{"code":"пІ·","page":106,"end":false},{"code":"пІё","page":106,"end":false},{"code":"пІ№","page":106,"end":false},{"code":"пІәпІ»","page":106,"end":false},{"code":"пІј","page":106,"end":false},{"code":"пІҪ","page":106,"end":false},{"code":"пІҫ","page":106,"end":false},{"code":"пІҝпіҖ","page":106,"end":false},{"code":"піҒ","page":106,"end":false},{"code":"піӮ","page":106,"end":false},{"code":"піғ","page":106,"end":false},{"code":"пі„","page":106,"end":false},{"code":"пі…піҶ","page":106,"end":false},{"code":"піҮ","page":106,"end":false},{"code":"піҲпіү","page":106,"end":false},{"code":"піҠ","page":106,"end":false},{"code":"піӢ","page":106,"end":false},{"code":"піҢ","page":106,"end":false},{"code":"піҚ","page":106,"end":false},{"code":"піҺ","page":106,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҸШӯЩҗЩ„Щ‘ЩҸЩҲШ§Ыҹ ШҙЩҺШ№ЩҺЩҖЩ°Щ“ШҰЩҗШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§ ЩұЩ„ШҙЩ‘ЩҺЩҮЩ’ШұЩҺ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…ЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩұЩ„Щ’ЩҮЩҺШҜЩ’ЩүЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩұЩ„Щ’ЩӮЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗШҜЩҺ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЎЩҺШ§Щ“Щ…Щ‘ЩҗЩҠЩҶЩҺ ЩұЩ„Щ’ШЁЩҺЩҠЩ’ШӘЩҺ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…ЩҺ ЩҠЩҺШЁЩ’ШӘЩҺШәЩҸЩҲЩҶЩҺ ЩҒЩҺШ¶Щ’Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШұЩҗШ¶Щ’ЩҲЩҺЩ°ЩҶЩӢЫӯШ§ Ыҡ ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШӯЩҺЩ„ЩҺЩ„Щ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩұШөЩ’Ш·ЩҺШ§ШҜЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ¬Щ’ШұЩҗЩ…ЩҺЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ ШҙЩҺЩҶЩҺЩҖЩ”ЩҺШ§ЩҶЩҸ ЩӮЩҺЩҲЩ’Щ…ЩҚ ШЈЩҺЩҶ ШөЩҺШҜЩ‘ЩҸЩҲЩғЩҸЩ…Щ’ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҗ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…Щҗ ШЈЩҺЩҶ ШӘЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲШ§Ыҹ Ыҳ ЩҲЩҺШӘЩҺШ№ЩҺШ§ЩҲЩҺЩҶЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЁЩҗШұЩ‘Щҗ ЩҲЩҺЩұЩ„ШӘЩ‘ЩҺЩӮЩ’ЩҲЩҺЩүЩ° Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ№ЩҺШ§ЩҲЩҺЩҶЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШҘЩҗШ«Щ’Щ…Щҗ ЩҲЩҺЩұЩ„Щ’Ш№ЩҸШҜЩ’ЩҲЩҺЩ°ЩҶЩҗ Ыҡ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ы– ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШҙЩҺШҜЩҗЩҠШҜЩҸ ЩұЩ„Щ’Ш№ЩҗЩӮЩҺШ§ШЁЩҗ"}]}
"code":"пұЎ","page":538,"end":false},{"code":"пұўпұЈ","page":538,"end":false},{"code":"пұӨ","page":538,"end":false},{"code":"пұҘ","page":538,"end":false},{"code":"пұҰ","page":538,"end":false},{"code":"пұ§","page":538,"end":false},{"code":"пұЁ","page":538,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ЩҒЩҗЩү ШіЩҗШӘЩ‘ЩҺШ©Щҗ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚЫў Ш«ЩҸЩ…Щ‘ЩҺ ЩұШіЩ’ШӘЩҺЩҲЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Ш№ЩҺШұЩ’ШҙЩҗ Ыҡ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Щ…ЩҺШ§ ЩҠЩҺЩ„ЩҗШ¬ЩҸ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ®Щ’ШұЩҸШ¬ЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺЩҶШІЩҗЩ„ЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ№Щ’ШұЩҸШ¬ЩҸ ЩҒЩҗЩҠЩҮЩҺШ§ Ы– ЩҲЩҺЩҮЩҸЩҲЩҺ Щ…ЩҺШ№ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҠЩ’ЩҶЩҺ Щ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫӯ"},{"key":"57:5","surah":57,"ayah":5,"num":5080,"page":538,"words":[{"code":"пұ©","page":538,"end":false},{"code":"пұӘ","page":538,"end":false},{"code":"пұ«","page":538,"end":false},{"code":"пұ¬пұӯ","page":538,"end":false},{"code":"пұ®","page":538,"end":false},{"code":"пұҜ","page":538,"end":false},{"code":"пұ°","page":538,"end":false},{"code":"пұұ","page":538,"end":false},{"code":"пұІ","page":538,"end":true}],"text":"Щ„Щ‘ЩҺЩҮЩҸЫҘ Щ…ЩҸЩ„Щ’ЩғЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ЩҲЩҺШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҸ"},{"key":"57:6","surah":57,"ayah":6,"num":5081,"page":538,"words":[{"code":"пұі","page":538,"end":false},{"code":"пұҙ","page":538,"end":false},{"code":"пұө","page":538,"end":false},{"code":"пұ¶","page":538,"end":false},{"code":"пұ·","page":538,"end":false},{"code":"пұё","page":538,"end":false},{"code":"пұ№","page":538,"end":false},{"code":"пұәпұ»","page":538,"end":false},{"code":"пұј","page":538,"end":false},{"code":"пұҪ","page":538,"end":false},{"code":"пұҫ","page":538,"end":false},{"code":"пұҝ","page":538,"end":false},{"code":"пІҖ","page":538,"end":true}],"text":"ЩҠЩҸЩҲЩ„ЩҗШ¬ЩҸ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„ЩҺ ЩҒЩҗЩү ЩұЩ„Щ
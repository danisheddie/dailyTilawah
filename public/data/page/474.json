},{"code":"пұғ","page":474,"end":false},{"code":"пұ„","page":474,"end":false},{"code":"пұ…","page":474,"end":false},{"code":"пұҶ","page":474,"end":false},{"code":"пұҮ","page":474,"end":false},{"code":"пұҲ","page":474,"end":false},{"code":"пұү","page":474,"end":false},{"code":"пұҠ","page":474,"end":false},{"code":"пұӢ","page":474,"end":false},{"code":"пұҢ","page":474,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„ШіЩ‘ЩҺШ§Ш№ЩҺШ©ЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ШӘЩҗЩҠЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҺШ§ ШұЩҺЩҠЩ’ШЁЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ„ЩҺШ§ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"40:60","surah":40,"ayah":60,"num":4193,"page":474,"words":[{"code":"пұҚ","page":474,"end":false},{"code":"пұҺ","page":474,"end":false},{"code":"пұҸ","page":474,"end":false},{"code":"пұҗ","page":474,"end":false},{"code":"пұ‘пұ’","page":474,"end":false},{"code":"пұ“","page":474,"end":false},{"code":"пұ”","page":474,"end":false},{"code":"пұ•","page":474,"end":false},{"code":"пұ–","page":474,"end":false},{"code":"пұ—","page":474,"end":false},{"code":"пұҳ","page":474,"end":false},{"code":"пұҷ","page":474,"end":false},{"code":"пұҡ","page":474,"end":false},{"code":"пұӣ","page":474,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…ЩҸ ЩұШҜЩ’Ш№ЩҸЩҲЩҶЩҗЩүЩ“ ШЈЩҺШіЩ’ШӘЩҺШ¬ЩҗШЁЩ’ Щ„ЩҺЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШіЩ’ШӘЩҺЩғЩ’ШЁЩҗШұЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ’ Ш№ЩҗШЁЩҺШ§ШҜЩҺШӘЩҗЩү ШіЩҺЩҠЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲЩҶЩҺ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ ШҜЩҺШ§Ш®ЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"40:61","surah":40,"ayah":61,"num":4194,"page":474,"words":[{"code":"пұң","page":474,"end":false},{"code":"пұқ","page":474,"end":false},{"code":"пұһ","page":474,"end":false},{"code":"пұҹ","page":474,"end":false},{"code":"пұ ","page":474,"end":false},{"code":"пұЎ","page":474,"end":false},{"code":"пұў","page":474,"end":false},{"code":"пұЈ","page":474,"end":false},{"code":"пұӨпұҘ","page":474,"end":false},{"code":"пұҰ","page":474,"end":false},{"code":"пұ§","page":474,"end":false},{"code":"пұЁ","page":474,"end":false},{"code":"пұ©","page":474,"end":false},{"code":"пұӘ","page":474,"end":false},{"code":"пұ«","page":474,"end":false},{"code":"пұ¬","page":474,"end":false},{"code":"пұӯ","page":474,"end":false},{"code":"пұ®","page":474,"end":false},{"code":"пұҜ","page":474,"end":false},{"code":"пұ°","page":474,"end":false},{"code":"пұұ","page":474,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш¬ЩҺШ№ЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„ЩҺ Щ„ЩҗШӘЩҺШіЩ’ЩғЩҸЩҶЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҗ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҺ Щ…ЩҸШЁЩ’ШөЩҗШұЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ°ЩҸЩҲ ЩҒЩҺШ¶Щ’Щ„ЩҚ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ„ЩҺШ§ ЩҠЩҺШҙЩ’ЩғЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"40:62","surah":40,"ayah":62,"num":4195,"page":474,"words":[{"code":"пұІ","page":474,"end":false},{"code":"пұі","page":474,"end":false},{"code":"пұҙ","page":474,"end":false},{"code":"пұө","page":474,"end":false},{"code":"пұ¶","page":474,"end":false},{"code":"пұ·","page":474,"end":false},{"code":"пұё","page":474,"end":false},{"code":"пұ№","page":474,"end":false},{"code":"пұә","page":474,"end":false},{"code":"пұ»пұј","page":474,"end":false},{"code":"пұҪ","page":474,"end":false},{"code":"пұҫ","page":474,"end":false},{"code":"пұҝ","page":474,"end":true}],"text":"Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…Щ’ Ш®ЩҺЩҖЩ°Щ„ЩҗЩӮЩҸ ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў Щ„Щ‘ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ Ы– ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺЩүЩ° ШӘЩҸШӨЩ’ЩҒЩҺЩғЩҸЩҲЩҶЩҺ"},{"key":"40:63","surah":40,"ayah":63,"num":4196,"page":474,"words":[{"code":"пІҖ","page":474,"end":false},{"code":"пІҒ","page":474,"end":false},{"code":"пІӮ","page":474,"end":false},{"code":"пІғ","page":474,"end":false},{"code":"пІ„","page":474,"end":false},{"code":"пІ…","page":474,"end":false},{"code":"пІҶ","page":474,"end":false},{"code":"пІҮ","page":474,"end":true}],"text":"ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШӨЩ’ЩҒЩҺЩғЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺШ¬Щ’ШӯЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"40:64","surah":40,"ayah":64,"num":4197,"page":474,"words":[{"code":"пІҲ","page":474,"end":false},{"code":"пІү","page":474,"end":false},{"code":"пІҠ","page":474,"end":false},{"code":"пІӢ","page":474,"end":false},{"code":"пІҢ","page":474,"end":false},{"code":"пІҚ","page":474,"end":false},{"code":"пІҺ","page":474,"end":false},{"code":"пІҸ","page":474,"end":false},{"code":"пІҗ","page":474,"end":false},{"code":"пІ‘","page":474,"end":false},{"code":"пІ’","page":474,"end":false},{"code":"пІ“","page":474,"end":false},{"code":"пІ”","page":474,"end":false},{"code":"пІ•пІ–","page":474,"end":false},{"code":"пІ—","page":474,"end":false},{"code":"пІҳ","page":474,"end":false},{"code":"пІҷпІҡ","page":474,"end":false},{"code":"пІӣ","page":474,"end":false},{"code":"пІң","page":474,"end":false},{"code":"пІқ","page":474,"end":false},{"code":"пІһ","page":474,"end":false},{"code":"пІҹ","page":474,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш¬ЩҺШ№ЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ЩӮЩҺШұЩҺШ§ШұЩӢЫӯШ§ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҺ ШЁЩҗЩҶЩҺШ§Щ“ШЎЩӢЫӯ ЩҲЩҺШөЩҺЩҲЩ‘ЩҺШұЩҺЩғЩҸЩ…Щ’ ЩҒЩҺШЈЩҺШӯЩ’ШіЩҺЩҶЩҺ ШөЩҸЩҲЩҺШұЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШұЩҺШІЩҺЩӮЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Ш·Щ‘ЩҺЩҠЩ‘ЩҗШЁЩҺЩҖЩ°ШӘЩҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…Щ’ Ы– ЩҒЩҺШӘЩҺШЁЩҺШ§ШұЩҺЩғЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШұЩҺШЁЩ‘ЩҸ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"40:65","surah":40,"ayah":65,"num":4198,"page":474,"words":[{"code":"пІ ","page":474,"end":false},{"code":"пІЎ","page":474,"end":false},{"code":"пІў","page":474,"end":false},{"code":"пІЈ","page":474,"end":false},{"code":"пІӨ","page":474,"end":false},{"code":"пІҘ","page":474,"end":false},{"code":"пІҰ","page":474,"end":false},{"code":"пІ§","page":474,"end":false},{"code":"пІЁ","page":474,"end":false},{"code":"пІ©пІӘ","page":474,"end":false},{"code":"пІ«","page":474,"end":false},{"code":"пІ¬","page":474,"end":false},{"code":"пІӯ","page":474,"end":false},{"code":"пІ®","page":474,"end":false},{"code":"пІҜ","page":474,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ШӯЩҺЩүЩ‘ЩҸ Щ„ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ ЩҒЩҺЩұШҜЩ’Ш№ЩҸЩҲЩҮЩҸ Щ…ЩҸШ®Щ’Щ„ЩҗШөЩҗЩҠЩҶЩҺ Щ„ЩҺЩҮЩҸ ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҺ Ы— ЩұЩ„Щ’ШӯЩҺЩ…Щ’ШҜЩҸ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ШұЩҺШЁЩ‘Щҗ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"40:66","surah":40,"ayah":66,"num":4199,"page":474,"words":[{"code":"пІ° пІұ","page":474,"end":false},{"code":"пІІ","page":474,"end":false},{"code":"пІі","page":474,"end":false},{"code":"пІҙ","page":474,"end":false},{"code":"пІө","page":474,"end":false},{"code":"пІ¶","page":474,"end":false},{"code":"пІ·","page":474,"end":false},{"code":"пІё","page":474,"end":false},{"code":"пІ№","page":474,"end":false},{"code":"пІә","page":474,"end":false},{"code":"пІ»","page":474,"end":false},{"code":"пІј","page":474,"end":false},{"code":"пІҪ","page":474,"end":false},{"code":"пІҫ","page":474,"end":false},{"code":"пІҝ","page":474,"end":false},{"code":"піҖ","page":474,"end":false},{"code":"піҒ","page":474,"end":false},{"code":"піӮ","page":474,"end":false},{"code":"піғ","page":474,"end":false},{"code":"пі„","page":474,"end":false},{"code":"пі…","page":474,"end":true}],"text":"Ыһ ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҗЩү ЩҶЩҸЩҮЩҗЩҠШӘЩҸ ШЈЩҺЩҶЩ’ ШЈЩҺШ№Щ’ШЁЩҸШҜЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺЩ…Щ‘ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺЩҶЩҗЩүЩҺ ЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҸ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩү ЩҲЩҺШЈЩҸЩ…ЩҗШұЩ’ШӘЩҸ ШЈЩҺЩҶЩ’ ШЈЩҸШіЩ’Щ„ЩҗЩ…ЩҺ Щ„ЩҗШұЩҺШЁЩ‘Щҗ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"}]}
Һ ЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҗЩүЩ“ ШЈЩҸЩ…ЩҺЩ…ЩҚЫў ЩӮЩҺШҜЩ’ Ш®ЩҺЩ„ЩҺШӘЩ’ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Ш¬ЩҗЩҶЩ‘Щҗ ЩҲЩҺЩұЩ„Щ’ШҘЩҗЩҶШіЩҗ ЩҒЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ы– ЩғЩҸЩ„Щ‘ЩҺЩ…ЩҺШ§ ШҜЩҺШ®ЩҺЩ„ЩҺШӘЩ’ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҺШ№ЩҺЩҶЩҺШӘЩ’ ШЈЩҸШ®Щ’ШӘЩҺЩҮЩҺШ§ Ы– ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§ ЩұШҜЩ‘ЩҺШ§ШұЩҺЩғЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҺШ§ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ ЩӮЩҺШ§Щ„ЩҺШӘЩ’ ШЈЩҸШ®Щ’ШұЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Щ„ЩҗШЈЩҸЩҲЩ„ЩҺЩүЩ°ЩҮЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§ ЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҸЩҲЩҶЩҺШ§ ЩҒЩҺЩҖЩ”ЩҺШ§ШӘЩҗЩҮЩҗЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩӢЫӯШ§ Ш¶ЩҗШ№Щ’ЩҒЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ы– ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҗЩғЩҸЩ„Щ‘ЩҚЫў Ш¶ЩҗШ№Щ’ЩҒЩҢЫӯ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ Щ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"7:39","surah":7,"ayah":39,"num":993,"page":155,"words":[{"code":"пұӯ","page":155,"end":false},{"code":"пұ®","page":155,"end":false},{"code":"пұҜ","page":155,"end":false},{"code":"пұ°","page":155,"end":false},{"code":"пұұ","page":155,"end":false},{"code":"пұІ","page":155,"end":false},{"code":"пұі","page":155,"end":false},{"code":"пұҙ","page":155,"end":false},{"code":"пұө","page":155,"end":false},{"code":"пұ¶","page":155,"end":false},{"code":"пұ·","page":155,"end":false},{"code":"пұё","page":155,"end":false},{"code":"пұ№","page":155,"end":false},{"code":"пұә","page":155,"end":false},{"code":"пұ»","page":155,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺШӘЩ’ ШЈЩҸЩҲЩ„ЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Щ„ЩҗШЈЩҸШ®Щ’ШұЩҺЩүЩ°ЩҮЩҸЩ…Щ’ ЩҒЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҗЩҶ ЩҒЩҺШ¶Щ’Щ„ЩҚЫў ЩҒЩҺШ°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ШЁЩҗЩ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"7:40","surah":7,"ayah":40,"num":994,"page":155,"words":[{"code":"пұј","page":155,"end":false},{"code":"пұҪ","page":155,"end":false},{"code":"пұҫ","page":155,"end":false},{"code":"пұҝ","page":155,"end":false},{"code":"пІҖ","page":155,"end":false},{"code":"пІҒ","page":155,"end":false},{"code":"пІӮ","page":155,"end":false},{"code":"пІғ","page":155,"end":false},{"code":"пІ„","page":155,"end":false},{"code":"пІ…","page":155,"end":false},{"co
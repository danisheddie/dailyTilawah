җ Ы– Щ„ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҸЩ„ЩҸЩҲШЁЩҢЫӯ Щ„Щ‘ЩҺШ§ ЩҠЩҺЩҒЩ’ЩӮЩҺЩҮЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҢЫӯ Щ„Щ‘ЩҺШ§ ЩҠЩҸШЁЩ’ШөЩҗШұЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ШЎЩҺШ§Ш°ЩҺШ§ЩҶЩҢЫӯ Щ„Щ‘ЩҺШ§ ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҺШ§Щ“ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩғЩҺЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ ШЁЩҺЩ„Щ’ ЩҮЩҸЩ…Щ’ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҸ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ШәЩҺЩҖЩ°ЩҒЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"7:180","surah":7,"ayah":180,"num":1134,"page":174,"words":[{"code":"пұЈ","page":174,"end":false},{"code":"пұӨ","page":174,"end":false},{"code":"пұҘ","page":174,"end":false},{"code":"пұҰ","page":174,"end":false},{"code":"пұ§пұЁ","page":174,"end":false},{"code":"пұ©","page":174,"end":false},{"code":"пұӘ","page":174,"end":false},{"code":"пұ«","page":174,"end":false},{"code":"пұ¬","page":174,"end":false},{"code":"пұӯпұ®","page":174,"end":false},{"code":"пұҜ","page":174,"end":false},{"code":"пұ°","page":174,"end":false},{"code":"пұұ","page":174,"end":false},{"code":"пұІ","page":174,"end":false},{"code":"пұі","page":174,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ШЈЩҺШіЩ’Щ…ЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ’ШӯЩҸШіЩ’ЩҶЩҺЩүЩ° ЩҒЩҺЩұШҜЩ’Ш№ЩҸЩҲЩҮЩҸ ШЁЩҗЩҮЩҺШ§ Ы– ЩҲЩҺШ°ЩҺШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩ„Щ’ШӯЩҗШҜЩҸЩҲЩҶЩҺ ЩҒЩҗЩүЩ“ ШЈЩҺШіЩ’Щ…ЩҺЩҖЩ°Щ“ШҰЩҗЩҮЩҗЫҰ Ыҡ ШіЩҺЩҠЩҸШ¬Щ’ШІЩҺЩҲЩ’ЩҶЩҺ Щ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"7:181","surah":7,"ayah":181,"num":1135,"page":174,"words":[{"code":"пұҙ","page":174,"end":false},{"code":"пұө","page":174,"end":false},{"code":"пұ¶","page":174,"end":false},{"code":"пұ·","page":174,"end":false},{"code":"пұё","page":174,"end":false},{"code":"пұ№","page":174,"end":false},{"code":"пұә","page":174,"end":false},{"code":"пұ»","page":174,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩ…Щ‘ЩҺЩҶЩ’ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺШ§Щ“ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҢЫӯ ЩҠЩҺЩҮЩ’ШҜЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺШЁЩҗЩҮЩҗЫҰ ЩҠЩҺШ№Щ’ШҜЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"7:182","surah":7,"ayah":182,"num":1136,"page":174,"words":[{"code":"пұј","page":174,"end":false},{"code":"пұҪ","page":174,"end":false},{"code":
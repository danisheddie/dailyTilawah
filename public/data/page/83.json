false},{"code":"пұҶ","page":83,"end":false},{"code":"пұҮ","page":83,"end":false},{"code":"пұҲ","page":83,"end":false},{"code":"пұү","page":83,"end":false},{"code":"пұҠ","page":83,"end":false},{"code":"пұӢ","page":83,"end":false},{"code":"пұҢ","page":83,"end":false},{"code":"пұҚ","page":83,"end":false},{"code":"пұҺ","page":83,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҸШұЩҗЩҠШҜЩҸ ШЈЩҺЩҶ ЩҠЩҺШӘЩҸЩҲШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҸШұЩҗЩҠШҜЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҮЩҺЩҲЩҺЩ°ШӘЩҗ ШЈЩҺЩҶ ШӘЩҺЩ…ЩҗЩҠЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҺЩҠЩ’Щ„ЩӢШ§ Ш№ЩҺШёЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:28","surah":4,"ayah":28,"num":521,"page":83,"words":[{"code":"пұҸ","page":83,"end":false},{"code":"пұҗ","page":83,"end":false},{"code":"пұ‘","page":83,"end":false},{"code":"пұ’","page":83,"end":false},{"code":"пұ“пұ”","page":83,"end":false},{"code":"пұ•","page":83,"end":false},{"code":"пұ–","page":83,"end":false},{"code":"пұ—","page":83,"end":false},{"code":"пұҳ","page":83,"end":true}],"text":"ЩҠЩҸШұЩҗЩҠШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺЩҶ ЩҠЩҸШ®ЩҺЩҒЩ‘ЩҗЩҒЩҺ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШ®ЩҸЩ„ЩҗЩӮЩҺ ЩұЩ„Щ’ШҘЩҗЩҶШіЩҺЩҖЩ°ЩҶЩҸ Ш¶ЩҺШ№ЩҗЩҠЩҒЩӢЫӯШ§"},{"key":"4:29","surah":4,"ayah":29,"num":522,"page":83,"words":[{"code":"пұҷ","page":83,"end":false},{"code":"пұҡ","page":83,"end":false},{"code":"пұӣ","page":83,"end":false},{"code":"пұң","page":83,"end":false},{"code":"пұқ","page":83,"end":false},{"code":"пұһ","page":83,"end":false},{"code":"пұҹ","page":83,"end":false},{"code":"пұ ","page":83,"end":false},{"code":"пұЎ","page":83,"end":false},{"code":"пұў","page":83,"end":false},{"code":"пұЈ","page":83,"end":false},{"code":"пұӨ","page":83,"end":false},{"code":"пұҘ","page":83,"end":false},{"code":"пұҰ","page":83,"end":false},{"code":"пұ§пұЁ","page":83,"end":false},{"code":"пұ©","page":83,"end":false},{"code":"пұӘ","page":83,"end":false},{"code":"пұ«пұ¬","page":83,"end":false},{"code":"пұӯ","page":83,"end":false},{"code":"пұ®","page":83,"end":false},{"code":"пұҜ","page":83,"end":false},{"code":"пұ°","page":83,"end":false},{"code":"пұұ","page":83,"end":false},{"code":"пұІ","page":83,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩғЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ… ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҖЩ°Ш·ЩҗЩ„Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ШӘЩҺЩғЩҸЩҲЩҶЩҺ ШӘЩҗШ¬ЩҺЩҖЩ°ШұЩҺШ©ЩӢ Ш№ЩҺЩҶ ШӘЩҺШұЩҺШ§Ш¶ЩҚЫў Щ…Щ‘ЩҗЩҶЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺЩӮЩ’ШӘЩҸЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҒЩҸШіЩҺЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ ШЁЩҗЩғЩҸЩ…Щ’ ШұЩҺШӯЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:30","surah":4,"ayah":30,"num":523,"page":83,"words":[{"code":"пұі","page":83,"end":false},{"code":"пұҙ","page":83,"end":false},{"code":"пұө","page":83,"end":false},{"code":"пұ¶","page":83,"end":false},{"code":"пұ·","page":83,"end":false},{"code":"пұё","page":83,"end":false},{"code":"пұ№","page":83,"end":false},{"code":"пұәпұ»","page":83,"end":false},{"code":"пұј","page":83,"end":false},{"code":"пұҪ","page":83,"end":false},{"code":"пұҫ","page":83,"end":false},{"code":"пұҝ","page":83,"end":false},{"code":"пІҖ","page":83,"end":false},{"code":"пІҒ","page":83,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„Щ’ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш№ЩҸШҜЩ’ЩҲЩҺЩ°ЩҶЩӢЫӯШ§ ЩҲЩҺШёЩҸЩ„Щ’Щ…ЩӢЫӯШ§ ЩҒЩҺШіЩҺЩҲЩ’ЩҒЩҺ ЩҶЩҸШөЩ’Щ„ЩҗЩҠЩҮЩҗ ЩҶЩҺШ§ШұЩӢЫӯШ§ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҠЩҺШіЩҗЩҠШұЩӢШ§"},{"key":"4:31","surah":4,"ayah":31,"num":524,"page":83,"words":[{"code":"пІӮ","page":83,"end":false},{"code":"пІғ","page":83,"end":false},{"code":"пІ„","page":83,"end":false},{"code":"пІ…","page":83,"end":false},{"code":"пІҶ","page":83,"end":false},{"code":"пІҮ","page":83,"end":false},{"code":"пІҲ","page":83,"end":false},{"code":"пІү","page":83,"end":false},{"code":"пІҠ","page":83,"end":false},{"code":"пІӢ","page":83,"end":false},{"code":"пІҢ","page":83,"end":false},{"code":"пІҚ","page":83,"end":false},{"code":"пІҺ","page":83,"end":true}],"text":"ШҘЩҗЩҶ ШӘЩҺШ¬Щ’ШӘЩҺЩҶЩҗШЁЩҸЩҲШ§Ыҹ ЩғЩҺШЁЩҺШ§Щ“ШҰЩҗШұЩҺ Щ…ЩҺШ§ ШӘЩҸЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩ’ЩҮЩҸ ЩҶЩҸЩғЩҺЩҒЩ‘ЩҗШұЩ’ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩҶЩҸШҜЩ’Ш®ЩҗЩ„Щ’ЩғЩҸЩ… Щ…Щ‘ЩҸШҜЩ’Ш®ЩҺЩ„ЩӢЫӯШ§ ЩғЩҺШұЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:32","surah":4,"ayah":32,"num":525,"page":83,"words":[{"code":"пІҸ","page":83,"end":false},{"code":"пІҗ","page":83,"end":false},{"code":"пІ‘","page":83,"end":false},{"code":"пІ’","page":83,"end":false},{"code":"пІ“","page":83,"end":false},{"code":"пІ”","page":83,"end":false},{"code":"пІ•","page":83,"end":false},{"code":"пІ–","page":83,"end":false},{"code":"пІ—пІҳ","page":83,"end":false},{"code":"пІҷ","page":83,"end":false},{"code":"пІҡ","page":83,"end":false},{"code":"пІӣ","page":83,"end":false},{"code":"пІңпІқ","page":83,"end":false},{"code":"пІһ","page":83,"end":false},{"code":"пІҹ","page":83,"end":false},{"code":"пІ ","page":83,"end":false},{"code":"пІЎпІў","page":83,"end":false},{"code":"пІЈ","page":83,"end":false},{"code":"пІӨ","page":83,"end":false},{"code":"пІҘ","page":83,"end":false},{"code":"пІҰпІ§","page":83,"end":false},{"code":"пІЁ","page":83,"end":false},{"code":"пІ©","page":83,"end":false},{"code":"пІӘ","page":83,"end":false},{"code":"пІ«","page":83,"end":false},{"code":"пІ¬","page":83,"end":false},{"code":"пІӯ","page":83,"end":false},{"code":"пІ®","page":83,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩҺЩ…ЩҺЩҶЩ‘ЩҺЩҲЩ’Ш§Ыҹ Щ…ЩҺШ§ ЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҗЫҰ ШЁЩҺШ№Щ’Ш¶ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ Щ„Щ‘ЩҗЩ„ШұЩ‘ЩҗШ¬ЩҺШ§Щ„Щҗ ЩҶЩҺШөЩҗЩҠШЁЩҢЫӯ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩұЩғЩ’ШӘЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺЩ„ЩҗЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ ЩҶЩҺШөЩҗЩҠШЁЩҢЫӯ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩұЩғЩ’ШӘЩҺШіЩҺШЁЩ’ЩҶЩҺ Ыҡ ЩҲЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҗЩҶ ЩҒЩҺШ¶Щ’Щ„ЩҗЩҮЩҗЫҰЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:33","surah":4,"ayah":33,"num":526,"page":83,"words":[{"code":"пІҜ","page":83,"end":false},{"code":"пІ°","page":83,"end":false},{"code":"пІұ","page":83,"end":false},{"code":"пІІ","page":83,"end":false},{"code":"пІі","page":83,"end":false},{"code":"пІҙ","page":83,"end":false},{"code":"пІөпІ¶","page":83,"end":false},{"code":"пІ·","page":83,"end":false},{"code":"пІё","page":83,"end":false},{"code":"пІ№","page":83,"end":false},{"code":"пІә","page":83,"end":false},{"code":"пІ»пІј","page":83,"end":false},{"code":"пІҪ","page":83,"end":false},{"code":"пІҫ","page":83,"end":false},{"code":"пІҝ","page":83,"end":false},{"code":"піҖ","page":83,"end":false},{"code":"піҒ","page":83,"end":false},{"code":"піӮ","page":83,"end":false},{"code":"піғ","page":83,"end":false},{"code":"пі„","page":83,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩғЩҸЩ„Щ‘ЩҚЫў Ш¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ Щ…ЩҺЩҲЩҺЩ°Щ„ЩҗЩүЩҺ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШӘЩҺШұЩҺЩғЩҺ ЩұЩ„Щ’ЩҲЩҺЩ°Щ„ЩҗШҜЩҺШ§ЩҶЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺЩӮЩ’ШұЩҺШЁЩҸЩҲЩҶЩҺ Ыҡ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Ш№ЩҺЩӮЩҺШҜЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ…Щ’ ЩҒЩҺЩҖЩ”ЩҺШ§ШӘЩҸЩҲЩҮЩҸЩ…Щ’ ЩҶЩҺШөЩҗЩҠШЁЩҺЩҮЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ШҙЩҺЩҮЩҗЩҠШҜЩӢШ§"}]}
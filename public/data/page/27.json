ah":2,"ayah":177,"num":184,"page":27,"words":[{"code":"пұҒ пұӮ","page":27,"end":false},{"code":"пұғ","page":27,"end":false},{"code":"пұ„","page":27,"end":false},{"code":"пұ…","page":27,"end":false},{"code":"пұҶ","page":27,"end":false},{"code":"пұҮ","page":27,"end":false},{"code":"пұҲ","page":27,"end":false},{"code":"пұү","page":27,"end":false},{"code":"пұҠ","page":27,"end":false},{"code":"пұӢ","page":27,"end":false},{"code":"пұҢ","page":27,"end":false},{"code":"пұҚ","page":27,"end":false},{"code":"пұҺ","page":27,"end":false},{"code":"пұҸ","page":27,"end":false},{"code":"пұҗ","page":27,"end":false},{"code":"пұ‘","page":27,"end":false},{"code":"пұ’","page":27,"end":false},{"code":"пұ“","page":27,"end":false},{"code":"пұ”","page":27,"end":false},{"code":"пұ•","page":27,"end":false},{"code":"пұ–","page":27,"end":false},{"code":"пұ—","page":27,"end":false},{"code":"пұҳ","page":27,"end":false},{"code":"пұҷ","page":27,"end":false},{"code":"пұҡ","page":27,"end":false},{"code":"пұӣ","page":27,"end":false},{"code":"пұң","page":27,"end":false},{"code":"пұқ","page":27,"end":false},{"code":"пұһ","page":27,"end":false},{"code":"пұҹ","page":27,"end":false},{"code":"пұ ","page":27,"end":false},{"code":"пұЎ","page":27,"end":false},{"code":"пұў","page":27,"end":false},{"code":"пұЈ","page":27,"end":false},{"code":"пұӨ","page":27,"end":false},{"code":"пұҘ","page":27,"end":false},{"code":"пұҰ","page":27,"end":false},{"code":"пұ§","page":27,"end":false},{"code":"пұЁпұ©","page":27,"end":false},{"code":"пұӘ","page":27,"end":false},{"code":"пұ«","page":27,"end":false},{"code":"пұ¬","page":27,"end":false},{"code":"пұӯ","page":27,"end":false},{"code":"пұ®","page":27,"end":false},{"code":"пұҜпұ°","page":27,"end":false},{"code":"пұұ","page":27,"end":false},{"code":"пұІ","page":27,"end":false},{"code":"пұіпұҙ","page":27,"end":false},{"code":"пұө","page":27,"end":false},{"code":"пұ¶","page":27,"end":false},{"code":"пұ·","page":27,"end":false},{"code":"пұё","page":27,"end":true}],"text":"Ыһ Щ„Щ‘ЩҺЩҠЩ’ШіЩҺ ЩұЩ„Щ’ШЁЩҗШұЩ‘ЩҺ ШЈЩҺЩҶ ШӘЩҸЩҲЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ЩҲЩҸШ¬ЩҸЩҲЩҮЩҺЩғЩҸЩ…Щ’ ЩӮЩҗШЁЩҺЩ„ЩҺ ЩұЩ„Щ’Щ…ЩҺШҙЩ’ШұЩҗЩӮЩҗ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШәЩ’ШұЩҗШЁЩҗ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ’ШЁЩҗШұЩ‘ЩҺ Щ…ЩҺЩҶЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©Щҗ ЩҲЩҺЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩҗЩҖЫ§ЩҶЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩү ЩұЩ„Щ’Щ…ЩҺШ§Щ„ЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ШӯЩҸШЁЩ‘ЩҗЩҮЩҗЫҰ Ш°ЩҺЩҲЩҗЩү ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЁЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҠЩҶЩҺ ЩҲЩҺЩұШЁЩ’ЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺШ§Щ“ШҰЩҗЩ„ЩҗЩҠЩҶЩҺ ЩҲЩҺЩҒЩҗЩү ЩұЩ„ШұЩ‘ЩҗЩӮЩҺШ§ШЁЩҗ ЩҲЩҺШЈЩҺЩӮЩҺШ§Щ…ЩҺ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩү ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸЩҲЩҒЩҸЩҲЩҶЩҺ ШЁЩҗШ№ЩҺЩҮЩ’ШҜЩҗЩҮЩҗЩ…Щ’ ШҘЩҗШ°ЩҺШ§ Ш№ЩҺЩҖЩ°ЩҮЩҺШҜЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺЩұЩ„ШөЩ‘ЩҺЩҖЩ°ШЁЩҗШұЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЁЩҺШЈЩ’ШіЩҺШ§Щ“ШЎЩҗ ЩҲЩҺЩұЩ„Ш¶Щ‘ЩҺШұЩ‘ЩҺШ§Щ“ШЎЩҗ ЩҲЩҺШӯЩҗЩҠЩҶЩҺ ЩұЩ„Щ’ШЁЩҺШЈЩ’ШіЩҗ Ы— ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШөЩҺШҜЩҺЩӮЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"2:178","surah":2,"ayah":178,"num":185,"page":27,"words":[{"code":"пұ№","page":27,"end":false},{"code":"пұә","page":27,"end":false},{"code":"пұ»","page":27,"end":false},{"code":"пұј","page":27,"end":false},{"code":"пұҪ","page":27,"end":false},{"code":"пұҫ","page":27,"end":false},{"code":"пұҝ","page":27,"end":false},{"code":"пІҖпІҒ","page":27,"end":false},{"code":"пІӮ","page":27,"end":false},{"code":"пІғ","page":27,"end":false},{"code":"пІ„","page":27,"end":false},{"code":"пІ…","page":27,"end":false},{"code":"пІҶ","page":27,"end":false},{"code":"пІҮпІҲ","page":27,"end":false},{"code":"пІү","page":27,"end":false},{"code":"пІҠ","page":27,"end":false},{"code":"пІӢ","page":27,"end":false},{"code":"пІҢ","page":27,"end":false},{"code":"пІҚ","page":27,"end":false},{"code":"пІҺ","page":27,"end":false},{"code":"пІҸ","page":27,"end":false},{"code":"пІҗ","page":27,"end":false},{"code":"пІ‘","page":27,"end":false},{"code":"пІ’","page":27,"end":false},{"code":"пІ“пІ”","page":27,"end":false},{"code":"пІ•","page":27,"end":false},{"code":"пІ–","page":27,"end":false},{"code":"пІ—","page":27,"end":false},{"code":"пІҳ","page":27,"end":false},{"code":"пІҷпІҡ","page":27,"end":false},{"code":"пІӣ","page":27,"end":false},{"code":"пІң","page":27,"end":false},{"code":"пІқ","page":27,"end":false},{"code":"пІһ","page":27,"end":false},{"code":"пІҹ","page":27,"end":false},{"code":"пІ ","page":27,"end":false},{"code":"пІЎ","page":27,"end":false},{"code":"пІў","page":27,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩӮЩҗШөЩҺШ§ШөЩҸ ЩҒЩҗЩү ЩұЩ„Щ’ЩӮЩҺШӘЩ’Щ„ЩҺЩү Ы– ЩұЩ„Щ’ШӯЩҸШұЩ‘ЩҸ ШЁЩҗЩұЩ„Щ’ШӯЩҸШұЩ‘Щҗ ЩҲЩҺЩұЩ„Щ’Ш№ЩҺШЁЩ’ШҜЩҸ ШЁЩҗЩұЩ„Щ’Ш№ЩҺШЁЩ’ШҜЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҸЩҶШ«ЩҺЩүЩ° ШЁЩҗЩұЩ„Щ’ШЈЩҸЩҶШ«ЩҺЩүЩ° Ыҡ ЩҒЩҺЩ…ЩҺЩҶЩ’ Ш№ЩҸЩҒЩҗЩүЩҺ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶЩ’ ШЈЩҺШ®ЩҗЩҠЩҮЩҗ ШҙЩҺЩүЩ’ШЎЩҢЫӯ ЩҒЩҺЩұШӘЩ‘ЩҗШЁЩҺШ§Ш№ЩҢЫў ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺШЈЩҺШҜЩҺШ§Щ“ШЎЩҢ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЁЩҗШҘЩҗШӯЩ’ШіЩҺЩҖЩ°ЩҶЩҚЫў Ы— Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШӘЩҺШ®Щ’ЩҒЩҗЩҠЩҒЩҢЫӯ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩҢЫӯ Ы— ЩҒЩҺЩ…ЩҺЩҶЩҗ ЩұШ№Щ’ШӘЩҺШҜЩҺЩүЩ° ШЁЩҺШ№Щ’ШҜЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҒЩҺЩ„ЩҺЩҮЩҸЫҘ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:179","surah":2,"ayah":179,"num":186,"page":27,"words":[{"code":"пІЈ","page":27,"end":false},{"code":"пІӨ","page":27,"end":false},{"code":"пІҘ","page":27,"end":false},{"code":"пІҰ","page":27,"end":false},{"code":"пІ§","page":27,"end":false},{"code":"пІЁ","page":27,"end":false},{"code":"пІ©","page":27,"end":false},{"code":"пІӘ","page":27,"end":false},{"code":"пІ«","page":27,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩғЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ЩӮЩҗШөЩҺШ§ШөЩҗ ШӯЩҺЩҠЩҺЩҲЩ°Ш©ЩҢЫӯ ЩҠЩҺЩҖЩ°Щ“ШЈЩҸЩҲЫҹЩ„ЩҗЩү ЩұЩ„Щ’ШЈЩҺЩ„Щ’ШЁЩҺЩҖЩ°ШЁЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"2:180","surah":2,"ayah":180,"num":187,"page":27,"words":[{"code":"пІ¬","page":27,"end":false},{"code":"пІӯ","page":27,"end":false},{"code":"пІ®","page":27,"end":false},{"code
age":527,"end":true}],"text":"Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ…ЩҺШЁЩ’Щ„ЩҺШәЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҗЩ„Щ’Щ…Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ЩҮЩҸЩҲЩҺ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗЩ…ЩҺЩҶ Ш¶ЩҺЩ„Щ‘ЩҺ Ш№ЩҺЩҶ ШіЩҺШЁЩҗЩҠЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺЩҮЩҸЩҲЩҺ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗЩ…ЩҺЩҶЩҗ ЩұЩҮЩ’ШӘЩҺШҜЩҺЩүЩ°"},{"key":"53:31","surah":53,"ayah":31,"num":4815,"page":527,"words":[{"code":"пұј","page":527,"end":false},{"code":"пұҪ","page":527,"end":false},{"code":"пұҫ","page":527,"end":false},{"code":"пұҝ","page":527,"end":false},{"code":"пІҖ","page":527,"end":false},{"code":"пІҒ","page":527,"end":false},{"code":"пІӮ","page":527,"end":false},{"code":"пІғ","page":527,"end":false},{"code":"пІ„","page":527,"end":false},{"code":"пІ…","page":527,"end":false},{"code":"пІҶ","page":527,"end":false},{"code":"пІҮ","page":527,"end":false},{"code":"пІҲ","page":527,"end":false},{"code":"пІү","page":527,"end":false},{"code":"пІҠ","page":527,"end":false},{"code":"пІӢ","page":527,"end":false},{"code":"пІҢ","page":527,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ„ЩҗЩҠЩҺШ¬Щ’ШІЩҗЩүЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҺШіЩҺЩҖЩ°Щ“ЩҖЩ”ЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҲЩҺЩҠЩҺШ¬Щ’ШІЩҗЩүЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҺШӯЩ’ШіЩҺЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ’ШӯЩҸШіЩ’ЩҶЩҺЩү"},{"key":"53:32","surah":53,"ayah":32,"num":4816,"page":527,"words":[{"code":"пІҚ","page":527,"end":false},{"code":"пІҺ","page":527,"end":false},{"code":"пІҸ","page":527,"end":false},{"code":"пІҗ","page":527,"end":false},{"code":"пІ‘","page":527,"end":false},{"code":"пІ’","page":527,"end":false},{"code":"пІ“пІ”","page":527,"end":false},{"code":"пІ•","page":527,"end":false},{"code":"пІ–","page":527,"end":false},{"code":"пІ—","page":527,"end":false},{"code":"пІҳпІҷ","page":527,"end":false},{"code":"пІҡ","page":527,"end":false},{"code":"пІӣ","page":527,"end":false},{"code":"пІң","page":527,"end":false},{"code":"пІқ","page":527,"end":false},{"code":"пІһ","page":527,"end":false},{"code":"пІҹ","page":527,"end":false},{"code"
"code":"пұһ","page":150,"end":false},{"code":"пұҹ","page":150,"end":false},{"code":"пұ ","page":150,"end":false},{"code":"пұЎ","page":150,"end":false},{"code":"пұўпұЈ","page":150,"end":false},{"code":"пұӨ","page":150,"end":false},{"code":"пұҘ","page":150,"end":false},{"code":"пұҰ","page":150,"end":false},{"code":"пұ§","page":150,"end":false},{"code":"пұЁ","page":150,"end":true}],"text":"ЩҮЩҺЩ„Щ’ ЩҠЩҺЩҶШёЩҸШұЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ШӘЩҺШЈЩ’ШӘЩҗЩҠЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©ЩҸ ШЈЩҺЩҲЩ’ ЩҠЩҺШЈЩ’ШӘЩҗЩүЩҺ ШұЩҺШЁЩ‘ЩҸЩғЩҺ ШЈЩҺЩҲЩ’ ЩҠЩҺШЈЩ’ШӘЩҗЩүЩҺ ШЁЩҺШ№Щ’Ш¶ЩҸ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҺ Ы— ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШЈЩ’ШӘЩҗЩү ШЁЩҺШ№Щ’Ш¶ЩҸ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҺ Щ„ЩҺШ§ ЩҠЩҺЩҶЩҒЩҺШ№ЩҸ ЩҶЩҺЩҒЩ’ШіЩӢШ§ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҸЩҮЩҺШ§ Щ„ЩҺЩ…Щ’ ШӘЩҺЩғЩҸЩҶЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҺШӘЩ’ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ ШЈЩҺЩҲЩ’ ЩғЩҺШіЩҺШЁЩҺШӘЩ’ ЩҒЩҗЩүЩ“ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҗЩҮЩҺШ§ Ш®ЩҺЩҠЩ’ШұЩӢЫӯШ§ Ы— ЩӮЩҸЩ„Щҗ ЩұЩҶШӘЩҺШёЩҗШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ Щ…ЩҸЩҶШӘЩҺШёЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"6:159","surah":6,"ayah":159,"num":948,"page":150,"words":[{"code":"пұ©","page":150,"end":false},{"code":"пұӘ","page":150,"end":false},{"code":"пұ«","page":150,"end":false},{"code":"пұ¬","page":150,"end":false},{"code":"пұӯ","page":150,"end":false},{"code":"пұ®","page":150,"end":false},{"code":"пұҜ","page":150,"end":false},{"code":"пұ°","page":150,"end":false},{"code":"пұұ","page":150,"end":false},{"code":"пұІпұі","page":150,"end":false},{"code":"пұҙ","page":150,"end":false},{"code":"пұө","page":150,"end":false},{"code":"пұ¶","page":150,"end":false},{"code":"пұ·","page":150,"end":false},{"code":"пұё","page":150,"end":false},{"code":"пұ№","page":150,"end":false},{"code":"пұә","page":150,"end":false},{"code":"пұ»","page":150,"end":false},{"code":"пұј","page":150,"end":false},{"code":"пұҪ","page":150,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҒЩҺШұЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ШҜЩҗЩҠЩҶЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШҙЩҗЩҠЩҺШ№ЩӢЫӯШ§ Щ„Щ‘ЩҺШіЩ’ШӘЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ШҙЩҺЩүЩ’ШЎЩҚ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩ…Щ’ШұЩҸ
age":549,"end":false},{"code":"пұ®","page":549,"end":false},{"code":"пұҜ","page":549,"end":false},{"code":"пұ°","page":549,"end":false},{"code":"пұұ","page":549,"end":false},{"code":"пұІ","page":549,"end":false},{"code":"пұі","page":549,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸЩҲШ§Ыҹ Ш№ЩҺШҜЩҸЩҲЩ‘ЩҗЩү ЩҲЩҺШ№ЩҺШҜЩҸЩҲЩ‘ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҺ ШӘЩҸЩ„Щ’ЩӮЩҸЩҲЩҶЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ… ШЁЩҗЩұЩ„Щ’Щ…ЩҺЩҲЩҺШҜЩ‘ЩҺШ©Щҗ ЩҲЩҺЩӮЩҺШҜЩ’ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩ…ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҠЩҸШ®Щ’ШұЩҗШ¬ЩҸЩҲЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ ЩҲЩҺШҘЩҗЩҠЩ‘ЩҺШ§ЩғЩҸЩ…Щ’ Ыҷ ШЈЩҺЩҶ ШӘЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ Ш®ЩҺШұЩҺШ¬Щ’ШӘЩҸЩ…Щ’ Ш¬ЩҗЩҮЩҺЩҖЩ°ШҜЩӢЫӯШ§ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„ЩҗЩү ЩҲЩҺЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ Щ…ЩҺШұЩ’Ш¶ЩҺШ§ШӘЩҗЩү Ыҡ ШӘЩҸШіЩҗШұЩ‘ЩҸЩҲЩҶЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗЩ… ШЁЩҗЩұЩ„Щ’Щ…ЩҺЩҲЩҺШҜЩ‘ЩҺШ©Щҗ ЩҲЩҺШЈЩҺЩҶЩҺШ§Ы  ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҺШ®Щ’ЩҒЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШ№Щ’Щ„ЩҺЩҶШӘЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„Щ’ЩҮЩҸ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ ЩҒЩҺЩӮЩҺШҜЩ’ Ш¶ЩҺЩ„Щ‘ЩҺ ШіЩҺЩҲЩҺШ§Щ“ШЎЩҺ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ"},{"key":"60:2","surah":60,"ayah":2,"num":5152,"page":549,"words":[{"code":"пұҙ","page":549,"end":false},{"code":"пұө","page":549,"end":false},{"code":"пұ¶","page":549,"end":false},{"code":"пұ·","page":549,"end":false},{"code":"пұё","page":549,"end":false},{"code":"пұ№","page":549,"end":false},{"code":"пұә","page":549,"end":false},{"code":"пұ»","page":549,"end":false},{"code":"пұј","page":549,"end":false},{"code":"пұҪ","page":549,"end":false},{"code":"пұҫ","page":549,"end":false},{"code":"пұҝ","page":549,"end":false},{"code":"пІҖ","page":549,"end":false},{"code":"пІҒ","page":549,"end":true}],"text":"ШҘЩҗЩҶ ЩҠЩҺШ«Щ’ЩӮЩҺЩҒЩҸЩҲЩғЩҸЩ…Щ’ ЩҠЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺЩғЩҸЩ…Щ’ ШЈЩҺШ№Щ’ШҜЩҺШ§Щ“ШЎЩӢЫӯ ЩҲЩҺЩҠЩҺШЁЩ’ШіЩҸШ·ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩ„Щ’ШіЩҗЩҶЩҺШӘЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„ШіЩ‘ЩҸЩҲЩ“ШЎЩҗ ЩҲЩҺЩҲЩҺШҜЩ‘ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’ ШӘЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"60:3","surah":60,"ayah":3,"num":5153,"page":549,"words":[{"code":"пІӮ","page":549,"end":false},{"code":"пІғ","page":549,"end":false},{"code":"пІ„","page":549,"end":false},{"code":"пІ…","page":549,"end":false},{"code":"пІҶпІҮ","page":549,"end":false},{"code":"пІҲ","page":549,"end":false},{"code":"пІү","page":549,"end":false},{"code":"пІҠ","page":549,"end":false},{"code":"пІӢпІҢ","page":549,"end":false},{"code":"пІҚ","page":549,"end":false},{"code":"пІҺ","page":549,"end":false},{"code":"пІҸ","page":549,"end":false},{"code":"пІҗ","page":549,"end":false},{"code":"пІ‘","page":549,"end":true}],"text":"Щ„ЩҺЩҶ ШӘЩҺЩҶЩҒЩҺШ№ЩҺЩғЩҸЩ…Щ’ ШЈЩҺШұЩ’ШӯЩҺШ§Щ…ЩҸЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺЩҲЩ’Щ„ЩҺЩҖЩ°ШҜЩҸЩғЩҸЩ…Щ’ Ыҡ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ ЩҠЩҺЩҒЩ’ШөЩҗЩ„ЩҸ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫӯ"},{"key":"60:4","surah":60,"ayah":4,"num":5154,"page":549,"words":[{"code":"пІ’","page":549,"end":false},{"code":"пІ“","page":549,"end":false},{"code":"пІ”","page":549,"end":false},{"code":"пІ•","page":549,"end":false},{"code":"пІ–","page":549,"end":false},{"code":"пІ—","page":549,"end":false},{"code":"пІҳ","page":549,"end":false},{"code":"пІҷ","page":549,"end":false},{"code":"пІҡ","page":549,"end":false},{"code":"пІӣ","page":549,"end":false},{"code":"пІң","page":549,"end":false},{"code":"пІқ","page":549,"end":false},{"code":"пІһ","page":549,"end":false},{"code":"пІҹ","page":549,"end":false},{"code":"пІ ","page":549,"end":false},{"code":"пІЎ","page":549,"end":false},{"code":"пІў","page":549,"end":false},{"code":"пІЈ","page":549,"end":false},{"code":"пІӨ","page":549,"end":false},{"code":"пІҘ","page":549,"end":false},{"code":"пІҰ","page":549,"end":false},{"code":"пІ§","page":549,"end":false},{"code":"пІЁ","page":549,"end":false},{"code":"пІ©","page":549,"end":false},{"code":"пІӘ","page":549,"end":false},{"code":"пІ«","page":549,"end":false},{"code":"пІ¬","page":549,"end":false},{"code":"п
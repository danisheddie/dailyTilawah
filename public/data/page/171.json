","page":171,"end":false},{"code":"пІҡ","page":171,"end":true}],"text":"ЩҒЩҺШЁЩҺШҜЩ‘ЩҺЩ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩӮЩҺЩҲЩ’Щ„ЩӢШ§ ШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШұЩҗШ¬Щ’ШІЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШёЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"7:163","surah":7,"ayah":163,"num":1117,"page":171,"words":[{"code":"пІӣ","page":171,"end":false},{"code":"пІң","page":171,"end":false},{"code":"пІқ","page":171,"end":false},{"code":"пІһ","page":171,"end":false},{"code":"пІҹ","page":171,"end":false},{"code":"пІ ","page":171,"end":false},{"code":"пІЎ","page":171,"end":false},{"code":"пІў","page":171,"end":false},{"code":"пІЈ","page":171,"end":false},{"code":"пІӨ","page":171,"end":false},{"code":"пІҘ","page":171,"end":false},{"code":"пІҰ","page":171,"end":false},{"code":"пІ§","page":171,"end":false},{"code":"пІЁ","page":171,"end":false},{"code":"пІ©","page":171,"end":false},{"code":"пІӘ","page":171,"end":false},{"code":"пІ«","page":171,"end":false},{"code":"пІ¬","page":171,"end":false},{"code":"пІӯ","page":171,"end":false},{"code":"пІ®","page":171,"end":false},{"code":"пІҜ","page":171,"end":false},{"code":"пІ°пІұ","page":171,"end":false},{"code":"пІІ","page":171,"end":false},{"code":"пІі","page":171,"end":false},{"code":"пІҙ","page":171,"end":false},{"code":"пІө","page":171,"end":false},{"code":"пІ¶","page":171,"end":false},{"code":"пІ·","page":171,"end":true}],"text":"ЩҲЩҺШіЩ’ЩҖЩ”ЩҺЩ„Щ’ЩҮЩҸЩ…Щ’ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’ЩӮЩҺШұЩ’ЩҠЩҺШ©Щҗ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ЩғЩҺШ§ЩҶЩҺШӘЩ’ ШӯЩҺШ§Ш¶ЩҗШұЩҺШ©ЩҺ ЩұЩ„Щ’ШЁЩҺШӯЩ’ШұЩҗ ШҘЩҗШ°Щ’ ЩҠЩҺШ№Щ’ШҜЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺШЁЩ’ШӘЩҗ ШҘЩҗШ°Щ’ ШӘЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҗЩ…Щ’ ШӯЩҗЩҠШӘЩҺШ§ЩҶЩҸЩҮЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ШіЩҺШЁЩ’ШӘЩҗЩҮЩҗЩ…Щ’ ШҙЩҸШұЩ‘ЩҺШ№ЩӢЫӯШ§ ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШЁЩҗШӘЩҸЩҲЩҶЩҺ Ыҷ Щ„ЩҺШ§ ШӘЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҗЩ…Щ’ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҶЩҺШЁЩ’Щ„ЩҸЩҲЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩҒЩ’ШіЩҸЩӮЩҸЩҲЩҶЩҺ"}]}
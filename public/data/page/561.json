[{"code":"пұҒ","page":561,"end":false},{"code":"пұӮ","page":561,"end":false},{"code":"пұғ","page":561,"end":false},{"code":"пұ„","page":561,"end":false},{"code":"пұ…","page":561,"end":false},{"code":"пұҶ","page":561,"end":false},{"code":"пұҮ","page":561,"end":false},{"code":"пұҲ","page":561,"end":false},{"code":"пұү","page":561,"end":false},{"code":"пұҠ","page":561,"end":false},{"code":"пұӢ","page":561,"end":false},{"code":"пұҢ","page":561,"end":false},{"code":"пұҚ","page":561,"end":false},{"code":"пұҺ","page":561,"end":false},{"code":"пұҸ","page":561,"end":false},{"code":"пұҗ","page":561,"end":false},{"code":"пұ‘","page":561,"end":false},{"code":"пұ’","page":561,"end":false},{"code":"пұ“","page":561,"end":false},{"code":"пұ”","page":561,"end":false},{"code":"пұ•","page":561,"end":false},{"code":"пұ–","page":561,"end":false},{"code":"пұ—","page":561,"end":false},{"code":"пұҳ","page":561,"end":false},{"code":"пұҷ","page":561,"end":false},{"code":"пұҡ","page":561,"end":false},{"code":"пұӣ","page":561,"end":false},{"code":"пұңпұқ","page":561,"end":false},{"code":"пұһ","page":561,"end":false},{"code":"пұҹ","page":561,"end":false},{"code":"пұ ","page":561,"end":false},{"code":"пұЎ","page":561,"end":false},{"code":"пұў","page":561,"end":false},{"code":"пұЈ","page":561,"end":false},{"code":"пұӨ","page":561,"end":false},{"code":"пұҘ","page":561,"end":false},{"code":"пұҰ","page":561,"end":false},{"code":"пұ§","page":561,"end":false},{"code":"пұЁ","page":561,"end":false},{"code":"пұ©пұӘ","page":561,"end":false},{"code":"пұ«","page":561,"end":false},{"code":"пұ¬","page":561,"end":false},{"code":"пұӯ","page":561,"end":false},{"code":"пұ®","page":561,"end":false},{"code":"пұҜ","page":561,"end":false},{"code":"пұ°","page":561,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ШӘЩҸЩҲШЁЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҺЩҲЩ’ШЁЩҺШ©ЩӢЫӯ ЩҶЩ‘ЩҺШөЩҸЩҲШӯЩӢШ§ Ш№ЩҺШіЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҸЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ЩҠЩҸЩғЩҺЩҒЩ‘ЩҗШұЩҺ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҸШҜЩ’Ш®ЩҗЩ„ЩҺЩғЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ ЩҠЩҺЩҲЩ’Щ…ЩҺ Щ„ЩҺШ§ ЩҠЩҸШ®Щ’ШІЩҗЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘ЩҺ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ…ЩҺШ№ЩҺЩҮЩҸЫҘ Ы– ЩҶЩҸЩҲШұЩҸЩҮЩҸЩ…Щ’ ЩҠЩҺШіЩ’Ш№ЩҺЩүЩ° ШЁЩҺЩҠЩ’ЩҶЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺШЁЩҗШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҗЩҮЩҗЩ…Щ’ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§Щ“ ШЈЩҺШӘЩ’Щ…ЩҗЩ…Щ’ Щ„ЩҺЩҶЩҺШ§ ЩҶЩҸЩҲШұЩҺЩҶЩҺШ§ ЩҲЩҺЩұШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҺЩҶЩҺШ§Щ“ Ы– ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢЫӯ"},{"key":"66:9","surah":66,"ayah":9,"num":5238,"page":561,"words":[{"code":"пұұ","page":561,"end":false},{"code":"пұІ","page":561,"end":false},{"code":"пұі","page":561,"end":false},{"code":"пұҙ","page":561,"end":false},{"code":"пұө","page":561,"end":false},{"code":"пұ¶","page":561,"end":false},{"code":"пұ·пұё","page":561,"end":false},{"code":"пұ№","page":561,"end":false},{"code":"пұәпұ»","page":561,"end":false},{"code":"пұј","page":561,"end":false},{"code":"пұҪ","page":561,"end":false},{"code":"пұҫ","page":561,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘ЩҸ Ш¬ЩҺЩҖЩ°ЩҮЩҗШҜЩҗ ЩұЩ„Щ’ЩғЩҸЩҒЩ‘ЩҺШ§ШұЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҗЩҠЩҶЩҺ ЩҲЩҺЩұШәЩ’Щ„ЩҸШёЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ Ыҡ ЩҲЩҺЩ…ЩҺШЈЩ’ЩҲЩҺЩүЩ°ЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ Ы– ЩҲЩҺШЁЩҗШҰЩ’ШіЩҺ ЩұЩ„Щ’Щ…ЩҺШөЩҗЩҠШұЩҸ"},{"key":"66:10","surah":66,"ayah":10,"num":5239,"page":561,"words":[{"code":"пұҝ","page":561,"end":false},{"code":"пІҖ","page":561,"end":false},{"code":"пІҒ","page":561,"end":false},{"code":"пІӮ","page":561,"end":false},{"code":"пІғ","page":561,"end":false},{"code":"пІ„","page":561,"end":false},{"code":"пІ…","page":561,"end":false},{"code":"пІҶ","page":561,"end":false},{"code":"пІҮпІҲ","page":561,"end":false},{"code":"пІү","page":561,"end":false},{"code":"пІҠ","page":561,"end":false},{"code":"пІӢ","page":561,"end":false},{"code":"пІҢ","page":561,"end":false},{"code":"пІҚ","page":561,"end":false},{"code":"пІҺ","page":561,"end":false},{"code":"пІҸ","page":561,"end":false},{"code":"пІҗ","page":561,"end":false},{"code":"пІ‘","page":561,"end":false},{"code":"пІ’","page":561,"end":false},{"code":"пІ“","page":561,"end":false},{"code":"пІ”","page":561,"end":false},{"code":"пІ•","page":561,"end":false},{"code":"пІ–","page":561,"end":false},{"code":"пІ—","page":561,"end":false},{"code":"пІҳ","page":561,"end":false},{"code":"пІҷ","page":561,"end":false},{"code":"пІҡ","page":561,"end":false},{"code":"пІӣ","page":561,"end":true}],"text":"Ш¶ЩҺШұЩҺШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Щ„Щ‘ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩұЩ…Щ’ШұЩҺШЈЩҺШӘЩҺ ЩҶЩҸЩҲШӯЩҚЫў ЩҲЩҺЩұЩ…Щ’ШұЩҺШЈЩҺШӘЩҺ Щ„ЩҸЩҲШ·ЩҚЫў Ы– ЩғЩҺШ§ЩҶЩҺШӘЩҺШ§ ШӘЩҺШӯЩ’ШӘЩҺ Ш№ЩҺШЁЩ’ШҜЩҺЩҠЩ’ЩҶЩҗ Щ…ЩҗЩҶЩ’ Ш№ЩҗШЁЩҺШ§ШҜЩҗЩҶЩҺШ§ ШөЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҠЩ’ЩҶЩҗ ЩҒЩҺШ®ЩҺШ§ЩҶЩҺШӘЩҺШ§ЩҮЩҸЩ…ЩҺШ§ ЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҸШәЩ’ЩҶЩҗЩҠЩҺШ§ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ ЩҲЩҺЩӮЩҗЩҠЩ„ЩҺ ЩұШҜЩ’Ш®ЩҸЩ„ЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҺ Щ…ЩҺШ№ЩҺ ЩұЩ„ШҜЩ‘ЩҺЩ°Ш®ЩҗЩ„ЩҗЩҠЩҶЩҺ"},{"key":"66:11","surah":66,"ayah":11,"num":5240,"page":561,"words":[{"code":"пІң","page":561,"end":false},{"code":"пІқ","page":561,"end":false},{"code":"пІһ","page":561,"end":false},{"code":"пІҹ","page":561,"end":false},{"code":"пІ ","page":561,"end":false},{"code":"пІЎ","page":561,"end":false},{"code":"пІў","page":561,"end":false},{"code":"пІЈ","page":561,"end":false},{"code":"пІӨ","page":561,"end":false},{"code":"пІҘ","page":561,"end":false},{"code":"пІҰ","page":561,"end":false},{"code":"пІ§","page":561,"end":false},{"code":"пІЁ","page":561,"end":false},{"code":"пІ©","page":561,"end":false},{"code":"пІӘ","page":561,"end":false},{"code":"пІ«","page":561,"end":false},{"code":"пІ¬","page":561,"end":false},{"code":"пІӯ","page":561,"end":false},{"code":"пІ®","page":561,"end":false},{"code":"пІҜ","page":561,"end":false},{"code":"пІ°","page":561,"end":false},{"code":"пІұ","page":561,"end":false},{"code":"пІІ","page":561,"end":false},{"code":"пІі","page":561,"end":false},{"code":"пІҙ","page":561,"end":true}],"text":"ЩҲЩҺШ¶ЩҺШұЩҺШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Щ„Щ‘ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұЩ…Щ’ШұЩҺШЈЩҺШӘЩҺ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ШҘЩҗШ°Щ’ ЩӮЩҺШ§Щ„ЩҺШӘЩ’ ШұЩҺШЁЩ‘Щҗ ЩұШЁЩ’ЩҶЩҗ Щ„ЩҗЩү Ш№ЩҗЩҶШҜЩҺЩғЩҺ ШЁЩҺЩҠЩ’ШӘЩӢЫӯШ§ ЩҒЩҗЩү ЩұЩ„Щ’Ш¬ЩҺЩҶЩ‘ЩҺШ©Щҗ ЩҲЩҺЩҶЩҺШ¬Щ‘ЩҗЩҶЩҗЩү Щ…ЩҗЩҶ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ЩҲЩҺШ№ЩҺЩ…ЩҺЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺЩҶЩҺШ¬Щ‘ЩҗЩҶЩҗЩү Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"66:12","surah":66,"ayah":12,"num":5241,"page":561,"words":[{"code":"пІө","page":561,"end":false},{"code":"пІ¶","page":561,"end":false},{"code":"пІ·","page":561,"end":false},{"code":"пІё","page":561,"end":false},{"code":"пІ№","page":561,"end":false},{"code":"пІә","page":561,"end":false},{"code":"пІ»","page":561,"end":false},{"code":"пІј","page":561,"end":false},{"code":"пІҪ","page":561,"end":false},{"code":"пІҫ","page":561,"end":false},{"code":"пІҝ","page":561,"end":false},{"code":"піҖ","page":561,"end":false},{"code":"піҒ","page":561,"end":false},{"code":"піӮ","page":561,"end":false},{"code":"піғ","page":561,"end":false},{"code":"пі„","page":561,"end":false},{"code":"пі…","page":561,"end":false},{"code":"піҶ","page":561,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШұЩ’ЩҠЩҺЩ…ЩҺ ЩұШЁЩ’ЩҶЩҺШӘЩҺ Ш№ЩҗЩ…Щ’ШұЩҺЩ°ЩҶЩҺ ЩұЩ„Щ‘ЩҺШӘЩҗЩүЩ“ ШЈЩҺШӯЩ’ШөЩҺЩҶЩҺШӘЩ’ ЩҒЩҺШұЩ’Ш¬ЩҺЩҮЩҺШ§ ЩҒЩҺЩҶЩҺЩҒЩҺШ®Щ’ЩҶЩҺШ§ ЩҒЩҗЩҠЩҮЩҗ Щ…ЩҗЩҶ ШұЩ‘ЩҸЩҲШӯЩҗЩҶЩҺШ§ ЩҲЩҺШөЩҺШҜЩ‘ЩҺЩӮЩҺШӘЩ’ ШЁЩҗЩғЩҺЩ„ЩҗЩ…ЩҺЩҖЩ°ШӘЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҺШ§ ЩҲЩҺЩғЩҸШӘЩҸШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩғЩҺШ§ЩҶЩҺШӘЩ’ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҺЩҖЩ°ЩҶЩҗШӘЩҗЩҠЩҶЩҺ"}]}
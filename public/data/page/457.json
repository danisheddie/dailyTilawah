e":457,"end":true}],"text":"ШЈЩҺШӘЩ‘ЩҺШ®ЩҺШ°Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ШіЩҗШ®Щ’ШұЩҗЩҠЩ‘ЩӢШ§ ШЈЩҺЩ…Щ’ ШІЩҺШ§ШәЩҺШӘЩ’ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШЁЩ’ШөЩҺЩҖЩ°ШұЩҸ"},{"key":"38:64","surah":38,"ayah":64,"num":4034,"page":457,"words":[{"code":"пұ“","page":457,"end":false},{"code":"пұ”","page":457,"end":false},{"code":"пұ•","page":457,"end":false},{"code":"пұ–","page":457,"end":false},{"code":"пұ—","page":457,"end":false},{"code":"пұҳ","page":457,"end":false},{"code":"пұҷ","page":457,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺШӯЩҺЩӮЩ‘ЩҢЫӯ ШӘЩҺШ®ЩҺШ§ШөЩҸЩ…ЩҸ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ"},{"key":"38:65","surah":38,"ayah":65,"num":4035,"page":457,"words":[{"code":"пұҡ","page":457,"end":false},{"code":"пұӣ","page":457,"end":false},{"code":"пұң","page":457,"end":false},{"code":"пұқпұһ","page":457,"end":false},{"code":"пұҹ","page":457,"end":false},{"code":"пұ ","page":457,"end":false},{"code":"пұЎ","page":457,"end":false},{"code":"пұў","page":457,"end":false},{"code":"пұЈ","page":457,"end":false},{"code":"пұӨ","page":457,"end":false},{"code":"пұҘ","page":457,"end":false},{"code":"пұҰ","page":457,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶЩҺШ§Ы  Щ…ЩҸЩҶШ°ЩҗШұЩҢЫӯ Ы– ЩҲЩҺЩ…ЩҺШ§ Щ…ЩҗЩҶЩ’ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’ЩҲЩҺЩ°ШӯЩҗШҜЩҸ ЩұЩ„Щ’ЩӮЩҺЩҮЩ‘ЩҺШ§ШұЩҸ"},{"key":"38:66","surah":38,"ayah":66,"num":4036,"page":457,"words":[{"code":"пұ§","page":457,"end":false},{"code":"пұЁ","page":457,"end":false},{"code":"пұ©","page":457,"end":false},{"code":"пұӘ","page":457,"end":false},{"code":"пұ«","page":457,"end":false},{"code":"пұ¬","page":457,"end":false},{"code":"пұӯ","page":457,"end":false},{"code":"пұ®","page":457,"end":true}],"text":"ШұЩҺШЁЩ‘ЩҸ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШәЩҺЩҒЩ‘ЩҺЩҖЩ°ШұЩҸ"},{"key":"38:67","surah":38,"ayah":67,"num":4037,"page":457,"words":[{"code":"пұҜ","page":457,"end":false},{"code":"пұ°","page":457,"end":false},{"code":"пұұ","page":457,"end":false},
ge":425,"end":false},{"code":"піҒ","page":425,"end":false},{"code":"піӮ","page":425,"end":false},{"code":"піғ","page":425,"end":false},{"code":"пі„","page":425,"end":false},{"code":"пі…","page":425,"end":false},{"code":"піҶ","page":425,"end":false},{"code":"піҮ","page":425,"end":false},{"code":"піҲпіү","page":425,"end":false},{"code":"піҠ","page":425,"end":false},{"code":"піӢ","page":425,"end":false},{"code":"піҢ","page":425,"end":false},{"code":"піҚ","page":425,"end":false},{"code":"піҺ","page":425,"end":false},{"code":"піҸ","page":425,"end":false},{"code":"піҗ","page":425,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ШЁЩҸЩҠЩҸЩҲШӘЩҺ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҸШӨЩ’Ш°ЩҺЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩүЩ° Ш·ЩҺШ№ЩҺШ§Щ…ЩҚ ШәЩҺЩҠЩ’ШұЩҺ ЩҶЩҺЩҖЩ°ШёЩҗШұЩҗЩҠЩҶЩҺ ШҘЩҗЩҶЩҺЩүЩ°ЩҮЩҸ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ’ ШҘЩҗШ°ЩҺШ§ ШҜЩҸШ№ЩҗЩҠШӘЩҸЩ…Щ’ ЩҒЩҺЩұШҜЩ’Ш®ЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш·ЩҺШ№ЩҗЩ…Щ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩұЩҶШӘЩҺШҙЩҗШұЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺШ§ Щ…ЩҸШіЩ’ШӘЩҺЩҖЩ”Щ’ЩҶЩҗШіЩҗЩҠЩҶЩҺ Щ„ЩҗШӯЩҺШҜЩҗЩҠШ«ЩҚ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҺ ЩҠЩҸШӨЩ’Ш°ЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘ЩҺ ЩҒЩҺЩҠЩҺШіЩ’ШӘЩҺШӯЩ’ЩүЩҗЫҰ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ы– ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШӯЩ’ЩүЩҗЫҰ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Ыҡ ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩӢЫӯШ§ ЩҒЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҗЩҶ ЩҲЩҺШұЩҺШ§Щ“ШЎЩҗ ШӯЩҗШ¬ЩҺШ§ШЁЩҚЫў Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ШЈЩҺШ·Щ’ЩҮЩҺШұЩҸ Щ„ЩҗЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩҶЩ‘ЩҺ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ШӘЩҸШӨЩ’Ш°ЩҸЩҲШ§Ыҹ ШұЩҺШіЩҸЩҲЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺЩҶ ШӘЩҺЩҶЩғЩҗШӯЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗЩҮЩҗЫҰЩ“ ШЈЩҺШЁЩҺШҜЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺШёЩҗЩҠЩ…ЩӢШ§"},{"key":"33:54","surah":33,"ayah":54,"num":3587,"page":425,"words":[{"code":"пі‘","page":425,"end":false},{"code":"пі’","page":425,"end":false},{"code":"пі“","page":425,"end":false},{"code":"пі”",
:64,"end":false},{"code":"пұ„","page":64,"end":false},{"code":"пұ…","page":64,"end":false},{"code":"пұҶ","page":64,"end":false},{"code":"пұҮпұҲ","page":64,"end":false},{"code":"пұү","page":64,"end":false},{"code":"пұҠ","page":64,"end":false},{"code":"пұӢ","page":64,"end":false},{"code":"пұҢ","page":64,"end":false},{"code":"пұҚ","page":64,"end":true}],"text":"ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ЩҲЩҺШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҸ"},{"key":"3:110","surah":3,"ayah":110,"num":403,"page":64,"words":[{"code":"пұҺ","page":64,"end":false},{"code":"пұҸ","page":64,"end":false},{"code":"пұҗ","page":64,"end":false},{"code":"пұ‘","page":64,"end":false},{"code":"пұ’","page":64,"end":false},{"code":"пұ“","page":64,"end":false},{"code":"пұ”","page":64,"end":false},{"code":"пұ•","page":64,"end":false},{"code":"пұ–","page":64,"end":false},{"code":"пұ—","page":64,"end":false},{"code":"пұҳ","page":64,"end":false},{"code":"пұҷпұҡ","page":64,"end":false},{"code":"пұӣ","page":64,"end":false},{"code":"пұң","page":64,"end":false},{"code":"пұқ","page":64,"end":false},{"code":"пұһ","page":64,"end":false},{"code":"пұҹ","page":64,"end":false},{"code":"пұ ","page":64,"end":false},{"code":"пұЎпұў","page":64,"end":false},{"code":"пұЈ","page":64,"end":false},{"code":"пұӨ","page":64,"end":false},{"code":"пұҘ","page":64,"end":false},{"code":"пұҰ","page":64,"end":false},{"code":"пұ§","page":64,"end":true}],"text":"ЩғЩҸЩҶШӘЩҸЩ…Щ’ Ш®ЩҺЩҠЩ’ШұЩҺ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҚ ШЈЩҸШ®Щ’ШұЩҗШ¬ЩҺШӘЩ’ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШӘЩҺШЈЩ’Щ…ЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺШӘЩҺЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ ЩҲЩҺШӘЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы— ЩҲЩҺЩ„ЩҺЩҲЩ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҺ ШЈЩҺЩҮЩ’Щ„ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ„ЩҺЩғЩҺШ§ЩҶЩҺ Ш®ЩҺЩҠЩ’ШұЩӢЫӯШ§ Щ„Щ‘ЩҺЩҮЩҸЩ… Ыҡ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ЩҲЩҺШЈЩҺЩғЩ’Ш«ЩҺШұЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"3:111","surah":3,"ayah":111,"num":404,"page":64,"words":[{"code":"пұЁ","page":64,"end":false},{"code":"пұ©","page":64,"end":false},{"code":"пұӘ","page":64,"end":false},{"code":"пұ«пұ¬","page":64,"end":false},{"code":"пұӯ","page":64,"end":false},{"code":"пұ®","page":64,"end":false},{"code":"пұҜ","page":64,"end":false},{"code":"пұ°","page":64,"end":false},{"code":"пұұ","page":64,"end":false},{"code":"пұІ","page":64,"end":false},{"code":"пұі","page":64,"end":false},{"code":"пұҙ","page":64,"end":true}],"text":"Щ„ЩҺЩҶ ЩҠЩҺШ¶ЩҸШұЩ‘ЩҸЩҲЩғЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺШ°ЩӢЫӯЩү Ы– ЩҲЩҺШҘЩҗЩҶ ЩҠЩҸЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲЩғЩҸЩ…Щ’ ЩҠЩҸЩҲЩҺЩ„Щ‘ЩҸЩҲЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШҜЩ’ШЁЩҺШ§ШұЩҺ Ш«ЩҸЩ…Щ‘ЩҺ Щ„ЩҺШ§ ЩҠЩҸЩҶШөЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"3:112","surah":3,"ayah":112,"num":405,"page":64,"words":[{"code":"пұө","page":64,"end":false},{"code":"пұ¶","page":64,"end":false},{"code":"пұ·","page":64,"end":false},{"code":"пұё","page":64,"end":false},{"code":"пұ№","page":64,"end":false},{"code":"пұә","page":64,"end":false},{"code":"пұ»","page":64,"end":false},{"code":"пұј","page":64,"end":false},{"code":"пұҪ","page":64,"end":false},{"code":"пұҫ","page":64,"end":false},{"code":"пұҝ","page":64,"end":false},{"code":"пІҖ","page":64,"end":false},{"code":"пІҒ","page":64,"end":false},{"code":"пІӮ","page":64,"end":false},{"code":"пІғ","page":64,"end":false},{"code":"пІ„","page":64,"end":false},{"code":"пІ…","page":64,"end":false},{"code":"пІҶ","page":64,"end":false},{"code":"пІҮ","page":64,"end":false},{"code":"пІҲпІү","page":64,"end":false},{"code":"пІҠ","page":64,"end":false},{"code":"пІӢ","page":64,"end":false},{"code":"пІҢ","page":64,"end":false},{"code":"пІҚ","page":64,"end":false},{"code":"пІҺ","page":64,"end":false},{"code":"пІҸ","page":64,"end":false},{"code":"пІҗ","page":64,"end":false},{"code":"пІ‘","page":64,"end":false},{"code":"пІ’","page":64,"end":false},{"code":"пІ“пІ”","page":64,"end":false},{"code":"пІ•","page":64,"end":false},{"code":"пІ–","page":64,"end":false},{"code":"пІ—","page":64,"end":false},{"code":"пІҳ","page":64,"end":false},{"code":"пІҷ","page":64,"end":false},{"code":"пІҡ","page":64,"end":true}],"text":"Ш¶ЩҸШұЩҗШЁЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Ш°Щ‘ЩҗЩ„Щ‘ЩҺШ©ЩҸ ШЈЩҺЩҠЩ’ЩҶЩҺ Щ…ЩҺШ§ Ш«ЩҸЩӮЩҗЩҒЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҗШӯЩҺШЁЩ’Щ„ЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШӯЩҺШЁЩ’Щ„ЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺШЁЩҺШ§Щ“ШЎЩҸЩҲ ШЁЩҗШәЩҺШ¶ЩҺШЁЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШ¶ЩҸШұЩҗШЁЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҺШіЩ’ЩғЩҺЩҶЩҺШ©ЩҸ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩҠЩҺЩӮЩ’ШӘЩҸЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ШЈЩҺЩҶЫўШЁЩҗЩҠЩҺШ§Щ“ШЎЩҺ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ШӯЩҺЩӮЩ‘ЩҚЫў Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺШөЩҺЩҲШ§Ыҹ ЩҲЩ‘ЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"3:113","surah":3,"ayah":113,"num":406,"page":64,"words":[{"code":"пІӣ пІң","page":64,"end":false},{"code":"пІқпІһ","page":64,"end":false},{"code":"пІҹ","page":64,"end":false},{"code":"пІ ","page":64,"end":false},{"code":"пІЎ","page":64,"end":false},{"code":"пІў","page":64,"end":false},{"code":"пІЈ","page":64,"end":false},{"code":"пІӨ","page":64,"end":false},{"code":"пІҘ","page":64,"end":false},{"code":"пІҰ","page":64,"end":false},{"code":"пІ§","page":64,"end":false},{"code":"пІЁ","page":64,"end":false},{"code":"пІ©","page":64,"end":false},{"code":"пІӘ","page":64,"end":false},{"code":"пІ«","page":64,"end":true}],"text":"Ыһ Щ„ЩҺЩҠЩ’ШіЩҸЩҲШ§Ыҹ ШіЩҺЩҲЩҺШ§Щ“ШЎЩӢЫӯ Ы— Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҢЫӯ ЩӮЩҺШ§Щ“ШҰЩҗЩ…ЩҺШ©ЩҢЫӯ ЩҠЩҺШӘЩ’Щ„ЩҸЩҲЩҶЩҺ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЎЩҺШ§ЩҶЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҲЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШіЩ’Ш¬ЩҸШҜЩҸЩҲЩҶЩҺ"},{"key":"3:114","surah":3,"ayah":114,"num":407,"page":64,"words":[{"code":"пІ¬","page":64,"end":false},{"code":"пІӯ","page":64,"end":false},{"code":"пІ®","page":64,"end":false},{"code":"пІҜ","page":64,"end":false},{"code":"пІ°","page":64,"end":false},{"code":"пІұ","page":64,"end":false},{"code":"пІІ","page":64,"end":false},{"code":"пІі","page":64,"end":false},{"code":"пІҙ","page":64,"end":false},{"code":"пІө","page":64,"end":false},{"code":"пІ¶","page":64,"end":false},{"code":"пІ·пІё","page":64,"end":false},{"code":"пІ№","page":64,"end":false},{"code":"пІә","page":64,"end":false},{"code":"пІ»","page":64,"end":false},{"code":"пІј","page":64,"end":true}],"text":"ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ ЩҲЩҺЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺЩҠЩҺЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ ЩҲЩҺЩҠЩҸШіЩҺЩҖЩ°ШұЩҗШ№ЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’Ш®ЩҺЩҠЩ’ШұЩҺЩ°ШӘЩҗ ЩҲЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҗЩҠЩҶЩҺ"},{"key":"3:115","surah":3,"ayah":115,"num":408,"page":64,"words":[{"code":"пІҪ","page":64,"end":false},{"code":"пІҫ","page":64,"end":false},{"code":"пІҝ","page":64,"end":false},{"code":"піҖ","page":64,"end":false},{"code":"піҒ","page":64,"end":false},{"code":"піӮпіғ","page":64,"end":false},{"code":"пі„","page":64,"end":false},{"code":"пі…","page":64,"end":false},{"code":"піҶ","page":64,"end":false},{"code":"піҮ","page":64,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў ЩҒЩҺЩ„ЩҺЩҶ ЩҠЩҸЩғЩ’ЩҒЩҺШұЩҸЩҲЩҮЩҸ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗЩұЩ„Щ’Щ…ЩҸШӘЩ‘ЩҺЩӮЩҗЩҠЩҶЩҺ"}]}
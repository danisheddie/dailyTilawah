,{"key":"36:59","surah":36,"ayah":59,"num":3764,"page":444,"words":[{"code":"пұһ","page":444,"end":false},{"code":"пұҹ","page":444,"end":false},{"code":"пұ ","page":444,"end":false},{"code":"пұЎ","page":444,"end":false},{"code":"пұў","page":444,"end":true}],"text":"ЩҲЩҺЩұЩ…Щ’ШӘЩҺЩҖЩ°ШІЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ’Щ…ЩҸШ¬Щ’ШұЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"36:60","surah":36,"ayah":60,"num":3765,"page":444,"words":[{"code":"пұЈ пұӨ","page":444,"end":false},{"code":"пұҘ","page":444,"end":false},{"code":"пұҰ","page":444,"end":false},{"code":"пұ§","page":444,"end":false},{"code":"пұЁ","page":444,"end":false},{"code":"пұ©","page":444,"end":false},{"code":"пұӘ","page":444,"end":false},{"code":"пұ«","page":444,"end":false},{"code":"пұ¬пұӯ","page":444,"end":false},{"code":"пұ®","page":444,"end":false},{"code":"пұҜ","page":444,"end":false},{"code":"пұ°","page":444,"end":false},{"code":"пұұ","page":444,"end":false},{"code":"пұІ","page":444,"end":true}],"text":"Ыһ ШЈЩҺЩ„ЩҺЩ…Щ’ ШЈЩҺШ№Щ’ЩҮЩҺШҜЩ’ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҠЩҺЩҖЩ°ШЁЩҺЩҶЩҗЩүЩ“ ШЎЩҺШ§ШҜЩҺЩ…ЩҺ ШЈЩҺЩҶ Щ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲШ§Ыҹ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҺ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺШҜЩҸЩҲЩ‘ЩҢЫӯ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҢЫӯ"},{"key":"36:61","surah":36,"ayah":61,"num":3766,"page":444,"words":[{"code":"пұі","page":444,"end":false},{"code":"пұҙпұө","page":444,"end":false},{"code":"пұ¶","page":444,"end":false},{"code":"пұ·","page":444,"end":false},{"code":"пұё","page":444,"end":false},{"code":"пұ№","page":444,"end":true}],"text":"ЩҲЩҺШЈЩҺЩҶЩҗ ЩұШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҗЩү Ыҡ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ШөЩҗШұЩҺЩ°Ш·ЩҢЫӯ Щ…Щ‘ЩҸШіЩ’ШӘЩҺЩӮЩҗЩҠЩ…ЩҢЫӯ"},{"key":"36:62","surah":36,"ayah":62,"num":3767,"page":444,"words":[{"code":"пұә","page":444,"end":false},{"code":"пұ»","page":444,"end":false},{"code":"пұј","page":444,"end":false},{"code":"пұҪ","page":444,"end":false},{"code":"пұҫпұҝ","page":444,"end":false},{"code":"пІҖ","page":444,"end":false},{"code":"пІҒ","page":444,"end":false},{"code":"пІӮ","page":444,"end":false},{"code":"пІғ","page":444,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ш¬ЩҗШЁЩҗЩ„Щ‘ЩӢЫӯШ§ ЩғЩҺШ«ЩҗЩҠШұЩӢШ§ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ШӘЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"36:63","surah":36,"ayah":63,"num":3768,"page":444,"words":[{"code":"пІ„","page":444,"end":false},{"code":"пІ…","page":444,"end":false},{"code":"пІҶ","page":444,"end":false},{"code":"пІҮ","page":444,"end":false},{"code":"пІҲ","page":444,"end":false},{"code":"пІү","page":444,"end":true}],"text":"ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗЫҰ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҸЩҲШ№ЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"36:64","surah":36,"ayah":64,"num":3769,"page":444,"words":[{"code":"пІҠ","page":444,"end":false},{"code":"пІӢ","page":444,"end":false},{"code":"пІҢ","page":444,"end":false},{"code":"пІҚ","page":444,"end":false},{"code":"пІҺ","page":444,"end":false},{"code":"пІҸ","page":444,"end":true}],"text":"ЩұШөЩ’Щ„ЩҺЩҲЩ’ЩҮЩҺШ§ ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ШЁЩҗЩ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"36:65","surah":36,"ayah":65,"num":3770,"page":444,"words":[{"code":"пІҗ","page":444,"end":false},{"code":"пІ‘","page":444,"end":false},{"code":"пІ’","page":444,"end":false},{"code":"пІ“","page":444,"end":false},{"code":"пІ”","page":444,"end":false},{"code":"пІ•","page":444,"end":false},{"code":"пІ–","page":444,"end":false},{"code":"пІ—","page":444,"end":false},{"code":"пІҳ","page":444,"end":false},{"code":"пІҷ","page":444,"end":false},{"code":"пІҡ","page":444,"end":false},{"code":"пІӣ","page":444,"end":true}],"text":"ЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҶЩҺШ®Щ’ШӘЩҗЩ…ЩҸ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҒЩ’ЩҲЩҺЩ°ЩҮЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШӘЩҸЩғЩҺЩ„Щ‘ЩҗЩ…ЩҸЩҶЩҺШ§Щ“ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺШӘЩҺШҙЩ’ЩҮЩҺШҜЩҸ ШЈЩҺШұЩ’Ш¬ЩҸЩ„ЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"36:66","surah":36,"ayah":66,"num":3771,"page":444,"words":[{"code":"пІң","page":444,"end":false},{"code":"пІқ","page":444,"end":false},{"code":"пІһ","page":444,"end":false},{"code":"пІҹ","page":444,"end":false},{"code":"пІ ","page":444,"end":false},{"code":"пІЎ","page":444,"end":false},{"code":"пІў","page":444,"end":false},{"code":"пІЈ","page":444,"end":false},{"code":"пІӨ","page":444,"end":false},{"code":"пІҘ","page":444,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩҶЩҺШҙЩҺШ§Щ“ШЎЩҸ Щ„ЩҺШ·ЩҺЩ…ЩҺШіЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҗЩҮЩҗЩ…Щ’ ЩҒЩҺЩұШіЩ’ШӘЩҺШЁЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҗШұЩҺЩ°Ш·ЩҺ ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺЩүЩ° ЩҠЩҸШЁЩ’ШөЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"36:67","surah":36,"ayah":67,"num":3772,"page":444,"words":[{"code":"пІҰ","page":444,"end":false},{"code":"пІ§","page":444,"end":false},{"code":"пІЁ","page":444,"end":false},{"code":"пІ©","page":444,"end":false},{"code":"пІӘ","page":444,"end":false},{"code":"пІ«","page":444,"end":false},{"code":"пІ¬","page":444,"end":false},{"code":"пІӯ","page":444,"end":false},{"code":"пІ®","page":444,"end":false},{"code":"пІҜ","page":444,"end":false},{"code":"пІ°","page":444,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩҶЩҺШҙЩҺШ§Щ“ШЎЩҸ Щ„ЩҺЩ…ЩҺШіЩҺШ®Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺЩғЩҺШ§ЩҶЩҺШӘЩҗЩҮЩҗЩ…Щ’ ЩҒЩҺЩ…ЩҺШ§ ЩұШіЩ’ШӘЩҺШ·ЩҺЩҖЩ°Ш№ЩҸЩҲШ§Ыҹ Щ…ЩҸШ¶ЩҗЩҠЩ‘ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҲЩҶЩҺ"},{"key":"36:68","surah":36,"ayah":68,"num":3773,"page":444,"words":[{"code":"пІұ","page":444,"end":false},{"code":"пІІ","page":444,"end":false},{"code":"пІі","page":444,"end":false},{"code":"пІҙ","page":444,"end":false},{"code":"пІөпІ¶","page":444,"end":false},{"code":"пІ·","page":444,"end":false},{"code":"пІё","page":444,"end":false},{"code":"пІ№","page":444,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩҶЩ‘ЩҸШ№ЩҺЩ…Щ‘ЩҗШұЩ’ЩҮЩҸ ЩҶЩҸЩҶЩҺЩғЩ‘ЩҗШіЩ’ЩҮЩҸ ЩҒЩҗЩү ЩұЩ„Щ’Ш®ЩҺЩ„Щ’ЩӮЩҗ Ы– ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ЩҠЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"36:69","surah":36,"ayah":69,"num":3774,"page":444,"words":[{"code":"пІә","page":444,"end":false},{"code":"пІ»","page":444,"end":false},{"code":"пІј","page":444,"end":false},{"code":"пІҪ","page":444,"end":false},{"code":"пІҫ","page":444,"end":false},{"code":"пІҝпіҖ","page":444,"end":false},{"code":"піҒ","page":444,"end":false},{"code":"піӮ","page":444,"end":false},{"code":"піғ","page":444,"end":false},{"code":"пі„","page":444,"end":false},{"code":"пі…","page":444,"end":false},{"code":"піҶ","page":444,"end":false},{"code":"піҮ","page":444,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ Ш№ЩҺЩ„Щ‘ЩҺЩ…Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸ ЩұЩ„ШҙЩ‘ЩҗШ№Щ’ШұЩҺ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺЩҶЫўШЁЩҺШәЩҗЩү Щ„ЩҺЩҮЩҸЫҘЩ“ Ыҡ ШҘЩҗЩҶЩ’ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш°ЩҗЩғЩ’ШұЩҢЫӯ ЩҲЩҺЩӮЩҸШұЩ’ШЎЩҺШ§ЩҶЩҢЫӯ Щ…Щ‘ЩҸШЁЩҗЩҠЩҶЩҢЫӯ"},{"key":"36:70","surah":36,"ayah":70,"num":3775,"page":444,"words":[{"code":"піҲ","page":444,"end":false},{"code":"піү","page":444,"end":false},{"code":"піҠ","page":444,"end":false},{"code":"піӢ","page":444,"end":false},{"code":"піҢ","page":444,"end":false},{"code":"піҚ","page":444,"end":false},{"code":"піҺ","page":444,"end":false},{"code":"піҸ","page":444,"end":false},{"code":"піҗ","page":444,"end":true}],"text":"Щ„Щ‘ЩҗЩҠЩҸЩҶШ°ЩҗШұЩҺ Щ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ ШӯЩҺЩҠЩ‘ЩӢЫӯШ§ ЩҲЩҺЩҠЩҺШӯЩҗЩӮЩ‘ЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ„ЩҸ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"}]}
},{"code":"піҠ","end":false},{"code":"піӢ","end":true}]}],"verses":[{"key":"40:41","surah":40,"ayah":41,"num":4174,"page":472,"words":[{"code":"пұҒ пұӮ","page":472,"end":false},{"code":"пұғ","page":472,"end":false},{"code":"пұ„","page":472,"end":false},{"code":"пұ…","page":472,"end":false},{"code":"пұҶ","page":472,"end":false},{"code":"пұҮ","page":472,"end":false},{"code":"пұҲ","page":472,"end":false},{"code":"пұү","page":472,"end":false},{"code":"пұҠ","page":472,"end":false},{"code":"пұӢ","page":472,"end":true}],"text":"Ыһ ЩҲЩҺЩҠЩҺЩҖЩ°ЩӮЩҺЩҲЩ’Щ…Щҗ Щ…ЩҺШ§ Щ„ЩҗЩүЩ“ ШЈЩҺШҜЩ’Ш№ЩҸЩҲЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ¬ЩҺЩҲЩ°Ш©Щҗ ЩҲЩҺШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺЩҶЩҗЩүЩ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ"},{"key":"40:42","surah":40,"ayah":42,"num":4175,"page":472,"words":[{"code":"пұҢ","page":472,"end":false},{"code":"пұҚ","page":472,"end":false},{"code":"пұҺ","page":472,"end":false},{"code":"пұҸ","page":472,"end":false},{"code":"пұҗ","page":472,"end":false},{"code":"пұ‘","page":472,"end":false},{"code":"пұ’","page":472,"end":false},{"code":"пұ“","page":472,"end":false},{"code":"пұ”","page":472,"end":false},{"code":"пұ•","page":472,"end":false},{"code":"пұ–","page":472,"end":false},{"code":"пұ—","page":472,"end":false},{"code":"пұҳ","page":472,"end":false},{"code":"пұҷ","page":472,"end":false},{"code":"пұҡ","page":472,"end":false},{"code":"пұӣ","page":472,"end":true}],"text":"ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺЩҶЩҗЩү Щ„ЩҗШЈЩҺЩғЩ’ЩҒЩҸШұЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЈЩҸШҙЩ’ШұЩҗЩғЩҺ ШЁЩҗЩҮЩҗЫҰ Щ…ЩҺШ§ Щ„ЩҺЩҠЩ’ШіЩҺ Щ„ЩҗЩү ШЁЩҗЩҮЩҗЫҰ Ш№ЩҗЩ„Щ’Щ…ЩҢЫӯ ЩҲЩҺШЈЩҺЩҶЩҺШ§Ы  ШЈЩҺШҜЩ’Ш№ЩҸЩҲЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҗ ЩұЩ„Щ’ШәЩҺЩҒЩ‘ЩҺЩҖЩ°ШұЩҗ"},{"key":"40:43","surah":40,"ayah":43,"num":4176,"page":472,"words":[{"code":"пұң","page":472,"end":false},{"code":"пұқ","page":472,"end":false},{"code":"пұһ","page":472,"end":false},{"code":"пұҹ","page":472,"end":false},{"code":"пұ ","page":472,"end":false},{"code":"пұЎ","page":472,"end":false},{"code":"пұў","page":472,"end":false},{"code":"пұЈ","page":472,"end":false},{"code":"пұӨ","page":472,"end":false},{"code":"пұҘ","page":472,"end":false},{"code":"пұҰ","page":472,"end":false},{"code":"пұ§","page":472,"end":false},{"code":"пұЁ","page":472,"end":false},{"code":"пұ©","page":472,"end":false},{"code":"пұӘ","page":472,"end":false},{"code":"пұ«","page":472,"end":false},{"code":"пұ¬","page":472,"end":false},{"code":"пұӯ","page":472,"end":false},{"code":"пұ®","page":472,"end":false},{"code":"пұҜ","page":472,"end":false},{"code":"пұ°","page":472,"end":false},{"code":"пұұ","page":472,"end":false},{"code":"пұІ","page":472,"end":true}],"text":"Щ„ЩҺШ§ Ш¬ЩҺШұЩҺЩ…ЩҺ ШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺЩҶЩҗЩүЩ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ Щ„ЩҺЩҠЩ’ШіЩҺ Щ„ЩҺЩҮЩҸЫҘ ШҜЩҺШ№Щ’ЩҲЩҺШ©ЩҢЫӯ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ Щ…ЩҺШұЩҺШҜЩ‘ЩҺЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ’Щ…ЩҸШіЩ’ШұЩҗЩҒЩҗЩҠЩҶЩҺ ЩҮЩҸЩ…Щ’ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ"},{"key":"40:44","surah":40,"ayah":44,"num":4177,"page":472,"words":[{"code":"пұі","page":472,"end":false},{"code":"пұҙ","page":472,"end":false},{"code":"пұө","page":472,"end":false},{"code":"пұ¶пұ·","page":472,"end":false},{"code":"пұё","page":472,"end":false},{"code":"пұ№","page":472,"end":false},{"code":"пұә","page":472,"end":false},{"code":"пұ»пұј","page":472,"end":false},{"code":"пұҪ","page":472,"end":false},{"code":"пұҫ","page":472,"end":false},{"code":"пұҝ","page":472,"end":false},{"code":"пІҖ","page":472,"end":false},{"code":"пІҒ","page":472,"end":true}],"text":"ЩҒЩҺШіЩҺШӘЩҺШ°Щ’ЩғЩҸШұЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Щ“ ШЈЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШЈЩҸЩҒЩҺЩҲЩ‘ЩҗШ¶ЩҸ ШЈЩҺЩ…Щ’ШұЩҗЩүЩ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫў ШЁЩҗЩұЩ„Щ’Ш№ЩҗШЁЩҺШ§ШҜЩҗ"},{"key":"40:45","surah":40,"ayah":45,"num":4178,"page":472,"words":[{"code":"пІӮ","page":472,"end":false},{"code":"пІғ","page":472,"end":false},{"code":"пІ„","page":472,"end":false},{"code":"пІ…","page":472,"end":false},{"code":"пІҶпІҮ","page":472,"end":false},{"code":"пІҲ","page":472,"end":false},{"code":"пІү","page":472,"end":false},{"code":"пІҠ","page":472,"end":false},{"code":"пІӢ","page":472,"end":false},{"code":"пІҢ","page":472,"end":false},{"code":"пІҚ","page":472,"end":true}],"text":"ЩҒЩҺЩҲЩҺЩӮЩҺЩүЩ°ЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗ Щ…ЩҺШ§ Щ…ЩҺЩғЩҺШұЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺШӯЩҺШ§ЩӮЩҺ ШЁЩҗЩҖЩ”ЩҺШ§Щ„Щҗ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ШіЩҸЩҲЩ“ШЎЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ"},{"key":"40:46","surah":40,"ayah":46,"num":4179,"page":472,"words":[{"code":"пІҺ","page":472,"end":false},{"code":"пІҸ","page":472,"end":false},{"code":"пІҗ","page":472,"end":false},{"code":"пІ‘","page":472,"end":false},{"code":"пІ’пІ“","page":472,"end":false},{"code":"пІ”","page":472,"end":false},{"code":"пІ•","page":472,"end":false},{"code":"пІ–","page":472,"end":false},{"code":"пІ—","page":472,"end":false},{"code":"пІҳ","page":472,"end":false},{"code":"пІҷ","page":472,"end":false},{"code":"пІҡ","page":472,"end":false},{"code":"пІӣ","page":472,"end":false},{"code":"пІң","page":472,"end":true}],"text":"ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҸ ЩҠЩҸШ№Щ’ШұЩҺШ¶ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ ШәЩҸШҜЩҸЩҲЩ‘ЩӢЫӯШ§ ЩҲЩҺШ№ЩҺШҙЩҗЩҠЩ‘ЩӢЫӯШ§ Ы– ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҺЩӮЩҸЩҲЩ…ЩҸ ЩұЩ„ШіЩ‘ЩҺШ§Ш№ЩҺШ©ЩҸ ШЈЩҺШҜЩ’Ш®ЩҗЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§Щ„ЩҺ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҺ ШЈЩҺШҙЩҺШҜЩ‘ЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ"},{"key":"40:47","surah":40,"ayah":47,"num":4180,"page":472,"words":[{"code":"пІқ","page":472,"end":false},{"code":"пІһ","page":472,"end":false},{"code":"пІҹ","page":472,"end":false},{"code":"пІ ","page":472,"end":false},{"code":"пІЎ","page":472,"end":false},{"code":"пІў","page":472,"end":false},{"code":"пІЈ","page":472,"end":false},{"code":"пІӨ","page":472,"end":false},{"code":"пІҘ","page":472,"end":false},{"code":"пІҰ","page":472,"end":false},{"code":"пІ§","page":472,"end":false},{"code":"пІЁ","page":472,"end":false},{"code":"пІ©","page":472,"end":false},{"code":"пІӘ","page":472,"end":false},{"code":"пІ«","page":472,"end":false},{"code":"пІ¬","page":472,"end":false},{"code":"пІӯ","page":472,"end":false},{"code":"пІ®","page":472,"end":false},{"code":"пІҜ","page":472,"end":false},{"code":"пІ°","page":472,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ЩҠЩҺШӘЩҺШӯЩҺШ§Щ“Ш¬Щ‘ЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҒЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ ЩұЩ„Ш¶Щ‘ЩҸШ№ЩҺЩҒЩҺЩҖЩ°Щ“ШӨЩҸШ§Ыҹ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШіЩ’ШӘЩҺЩғЩ’ШЁЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩғЩҸЩҶЩ‘ЩҺШ§ Щ„ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШЁЩҺШ№ЩӢЫӯШ§ ЩҒЩҺЩҮЩҺЩ„Щ’ ШЈЩҺЩҶШӘЩҸЩ… Щ…Щ‘ЩҸШәЩ’ЩҶЩҸЩҲЩҶЩҺ Ш№ЩҺЩҶЩ‘ЩҺШ§ ЩҶЩҺШөЩҗЩҠШЁЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ"},{"key":"40:48","surah":40,"ayah":48,"num":4181,"page":472,"words":[{"code":"пІұ","page":472,"end":false},{"code":"пІІ","page":472,"end":false},{"code":"пІі","page":472,"end":false},{"code":"пІҙ","page":472,"end":false},{"code":"пІө","page":472,"end":false},{"code":"пІ¶","page":472,"end":false},{"code":"пІ·","page":472,"end":false},{"code":"пІё","page":472,"end":false},{"code":"пІ№","page":472,"end":false},{"code":"пІә","page":472,"end":false},{"code":"пІ»","page":472,"end":false},{"code":"пІј","page":472,"end":false},{"code":"пІҪ","page":472,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩұШіЩ’ШӘЩҺЩғЩ’ШЁЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺШ§ ЩғЩҸЩ„Щ‘ЩҢЫӯ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺШҜЩ’ ШӯЩҺЩғЩҺЩ…ЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„Щ’Ш№ЩҗШЁЩҺШ§ШҜЩҗ"},{"key":"40:49","surah":40,"ayah":49,"num":4182,"page":472,"words":[{"code":"пІҫ","page":472,"end":false},{"code":"пІҝ","page":472,"end":false},{"code":"піҖ","page":472,"end":false},{"code":"піҒ","page":472,"end":false},{"code":"піӮ","page":472,"end":false},{"code":"піғ","page":472,"end":false},{"code":"пі„","page":472,"end":false},{"code":"пі…","page":472,"end":false},{"code":"піҶ","page":472,"end":false},{"code":"піҮ","page":472,"end":false},{"code":"піҲ","page":472,"end":false},{"code":"піү","page":472,"end":false},{"code":"піҠ","page":472,"end":false},{"code":"піӢ","page":472,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Щ„ЩҗШ®ЩҺШІЩҺЩҶЩҺШ©Щҗ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ ЩұШҜЩ’Ш№ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҺЩғЩҸЩ…Щ’ ЩҠЩҸШ®ЩҺЩҒЩ‘ЩҗЩҒЩ’ Ш№ЩҺЩҶЩ‘ЩҺШ§ ЩҠЩҺЩҲЩ’Щ…ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ"}]}
se},{"code":"пұҝ","page":29,"end":false},{"code":"пІҖ","page":29,"end":false},{"code":"пІҒпІӮ","page":29,"end":false},{"code":"пІғ","page":29,"end":false},{"code":"пІ„","page":29,"end":false},{"code":"пІ…","page":29,"end":false},{"code":"пІҶ","page":29,"end":false},{"code":"пІҮ","page":29,"end":false},{"code":"пІҲ","page":29,"end":false},{"code":"пІү","page":29,"end":false},{"code":"пІҠ","page":29,"end":true}],"text":"ШЈЩҸШӯЩҗЩ„Щ‘ЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ Щ„ЩҺЩҠЩ’Щ„ЩҺШ©ЩҺ ЩұЩ„ШөЩ‘ЩҗЩҠЩҺШ§Щ…Щҗ ЩұЩ„ШұЩ‘ЩҺЩҒЩҺШ«ЩҸ ШҘЩҗЩ„ЩҺЩүЩ° ЩҶЩҗШіЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ Ыҡ ЩҮЩҸЩҶЩ‘ЩҺ Щ„ЩҗШЁЩҺШ§ШіЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ Щ„ЩҗШЁЩҺШ§ШіЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЩҶЩ‘ЩҺ Ы— Ш№ЩҺЩ„ЩҗЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ®Щ’ШӘЩҺШ§ЩҶЩҸЩҲЩҶЩҺ ШЈЩҺЩҶЩҒЩҸШіЩҺЩғЩҸЩ…Щ’ ЩҒЩҺШӘЩҺШ§ШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺШ№ЩҺЩҒЩҺШ§ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ Ы– ЩҒЩҺЩұЩ„Щ’ЩҖЩ”ЩҺЩҖЩ°ЩҶЩҺ ШЁЩҺЩҖЩ°ШҙЩҗШұЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺЩұШЁЩ’ШӘЩҺШәЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩғЩҺШӘЩҺШЁЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩғЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҲЩҺЩұШҙЩ’ШұЩҺШЁЩҸЩҲШ§Ыҹ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШӘЩҺШЁЩҺЩҠЩ‘ЩҺЩҶЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Ш®ЩҺЩҠЩ’Ш·ЩҸ ЩұЩ„Щ’ШЈЩҺШЁЩ’ЩҠЩҺШ¶ЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш®ЩҺЩҠЩ’Ш·Щҗ ЩұЩ„Щ’ШЈЩҺШіЩ’ЩҲЩҺШҜЩҗ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩҒЩҺШ¬Щ’ШұЩҗ Ы– Ш«ЩҸЩ…Щ‘ЩҺ ШЈЩҺШӘЩҗЩ…Щ‘ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҗЩҠЩҺШ§Щ…ЩҺ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШЁЩҺЩҖЩ°ШҙЩҗШұЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ Ш№ЩҺЩҖЩ°ЩғЩҗЩҒЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’Щ…ЩҺШіЩҺЩҖЩ°Ш¬ЩҗШҜЩҗ Ы— ШӘЩҗЩ„Щ’ЩғЩҺ ШӯЩҸШҜЩҸЩҲШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺЩӮЩ’ШұЩҺШЁЩҸЩҲЩҮЩҺШ§ Ы— ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҮЩҗЫҰ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"2:188","surah":2,"ayah":188,"num":195,"page":29,"words":[{"code":"пІӢ","page":29,"end":false},{"code":"пІҢ","page":29,"end":false},{"code":"пІҚ","page":29,"end":false},{"code":"пІҺ","page":29,"end":false},{"code":"пІҸ","page":29,"end":false},{"code":"пІҗ","page":29,"end":false},{"code":"пІ‘","page":29,"end":false},{"code":"пІ’","page":29,"end":false},{"code":"пІ“","page":29,"end":false},{"code":"пІ”","page":29,"end":false},{"code":"пІ•","page":29,"end":false},{"code":"пІ–","page":29,"end":false},{"code":"пІ—","page":29,"end":false},{"code":"пІҳ","page":29,"end":false},{"code":"пІҷ","page":29,"end":false},{"code":"пІҡ","page":29,"end":false},{"code":"пІӣ","page":29,"end":false},{"code":"пІң","page":29,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҺЩғЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ… ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҖЩ°Ш·ЩҗЩ„Щҗ ЩҲЩҺШӘЩҸШҜЩ’Щ„ЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’ШӯЩҸЩғЩ‘ЩҺШ§Щ…Щҗ Щ„ЩҗШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҺШұЩҗЩҠЩӮЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„Щҗ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШЁЩҗЩұЩ„Щ’ШҘЩҗШ«Щ’Щ…Щҗ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:189","surah":2,"ayah":189,"num":196,"page":29,"words":[{"code":"пІқ пІһ","page":29,"end":false},{"code":"пІҹ","page":29,"end":false},{"code":"пІ пІЎ","page":29,"end":false},{"code":"пІў","page":29,"end":false},{"code":"пІЈ","page":29,"end":false},{"code":"пІӨ","page":29,"end":false},{"code":"пІҘ","page":29,"end":false},{"code":"пІҰпІ§","page":29,"end":false},{"code":"пІЁ","page":29,"end":false},{"code":"пІ©","page":29,"end":false},{"code":"пІӘ","page":29,"end":false},{"code":"пІ«","page":29,"end":false},{"code":"пІ¬","page":29,"end":false},{"code":"пІӯ","page":29,"end":false},{"code":"пІ®","page":29,"end":false},{"code":"пІҜ","page":29,"end":false},{"code":"пІ°","page":29,"end":false},{"code":"пІұ","page":29,"end":false},{"code":"пІІпІі","page":29,"end":false},{"code":"пІҙ","page":29,"end":false},{"code":"пІө","page":29,"end":false},{"code":"пІ¶","page":29,"end":false},{"code":"пІ·пІё","page":29,"end":false},{"code":"пІ№","page":29,"end":false},{"code":"пІә","page":29,"end":false},{"code":"пІ»","page":29,"end":false},{"code":"пІј","page":29,"end":false},{"code":"пІҪ","page":29,"end":true}],"text":"Ыһ ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺЩғЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’ШЈЩҺЩҮЩҗЩ„Щ‘ЩҺШ©Щҗ Ы– ЩӮЩҸЩ„Щ’ ЩҮЩҗЩүЩҺ Щ…ЩҺЩҲЩҺЩ°ЩӮЩҗЩҠШӘЩҸ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺЩұЩ„Щ’ШӯЩҺШ¬Щ‘Щҗ Ы— ЩҲЩҺЩ„ЩҺЩҠЩ’ШіЩҺ ЩұЩ„Щ’ШЁЩҗШұЩ‘ЩҸ ШЁЩҗШЈЩҺЩҶ ШӘЩҺШЈЩ’ШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЁЩҸЩҠЩҸЩҲШӘЩҺ Щ…ЩҗЩҶ ШёЩҸЩҮЩҸЩҲШұЩҗЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ’ШЁЩҗШұЩ‘ЩҺ Щ…ЩҺЩҶЩҗ ЩұШӘЩ‘ЩҺЩӮЩҺЩүЩ° Ы— ЩҲЩҺШЈЩ’ШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЁЩҸЩҠЩҸЩҲШӘЩҺ Щ…ЩҗЩҶЩ’ ШЈЩҺШЁЩ’ЩҲЩҺЩ°ШЁЩҗЩҮЩҺШ§ Ыҡ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"2:190","surah":2,"ayah":190,"num":197,"page":29,"words":[{"code":"пІҫ","page":29,"end":false},{"code":"пІҝ","page":29,"end":false},{"code":"піҖ","page":29,"end":false},{"code":"піҒ","page":29,"end":false},{"code":"піӮ","page":29,"end":false},{"code":"піғ","page":29,"end":false},{"code":"пі„","page":29,"end":false},{"code":"пі…піҶ","page":29,"end":false},{"code":"піҮ","page":29,"end":false},{"code":"піҲ","page":29,"end":false},{"code":"піү","page":29,"end":false},{"code":"піҠ","page":29,"end":false},{"code":"піӢ","page":29,"end":false},{"code":"піҢ","page":29,"end":true}],"text":"ЩҲЩҺЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲЩҶЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ№Щ’ШӘЩҺШҜЩҸЩҲЩ“Ш§Ыҹ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҸШӯЩҗШЁЩ‘ЩҸ ЩұЩ„Щ’Щ…ЩҸШ№Щ’ШӘЩҺШҜЩҗЩҠЩҶЩҺ"}]}
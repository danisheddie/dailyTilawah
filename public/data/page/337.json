"key":"22:39","surah":22,"ayah":39,"num":2634,"page":337,"words":[{"code":"пұҒ","page":337,"end":false},{"code":"пұӮ","page":337,"end":false},{"code":"пұғ","page":337,"end":false},{"code":"пұ„","page":337,"end":false},{"code":"пұ…пұҶ","page":337,"end":false},{"code":"пұҮ","page":337,"end":false},{"code":"пұҲ","page":337,"end":false},{"code":"пұү","page":337,"end":false},{"code":"пұҠ","page":337,"end":false},{"code":"пұӢ","page":337,"end":false},{"code":"пұҢ","page":337,"end":true}],"text":"ШЈЩҸШ°ЩҗЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩӮЩҺЩҖЩ°ШӘЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ШёЩҸЩ„ЩҗЩ…ЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҺЩүЩ° ЩҶЩҺШөЩ’ШұЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺЩӮЩҺШҜЩҗЩҠШұЩҢ"},{"key":"22:40","surah":22,"ayah":40,"num":2635,"page":337,"words":[{"code":"пұҚ","page":337,"end":false},{"code":"пұҺ","page":337,"end":false},{"code":"пұҸ","page":337,"end":false},{"code":"пұҗ","page":337,"end":false},{"code":"пұ‘","page":337,"end":false},{"code":"пұ’","page":337,"end":false},{"code":"пұ“","page":337,"end":false},{"code":"пұ”","page":337,"end":false},{"code":"пұ•","page":337,"end":false},{"code":"пұ–","page":337,"end":false},{"code":"пұ—пұҳ","page":337,"end":false},{"code":"пұҷ","page":337,"end":false},{"code":"пұҡ","page":337,"end":false},{"code":"пұӣ","page":337,"end":false},{"code":"пұң","page":337,"end":false},{"code":"пұқ","page":337,"end":false},{"code":"пұһ","page":337,"end":false},{"code":"пұҹ","page":337,"end":false},{"code":"пұ ","page":337,"end":false},{"code":"пұЎ","page":337,"end":false},{"code":"пұў","page":337,"end":false},{"code":"пұЈ","page":337,"end":false},{"code":"пұӨ","page":337,"end":false},{"code":"пұҘ","page":337,"end":false},{"code":"пұҰ","page":337,"end":false},{"code":"пұ§","page":337,"end":false},{"code":"пұЁпұ©","page":337,"end":false},{"code":"пұӘ","page":337,"end":false},{"code":"пұ«","page":337,"end":false},{"code":"пұ¬","page":337,"end":false},{"code":"пұӯпұ®","page":337,"end":false},{"code":"пұҜ","page":337,"end":false},{"code":"пұ°","page":337,"end":false},{"code":"пұұ","page":337,"end":false},{"code":"пұІ","page":337,"end":false},{"code":"пұі","page":337,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸШ®Щ’ШұЩҗШ¬ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ШҜЩҗЩҠЩҺЩҖЩ°ШұЩҗЩҮЩҗЩ… ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ШӯЩҺЩӮЩ‘ЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҸЩҶЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы— ЩҲЩҺЩ„ЩҺЩҲЩ’Щ„ЩҺШ§ ШҜЩҺЩҒЩ’Ш№ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ШЁЩҺШ№Щ’Ш¶ЩҺЩҮЩҸЩ… ШЁЩҗШЁЩҺШ№Щ’Ш¶ЩҚЫў Щ„Щ‘ЩҺЩҮЩҸШҜЩ‘ЩҗЩ…ЩҺШӘЩ’ ШөЩҺЩҲЩҺЩ°Щ…ЩҗШ№ЩҸ ЩҲЩҺШЁЩҗЩҠЩҺШ№ЩҢЫӯ ЩҲЩҺШөЩҺЩ„ЩҺЩҲЩҺЩ°ШӘЩҢЫӯ ЩҲЩҺЩ…ЩҺШіЩҺЩҖЩ°Ш¬ЩҗШҜЩҸ ЩҠЩҸШ°Щ’ЩғЩҺШұЩҸ ЩҒЩҗЩҠЩҮЩҺШ§ ЩұШіЩ’Щ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Ы— ЩҲЩҺЩ„ЩҺЩҠЩҺЩҶШөЩҸШұЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺЩҶ ЩҠЩҺЩҶШөЩҸШұЩҸЩҮЩҸЫҘЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺЩӮЩҺЩҲЩҗЩүЩ‘ЩҢ Ш№ЩҺШІЩҗЩҠШІЩҢ"},{"key":"22:41","surah":22,"ayah":41,"num":2636,"page":337,"words":[{"code":"пұҙ","page":337,"end":false},{"code":"пұө","page":337,"end":false},{"code":"пұ¶","page":337,"end":false},{"code":"пұ·","page":337,"end":false},{"code":"пұё","page":337,"end":false},{"code":"пұ№","page":337,"end":false},{"code":"пұә","page":337,"end":false},{"code":"пұ»","page":337,"end":false},{"code":"пұј","page":337,"end":false},{"code":"пұҪ","page":337,"end":false},{"code":"пұҫ","page":337,"end":false},{"code":"пұҝ","page":337,"end":false},{"code":"пІҖ","page":337,"end":false},{"code":"пІҒпІӮ","page":337,"end":false},{"code":"пІғ","page":337,"end":false},{"code":"пІ„","page":337,"end":false},{"code":"пІ…","page":337,"end":false},{"code":"пІҶ","page":337,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШҘЩҗЩҶ Щ…Щ‘ЩҺЩғЩ‘ЩҺЩҶЩ‘ЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҺЩӮЩҺШ§Щ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҲЩҸШ§Ыҹ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЈЩҺЩ…ЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺЩҶЩҺЩҮЩҺЩҲЩ’Ш§Ыҹ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ Ы— ЩҲЩҺЩ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩҖЩ°ЩӮЩҗШЁЩҺШ©ЩҸ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҗ"},{"key":"22:42","surah":22,"ayah":42,"num":2637,"page":337,"words":[{"code":"пІҮ","page":337,"end":false},{"code":"пІҲ","page":337,"end":false},{"cod
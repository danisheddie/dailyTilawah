":false},{"code":"пұӨ","page":407,"end":false},{"code":"пұҘпұҰ","page":407,"end":false},{"code":"пұ§","page":407,"end":false},{"code":"пұЁ","page":407,"end":false},{"code":"пұ©","page":407,"end":false},{"code":"пұӘ","page":407,"end":false},{"code":"пұ«","page":407,"end":false},{"code":"пұ¬пұӯ","page":407,"end":false},{"code":"пұ®","page":407,"end":false},{"code":"пұҜ","page":407,"end":false},{"code":"пұ°","page":407,"end":false},{"code":"пұұ","page":407,"end":true}],"text":"ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҺШЁЩ’ШҜЩҺШӨЩҸШ§Ыҹ ЩұЩ„Щ’Ш®ЩҺЩ„Щ’ЩӮЩҺ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸШ№ЩҗЩҠШҜЩҸЩҮЩҸЫҘ ЩҲЩҺЩҮЩҸЩҲЩҺ ШЈЩҺЩҮЩ’ЩҲЩҺЩҶЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ Ыҡ ЩҲЩҺЩ„ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҺШ«ЩҺЩ„ЩҸ ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ„ЩҺЩүЩ° ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’ШӯЩҺЩғЩҗЩҠЩ…ЩҸ"},{"key":"30:28","surah":30,"ayah":28,"num":3437,"page":407,"words":[{"code":"пұІ","page":407,"end":false},{"code":"пұі","page":407,"end":false},{"code":"пұҙ","page":407,"end":false},{"code":"пұө","page":407,"end":false},{"code":"пұ¶пұ·","page":407,"end":false},{"code":"пұё","page":407,"end":false},{"code":"пұ№","page":407,"end":false},{"code":"пұә","page":407,"end":false},{"code":"пұ»","page":407,"end":false},{"code":"пұј","page":407,"end":false},{"code":"пұҪ","page":407,"end":false},{"code":"пұҫ","page":407,"end":false},{"code":"пұҝ","page":407,"end":false},{"code":"пІҖ","page":407,"end":false},{"code":"пІҒ","page":407,"end":false},{"code":"пІӮ","page":407,"end":false},{"code":"пІғ","page":407,"end":false},{"code":"пІ„","page":407,"end":false},{"code":"пІ…","page":407,"end":false},{"code":"пІҶ","page":407,"end":false},{"code":"пІҮ","page":407,"end":false},{"code":"пІҲпІү","page":407,"end":false},{"code":"пІҠ","page":407,"end":false},{"code":"пІӢ","page":407,"end":false},{"code":"пІҢ","page":407,"end":false},{"code":"пІҚ","page":407,"end":false},{"code":"пІҺ","page":407,"end":false},{"code":"пІҸ","page":407,"end":true}],"text":"Ш¶ЩҺШұЩҺШЁЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ ШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ Ы– ЩҮЩҺЩ„ Щ„Щ‘ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ Щ…Щ‘ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҙЩҸШұЩҺЩғЩҺШ§Щ“ШЎЩҺ ЩҒЩҗЩү Щ…ЩҺШ§ ШұЩҺШІЩҺЩӮЩ’ЩҶЩҺЩҖЩ°ЩғЩҸЩ…Щ’ ЩҒЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҗ ШіЩҺЩҲЩҺШ§Щ“ШЎЩҢЫӯ ШӘЩҺШ®ЩҺШ§ЩҒЩҸЩҲЩҶЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ®ЩҗЩҠЩҒЩҺШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҶЩҒЩҸШіЩҺЩғЩҸЩ…Щ’ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҶЩҸЩҒЩҺШөЩ‘ЩҗЩ„ЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ Щ„ЩҗЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"30:29","surah":30,"ayah":29,"num":3438,"page":407,"words":[{"code":"пІҗ","page":407,"end":false},{"code":"пІ‘","page":407,"end":false},{"code":"пІ’","page":407,"end":false},{"code":"пІ“","page":407,"end":false},{"code":"пІ”","page":407,"end":false},{"code":"пІ•","page":407,"end":false},{"code":"пІ–пІ—","page":407,"end":false},{"code":"пІҳ","page":407,"end":false},{"code":"пІҷ","page":407,"end":false},{"code":"пІҡ","page":407,"end":false},{"code":"пІӣ","page":407,"end":false},{"code":"пІңпІқ","page":407,"end":false},{"code":"пІһ","page":407,"end":false},{"code":"пІҹ","page":407,"end":false},{"code":"пІ ","page":407,"end":false},{"code":"пІЎ","page":407,"end":false},{"code":"пІў","page":407,"end":true}],"text":"ШЁЩҺЩ„Щҗ ЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҮЩ’ЩҲЩҺШ§Щ“ШЎЩҺЩҮЩҸЩ… ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ Ш№ЩҗЩ„Щ’Щ…ЩҚЫў Ы– ЩҒЩҺЩ…ЩҺЩҶ ЩҠЩҺЩҮЩ’ШҜЩҗЩү Щ…ЩҺЩҶЩ’ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ЩҲЩҺЩ…ЩҺШ§ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺЩҖЩ°ШөЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"30:30","surah":30,"ayah":30,"num":3439,"page":407,"words":[{"code":"пІЈ","page":407,"end":false},{"code":"пІӨ","page":407,"end":false},{"code":"пІҘ","page":407,"end":false},{"code":"пІҰпІ§","page":407,"end":false},{"code":"пІЁ","page":407,"end":false},{"code":"пІ©","page":407,"end":false},{"code":"пІӘ","page":407,"end":false},{"code":"пІ«","page":407,"end":false},{"code":"пІ¬","page":407,"end":false},{"code":"пІӯпІ®","page":407,"end":false},{"code":"пІҜ","page":407,"end":false},{"code":"пІ°","page":407,"end":false},{"code":"пІұ","page":407,"end":false},{"code":"пІІпІі","page":407,"
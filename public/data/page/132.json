:true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩҶЩҸШІЩ‘ЩҗЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЎЩҺШ§ЩҠЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ Ыҡ ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺШ§ШҜЩҗШұЩҢ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҶ ЩҠЩҸЩҶЩҺШІЩ‘ЩҗЩ„ЩҺ ШЎЩҺШ§ЩҠЩҺШ©ЩӢЫӯ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"6:38","surah":6,"ayah":38,"num":827,"page":132,"words":[{"code":"пұЈ","page":132,"end":false},{"code":"пұӨ","page":132,"end":false},{"code":"пұҘ","page":132,"end":false},{"code":"пұҰ","page":132,"end":false},{"code":"пұ§","page":132,"end":false},{"code":"пұЁ","page":132,"end":false},{"code":"пұ©","page":132,"end":false},{"code":"пұӘ","page":132,"end":false},{"code":"пұ«","page":132,"end":false},{"code":"пұ¬","page":132,"end":false},{"code":"пұӯ","page":132,"end":false},{"code":"пұ®пұҜ","page":132,"end":false},{"code":"пұ°","page":132,"end":false},{"code":"пұұ","page":132,"end":false},{"code":"пұІ","page":132,"end":false},{"code":"пұі","page":132,"end":false},{"code":"пұҙ","page":132,"end":false},{"code":"пұөпұ¶","page":132,"end":false},{"code":"пұ·","page":132,"end":false},{"code":"пұё","page":132,"end":false},{"code":"пұ№","page":132,"end":false},{"code":"пұә","page":132,"end":false},{"code":"пұ»","page":132,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§ Щ…ЩҗЩҶ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩҚЫў ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩ„ЩҺШ§ Ш·ЩҺЩҖЩ°Щ“ШҰЩҗШұЩҚЫў ЩҠЩҺШ·ЩҗЩҠШұЩҸ ШЁЩҗШ¬ЩҺЩҶЩҺШ§ШӯЩҺЩҠЩ’ЩҮЩҗ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҸЩ…ЩҺЩ…ЩҢ ШЈЩҺЩ…Щ’Ш«ЩҺШ§Щ„ЩҸЩғЩҸЩ… Ыҡ Щ…Щ‘ЩҺШ§ ЩҒЩҺШұЩ‘ЩҺШ·Щ’ЩҶЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ Щ…ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚЫў Ыҡ Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩ„ЩҺЩүЩ° ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ЩҠЩҸШӯЩ’ШҙЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"6:39","surah":6,"ayah":39,"num":828,"page":132,"words":[{"code":"пұј","page":132,"end":false},{"code":"пұҪ","page":132,"end":false},{"code":"пұҫ","page":132,"end":false},{"code":"пұҝ","page":132,"end":false},{"code":"пІҖ","page":132,"end":false},{"code":"пІҒ","page":132,"end":false},{"code":"пІӮпІғ","page":132,"end":false},{"code":"пІ„","page":132,"end":false},{"code":"
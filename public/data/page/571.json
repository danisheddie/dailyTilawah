alse},{"code":"піү","end":false},{"code":"піҠ","end":false},{"code":"піӢ","end":false},{"code":"піҢ","end":false},{"code":"піҚ","end":false}]},{"lineNumber":14,"words":[{"code":"піҺ","end":false},{"code":"піҸ","end":true},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":false},{"code":"пі—","end":false}]},{"lineNumber":15,"words":[{"code":"піҳ","end":false},{"code":"піҷпіҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":true}]}],"verses":[{"key":"71:11","surah":71,"ayah":11,"num":5430,"page":571,"words":[{"code":"пұҒ","page":571,"end":false},{"code":"пұӮ","page":571,"end":false},{"code":"пұғ","page":571,"end":false},{"code":"пұ„","page":571,"end":false},{"code":"пұ…","page":571,"end":true}],"text":"ЩҠЩҸШұЩ’ШіЩҗЩ„Щҗ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗШҜЩ’ШұЩҺШ§ШұЩӢЫӯШ§"},{"key":"71:12","surah":71,"ayah":12,"num":5431,"page":571,"words":[{"code":"пұҶ","page":571,"end":false},{"code":"пұҮ","page":571,"end":false},{"code":"пұҲ","page":571,"end":false},{"code":"пұү","page":571,"end":false},{"code":"пұҠ","page":571,"end":false},{"code":"пұӢ","page":571,"end":false},{"code":"пұҢ","page":571,"end":false},{"code":"пұҚ","page":571,"end":false},{"code":"пұҺ","page":571,"end":false},{"code":"пұҸ","page":571,"end":true}],"text":"ЩҲЩҺЩҠЩҸЩ…Щ’ШҜЩҗШҜЩ’ЩғЩҸЩ… ШЁЩҗШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҚЫў ЩҲЩҺШЁЩҺЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ЩҲЩҺЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩӢЫӯШ§"},{"key":"71:13","surah":71,"ayah":13,"num":5432,"page":571,"words":[{"code":"пұҗ","page":571,"end":false},{"code":"пұ‘","page":571,"end":false},{"code":"пұ’","page":571,"end":false},{"code":"пұ“","page":571,"end":false},{"code":"пұ”","page":571,"end":false},{"code":"пұ•","page":571,"end":false},{"code":"пұ–","
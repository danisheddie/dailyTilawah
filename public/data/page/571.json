ҙ","page":571,"end":false},{"code":"пұө","page":571,"end":false},{"code":"пұ¶","page":571,"end":false},{"code":"пұ·","page":571,"end":true}],"text":"Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸШ№ЩҗЩҠШҜЩҸЩғЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҲЩҺЩҠЩҸШ®Щ’ШұЩҗШ¬ЩҸЩғЩҸЩ…Щ’ ШҘЩҗШ®Щ’ШұЩҺШ§Ш¬ЩӢЫӯШ§"},{"key":"71:19","surah":71,"ayah":19,"num":5438,"page":571,"words":[{"code":"пұё","page":571,"end":false},{"code":"пұ№","page":571,"end":false},{"code":"пұә","page":571,"end":false},{"code":"пұ»","page":571,"end":false},{"code":"пұј","page":571,"end":false},{"code":"пұҪ","page":571,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш¬ЩҺШ№ЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ШЁЩҗШіЩҺШ§Ш·ЩӢЫӯШ§"},{"key":"71:20","surah":71,"ayah":20,"num":5439,"page":571,"words":[{"code":"пұҫ","page":571,"end":false},{"code":"пұҝ","page":571,"end":false},{"code":"пІҖ","page":571,"end":false},{"code":"пІҒ","page":571,"end":false},{"code":"пІӮ","page":571,"end":true}],"text":"Щ„Щ‘ЩҗШӘЩҺШіЩ’Щ„ЩҸЩғЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШіЩҸШЁЩҸЩ„ЩӢЫӯШ§ ЩҒЩҗШ¬ЩҺШ§Ш¬ЩӢЫӯШ§"},{"key":"71:21","surah":71,"ayah":21,"num":5440,"page":571,"words":[{"code":"пІғ","page":571,"end":false},{"code":"пІ„","page":571,"end":false},{"code":"пІ…","page":571,"end":false},{"code":"пІҶ","page":571,"end":false},{"code":"пІҮ","page":571,"end":false},{"code":"пІҲ","page":571,"end":false},{"code":"пІү","page":571,"end":false},{"code":"пІҠ","page":571,"end":false},{"code":"пІӢ","page":571,"end":false},{"code":"пІҢ","page":571,"end":false},{"code":"пІҚ","page":571,"end":false},{"code":"пІҺ","page":571,"end":false},{"code":"пІҸ","page":571,"end":false},{"code":"пІҗ","page":571,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩҶЩҸЩҲШӯЩҢЫӯ ШұЩ‘ЩҺШЁЩ‘Щҗ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШөЩҺЩҲЩ’ЩҶЩҗЩү ЩҲЩҺЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҸЩҲШ§Ыҹ Щ…ЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШІЩҗШҜЩ’ЩҮЩҸ Щ…ЩҺШ§Щ„ЩҸЩҮЩҸЫҘ ЩҲЩҺЩҲЩҺЩ„ЩҺШҜЩҸЩҮЩҸЫҘЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш®ЩҺШіЩҺШ§ШұЩӢЫӯШ§"},{"key":"71:22","surah":71,"ayah":22,"num":5441,"page":571,"words":[{"code":"пІ‘","page":571,"end":false},{"code":"пІ’","page":571,"end":false},{"code":"пІ“","page":571,"end":false},{"code":"пІ”","page":571,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩғЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҺЩғЩ’ШұЩӢЫӯШ§ ЩғЩҸШЁЩ‘ЩҺШ§ШұЩӢЫӯШ§"},{"key":"71:23","surah":71,"ayah":23,"num":5442,"page":571,"words":[{"code":"пІ•","page":571,"end":false},{"code":"пІ–","page":571,"end":false},{"code":"пІ—","page":571,"end":false},{"code":"пІҳ","page":571,"end":false},{"code":"пІҷ","page":571,"end":false},{"code":"пІҡ","page":571,"end":false},{"code":"пІӣ","page":571,"end":false},{"code":"пІң","page":571,"end":false},{"code":"пІқ","page":571,"end":false},{"code":"пІһ","page":571,"end":false},{"code":"пІҹ","page":571,"end":false},{"code":"пІ ","page":571,"end":false},{"code":"пІЎ","page":571,"end":false},{"code":"пІў","page":571,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШ°ЩҺШұЩҸЩҶЩ‘ЩҺ ШЎЩҺШ§Щ„ЩҗЩҮЩҺШӘЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ°ЩҺШұЩҸЩҶЩ‘ЩҺ ЩҲЩҺШҜЩ‘ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ ШіЩҸЩҲЩҺШ§Ш№ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШәЩҸЩҲШ«ЩҺ ЩҲЩҺЩҠЩҺШ№ЩҸЩҲЩӮЩҺ ЩҲЩҺЩҶЩҺШіЩ’ШұЩӢЫӯШ§"},{"key":"71:24","surah":71,"ayah":24,"num":5443,"page":571,"words":[{"code":"пІЈ","page":571,"end":false},{"code":"пІӨ","page":571,"end":false},{"code":"пІҘпІҰ","page":571,"end":false},{"code":"пІ§","page":571,"end":false},{"code":"пІЁ","page":571,"end":false},{"code":"пІ©","page":571,"end":false},{"code":"пІӘ","page":571,"end":false},{"code":"пІ«","page":571,"end":false},{"code":"пІ¬","page":571,"end":true}],"text":"ЩҲЩҺЩӮЩҺШҜЩ’ ШЈЩҺШ¶ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШІЩҗШҜЩҗ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩӢЫӯШ§"},{"key":"71:25","surah":71,"ayah":25,"num":5444,"page":571,"words":[{"code":"пІӯ","page":571,"end":false},{"code":"пІ®","page":571,"end":false},{"code":"пІҜ","page":571,"end":false},{"code":"пІ°","page":571,"end":false},{"code":"пІұ","page":571,"end":false},{"code":"пІІ","page":571,"end":false},{"code":"пІі","page":571,"end":false},{"code":"пІҙ","page":571,"end":false},{"code":"пІө","page":571,"end":false},{"code":"пІ¶","page":571,"end":false},{"code":"пІ·","page":571,"end":false},{"code":"пІё","page":571,"end":false},{"code":"пІ№","page":571,"end":true}],"text":"Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ Ш®ЩҺШ·ЩҗЩҠЩ“ЩҖЩ”ЩҺЩҖЩ°ШӘЩҗЩҮЩҗЩ…Щ’ ШЈЩҸШәЩ’ШұЩҗЩӮЩҸЩҲШ§Ыҹ ЩҒЩҺШЈЩҸШҜЩ’Ш®ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҶЩҺШ§ШұЩӢЫӯШ§ ЩҒЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШ¬ЩҗШҜЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺЩҶШөЩҺШ§ШұЩӢЫӯШ§"},{"key":"71:26","surah":71,"ayah":26,"num":5445,"page":571,"words":[{"code":"пІә","page":571,"end":false},{"code":"пІ»","page":571,"end":false},{"code":"пІј","page":571,"end":false},{"code":"пІҪ","page":571,"end":false},{"code":"пІҫ","page":571,"end":false},{"code":"пІҝ","page":571,"end":false},{"code":"піҖ","page":571,"end":false},{"code":"піҒ","page":571,"end":false},{"code":"піӮ","page":571,"end":false},{"code":"піғ","page":571,"end":false},{"code":"пі„","page":571,"end":true}],"text":"ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩҶЩҸЩҲШӯЩҢЫӯ ШұЩ‘ЩҺШЁЩ‘Щҗ Щ„ЩҺШ§ ШӘЩҺШ°ЩҺШұЩ’ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ ШҜЩҺЩҠЩ‘ЩҺШ§ШұЩӢШ§"},{"key":"71:27","surah":71,"ayah":27,"num":5446,"page":571,"words":[{"code":"пі…","page":571,"end":false},{"code":"піҶ","page":571,"end":false},{"code":"піҮ","page":571,"end":false},{"code":"піҲ","page":571,"end":false},{"code":"піү","page":571,"end":false},{"code":"піҠ","page":571,"end":false},{"code":"піӢ","page":571,"end":false},{"code":"піҢ","page":571,"end":false},{"code":"піҚ","page":571,"end":false},{"code":"піҺ","page":571,"end":false},{"code":"піҸ","page":571,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ ШҘЩҗЩҶ ШӘЩҺШ°ЩҺШұЩ’ЩҮЩҸЩ…Щ’ ЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҸЩҲШ§Ыҹ Ш№ЩҗШЁЩҺШ§ШҜЩҺЩғЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩ„ЩҗШҜЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҒЩҺШ§Ш¬ЩҗШұЩӢЫӯШ§ ЩғЩҺЩҒЩ‘ЩҺШ§ШұЩӢЫӯШ§"},{"key":"71:28","surah":71,"ayah":28,"num":5447,"page":571,"words":[{"code":"піҗ","page":571,"end":false},{"code":"пі‘","page":571,"end":false},{"code":"пі’","page":571,"end":false},{"code":"пі“","page":571,"end":false},{"code":"пі”","page":571,"end":false},{"code":"пі•","page":571,"end":false},{"code":"пі–","page":571,"end":false},{"code":"пі—","page":571,"end":false},{"code":"піҳ","page":571,"end":false},{"code":"піҷпіҡ","page":571,"end":false},{"code":"піӣ","page":571,"end":false},{"code":"пің","page":571,"end":false},{"code":"піқ","page":571,"end":false},{"code":"піһ","page":571,"end":false},{"code":"піҹ","page":571,"end":false},{"code":"пі ","page":571,"end":true}],"text":"ШұЩ‘ЩҺШЁЩ‘Щҗ ЩұШәЩ’ЩҒЩҗШұЩ’ Щ„ЩҗЩү ЩҲЩҺЩ„ЩҗЩҲЩҺЩ°Щ„ЩҗШҜЩҺЩүЩ‘ЩҺ ЩҲЩҺЩ„ЩҗЩ…ЩҺЩҶ ШҜЩҺШ®ЩҺЩ„ЩҺ ШЁЩҺЩҠЩ’ШӘЩҗЩүЩҺ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩӢЫӯШ§ ЩҲЩҺЩ„ЩҗЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШІЩҗШҜЩҗ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺШЁЩҺШ§ШұЩӢЫўШ§"}]}
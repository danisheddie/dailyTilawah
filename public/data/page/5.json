rah":2,"ayah":25,"num":32,"page":5,"words":[{"code":"пұҒ","page":5,"end":false},{"code":"пұӮ","page":5,"end":false},{"code":"пұғ","page":5,"end":false},{"code":"пұ„","page":5,"end":false},{"code":"пұ…","page":5,"end":false},{"code":"пұҶ","page":5,"end":false},{"code":"пұҮ","page":5,"end":false},{"code":"пұҲ","page":5,"end":false},{"code":"пұү","page":5,"end":false},{"code":"пұҠ","page":5,"end":false},{"code":"пұӢ","page":5,"end":false},{"code":"пұҢпұҚ","page":5,"end":false},{"code":"пұҺ","page":5,"end":false},{"code":"пұҸ","page":5,"end":false},{"code":"пұҗ","page":5,"end":false},{"code":"пұ‘","page":5,"end":false},{"code":"пұ’","page":5,"end":false},{"code":"пұ“","page":5,"end":false},{"code":"пұ”","page":5,"end":false},{"code":"пұ•","page":5,"end":false},{"code":"пұ–","page":5,"end":false},{"code":"пұ—","page":5,"end":false},{"code":"пұҳ","page":5,"end":false},{"code":"пұҷпұҡ","page":5,"end":false},{"code":"пұӣ","page":5,"end":false},{"code":"пұң","page":5,"end":false},{"code":"пұқпұһ","page":5,"end":false},{"code":"пұҹ","page":5,"end":false},{"code":"пұ ","page":5,"end":false},{"code":"пұЎ","page":5,"end":false},{"code":"пұўпұЈ","page":5,"end":false},{"code":"пұӨ","page":5,"end":false},{"code":"пұҘ","page":5,"end":false},{"code":"пұҰ","page":5,"end":false},{"code":"пұ§","page":5,"end":true}],"text":"ЩҲЩҺШЁЩҺШҙЩ‘ЩҗШұЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ы– ЩғЩҸЩ„Щ‘ЩҺЩ…ЩҺШ§ ШұЩҸШІЩҗЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ЩҮЩҺШ§ Щ…ЩҗЩҶ Ш«ЩҺЩ…ЩҺШұЩҺШ©ЩҚЫў ШұЩ‘ЩҗШІЩ’ЩӮЩӢЫӯШ§ Ыҷ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ШұЩҸШІЩҗЩӮЩ’ЩҶЩҺШ§ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Ы– ЩҲЩҺШЈЩҸШӘЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ Щ…ЩҸШӘЩҺШҙЩҺЩҖЩ°ШЁЩҗЩҮЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҢЫӯ Щ…Щ‘ЩҸШ·ЩҺЩҮЩ‘ЩҺШұЩҺШ©ЩҢЫӯ Ы– ЩҲЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҸЩҲЩҶЩҺ"},{"key":"2:26","surah":2,"ayah":26,"num":33,"page":5,"words":[{"code":"пұЁ пұ©","page":5,"end":false},{"code":"пұӘ","page":5,"end":false},{"code":"пұ«","page":5,"end":false},{"code":"пұ¬","page":5,"end":false},{"code":"пұӯ","page":5,"end":false},{"code":"пұ®","page":5,"end":false},{"code":"пұҜ","page":5,"end":false},{"code":"пұ°","page":5,"end":false},{"code":"пұұ","page":5,"end":false},{"code":"пұІ","page":5,"end":false},{"code":"пұіпұҙ","page":5,"end":false},{"code":"пұө","page":5,"end":false},{"code":"пұ¶","page":5,"end":false},{"code":"пұ·","page":5,"end":false},{"code":"пұё","page":5,"end":false},{"code":"пұ№","page":5,"end":false},{"code":"пұә","page":5,"end":false},{"code":"пұ»","page":5,"end":false},{"code":"пұјпұҪ","page":5,"end":false},{"code":"пұҫ","page":5,"end":false},{"code":"пұҝ","page":5,"end":false},{"code":"пІҖ","page":5,"end":false},{"code":"пІҒ","page":5,"end":false},{"code":"пІӮ","page":5,"end":false},{"code":"пІғ","page":5,"end":false},{"code":"пІ„","page":5,"end":false},{"code":"пІ…","page":5,"end":false},{"code":"пІҶпІҮ","page":5,"end":false},{"code":"пІҲ","page":5,"end":false},{"code":"пІү","page":5,"end":false},{"code":"пІҠ","page":5,"end":false},{"code":"пІӢ","page":5,"end":false},{"code":"пІҢ","page":5,"end":false},{"code":"пІҚпІҺ","page":5,"end":false},{"code":"пІҸ","page":5,"end":false},{"code":"пІҗ","page":5,"end":false},{"code":"пІ‘","page":5,"end":false},{"code":"пІ’","page":5,"end":false},{"code":"пІ“","page":5,"end":false},{"code":"пІ”","page":5,"end":true}],"text":"Ыһ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШӯЩ’ЩүЩҗЫҰЩ“ ШЈЩҺЩҶ ЩҠЩҺШ¶Щ’ШұЩҗШЁЩҺ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Щ…Щ‘ЩҺШ§ ШЁЩҺШ№ЩҸЩҲШ¶ЩҺШ©ЩӢЫӯ ЩҒЩҺЩ…ЩҺШ§ ЩҒЩҺЩҲЩ’ЩӮЩҺЩҮЩҺШ§ Ыҡ ЩҒЩҺШЈЩҺЩ…Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҒЩҺЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘ЩҸ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺШЈЩҺЩ…Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҒЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Ш°ЩҺШ§Щ“ ШЈЩҺШұЩҺШ§ШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҺЩҖЩ°Ш°ЩҺШ§ Щ…ЩҺШ«ЩҺЩ„ЩӢЫӯШ§ Ыҳ ЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҸ ШЁЩҗЩҮЩҗЫҰ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩү ШЁЩҗЩҮЩҗЫҰ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҸШ¶ЩҗЩ„Щ‘ЩҸ ШЁЩҗЩҮЩҗЫҰЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"2:27","surah":2,"ayah":27,"num":34,"page":5,"words":[{"code":"пІ•","page":5,"end":false},{"code":"пІ–","page":5,"end":false},{"code":"пІ—","page":5,"end":false},{"code":"пІҳ","page":5,"end":false},{"code":"пІҷ","page":5,"end":false},{"code":"пІҡ","page":5,"end":false},{"code":"пІӣ","page":5,"end":false},{"code":"пІң","page":5,"end":false},{"code":"пІқ","page":5,"end":false},{"code":"пІһ","page":5,"end":false},{"code":"пІҹ","page":5,"end":false},{"code":"пІ ","page":5,"end":false},{"code":"пІЎ","page":5,"end":false},{"code":"пІў","page":5,"end":false},{"code":"пІЈ","page":5,"end":false},{"code":"пІӨ","page":5,"end":false},{"code":"пІҘпІҰ","page":5,"end":false},{"code":"пІ§","page":5,"end":false},{"code":"пІЁ","page":5,"end":false},{"code":"пІ©","page":5,"end":false},{"code":"пІӘ","page":5,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩҶЩӮЩҸШ¶ЩҸЩҲЩҶЩҺ Ш№ЩҺЩҮЩ’ШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Щ…ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҗЩҮЩҗЫҰ ЩҲЩҺЩҠЩҺЩӮЩ’Ш·ЩҺШ№ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Щ“ ШЈЩҺЩ…ЩҺШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҶ ЩҠЩҸЩҲШөЩҺЩ„ЩҺ ЩҲЩҺЩҠЩҸЩҒЩ’ШіЩҗШҜЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш®ЩҺЩҖЩ°ШіЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"2:28","surah":2,"ayah":28,"num":35,"page":5,"words":[{"code":"пІ«","page":5,"end":false},{"code":"пІ¬","page":5,"end":false},{"code":"пІӯ","page":5,"end":false},{"code":"пІ®","page":5,"end":false},{"code":"пІҜ","page":5,"end":false},{"code":"пІ°пІұ","page":5,"end":false},{"code":"пІІ","page":5,"end":false},{"code":"пІі","page":5,"end":false},{"code":"пІҙ","page":5,"end":false},{"code":"пІө","page":5,"end":false},{"code":"пІ¶","page":5,"end":false},{"code":"пІ·","page":5,"end":false},{"code":"пІё","page":5,"end":false},{"code":"пІ№","page":5,"end":true}],"text":"ЩғЩҺЩҠЩ’ЩҒЩҺ ШӘЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩғЩҸЩҶШӘЩҸЩ…Щ’ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°ШӘЩӢЫӯШ§ ЩҒЩҺШЈЩҺШӯЩ’ЩҠЩҺЩҖЩ°ЩғЩҸЩ…Щ’ Ы– Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸЩ…ЩҗЩҠШӘЩҸЩғЩҸЩ…Щ’ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸШӯЩ’ЩҠЩҗЩҠЩғЩҸЩ…Щ’ Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"2:29","surah":2,"ayah":29,"num":36,"page":5,"words":[{"code":"пІә","page":5,"end":false},{"code":"пІ»","page":5,"end":false},{"code":"пІј","page":5,"end":false},{"code":"пІҪ","page":5,"end":false},{"code":"пІҫ","page":5,"end":false},{"code":"пІҝ","page":5,"end":false},{"code":"піҖ","page":5,"end":false},{"code":"піҒ","page":5,"end":false},{"code":"піӮ","page":5,"end":false},{"code":"піғ","page":5,"end":false},{"code":"пі„","page":5,"end":false},{"code":"пі…","page":5,"end":false},{"code":"піҶ","page":5,"end":false},{"code":"піҮ","page":5,"end":false},{"code":"піҲпіү","page":5,"end":false},{"code":"піҠ","page":5,"end":false},{"code":"піӢ","page":5,"end":false},{"code":"піҢ","page":5,"end":false},{"code":"піҚ","page":5,"end":false},{"code":"піҺ","page":5,"end":true}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢЫӯШ§ Ш«ЩҸЩ…Щ‘ЩҺ ЩұШіЩ’ШӘЩҺЩҲЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ЩҒЩҺШіЩҺЩҲЩ‘ЩҺЩүЩ°ЩҮЩҸЩҶЩ‘ЩҺ ШіЩҺШЁЩ’Ш№ЩҺ ШіЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҚЫў Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"}]}
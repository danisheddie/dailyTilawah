":16,"end":false},{"code":"пұҪпұҫ","page":16,"end":false},{"code":"пұҝ","page":16,"end":false},{"code":"пІҖ","page":16,"end":false},{"code":"пІҒ","page":16,"end":false},{"code":"пІӮ","page":16,"end":false},{"code":"пІғ","page":16,"end":false},{"code":"пІ„","page":16,"end":false},{"code":"пІ…","page":16,"end":false},{"code":"пІҶ","page":16,"end":false},{"code":"пІҮ","page":16,"end":false},{"code":"пІҲпІү","page":16,"end":false},{"code":"пІҠ","page":16,"end":false},{"code":"пІӢ","page":16,"end":false},{"code":"пІҢ","page":16,"end":false},{"code":"пІҚ","page":16,"end":false},{"code":"пІҺпІҸ","page":16,"end":false},{"code":"пІҗ","page":16,"end":false},{"code":"пІ‘","page":16,"end":false},{"code":"пІ’","page":16,"end":false},{"code":"пІ“","page":16,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺШЁЩҺШ№ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ШӘЩҺШӘЩ’Щ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШҙЩ‘ЩҺЩҠЩҺЩҖЩ°Ш·ЩҗЩҠЩҶЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҸЩ„Щ’ЩғЩҗ ШіЩҸЩ„ЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҺ Ы– ЩҲЩҺЩ…ЩҺШ§ ЩғЩҺЩҒЩҺШұЩҺ ШіЩҸЩ„ЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩҺЩҖЩ°Ш·ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҠЩҸШ№ЩҺЩ„Щ‘ЩҗЩ…ЩҸЩҲЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩұЩ„ШіЩ‘ЩҗШӯЩ’ШұЩҺ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩғЩҺЩҠЩ’ЩҶЩҗ ШЁЩҗШЁЩҺШ§ШЁЩҗЩ„ЩҺ ЩҮЩҺЩҖЩ°ШұЩҸЩҲШӘЩҺ ЩҲЩҺЩ…ЩҺЩҖЩ°ШұЩҸЩҲШӘЩҺ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҸШ№ЩҺЩ„Щ‘ЩҗЩ…ЩҺШ§ЩҶЩҗ Щ…ЩҗЩҶЩ’ ШЈЩҺШӯЩҺШҜЩҚ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺЩӮЩҸЩҲЩ„ЩҺШ§Щ“ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҶЩҺШӯЩ’ЩҶЩҸ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢЫӯ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺЩғЩ’ЩҒЩҸШұЩ’ Ы– ЩҒЩҺЩҠЩҺШӘЩҺШ№ЩҺЩ„Щ‘ЩҺЩ…ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҺШ§ Щ…ЩҺШ§ ЩҠЩҸЩҒЩҺШұЩ‘ЩҗЩӮЩҸЩҲЩҶЩҺ ШЁЩҗЩҮЩҗЫҰ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺШұЩ’ШЎЩҗ ЩҲЩҺШІЩҺЩҲЩ’Ш¬ЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩ… ШЁЩҗШ¶ЩҺШ§Щ“ШұЩ‘ЩҗЩҠЩҶЩҺ ШЁЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ ШЈЩҺШӯЩҺШҜЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩҠЩҺШӘЩҺШ№ЩҺЩ„Щ‘ЩҺЩ…ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§ ЩҠЩҺШ¶ЩҸШұЩ‘ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩҶЩҒЩҺШ№ЩҸЩҮЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ Ш№ЩҺЩ„ЩҗЩ…ЩҸЩҲШ§Ыҹ Щ„ЩҺЩ…ЩҺЩҶЩҗ ЩұШҙЩ’ШӘЩҺШұЩҺЩүЩ°ЩҮЩҸ Щ…ЩҺШ§ Щ„ЩҺЩҮЩҸЫҘ ЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩ„ЩҺЩҖЩ°ЩӮЩҚЫў Ыҡ ЩҲЩҺЩ„ЩҺШЁЩҗШҰЩ’ШіЩҺ Щ…ЩҺШ§ ШҙЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЁЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ Ыҡ Щ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:103","surah":2,"ayah":103,"num":110,"page":16,"words":[{"code":"пІ”","page":16,"end":false},{"code":"пІ•","page":16,"end":false},{"code":"пІ–","page":16,"end":false},{"code":"пІ—","page":16,"end":false},{"code":"пІҳ","page":16,"end":false},{"code":"пІҷ","page":16,"end":false},{"code":"пІҡ","page":16,"end":false},{"code":"пІӣ","page":16,"end":false},{"code":"пІңпІқ","page":16,"end":false},{"code":"пІһ","page":16,"end":false},{"code":"пІҹ","page":16,"end":false},{"code":"пІ ","page":16,"end":false},{"code":"пІЎ","page":16,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҺЩҲЩ’Ш§Ыҹ Щ„ЩҺЩ…ЩҺШ«ЩҸЩҲШЁЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Ы– Щ„Щ‘ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:104","surah":2,"ayah":104,"num":111,"page":16,"words":[{"code":"пІў","page":16,"end":false},{"code":"пІЈ","page":16,"end":false},{"code":"пІӨ","page":16,"end":false},{"code":"пІҘ","page":16,"end":false},{"code":"пІҰ","page":16,"end":false},{"code":"пІ§","page":16,"end":false},{"code":"пІЁ","page":16,"end":false},{"code":"пІ©","page":16,"end":false},{"code":"пІӘпІ«","page":16,"end":false},{"code":"пІ¬","page":16,"end":false},{"code":"пІӯ","page":16,"end":false},{"code":"пІ®","page":16,"end":false},{"code":"пІҜ","page":16,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ШұЩҺЩ°Ш№ЩҗЩҶЩҺШ§ ЩҲЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ЩұЩҶШёЩҸШұЩ’ЩҶЩҺШ§ ЩҲЩҺЩұШіЩ’Щ…ЩҺШ№ЩҸЩҲШ§Ыҹ Ы— ЩҲЩҺЩ„ЩҗЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШЈЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:105","surah":2,"ayah":105,"num":112,"page":16,"words":[{"code":"пІ°","page":16,"end":false},{"code":"пІұ","page":16,"end":false},{"code":"пІІ","page":16,"end":false},{"code":"пІі","page":16,"end":false},{"code":"пІҙ","page":16,"end":false},{"code":"пІө","page":16,"end":false},{"code":"пІ¶","page":16,"end":false},{"code":"пІ·","page":16,"end":false},{"code":"пІё","page":16,"end":false},{"code":"пІ№","page":16,"end":false},{"code":"пІә","page":16,"end":false},{"code":"пІ»","page":16,"end":false},{"code":"пІј","page":16,"end":false},{"code":"пІҪ","page":16,"end":false},{"code":"пІҫ","page":16,"end":false},{"code":"пІҝпіҖ","page":16,"end":false},{"code":"піҒ","page":16,"end":false},{"code":"піӮ","page":16,"end":false},{"code":"піғ","page":16,"end":false},{"code":"пі„","page":16,"end":false},{"code":"пі…піҶ","page":16,"end":false},{"code":"піҮ","page":16,"end":false},{"code":"піҲ","page":16,"end":false},{"code":"піү","page":16,"end":false},{"code":"піҠ","page":16,"end":false},{"code":"піӢ","page":16,"end":true}],"text":"Щ…Щ‘ЩҺШ§ ЩҠЩҺЩҲЩҺШҜЩ‘ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЩ’ ШЈЩҺЩҮЩ’Щ„Щҗ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҲЩҺЩ„ЩҺШ§ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ ШЈЩҺЩҶ ЩҠЩҸЩҶЩҺШІЩ‘ЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҺШ®Щ’ШӘЩҺШөЩ‘ЩҸ ШЁЩҗШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш°ЩҸЩҲ ЩұЩ„Щ’ЩҒЩҺШ¶Щ’Щ„Щҗ ЩұЩ„Щ’Ш№ЩҺШёЩҗЩҠЩ…Щҗ"}]}
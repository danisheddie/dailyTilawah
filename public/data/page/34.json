words":[{"code":"пұҒ","page":34,"end":false},{"code":"пұӮ","page":34,"end":false},{"code":"пұғ","page":34,"end":false},{"code":"пұ„","page":34,"end":false},{"code":"пұ…","page":34,"end":false},{"code":"пұҶпұҮ","page":34,"end":false},{"code":"пұҲ","page":34,"end":false},{"code":"пұү","page":34,"end":false},{"code":"пұҠ","page":34,"end":false},{"code":"пұӢ","page":34,"end":false},{"code":"пұҢ","page":34,"end":false},{"code":"пұҚ","page":34,"end":false},{"code":"пұҺпұҸ","page":34,"end":false},{"code":"пұҗ","page":34,"end":false},{"code":"пұ‘","page":34,"end":false},{"code":"пұ’","page":34,"end":false},{"code":"пұ“","page":34,"end":false},{"code":"пұ”","page":34,"end":false},{"code":"пұ•","page":34,"end":false},{"code":"пұ–пұ—","page":34,"end":false},{"code":"пұҳ","page":34,"end":false},{"code":"пұҷ","page":34,"end":false},{"code":"пұҡ","page":34,"end":false},{"code":"пұӣ","page":34,"end":false},{"code":"пұң","page":34,"end":false},{"code":"пұқ","page":34,"end":true}],"text":"ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩӮЩҗШӘЩҺШ§Щ„ЩҸ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩғЩҸШұЩ’ЩҮЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы– ЩҲЩҺШ№ЩҺШіЩҺЩүЩ°Щ“ ШЈЩҺЩҶ ШӘЩҺЩғЩ’ШұЩҺЩҮЩҸЩҲШ§Ыҹ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ ЩҲЩҺЩҮЩҸЩҲЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы– ЩҲЩҺШ№ЩҺШіЩҺЩүЩ°Щ“ ШЈЩҺЩҶ ШӘЩҸШӯЩҗШЁЩ‘ЩҸЩҲШ§Ыҹ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ ЩҲЩҺЩҮЩҸЩҲЩҺ ШҙЩҺШұЩ‘ЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ЩҲЩҺШЈЩҺЩҶШӘЩҸЩ…Щ’ Щ„ЩҺШ§ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:217","surah":2,"ayah":217,"num":224,"page":34,"words":[{"code":"пұһ","page":34,"end":false},{"code":"пұҹ","page":34,"end":false},{"code":"пұ ","page":34,"end":false},{"code":"пұЎ","page":34,"end":false},{"code":"пұў","page":34,"end":false},{"code":"пұЈпұӨ","page":34,"end":false},{"code":"пұҘ","page":34,"end":false},{"code":"пұҰ","page":34,"end":false},{"code":"пұ§","page":34,"end":false},{"code":"пұЁпұ©","page":34,"end":false},{"code":"пұӘ","page":34,"end":false},{"code":"пұ«","page":34,"end":false},{"code":"пұ¬","page":34,"end":false},{"code":"пұӯ","page":34,"end":false},{"code":"пұ®","page":34,"end":false},{"code":"пұҜ","page":34,"end":false},{"code":"пұ°","page":34,"end":false},{"code":"пұұ","page":34,"end":false},{"code":"пұІ","page":34,"end":false},{"code":"пұі","page":34,"end":false},{"code":"пұҙ","page":34,"end":false},{"code":"пұө","page":34,"end":false},{"code":"пұ¶","page":34,"end":false},{"code":"пұ·пұё","page":34,"end":false},{"code":"пұ№","page":34,"end":false},{"code":"пұә","page":34,"end":false},{"code":"пұ»","page":34,"end":false},{"code":"пұјпұҪ","page":34,"end":false},{"code":"пұҫ","page":34,"end":false},{"code":"пұҝ","page":34,"end":false},{"code":"пІҖ","page":34,"end":false},{"code":"пІҒ","page":34,"end":false},{"code":"пІӮ","page":34,"end":false},{"code":"пІғ","page":34,"end":false},{"code":"пІ„","page":34,"end":false},{"code":"пІ…","page":34,"end":false},{"code":"пІҶпІҮ","page":34,"end":false},{"code":"пІҲ","page":34,"end":false},{"code":"пІү","page":34,"end":false},{"code":"пІҠ","page":34,"end":false},{"code":"пІӢ","page":34,"end":false},{"code":"пІҢ","page":34,"end":false},{"code":"пІҚ","page":34,"end":false},{"code":"пІҺ","page":34,"end":false},{"code":"пІҸ","page":34,"end":false},{"code":"пІҗ","page":34,"end":false},{"code":"пІ‘","page":34,"end":false},{"code":"пІ’","page":34,"end":false},{"code":"пІ“","page":34,"end":false},{"code":"пІ”","page":34,"end":false},{"code":"пІ•пІ–","page":34,"end":false},{"code":"пІ—","page":34,"end":false},{"code":"пІҳ","page":34,"end":false},{"code":"пІҷпІҡ","page":34,"end":false},{"code":"пІӣ","page":34,"end":false},{"code":"пІң","page":34,"end":false},{"code":"пІқ","page":34,"end":false},{"code":"пІһ","page":34,"end":true}],"text":"ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺЩғЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„ШҙЩ‘ЩҺЩҮЩ’ШұЩҗ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…Щҗ ЩӮЩҗШӘЩҺШ§Щ„ЩҚЫў ЩҒЩҗЩҠЩҮЩҗ Ы– ЩӮЩҸЩ„Щ’ ЩӮЩҗШӘЩҺШ§Щ„ЩҢЫӯ ЩҒЩҗЩҠЩҮЩҗ ЩғЩҺШЁЩҗЩҠШұЩҢЫӯ Ы– ЩҲЩҺШөЩҺШҜЩ‘ЩҢ Ш№ЩҺЩҶ ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩғЩҸЩҒЩ’ШұЩҢЫў ШЁЩҗЩҮЩҗЫҰ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШіЩ’Ш¬ЩҗШҜЩҗ ЩұЩ„Щ’ШӯЩҺШұЩҺШ§Щ…Щҗ ЩҲЩҺШҘЩҗШ®Щ’ШұЩҺШ§Ш¬ЩҸ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ЩҮЩҸ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩұЩ„Щ’ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҸ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩӮЩҺШӘЩ’Щ„Щҗ Ы— ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШІЩҺШ§Щ„ЩҸЩҲЩҶЩҺ ЩҠЩҸЩӮЩҺЩҖЩ°ШӘЩҗЩ„ЩҸЩҲЩҶЩҺЩғЩҸЩ…Щ’ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШұЩҸШҜЩ‘ЩҸЩҲЩғЩҸЩ…Щ’ Ш№ЩҺЩҶ ШҜЩҗЩҠЩҶЩҗЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩҗ ЩұШіЩ’ШӘЩҺШ·ЩҺЩҖЩ°Ш№ЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШұЩ’ШӘЩҺШҜЩҗШҜЩ’ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ш№ЩҺЩҶ ШҜЩҗЩҠЩҶЩҗЩҮЩҗЫҰ ЩҒЩҺЩҠЩҺЩ…ЩҸШӘЩ’ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩғЩҺШ§ЩҒЩҗШұЩҢЫӯ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШӯЩҺШЁЩҗШ·ЩҺШӘЩ’ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҸЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҲЩҺЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ы– ЩҲЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ы– ЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҸЩҲЩҶЩҺ"},{"key":"2:218","surah":2,"ayah":218,"num":225,"page":34,"words":[{"code":"пІҹ","page":34,"end":false},{"code":"пІ ","page":34,"end":false},{"code":"пІЎ","page":34,"end":false},{"code":"пІў","page":34,"end":false},{"code":"пІЈ","page":34,"end":false},{"code":"пІӨ","page":34,"end":false},{"code":"пІҘ","page":34,"end":false},{"code":"пІҰ","page":34,"end":false},{"code":"пІ§","page":34,"end":false},{"code":"пІЁ","page":34,"end":false},{"code":"пІ©","page":34,"end":false},{"code":"пІӘ","page":34,"end":false},{"code":"пІ«пІ¬","page":34,"end":false},{"code":"пІӯ","page":34,"end":false},{"code":"пІ®","page":34,"end":false},{"code":"пІҜ","page":34,"end":false},{"code":"пІ°","page":34,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҮЩҺШ§Ш¬ЩҺШұЩҸЩҲШ§Ыҹ ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҮЩҺШҜЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҠЩҺШұЩ’Ш¬ЩҸЩҲЩҶЩҺ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:219","surah":2,"ayah":219,"num":226,"page":34,"words":[{"code":"пІұ пІІ","page":34,"end":false},{"code":"пІі","page":34,"end":false},{"code":"пІҙ","page":34,"end":false},{"code":"пІөпІ¶","page":34,"end":false},{"code":"пІ·","page":34,"end":false},{"code":"пІё","page":34,"end":false},{"code":"пІ№","page":34,"end":false},{"code":"пІә","page":34,"end":false},{"code":"пІ»","page":34,"end":false},{"code":"пІј","page":34,"end":false},{"code":"пІҪ","page":34,"end":false},{"code":"пІҫ","page":34,"end":false},{"code":"пІҝ","page":34,"end":false},{"code":"піҖпіҒ","page":34,"end":false},{"code":"піӮ","page":34,"end":false},{"code":"піғ","page":34,"end":false},{"code":"пі„пі…","page":34,"end":false},{"code":"піҶ","page":34,"end":false},{"code":"піҮпіҲ","page":34,"end":false},{"code":"піү","page":34,"end":false},{"code":"піҠ","page":34,"end":false},{"code":"піӢ","page":34,"end":false},{"code":"піҢ","page":34,"end":false},{"code":"піҚ","page":34,"end":false},{"code":"піҺ","page":34,"end":false},{"code":"піҸ","page":34,"end":false},{"code":"піҗ","page":34,"end":true}],"text":"Ыһ ЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺЩғЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Ш®ЩҺЩ…Щ’ШұЩҗ ЩҲЩҺЩұЩ„Щ’Щ…ЩҺЩҠЩ’ШіЩҗШұЩҗ Ы– ЩӮЩҸЩ„Щ’ ЩҒЩҗЩҠЩҮЩҗЩ…ЩҺШ§Щ“ ШҘЩҗШ«Щ’Щ…ЩҢЫӯ ЩғЩҺШЁЩҗЩҠШұЩҢЫӯ ЩҲЩҺЩ…ЩҺЩҶЩҺЩҖЩ°ЩҒЩҗШ№ЩҸ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҲЩҺШҘЩҗШ«Щ’Щ…ЩҸЩҮЩҸЩ…ЩҺШ§Щ“ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ Щ…ЩҗЩҶ ЩҶЩ‘ЩҺЩҒЩ’Ш№ЩҗЩҮЩҗЩ…ЩҺШ§ Ы— ЩҲЩҺЩҠЩҺШіЩ’ЩҖЩ”ЩҺЩ„ЩҸЩҲЩҶЩҺЩғЩҺ Щ…ЩҺШ§Ш°ЩҺШ§ ЩҠЩҸЩҶЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ЩӮЩҸЩ„Щҗ ЩұЩ„Щ’Ш№ЩҺЩҒЩ’ЩҲЩҺ Ы— ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШӘЩҺЩҒЩҺЩғЩ‘ЩҺШұЩҸЩҲЩҶЩҺ"}]}
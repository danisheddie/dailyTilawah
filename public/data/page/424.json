ҶЩҺЩҖЩ°ШӘЩҗ Ш«ЩҸЩ…Щ‘ЩҺ Ш·ЩҺЩ„Щ‘ЩҺЩӮЩ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„Щҗ ШЈЩҺЩҶ ШӘЩҺЩ…ЩҺШіЩ‘ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҺЩ…ЩҺШ§ Щ„ЩҺЩғЩҸЩ…Щ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩ’ Ш№ЩҗШҜЩ‘ЩҺШ©ЩҚЫў ШӘЩҺШ№Щ’ШӘЩҺШҜЩ‘ЩҸЩҲЩҶЩҺЩҮЩҺШ§ Ы– ЩҒЩҺЩ…ЩҺШӘЩ‘ЩҗШ№ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ЩҲЩҺШіЩҺШұЩ‘ЩҗШӯЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШіЩҺШұЩҺШ§ШӯЩӢЫӯШ§ Ш¬ЩҺЩ…ЩҗЩҠЩ„ЩӢЫӯШ§"},{"key":"33:50","surah":33,"ayah":50,"num":3583,"page":424,"words":[{"code":"пІү","page":424,"end":false},{"code":"пІҠ","page":424,"end":false},{"code":"пІӢ","page":424,"end":false},{"code":"пІҢ","page":424,"end":false},{"code":"пІҚ","page":424,"end":false},{"code":"пІҺ","page":424,"end":false},{"code":"пІҸ","page":424,"end":false},{"code":"пІҗ","page":424,"end":false},{"code":"пІ‘","page":424,"end":false},{"code":"пІ’","page":424,"end":false},{"code":"пІ“","page":424,"end":false},{"code":"пІ”","page":424,"end":false},{"code":"пІ•","page":424,"end":false},{"code":"пІ–","page":424,"end":false},{"code":"пІ—","page":424,"end":false},{"code":"пІҳ","page":424,"end":false},{"code":"пІҷ","page":424,"end":false},{"code":"пІҡ","page":424,"end":false},{"code":"пІӣ","page":424,"end":false},{"code":"пІң","page":424,"end":false},{"code":"пІқ","page":424,"end":false},{"code":"пІһ","page":424,"end":false},{"code":"пІҹ","page":424,"end":false},{"code":"пІ ","page":424,"end":false},{"code":"пІЎ","page":424,"end":false},{"code":"пІў","page":424,"end":false},{"code":"пІЈ","page":424,"end":false},{"code":"пІӨ","page":424,"end":false},{"code":"пІҘ","page":424,"end":false},{"code":"пІҰ","page":424,"end":false},{"code":"пІ§","page":424,"end":false},{"code":"пІЁ","page":424,"end":false},{"code":"пІ©","page":424,"end":false},{"code":"пІӘ","page":424,"end":false},{"code":"пІ«","page":424,"end":false},{"code":"пІ¬","page":424,"end":false},{"code":"пІӯ","page":424,"end":false},{"code":"пІ®","page":424,"end":false},{"code":"пІҜ","page":424,"end":false},{"code":"пІ°","page":424,"end":false},{"code":"пІұ","page":424,"end":false},{"code":"пІІ","page":424,"end":false},{"code":"пІіпІҙ"
4","surah":33,"ayah":44,"num":3577,"page":424,"words":[{"code":"пұҒ","page":424,"end":false},{"code":"пұӮ","page":424,"end":false},{"code":"пұғ","page":424,"end":false},{"code":"пұ„пұ…","page":424,"end":false},{"code":"пұҶ","page":424,"end":false},{"code":"пұҮ","page":424,"end":false},{"code":"пұҲ","page":424,"end":false},{"code":"пұү","page":424,"end":false},{"code":"пұҠ","page":424,"end":true}],"text":"ШӘЩҺШӯЩҗЩҠЩ‘ЩҺШӘЩҸЩҮЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺЩ„Щ’ЩӮЩҺЩҲЩ’ЩҶЩҺЩҮЩҸЫҘ ШіЩҺЩ„ЩҺЩҖЩ°Щ…ЩҢЫӯ Ыҡ ЩҲЩҺШЈЩҺШ№ЩҺШҜЩ‘ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩӢЫӯШ§ ЩғЩҺШұЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"33:45","surah":33,"ayah":45,"num":3578,"page":424,"words":[{"code":"пұӢ","page":424,"end":false},{"code":"пұҢ","page":424,"end":false},{"code":"пұҚ","page":424,"end":false},{"code":"пұҺ","page":424,"end":false},{"code":"пұҸ","page":424,"end":false},{"code":"пұҗ","page":424,"end":false},{"code":"пұ‘","page":424,"end":false},{"code":"пұ’","page":424,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘ЩҸ ШҘЩҗЩҶЩ‘ЩҺШ§Щ“ ШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩғЩҺ ШҙЩҺЩҖЩ°ЩҮЩҗШҜЩӢЫӯШ§ ЩҲЩҺЩ…ЩҸШЁЩҺШҙЩ‘ЩҗШұЩӢЫӯШ§ ЩҲЩҺЩҶЩҺШ°ЩҗЩҠШұЩӢЫӯШ§"},{"key":"33:46","surah":33,"ayah":46,"num":3579,"page":424,"words":[{"code":"пұ“","page":424,"end":false},{"code":"пұ”","page":424,"end":false},{"code":"пұ•","page":424,"end":false},{"code":"пұ–","page":424,"end":false},{"code":"пұ—","page":424,"end":false},{"code":"пұҳ","page":424,"end":false},{"code":"пұҷ","page":424,"end":true}],"text":"ЩҲЩҺШҜЩҺШ§Ш№ЩҗЩҠЩӢШ§ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗЩҮЩҗЫҰ ЩҲЩҺШіЩҗШұЩҺШ§Ш¬ЩӢЫӯШ§ Щ…Щ‘ЩҸЩҶЩҗЩҠШұЩӢЫӯШ§"},{"key":"33:47","surah":33,"ayah":47,"num":3580,"page":424,"words":[{"code":"пұҡ","page":424,"end":false},{"code":"пұӣ","page":424,"end":false},{"code":"пұң","page":424,"end":false},{"code":"пұқ","page":424,"end":false},{"code":"пұһ","page":424,"end":false},{"code":"пұҹ","page":424,"end":false},{"code":"пұ ","page":424,"end":false},{"code":"пұЎ","page":424,"end":false},{"code":"пұў","page":424,"end":true}],"text":"ЩҲЩҺШЁЩҺШҙЩ‘ЩҗШ
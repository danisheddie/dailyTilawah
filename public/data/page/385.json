ge":385,"end":false},{"code":"пұҲ","page":385,"end":false},{"code":"пұү","page":385,"end":false},{"code":"пұҠ","page":385,"end":false},{"code":"пұӢ","page":385,"end":false},{"code":"пұҢ","page":385,"end":true}],"text":"Щ…ЩҺЩҶ Ш¬ЩҺШ§Щ“ШЎЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺШіЩҺЩҶЩҺШ©Щҗ ЩҒЩҺЩ„ЩҺЩҮЩҸЫҘ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҺШ§ ЩҲЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҒЩҺШІЩҺШ№ЩҚЫў ЩҠЩҺЩҲЩ’Щ…ЩҺШҰЩҗШ°ЩҚ ШЎЩҺШ§Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"27:90","surah":27,"ayah":90,"num":3249,"page":385,"words":[{"code":"пұҚ","page":385,"end":false},{"code":"пұҺ","page":385,"end":false},{"code":"пұҸ","page":385,"end":false},{"code":"пұҗ","page":385,"end":false},{"code":"пұ‘","page":385,"end":false},{"code":"пұ’","page":385,"end":false},{"code":"пұ“","page":385,"end":false},{"code":"пұ”","page":385,"end":false},{"code":"пұ•","page":385,"end":false},{"code":"пұ–","page":385,"end":false},{"code":"пұ—","page":385,"end":false},{"code":"пұҳ","page":385,"end":false},{"code":"пұҷ","page":385,"end":false},{"code":"пұҡ","page":385,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ Ш¬ЩҺШ§Щ“ШЎЩҺ ШЁЩҗЩұЩ„ШіЩ‘ЩҺЩҠЩ‘ЩҗШҰЩҺШ©Щҗ ЩҒЩҺЩғЩҸШЁЩ‘ЩҺШӘЩ’ ЩҲЩҸШ¬ЩҸЩҲЩҮЩҸЩҮЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҮЩҺЩ„Щ’ ШӘЩҸШ¬Щ’ШІЩҺЩҲЩ’ЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"27:91","surah":27,"ayah":91,"num":3250,"page":385,"words":[{"code":"пұӣ","page":385,"end":false},{"code":"пұң","page":385,"end":false},{"code":"пұқ","page":385,"end":false},{"code":"пұһ","page":385,"end":false},{"code":"пұҹ","page":385,"end":false},{"code":"пұ ","page":385,"end":false},{"code":"пұЎ","page":385,"end":false},{"code":"пұў","page":385,"end":false},{"code":"пұЈ","page":385,"end":false},{"code":"пұӨ","page":385,"end":false},{"code":"пұҘ","page":385,"end":false},{"code":"пұҰпұ§","page":385,"end":false},{"code":"пұЁ","page":385,"end":false},{"code":"пұ©","page":385,"end":false},{"code":"пұӘ","page":385,"end":false},{"code":"пұ«","page":385,"end":false},{"code":"пұ¬","page":385,"end":false},{"code":"пұӯ","page":385,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩ…ЩҗШұЩ
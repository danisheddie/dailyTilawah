code":"пұӮ","page":520,"end":false},{"code":"пұғ","page":520,"end":false},{"code":"пұ„","page":520,"end":false},{"code":"пұ…","page":520,"end":false},{"code":"пұҶ","page":520,"end":false},{"code":"пұҮ","page":520,"end":false},{"code":"пұҲ","page":520,"end":false},{"code":"пұү","page":520,"end":false},{"code":"пұҠ","page":520,"end":false},{"code":"пұӢ","page":520,"end":false},{"code":"пұҢ","page":520,"end":false},{"code":"пұҚ","page":520,"end":false},{"code":"пұҺ","page":520,"end":false},{"code":"пұҸ","page":520,"end":false},{"code":"пұҗ","page":520,"end":true}],"text":"ЩҲЩҺЩғЩҺЩ…Щ’ ШЈЩҺЩҮЩ’Щ„ЩҺЩғЩ’ЩҶЩҺШ§ ЩӮЩҺШЁЩ’Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩӮЩҺШұЩ’ЩҶЩҚ ЩҮЩҸЩ…Щ’ ШЈЩҺШҙЩҺШҜЩ‘ЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ… ШЁЩҺШ·Щ’ШҙЩӢЫӯШ§ ЩҒЩҺЩҶЩҺЩӮЩ‘ЩҺШЁЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЁЩҗЩ„ЩҺЩҖЩ°ШҜЩҗ ЩҮЩҺЩ„Щ’ Щ…ЩҗЩҶ Щ…Щ‘ЩҺШӯЩҗЩҠШөЩҚ"},{"key":"50:37","surah":50,"ayah":37,"num":4667,"page":520,"words":[{"code":"пұ‘","page":520,"end":false},{"code":"пұ’","page":520,"end":false},{"code":"пұ“","page":520,"end":false},{"code":"пұ”","page":520,"end":false},{"code":"пұ•","page":520,"end":false},{"code":"пұ–","page":520,"end":false},{"code":"пұ—","page":520,"end":false},{"code":"пұҳ","page":520,"end":false},{"code":"пұҷ","page":520,"end":false},{"code":"пұҡ","page":520,"end":false},{"code":"пұӣ","page":520,"end":false},{"code":"пұң","page":520,"end":false},{"code":"пұқ","page":520,"end":false},{"code":"пұһ","page":520,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺШ°ЩҗЩғЩ’ШұЩҺЩүЩ° Щ„ЩҗЩ…ЩҺЩҶ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩҮЩҸЫҘ ЩӮЩҺЩ„Щ’ШЁЩҢ ШЈЩҺЩҲЩ’ ШЈЩҺЩ„Щ’ЩӮЩҺЩү ЩұЩ„ШіЩ‘ЩҺЩ…Щ’Ш№ЩҺ ЩҲЩҺЩҮЩҸЩҲЩҺ ШҙЩҺЩҮЩҗЩҠШҜЩҢЫӯ"},{"key":"50:38","surah":50,"ayah":38,"num":4668,"page":520,"words":[{"code":"пұҹ","page":520,"end":false},{"code":"пұ ","page":520,"end":false},{"code":"пұЎ","page":520,"end":false},{"code":"пұў","page":520,"end":false},{"code":"пұЈ","page":520,"end":false},{"code":"пұӨ","page":520,"end":false},{"code":"пұҘ","page":520,"end":false},{"code":"пұҰ","page":520,"end":false},{"code":"пұ§","page":520,"end":false},{"code":"пұЁ","page":520,"end":false},{"code":"пұ©","page":520,"end":false},{"code":"пұӘ","page":520,"end":false},{"code":"пұ«","page":520,"end":false},{"code":"пұ¬","page":520,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ Ш®ЩҺЩ„ЩҺЩӮЩ’ЩҶЩҺШ§ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§ ЩҒЩҗЩү ШіЩҗШӘЩ‘ЩҺШ©Щҗ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚЫў ЩҲЩҺЩ…ЩҺШ§ Щ…ЩҺШіЩ‘ЩҺЩҶЩҺШ§ Щ…ЩҗЩҶ Щ„Щ‘ЩҸШәЩҸЩҲШЁЩҚЫў"},{"key":"50:39","surah":50,"ayah":39,"num":4669,"page":520,"words":[{"code":"пұӯ","page":520,"end":false},{"code":"пұ®","page":520,"end":false},{"code":"пұҜ","page":520,"end":false},{"code":"пұ°","page":520,"end":false},{"code":"пұұ","page":520,"end":false},{"code":"пұІ","page":520,"end":false},{"code":"пұі","page":520,"end":false},{"code":"пұҙ","page":520,"end":false},{"code":"пұө","page":520,"end":false},{"code":"пұ¶","page":520,"end":false},{"code":"пұ·","page":520,"end":false},{"code":"пұё","page":520,"end":false},{"code":"пұ№","page":520,"end":true}],"text":"ЩҒЩҺЩұШөЩ’ШЁЩҗШұЩ’ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺШ§ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ЩҲЩҺШіЩҺШЁЩ‘ЩҗШӯЩ’ ШЁЩҗШӯЩҺЩ…Щ’ШҜЩҗ ШұЩҺШЁЩ‘ЩҗЩғЩҺ ЩӮЩҺШЁЩ’Щ„ЩҺ Ш·ЩҸЩ„ЩҸЩҲШ№Щҗ ЩұЩ„ШҙЩ‘ЩҺЩ…Щ’ШіЩҗ ЩҲЩҺЩӮЩҺШЁЩ’Щ„ЩҺ ЩұЩ„Щ’ШәЩҸШұЩҸЩҲШЁЩҗ"},{"key":"50:40","surah":50,"ayah":40,"num":4670,"page":520,"words":[{"code":"пұә","page":520,"end":false},{"code":"пұ»","page":520,"end":false},{"code":"пұј","page":520,"end":false},{"code":"пұҪ","page":520,"end":false},{"code":"пұҫ","page":520,"end":false},{"code":"пұҝ","page":520,"end":true}],"text":"ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҒЩҺШіЩҺШЁЩ‘ЩҗШӯЩ’ЩҮЩҸ ЩҲЩҺШЈЩҺШҜЩ’ШЁЩҺЩҖЩ°ШұЩҺ ЩұЩ„ШіЩ‘ЩҸШ¬ЩҸЩҲШҜЩҗ"},{"key":"50:41","surah":50,"ayah":41,"num":4671,"page":520,"words":[{"code":"пІҖ","page":520,"end":false},{"code":"пІҒ","page":520,"end":false},{"code":"пІӮ","page":520,"end":false},{"code":"пІғ","page":520,"end":false},{"code":"пІ„","page":520,"end":false},{"code":"пІ…","page":520,"end":false},{"code":"пІҶ","page":520,"end":false},{"code":"пІҮ","page":520,"end":true}],"text":"ЩҲЩҺЩұШіЩ’ШӘЩҺЩ…ЩҗШ№Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҸЩҶЩҺШ§ШҜЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩҺШ§ШҜЩҗ Щ…ЩҗЩҶ Щ…Щ‘ЩҺЩғЩҺШ§ЩҶЩҚЫў ЩӮЩҺШұЩҗЩҠШЁЩҚЫў"},{"key":"50:42","surah":50,"ayah":42,"num":4672,"page":520,"words":[{"code":"пІҲ","page":520,"end":false},{"code":"пІү","page":520,"end":false},{"code":"пІҠ","page":520,"end":false},{"code":"пІӢпІҢ","page":520,"end":false},{"code":"пІҚ","page":520,"end":false},{"code":"пІҺ","page":520,"end":false},{"code":"пІҸ","page":520,"end":false},{"code":"пІҗ","page":520,"end":true}],"text":"ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҸЩҲЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩҠЩ’ШӯЩҺШ©ЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҺЩҲЩ’Щ…ЩҸ ЩұЩ„Щ’Ш®ЩҸШұЩҸЩҲШ¬Щҗ"},{"key":"50:43","surah":50,"ayah":43,"num":4673,"page":520,"words":[{"code":"пІ‘","page":520,"end":false},{"code":"пІ’","page":520,"end":false},{"code":"пІ“","page":520,"end":false},{"code":"пІ”","page":520,"end":false},{"code":"пІ•","page":520,"end":false},{"code":"пІ–","page":520,"end":false},{"code":"пІ—","page":520,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺШ§ ЩҶЩҺШӯЩ’ЩҶЩҸ ЩҶЩҸШӯЩ’ЩүЩҗЫҰ ЩҲЩҺЩҶЩҸЩ…ЩҗЩҠШӘЩҸ ЩҲЩҺШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ ЩұЩ„Щ’Щ…ЩҺШөЩҗЩҠШұЩҸ"},{"key":"50:44","surah":50,"ayah":44,"num":4674,"page":520,"words":[{"code":"пІҳ","page":520,"end":false},{"code":"пІҷ","page":520,"end":false},{"code":"пІҡ","page":520,"end":false},{"code":"пІӣ","page":520,"end":false},{"code":"пІңпІқ","page":520,"end":false},{"code":"пІһ","page":520,"end":false},{"code":"пІҹ","page":520,"end":false},{"code":"пІ ","page":520,"end":false},{"code":"пІЎ","page":520,"end":false},{"code":"пІў","page":520,"end":true}],"text":"ЩҠЩҺЩҲЩ’Щ…ЩҺ ШӘЩҺШҙЩҺЩӮЩ‘ЩҺЩӮЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ШіЩҗШұЩҺШ§Ш№ЩӢЫӯШ§ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШӯЩҺШҙЩ’ШұЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ ЩҠЩҺШіЩҗЩҠШұЩҢЫӯ"},{"key":"50:45","surah":50,"ayah":45,"num":4675,"page":520,"words":[{"code":"пІЈ","page":520,"end":false},{"code":"пІӨ","page":520,"end":false},{"code":"пІҘ","page":520,"end":false},{"code":"пІҰпІ§","page":520,"end":false},{"code":"пІЁ","page":520,"end":false},{"code":"пІ©","page":520,"end":false},{"code":"пІӘ","page":520,"end":false},{"code":"пІ«п
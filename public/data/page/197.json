lse},{"code":"пұҠ","page":197,"end":false},{"code":"пұӢ","page":197,"end":false},{"code":"пұҢ","page":197,"end":false},{"code":"пұҚ","page":197,"end":true}],"text":"ЩҠЩҺШӯЩ’Щ„ЩҗЩҒЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺЩғЩҸЩ…Щ’ Щ„ЩҗЩҠЩҸШұЩ’Ш¶ЩҸЩҲЩғЩҸЩ…Щ’ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҸЩҮЩҸЫҘЩ“ ШЈЩҺШӯЩҺЩӮЩ‘ЩҸ ШЈЩҺЩҶ ЩҠЩҸШұЩ’Ш¶ЩҸЩҲЩҮЩҸ ШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"9:63","surah":9,"ayah":63,"num":1298,"page":197,"words":[{"code":"пұҺ","page":197,"end":false},{"code":"пұҸ","page":197,"end":false},{"code":"пұҗ","page":197,"end":false},{"code":"пұ‘","page":197,"end":false},{"code":"пұ’","page":197,"end":false},{"code":"пұ“","page":197,"end":false},{"code":"пұ”","page":197,"end":false},{"code":"пұ•","page":197,"end":false},{"code":"пұ–","page":197,"end":false},{"code":"пұ—","page":197,"end":false},{"code":"пұҳ","page":197,"end":false},{"code":"пұҷ","page":197,"end":false},{"code":"пұҡпұӣ","page":197,"end":false},{"code":"пұң","page":197,"end":false},{"code":"пұқ","page":197,"end":false},{"code":"пұһ","page":197,"end":false},{"code":"пұҹ","page":197,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ…ЩҺЩҶ ЩҠЩҸШӯЩҺШ§ШҜЩҗШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҺЩҮЩҸЫҘ ЩҶЩҺШ§ШұЩҺ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩӢЫӯШ§ ЩҒЩҗЩҠЩҮЩҺШ§ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩұЩ„Щ’Ш®ЩҗШІЩ’ЩүЩҸ ЩұЩ„Щ’Ш№ЩҺШёЩҗЩҠЩ…ЩҸ"},{"key":"9:64","surah":9,"ayah":64,"num":1299,"page":197,"words":[{"code":"пұ ","page":197,"end":false},{"code":"пұЎ","page":197,"end":false},{"code":"пұў","page":197,"end":false},{"code":"пұЈ","page":197,"end":false},{"code":"пұӨ","page":197,"end":false},{"code":"пұҘ","page":197,"end":false},{"code":"пұҰ","page":197,"end":false},{"code":"пұ§","page":197,"end":false},{"code":"пұЁ","page":197,"end":false},{"code":"пұ©пұӘ","page":197,"end":false},{"code":"пұ«","page":197,"end":false},{"code":"пұ¬","page":197,"end":false},{"code":"пұӯ","page":197,"end":false},{"code":"пұ®","page":197,"end":false},{"code":"пұҜ","page":197,"end":false},{"code":"пұ°","page":197,"end":false},{"code":"пұұ","page":197,"end":false},{"code":"пұІ","page":197,"end":true}],"text":"ЩҠЩҺШӯЩ’Ш°ЩҺШұЩҸ ЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ШЈЩҺЩҶ ШӘЩҸЩҶЩҺШІЩ‘ЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШіЩҸЩҲШұЩҺШ©ЩҢЫӯ ШӘЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…Щ’ Ыҡ ЩӮЩҸЩ„Щҗ ЩұШіЩ’ШӘЩҺЩҮЩ’ШІЩҗШЎЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҸШ®Щ’ШұЩҗШ¬ЩҢЫӯ Щ…Щ‘ЩҺШ§ ШӘЩҺШӯЩ’Ш°ЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"9:65","surah":9,"ayah":65,"num":1300,"page":197,"words":[{"code":"пұі","page":197,"end":false},{"code":"пұҙ","page":197,"end":false},{"code":"пұө","page":197,"end":false},{"code":"пұ¶","page":197,"end":false},{"code":"пұ·","page":197,"end":false},{"code":"пұё","page":197,"end":false},{"code":"пұ№пұә","page":197,"end":false},{"code":"пұ»","page":197,"end":false},{"code":"пұј","page":197,"end":false},{"code":"пұҪ","page":197,"end":false},{"code":"пұҫ","page":197,"end":false},{"code":"пұҝ","page":197,"end":false},{"code":"пІҖ","page":197,"end":false},{"code":"пІҒ","page":197,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШҰЩҗЩҶ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҶЩ‘ЩҺ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩғЩҸЩҶЩ‘ЩҺШ§ ЩҶЩҺШ®ЩҸЩҲШ¶ЩҸ ЩҲЩҺЩҶЩҺЩ„Щ’Ш№ЩҺШЁЩҸ Ыҡ ЩӮЩҸЩ„Щ’ ШЈЩҺШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҮЩҗЫҰ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШіЩ’ШӘЩҺЩҮЩ’ШІЩҗШЎЩҸЩҲЩҶЩҺ"},{"key":"9:66","surah":9,"ayah":66,"num":1301,"page":197,"words":[{"code":"пІӮ","page":197,"end":false},{"code":"пІғ","page":197,"end":false},{"code":"пІ„","page":197,"end":false},{"code":"пІ…","page":197,"end":false},{"code":"пІҶ","page":197,"end":false},{"code":"пІҮпІҲ","page":197,"end":false},{"code":"пІү","page":197,"end":false},{"code":"пІҠ","page":197,"end":false},{"code":"пІӢ","page":197,"end":false},{"code":"пІҢ","page":197,"end":false},{"code":"пІҚ","page":197,"end":false},{"code":"пІҺ","page":197,"end":false},{"code":"пІҸ","page":197,"end":false},{"code":"пІҗ","page":197,"end":false},{"code":"пІ‘","page":197,"end":false},{"code":"пІ’","page":197,"end":false},{"code":"пІ“","page":197,"end":true}],"text":"Щ„ЩҺШ§ ШӘЩҺШ№Щ’ШӘЩҺШ°ЩҗШұЩҸЩҲШ§Ыҹ ЩӮЩҺШҜЩ’ ЩғЩҺЩҒЩҺШұЩ’ШӘЩҸЩ… ШЁЩҺШ№Щ’ШҜЩҺ ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҗЩғЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶ ЩҶЩ‘ЩҺШ№Щ’ЩҒЩҸ Ш№ЩҺЩҶ Ш·ЩҺШ§Щ“ШҰЩҗЩҒЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶЩғЩҸЩ…Щ’ ЩҶЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩ’ Ш·ЩҺШ§Щ“ШҰЩҗЩҒЩҺШ©ЩӢЫў ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ Щ…ЩҸШ¬Щ’ШұЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"9:67","surah":9,"ayah":67,"num":1302,"page":197,"words":[{"code":"пІ”","page":197,"end":false},{"code":"пІ•","page":197,"end":false},{"code":"пІ–","page":197,"end":false},{"code":"пІ—","page":197,"end":false},{"code":"пІҳпІҷ","page":197,"end":false},{"code":"пІҡ","page":197,"end":false},{"code":"пІӣ","page":197,"end":false},{"code":"пІң","page":197,"end":false},{"code":"пІқ","page":197,"end":false},{"code":"пІһ","page":197,"end":false},{"code":"пІҹ","page":197,"end":false},{"code":"пІ пІЎ","page":197,"end":false},{"code":"пІў","page":197,"end":false},{"code":"пІЈ","page":197,"end":false},{"code":"пІӨпІҘ","page":197,"end":false},{"code":"пІҰ","page":197,"end":false},{"code":"пІ§","page":197,"end":false},{"code":"пІЁ","page":197,"end":false},{"code":"пІ©","page":197,"end":false},{"code":"пІӘ","page":197,"end":true}],"text":"ЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҸЩҲЩҶЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҺЩҖЩ°ШӘЩҸ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЫў ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ ЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ ЩҲЩҺЩҠЩҺЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺЩҠЩҺЩӮЩ’ШЁЩҗШ¶ЩҸЩҲЩҶЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩ…Щ’ Ыҡ ЩҶЩҺШіЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҒЩҺЩҶЩҺШіЩҗЩҠЩҺЩҮЩҸЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҗЩҠЩҶЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"9:68","surah":9,"ayah":68,"num":1303,"page":197,"words":[{"code":"пІ«","page":197,"end":false},{"code":"пІ¬","page":197,"end":false},{"code":"пІӯ","page":197,"end":false},{"code":"пІ®","page":197,"end":false},{"code":"пІҜ","page":197,"end":false},{"code":"пІ°","page":197,"end":false},{"code":"пІұ","page":197,"end":false},{"code":"пІІ","page":197,"end":false},{"code":"пІіпІҙ","page":197,"end":false},{"code":"пІө","page":197,"end":false},{"code":"пІ¶пІ·","page":197,"end":false},{"code":"пІё","page":197,"end":false},{"code":"пІ№пІә","page":197,"end":false},{"code":"пІ»","page":197,"end":false},{"code":"пІј","page":197,"end":false},{"code":"пІҪ","page":197,"end":false},{"code":"пІҫ","page":197,"end":true}],"text":"ЩҲЩҺШ№ЩҺШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҗЩҠЩҶЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸЩҶЩҺЩҖЩ°ЩҒЩҗЩӮЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ЩғЩҸЩҒЩ‘ЩҺШ§ШұЩҺ ЩҶЩҺШ§ШұЩҺ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҺ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Ыҡ ЩҮЩҗЩүЩҺ ШӯЩҺШіЩ’ШЁЩҸЩҮЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ„ЩҺШ№ЩҺЩҶЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ЩҲЩҺЩ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ Щ…Щ‘ЩҸЩӮЩҗЩҠЩ…ЩҢЫӯ"}]}
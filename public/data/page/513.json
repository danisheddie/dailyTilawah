 ЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩ’ЩғЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩӢШ§ ШЈЩҺЩ„ЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"48:17","surah":48,"ayah":17,"num":4600,"page":513,"words":[{"code":"пұ ","page":513,"end":false},{"code":"пұЎ","page":513,"end":false},{"code":"пұў","page":513,"end":false},{"code":"пұЈ","page":513,"end":false},{"code":"пұӨ","page":513,"end":false},{"code":"пұҘ","page":513,"end":false},{"code":"пұҰ","page":513,"end":false},{"code":"пұ§","page":513,"end":false},{"code":"пұЁ","page":513,"end":false},{"code":"пұ©","page":513,"end":false},{"code":"пұӘ","page":513,"end":false},{"code":"пұ«пұ¬","page":513,"end":false},{"code":"пұӯ","page":513,"end":false},{"code":"пұ®","page":513,"end":false},{"code":"пұҜ","page":513,"end":false},{"code":"пұ°","page":513,"end":false},{"code":"пұұ","page":513,"end":false},{"code":"пұІ","page":513,"end":false},{"code":"пұі","page":513,"end":false},{"code":"пұҙ","page":513,"end":false},{"code":"пұө","page":513,"end":false},{"code":"пұ¶пұ·","page":513,"end":false},{"code":"пұё","page":513,"end":false},{"code":"пұ№","page":513,"end":false},{"code":"пұә","page":513,"end":false},{"code":"пұ»","page":513,"end":false},{"code":"пұј","page":513,"end":false},{"code":"пұҪ","page":513,"end":true}],"text":"Щ„Щ‘ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ…ЩҺЩүЩ° ШӯЩҺШұЩҺШ¬ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ¬Щҗ ШӯЩҺШұЩҺШ¬ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺШұЩҗЩҠШ¶Щҗ ШӯЩҺШұЩҺШ¬ЩҢЫӯ Ы— ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҸШ·ЩҗШ№Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘ ЩҠЩҸШҜЩ’Ш®ЩҗЩ„Щ’ЩҮЩҸ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ы– ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШӘЩҺЩҲЩҺЩ„Щ‘ЩҺ ЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩ’ЩҮЩҸ Ш№ЩҺШ°ЩҺШ§ШЁЩӢШ§ ШЈЩҺЩ„ЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"48:18","surah":48,"ayah":18,"num":4601,"page":513,"words":[{"code":"пұҫ пұҝ","page":513,"end":false},{"code":"пІҖ","page":513,"end":false},{"code":"пІҒ","page":513,"end":false},{"code":"пІӮ","page":513,"end":false},{"code":"пІғ","page":513,"end":false},{"code":"пІ„","page":513,"end":false},{"code":"пІ…","page":513,"end":false},{"code":"пІҶ","page":513,"end":false},{"code":"пІҮ","page":513,"end":false},{"code":"пІҲ","page":513,"end":false},{"code":"пІү","page":513,"end":false},{"code":"пІҠ","page":513,"end":false},{"code":"пІӢ","page":513,"end":false},{"code":"пІҢ","page":513,"end":false},{"code":"пІҚ","page":513,"end":false},{"code":"пІҺ","page":513,"end":false},{"code":"пІҸ","page":513,"end":false},{"code":"пІҗ","page":513,"end":false},{"code":"пІ‘","page":513,"end":false},{"code":"пІ’","page":513,"end":true}],"text":"Ыһ Щ„Щ‘ЩҺЩӮЩҺШҜЩ’ ШұЩҺШ¶ЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ШҘЩҗШ°Щ’ ЩҠЩҸШЁЩҺШ§ЩҠЩҗШ№ЩҸЩҲЩҶЩҺЩғЩҺ ШӘЩҺШӯЩ’ШӘЩҺ ЩұЩ„ШҙЩ‘ЩҺШ¬ЩҺШұЩҺШ©Щҗ ЩҒЩҺШ№ЩҺЩ„ЩҗЩ…ЩҺ Щ…ЩҺШ§ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…Щ’ ЩҒЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„ШіЩ‘ЩҺЩғЩҗЩҠЩҶЩҺШ©ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺШ«ЩҺЩҖЩ°ШЁЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺШӘЩ’ШӯЩӢЫӯШ§ ЩӮЩҺШұЩҗЩҠШЁЩӢЫӯШ§"},{"key":"48:19","surah":48,"ayah":19,"num":4602,"page":513,"words":[{"code":"пІ“","page":513,"end":false},{"code":"пІ”","page":513,"end":false},{"code":"пІ•пІ–","page":513,"end":false},{"code":"пІ—","page":513,"end":false},{"code":"пІҳ","page":513,"end":false},{"code":"пІҷ","page":513,"end":false},{"code":"пІҡ","page":513,"end":false},{"code":"пІӣ","page":513,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШәЩҺШ§ЩҶЩҗЩ…ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩӢЫӯ ЩҠЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲЩҶЩҺЩҮЩҺШ§ Ы— ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺШІЩҗЩҠШІЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"48:20","surah":48,"ayah":20,"num":4603,"page":513,"words":[{"code":"пІң","page":513,"end":false},{"code":"пІқ","page":513,"end":false},{"code":"пІһ","page":513,"end":false},{"code":"пІҹ","page":513,"end":false},{"code":"пІ ","page":513,"end":false},{"code":"пІЎ","page":513,"end":false},{"code":"пІў","page":513,"end":false},{"code":"пІЈ","page":513,"end":false},{"code":"пІӨ","page":513,"end":false},{"code":"пІҘ","page":513,"end":false},{"code":"пІҰ","page":513,"end":false},{"code":"пІ§","page":513,"end":false},{"code":"пІЁ","page":513,"end":false},{"code":"пІ©","page":513,"end":false},{"code":"пІӘ","page":513,"end":false},{"code":"пІ«","page":513,"end":false},{"code":"пІ¬","page":513,"end":false},{"code":"пІӯ","page":513,"end":false},{"code":"пІ®","page":513,"end":true}],"text":"ЩҲЩҺШ№ЩҺШҜЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШәЩҺШ§ЩҶЩҗЩ…ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩӢЫӯ ШӘЩҺШЈЩ’Ш®ЩҸШ°ЩҸЩҲЩҶЩҺЩҮЩҺШ§ ЩҒЩҺШ№ЩҺШ¬Щ‘ЩҺЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗЫҰ ЩҲЩҺЩғЩҺЩҒЩ‘ЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩүЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҗШӘЩҺЩғЩҸЩҲЩҶЩҺ ШЎЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Щ„Щ‘ЩҗЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩҠЩҺЩғЩҸЩ…Щ’ ШөЩҗШұЩҺЩ°Ш·ЩӢЫӯШ§ Щ…Щ‘ЩҸШіЩ’ШӘЩҺЩӮЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"48:21","surah":48,"ayah":21,"num":4604,"page":513,"words":[{"code":"пІҜ","page":513,"end":false},{"code":"пІ°","page":513,"end":false},{"code":"пІұ","page":513,"end":false},{"code":"пІІ","page":513,"end":false},{"code":"пІі","page":513,"end":false},{"code":"пІҙ","page":513,"end":false},{"code":"пІө","page":513,"end":false},{"code":"пІ¶пІ·","page":513,"end":false},{"code":"пІё","page":513,"end":false},{"code":"пІ№","page":513,"end":false},{"code":"пІә","page":513,"end":false},{"code":"пІ»","page":513,"end":false},{"code":"пІј","page":513,"end":false},{"code":"пІҪ","page":513,"end":false},{"code":"пІҫ","page":513,"end":true}],"text":"ЩҲЩҺШЈЩҸШ®Щ’ШұЩҺЩүЩ° Щ„ЩҺЩ…Щ’ ШӘЩҺЩӮЩ’ШҜЩҗШұЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҺШ§ ЩӮЩҺШҜЩ’ ШЈЩҺШӯЩҺШ§Ш·ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҺШ§ Ыҡ ЩҲЩҺЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩӢЫӯШ§"},{"key":"48:22","surah":48,"ayah":22,"num":4605,"page":513,"words":[{"code":"пІҝ","page":513,"end":false},{"code":"піҖ","page":513,"end":false},{"code":"піҒ","page":513,"end":false},{"code":"піӮ","page":513,"end":false},{"code":"піғ","page":513,"end":false},{"code":"пі„","page":513,"end":false},{"code":"пі…","page":513,"end":false},{"code":"піҶ","page":513,"end":false},{"code":"піҮ","page":513,"end":false},{"code":"піҲ","page":513,"end":false},{"code":"піү","page":513,"end":false},{"code":"піҠ","page":513,"end":false},{"code":"піӢ","page":513,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩӮЩҺЩҖЩ°ШӘЩҺЩ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩҺЩ„Щ‘ЩҺЩҲЩҸШ§Ыҹ ЩұЩ„Щ’ШЈЩҺШҜЩ’ШЁЩҺЩҖЩ°ШұЩҺ Ш«ЩҸЩ…Щ‘ЩҺ Щ„ЩҺШ§ ЩҠЩҺШ¬ЩҗШҜЩҸЩҲЩҶЩҺ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§ ЩҲЩҺЩ„ЩҺШ§ ЩҶЩҺШөЩҗЩҠШұЩӢЫӯШ§"},{"key":"48:23","surah":48,"ayah":23,"num":4606,"page":513,"words":[{"code":"піҢ","page":513,"end":false},{"code":"піҚ","page":513,"end":false},{"code":"піҺ","page":513,"end":false},{"code":"піҸ","page":513,"end":false},{"code":"піҗ","page":513,"end":false},{"code":"пі‘","page":513,"end":false},{"code":"пі’пі“","page":513,"end":false},{"code":"пі”","page":513,"end":false},{"code":"пі•","page":513,"end":false},{"code":"пі–","page":513,"end":false},{"code":"пі—","page":513,"end":false},{"code":"піҳ","page":513,"end":false},{"code":"піҷ","page":513,"end":true}],"text":"ШіЩҸЩҶЩ‘ЩҺШ©ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ЩӮЩҺШҜЩ’ Ш®ЩҺЩ„ЩҺШӘЩ’ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ Ы– ЩҲЩҺЩ„ЩҺЩҶ ШӘЩҺШ¬ЩҗШҜЩҺ Щ„ЩҗШіЩҸЩҶЩ‘ЩҺШ©Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҺШЁЩ’ШҜЩҗЩҠЩ„ЩӢЫӯШ§"}]}
s":[{"code":"піҢ","end":false},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":true},{"code":"пі–","end":false},{"code":"пі—","end":false}]},{"lineNumber":15,"words":[{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣпің","end":false},{"code":"піқ","end":false},{"code":"піһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":false},{"code":"піЎ","end":false},{"code":"піў","end":true}]}],"verses":[{"key":"13:19","surah":13,"ayah":19,"num":1726,"page":252,"words":[{"code":"пұҒ пұӮ","page":252,"end":false},{"code":"пұғ","page":252,"end":false},{"code":"пұ„","page":252,"end":false},{"code":"пұ…","page":252,"end":false},{"code":"пұҶ","page":252,"end":false},{"code":"пұҮ","page":252,"end":false},{"code":"пұҲ","page":252,"end":false},{"code":"пұү","page":252,"end":false},{"code":"пұҠ","page":252,"end":false},{"code":"пұӢ","page":252,"end":false},{"code":"пұҢпұҚ","page":252,"end":false},{"code":"пұҺ","page":252,"end":false},{"code":"пұҸ","page":252,"end":false},{"code":"пұҗ","page":252,"end":false},{"code":"пұ‘","page":252,"end":false},{"code":"пұ’","page":252,"end":true}],"text":"Ыһ ШЈЩҺЩҒЩҺЩ…ЩҺЩҶ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҶШІЩҗЩ„ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҺ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҺ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘ЩҸ ЩғЩҺЩ…ЩҺЩҶЩ’ ЩҮЩҸЩҲЩҺ ШЈЩҺШ№Щ’Щ…ЩҺЩүЩ°Щ“ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩҠЩҺШӘЩҺШ°ЩҺЩғЩ‘ЩҺШұЩҸ ШЈЩҸЩҲЫҹЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЈЩҺЩ„Щ’ШЁЩҺЩҖЩ°ШЁЩҗ"},{"key":"13:20","surah":13,"ayah":20,"num":1727,"page":252,"words":[{"code":"пұ“","page":252,"end":false},{"code":"пұ”","page":252,"end":false},{"code":"пұ•","page":252,"end":false},{"code":"пұ–","page":252,"end":false},{"code":"пұ—","page":252,"end":false},{"code":"пұҳ","page":252,"end":false},{"code":"пұҷ","page":252,"end":false},{"code":"пұҡ","page":252,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҸЩҲЩҒЩҸЩҲЩҶЩҺ ШЁЩҗШ№ЩҺЩҮЩ’ШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩҶЩӮЩҸШ¶ЩҸЩҲЩҶЩҺ ЩұЩ„Щ’Щ…ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҺ"},{"key":"13:21","surah":13,"ayah":21,"num":1728,"page":252,"words":[{"code":"пұӣ","page":252,"end":false},{"code":"пұң","page":252,"end":false},{"code":"пұқ","page":252,"end":false},{"code":"пұһ","page":252,"end":false},{"code":"пұҹ","page":252,"end":false},{"code":"пұ ","page":252,"end":false},{"code":"пұЎ","page":252,"end":false},{"code":"пұў","page":252,"end":false},{"code":"пұЈ","page":252,"end":false},{"code":"пұӨ","page":252,"end":false},{"code":"пұҘ","page":252,"end":false},{"code":"пұҰ","page":252,"end":false},{"code":"пұ§","page":252,"end":false},{"code":"пұЁ","page":252,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШөЩҗЩ„ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§Щ“ ШЈЩҺЩ…ЩҺШұЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҶ ЩҠЩҸЩҲШөЩҺЩ„ЩҺ ЩҲЩҺЩҠЩҺШ®Щ’ШҙЩҺЩҲЩ’ЩҶЩҺ ШұЩҺШЁЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺЩҠЩҺШ®ЩҺШ§ЩҒЩҸЩҲЩҶЩҺ ШіЩҸЩҲЩ“ШЎЩҺ ЩұЩ„Щ’ШӯЩҗШіЩҺШ§ШЁЩҗ"},{"key":"13:22","surah":13,"ayah":22,"num":1729,"page":252,"words":[{"code":"пұ©","page":252,"end":false},{"code":"пұӘ","page":252,"end":false},{"code":"пұ«","page":252,"end":false},{"code":"пұ¬","page":252,"end":false},{"code":"пұӯ","page":252,"end":false},{"code":"пұ®","page":252,"end":false},{"code":"пұҜ","page":252,"end":false},{"code":"пұ°","page":252,"end":false},{"code":"пұұ","page":252,"end":false},{"code":"пұІ","page":252,"end":false},{"code":"пұі","page":252,"end":false},{"code":"пұҙ","page":252,"end":false},{"code":"пұө","page":252,"end":false},{"code":"пұ¶","page":252,"end":false},{"code":"пұ·","page":252,"end":false},{"code":"пұё","page":252,"end":false},{"code":"пұ№","page":252,"end":false},{"code":"пұә","page":252,"end":false},{"code":"пұ»","page":252,"end":false},{"code":"пұј","page":252,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШөЩҺШЁЩҺШұЩҸЩҲШ§Ыҹ ЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ ЩҲЩҺШ¬Щ’ЩҮЩҗ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩӮЩҺШ§Щ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЈЩҺЩҶЩҒЩҺЩӮЩҸЩҲШ§Ыҹ Щ…ЩҗЩ…Щ‘ЩҺШ§ ШұЩҺШІЩҺЩӮЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ШіЩҗШұЩ‘ЩӢЫӯШ§ ЩҲЩҺШ№ЩҺЩ„ЩҺШ§ЩҶЩҗЩҠЩҺШ©ЩӢЫӯ ЩҲЩҺЩҠЩҺШҜЩ’ШұЩҺШЎЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’ШӯЩҺШіЩҺЩҶЩҺШ©Щҗ ЩұЩ„ШіЩ‘ЩҺЩҠЩ‘ЩҗШҰЩҺШ©ЩҺ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ Ш№ЩҸЩӮЩ’ШЁЩҺЩү ЩұЩ„ШҜЩ‘ЩҺШ§ШұЩҗ"},{"key":"13:23","surah":13,"ayah":23,"num":1730,"page":252,"words":[{"code":"пұҪ","page":252,"end":false},{"code":"пұҫ","page":252,"end":false},{"code":"пұҝ","page":252,"end":false},{"code":"пІҖ","page":252,"end":false},{"code":"пІҒ","page":252,"end":false},{"code":"пІӮ","page":252,"end":false},{"code":"пІғ","page":252,"end":false},{"code":"пІ„","page":252,"end":false},{"code":"пІ…пІҶ","page":252,"end":false},{"code":"пІҮ","page":252,"end":false},{"code":"пІҲ","page":252,"end":false},{"code":"пІү","page":252,"end":false},{"code":"пІҠ","page":252,"end":false},{"code":"пІӢ","page":252,"end":false},{"code":"пІҢ","page":252,"end":false},{"code":"пІҚ","page":252,"end":true}],"text":"Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҸ Ш№ЩҺШҜЩ’ЩҶЩҚЫў ЩҠЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲЩҶЩҺЩҮЩҺШ§ ЩҲЩҺЩ…ЩҺЩҶ ШөЩҺЩ„ЩҺШӯЩҺ Щ…ЩҗЩҶЩ’ ШЎЩҺШ§ШЁЩҺШ§Щ“ШҰЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШ°ЩҸШұЩ‘ЩҗЩҠЩ‘ЩҺЩҖЩ°ШӘЩҗЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺЩұЩ„Щ’Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©ЩҸ ЩҠЩҺШҜЩ’Ш®ЩҸЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШЁЩҺШ§ШЁЩҚЫў"},{"key":"13:24","surah":13,"ayah":24,"num":1731,"page":252,"words":[{"code":"пІҺ","page":252,"end":false},{"code":"пІҸ","page":252,"end":false},{"code":"пІҗ","page":252,"end":false},{"code":"пІ‘пІ’","page":252,"end":false},{"code":"пІ“","page":252,"end":false},{"code":"пІ”","page":252,"end":false},{"code":"пІ•","page":252,"end":false},{"code":"пІ–","page":252,"end":true}],"text":"ШіЩҺЩ„ЩҺЩҖЩ°Щ…ЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ШөЩҺШЁЩҺШұЩ’ШӘЩҸЩ…Щ’ Ыҡ ЩҒЩҺЩҶЩҗШ№Щ’Щ…ЩҺ Ш№ЩҸЩӮЩ’ШЁЩҺЩү ЩұЩ„ШҜЩ‘ЩҺШ§ШұЩҗ"},{"key":"13:25","surah":13,"ayah":25,"num":1732,"page":252,"words":[{"code":"пІ—","page":252,"end":false},{"code":"пІҳ","page":252,"end":false},{"code":"пІҷ","page":252,"end":false},{"code":"пІҡ","page":252,"end":false},{"code":"пІӣ","page":252,"end":false},{"code":"пІң","page":252,"end":false},{"code":"пІқ","page":252,"end":false},{"co
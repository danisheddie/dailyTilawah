Щ„Щ‘ЩҗЩӮЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ„ЩҗШ№ЩҗШҜЩ‘ЩҺШӘЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҲЩҺШЈЩҺШӯЩ’ШөЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҗШҜЩ‘ЩҺШ©ЩҺ Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҸЩ…Щ’ Ы– Щ„ЩҺШ§ ШӘЩҸШ®Щ’ШұЩҗШ¬ЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҗЩҶЫў ШЁЩҸЩҠЩҸЩҲШӘЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ®Щ’ШұЩҸШ¬Щ’ЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҶЩҺ ШЁЩҗЩҒЩҺЩҖЩ°ШӯЩҗШҙЩҺШ©ЩҚЫў Щ…Щ‘ЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҺШ©ЩҚЫў Ыҡ ЩҲЩҺШӘЩҗЩ„Щ’ЩғЩҺ ШӯЩҸШҜЩҸЩҲШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШӘЩҺШ№ЩҺШҜЩ‘ЩҺ ШӯЩҸШҜЩҸЩҲШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩӮЩҺШҜЩ’ ШёЩҺЩ„ЩҺЩ…ЩҺ ЩҶЩҺЩҒЩ’ШіЩҺЩҮЩҸЫҘ Ыҡ Щ„ЩҺШ§ ШӘЩҺШҜЩ’ШұЩҗЩү Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҸШӯЩ’ШҜЩҗШ«ЩҸ ШЁЩҺШ№Щ’ШҜЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЈЩҺЩ…Щ’ШұЩӢЫӯШ§"},{"key":"65:2","surah":65,"ayah":2,"num":5219,"page":558,"words":[{"code":"пұ°","page":558,"end":false},{"code":"пұұ","page":558,"end":false},{"code":"пұІ","page":558,"end":false},{"code":"пұі","page":558,"end":false},{"code":"пұҙ","page":558,"end":false},{"code":"пұө","page":558,"end":false},{"code":"пұ¶","page":558,"end":false},{"code":"пұ·","page":558,"end":false},{"code":"пұё","page":558,"end":false},{"code":"пұ№","page":558,"end":false},{"code":"пұә","page":558,"end":false},{"code":"пұ»","page":558,"end":false},{"code":"пұј","page":558,"end":false},{"code":"пұҪ","page":558,"end":false},{"code":"пұҫпұҝ","page":558,"end":false},{"code":"пІҖ","page":558,"end":false},{"code":"пІҒ","page":558,"end":false},{"code":"пІӮ","page":558,"end":false},{"code":"пІғ","page":558,"end":false},{"code":"пІ„","page":558,"end":false},{"code":"пІ…","page":558,"end":false},{"code":"пІҶ","page":558,"end":false},{"code":"пІҮ","page":558,"end":false},{"code":"пІҲпІү","page":558,"end":false},{"code":"пІҠ","page":558,"end":false},{"code":"пІӢ","page":558,"end":false},{"code":"пІҢ","page":558,"end":false},{"code":"пІҚ","page":558,"end":false},{"code":"пІҺ","page":558,"end":false},{"code":"пІҸ","page":558,"end":false},{"code":"пІҗ","page":558,"end":true}],"text":"ЩҒЩҺШҘЩҗШ°ЩҺШ§ ШЁЩҺЩ„ЩҺШәЩ’ЩҶЩҺ ШЈЩҺШ¬ЩҺЩ„ЩҺЩҮЩҸЩҶЩ‘ЩҺ ЩҒЩҺШЈЩҺЩ…Щ’ШіЩҗЩғЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗЩ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҚ
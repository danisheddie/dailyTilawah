пІҒ","page":87,"end":false},{"code":"пІӮ","page":87,"end":false},{"code":"пІғ","page":87,"end":false},{"code":"пІ„","page":87,"end":false},{"code":"пІ…","page":87,"end":false},{"code":"пІҶ","page":87,"end":false},{"code":"пІҮ","page":87,"end":false},{"code":"пІҲпІү","page":87,"end":false},{"code":"пІҠ","page":87,"end":false},{"code":"пІӢ","page":87,"end":false},{"code":"пІҢ","page":87,"end":false},{"code":"пІҚ","page":87,"end":false},{"code":"пІҺ","page":87,"end":false},{"code":"пІҸ","page":87,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ШіЩҺЩҲЩ’ЩҒЩҺ ЩҶЩҸШөЩ’Щ„ЩҗЩҠЩҮЩҗЩ…Щ’ ЩҶЩҺШ§ШұЩӢЫӯШ§ ЩғЩҸЩ„Щ‘ЩҺЩ…ЩҺШ§ ЩҶЩҺШ¶ЩҗШ¬ЩҺШӘЩ’ Ш¬ЩҸЩ„ЩҸЩҲШҜЩҸЩҮЩҸЩ… ШЁЩҺШҜЩ‘ЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ Ш¬ЩҸЩ„ЩҸЩҲШҜЩӢШ§ ШәЩҺЩҠЩ’ШұЩҺЩҮЩҺШ§ Щ„ЩҗЩҠЩҺШ°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҺ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺШІЩҗЩҠШІЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:57","surah":4,"ayah":57,"num":550,"page":87,"words":[{"code":"пІҗ","page":87,"end":false},{"code":"пІ‘","page":87,"end":false},{"code":"пІ’","page":87,"end":false},{"code":"пІ“","page":87,"end":false},{"code":"пІ”","page":87,"end":false},{"code":"пІ•","page":87,"end":false},{"code":"пІ–","page":87,"end":false},{"code":"пІ—","page":87,"end":false},{"code":"пІҳ","page":87,"end":false},{"code":"пІҷ","page":87,"end":false},{"code":"пІҡ","page":87,"end":false},{"code":"пІӣ","page":87,"end":false},{"code":"пІңпІқ","page":87,"end":false},{"code":"пІһ","page":87,"end":false},{"code":"пІҹ","page":87,"end":false},{"code":"пІ ","page":87,"end":false},{"code":"пІЎпІў","page":87,"end":false},{"code":"пІЈ","page":87,"end":false},{"code":"пІӨ","page":87,"end":false},{"code":"пІҘ","page":87,"end":false},{"code":"пІҰ","page":87,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ШіЩҺЩҶЩҸШҜЩ’Ш®ЩҗЩ„ЩҸЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺШЁЩҺШҜЩӢЫӯШ§ Ы– Щ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҢЫӯ Щ…Щ‘ЩҸШ·ЩҺЩҮЩ‘ЩҺШұЩҺШ©ЩҢЫӯ Ы– ЩҲЩҺЩҶЩҸШҜЩ’Ш®ЩҗЩ„ЩҸЩҮЩҸЩ…Щ’ ШёЩҗЩ„Щ‘ЩӢЫӯШ§ ШёЩҺЩ„ЩҗЩҠЩ„ЩӢШ§"},{"key":"4:58","surah":4,"ayah":58,"num":551,"page":87,"words":[{"code":"пІ§ пІЁ","page":87,"end":false},{"code":"пІ©","page":87,"end":false},{"code":"пІӘ","page":87,"end":false},{"code":"пІ«","page":87,"end":false},{"code":"пІ¬","page":87,"end":false},{"code":"пІӯ","page":87,"end":false},{"code":"пІ®","page":87,"end":false},{"code":"пІҜ","page":87,"end":false},{"code":"пІ°","page":87,"end":false},{"code":"пІұ","page":87,"end":false},{"code":"пІІ","page":87,"end":false},{"code":"пІі","page":87,"end":false},{"code":"пІҙ","page":87,"end":false},{"code":"пІө","page":87,"end":false},{"code":"пІ¶пІ·","page":87,"end":false},{"code":"пІё","page":87,"end":false},{"code":"пІ№","page":87,"end":false},{"code":"пІә","page":87,"end":false},{"code":"пІ»","page":87,"end":false},{"code":"пІјпІҪ","page":87,"end":false},{"code":"пІҫ","page":87,"end":false},{"code":"пІҝ","page":87,"end":false},{"code":"піҖ","page":87,"end":false},{"code":"піҒ","page":87,"end":false},{"code":"піӮ","page":87,"end":false},{"code":"піғ","page":87,"end":true}],"text":"Ыһ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ШӘЩҸШӨЩҺШҜЩ‘ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЈЩҺЩ…ЩҺЩҖЩ°ЩҶЩҺЩҖЩ°ШӘЩҗ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҺШ§ ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШӯЩҺЩғЩҺЩ…Щ’ШӘЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШЈЩҺЩҶ ШӘЩҺШӯЩ’ЩғЩҸЩ…ЩҸЩҲШ§Ыҹ ШЁЩҗЩұЩ„Щ’Ш№ЩҺШҜЩ’Щ„Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҶЩҗШ№ЩҗЩ…Щ‘ЩҺШ§ ЩҠЩҺШ№ЩҗШёЩҸЩғЩҸЩ… ШЁЩҗЩҮЩҗЫҰЩ“ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ ШіЩҺЩ…ЩҗЩҠШ№ЩӢЫўШ§ ШЁЩҺШөЩҗЩҠШұЩӢЫӯШ§"},{"key":"4:59","surah":4,"ayah":59,"num":552,"page":87,"words":[{"code":"пі„","page":87,"end":false},{"code":"пі…","page":87,"end":false},{"code":"піҶ","page":87,"end":false},{"code":"піҮ","page":87,"end":false},{"code":"піҲ","page":87,"end":false},{"code":"піү","page":87,"end":false},{"code":"піҠ","page":87,"end":false},{"code":"піӢ","page":87,"end":false},{"code":"піҢ","page":87,"end":false},{"code":"піҚпіҺ","page":87,"end":false},{"code":"піҸ","page":87,"end":false},{"code":"піҗ","page":87,"end":false},{"code":"пі‘","page":87,"end":false},{"code":"пі’","page":87,"end":false},{"code":"пі“","page":87,"end":false},{"code":"пі”","page":87,"end":false},{"code":"пі•","page":87,"end":false},{"code":"пі–","page":87,"end":false},{"code":"пі—","page":87,"end":false},{"code":"піҳ","page":87,"end":false},{"code":"піҷ","page":87,"end":false},{"code":"піҡ","page":87,"end":false},{"code":"піӣ","page":87,"end":false},{"code":"піңпіқ","page":87,"end":false},{"code":"піһ","page":87,"end":false},{"code":"піҹ","page":87,"end":false},{"code":"пі ","page":87,"end":false},{"code":"піЎ","page":87,"end":false},{"code":"піў","page":87,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШЈЩҺШ·ЩҗЩҠШ№ЩҸЩҲШ§Ыҹ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„ЩҺ ЩҲЩҺШЈЩҸЩҲЫҹЩ„ЩҗЩү ЩұЩ„Щ’ШЈЩҺЩ…Щ’ШұЩҗ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ы– ЩҒЩҺШҘЩҗЩҶ ШӘЩҺЩҶЩҺЩҖЩ°ШІЩҺШ№Щ’ШӘЩҸЩ…Щ’ ЩҒЩҗЩү ШҙЩҺЩүЩ’ШЎЩҚЫў ЩҒЩҺШұЩҸШҜЩ‘ЩҸЩҲЩҮЩҸ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…Щҗ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ ЩҲЩҺШЈЩҺШӯЩ’ШіЩҺЩҶЩҸ ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„ЩӢШ§"}]}
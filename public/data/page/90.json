’ШҙЩҺЩҲЩ’ЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩғЩҺШ®ЩҺШҙЩ’ЩҠЩҺШ©Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺЩҲЩ’ ШЈЩҺШҙЩҺШҜЩ‘ЩҺ Ш®ЩҺШҙЩ’ЩҠЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§ Щ„ЩҗЩ…ЩҺ ЩғЩҺШӘЩҺШЁЩ’ШӘЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ ЩұЩ„Щ’ЩӮЩҗШӘЩҺШ§Щ„ЩҺ Щ„ЩҺЩҲЩ’Щ„ЩҺШ§Щ“ ШЈЩҺШ®Щ‘ЩҺШұЩ’ШӘЩҺЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҚЫў ЩӮЩҺШұЩҗЩҠШЁЩҚЫў Ы— ЩӮЩҸЩ„Щ’ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҸ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩҢЫӯ ЩҲЩҺЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©ЩҸ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҗЩ…ЩҺЩҶЩҗ ЩұШӘЩ‘ЩҺЩӮЩҺЩүЩ° ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ ЩҒЩҺШӘЩҗЩҠЩ„ЩӢШ§"},{"key":"4:78","surah":4,"ayah":78,"num":571,"page":90,"words":[{"code":"пІ«","page":90,"end":false},{"code":"пІ¬","page":90,"end":false},{"code":"пІӯ","page":90,"end":false},{"code":"пІ®","page":90,"end":false},{"code":"пІҜ","page":90,"end":false},{"code":"пІ°","page":90,"end":false},{"code":"пІұ","page":90,"end":false},{"code":"пІІ","page":90,"end":false},{"code":"пІіпІҙ","page":90,"end":false},{"code":"пІө","page":90,"end":false},{"code":"пІ¶","page":90,"end":false},{"code":"пІ·","page":90,"end":false},{"code":"пІё","page":90,"end":false},{"code":"пІ№","page":90,"end":false},{"code":"пІә","page":90,"end":false},{"code":"пІ»","page":90,"end":false},{"code":"пІјпІҪ","page":90,"end":false},{"code":"пІҫ","page":90,"end":false},{"code":"пІҝ","page":90,"end":false},{"code":"піҖ","page":90,"end":false},{"code":"піҒ","page":90,"end":false},{"code":"піӮ","page":90,"end":false},{"code":"піғ","page":90,"end":false},{"code":"пі„пі…","page":90,"end":false},{"code":"піҶ","page":90,"end":false},{"code":"піҮ","page":90,"end":false},{"code":"піҲ","page":90,"end":false},{"code":"піү","page":90,"end":false},{"code":"піҠпіӢ","page":90,"end":false},{"code":"піҢ","page":90,"end":false},{"code":"піҚ","page":90,"end":false},{"code":"піҺ","page":90,"end":false},{"code":"піҸ","page":90,"end":false},{"code":"піҗ","page":90,"end":false},{"code":"пі‘","page":90,"end":false},{"code":"пі’","page":90,"end":false},{"code":"пі“","page":90,"end":true}],"text":"ШЈЩҺЩҠЩ’ЩҶЩҺЩ…ЩҺШ§ ШӘЩҺЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ЩҠЩҸШҜЩ’ШұЩҗЩғЩғЩ‘ЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҸ ЩҲЩҺЩ„ЩҺЩҲЩ’ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ЩҒЩҗЩү ШЁЩҸШұЩҸЩҲШ¬ЩҚЫў Щ…Щ‘ЩҸШҙЩҺЩҠЩ‘ЩҺШҜЩҺШ©ЩҚЫў Ы— ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШөЩҗШЁЩ’ЩҮЩҸЩ…Щ’ ШӯЩҺШіЩҺЩҶЩҺШ©ЩҢЫӯ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШөЩҗШЁЩ’ЩҮЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗШҰЩҺШ©ЩҢЫӯ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲШ§Ыҹ ЩҮЩҺЩҖЩ°Ш°ЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗЩғЩҺ Ыҡ ЩӮЩҸЩ„Щ’ ЩғЩҸЩ„Щ‘ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҒЩҺЩ…ЩҺШ§Щ„Щҗ ЩҮЩҺЩҖЩ°Щ“ШӨЩҸЩ„ЩҺШ§Щ“ШЎЩҗ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…Щҗ Щ„ЩҺШ§ ЩҠЩҺЩғЩҺШ§ШҜЩҸЩҲЩҶЩҺ ЩҠЩҺЩҒЩ’ЩӮЩҺЩҮЩҸЩҲЩҶЩҺ ШӯЩҺШҜЩҗЩҠШ«ЩӢЫӯШ§"},{"key":"4:79","surah":4,"ayah":79,"num":572,"page":90,"words":[{"code":"пі”","page":90,"end":false},{"code":"пі•","page":90,"end":false},{"code":"пі–","page":90,"end":false},{"code":"пі—","page":90,"end":false},{"code":"піҳ","page":90,"end":false},{"code":"піҷпіҡ","page":90,"end":false},{"code":"піӣ","page":90,"end":false},{"code":"пің","page":90,"end":false},{"code":"піқ","page":90,"end":false},{"code":"піһ","page":90,"end":false},{"code":"піҹ","page":90,"end":false},{"code":"пі піЎ","page":90,"end":false},{"code":"піў","page":90,"end":false},{"code":"піЈ","page":90,"end":false},{"code":"піӨпіҘ","page":90,"end":false},{"code":"піҰ","page":90,"end":false},{"code":"пі§","page":90,"end":false},{"code":"піЁ","page":90,"end":false},{"code":"пі©","page":90,"end":true}],"text":"Щ…Щ‘ЩҺШ§Щ“ ШЈЩҺШөЩҺШ§ШЁЩҺЩғЩҺ Щ…ЩҗЩҶЩ’ ШӯЩҺШіЩҺЩҶЩҺШ©ЩҚЫў ЩҒЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺШөЩҺШ§ШЁЩҺЩғЩҺ Щ…ЩҗЩҶ ШіЩҺЩҠЩ‘ЩҗШҰЩҺШ©ЩҚЫў ЩҒЩҺЩ…ЩҗЩҶ ЩҶЩ‘ЩҺЩҒЩ’ШіЩҗЩғЩҺ Ыҡ ЩҲЩҺШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺЩҖЩ°ЩғЩҺ Щ„ЩҗЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ШұЩҺШіЩҸЩҲЩ„ЩӢЫӯШ§ Ыҡ ЩҲЩҺЩғЩҺЩҒЩҺЩүЩ° ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҙЩҺЩҮЩҗЩҠШҜЩӢЫӯШ§"}]}
age":198,"end":false},{"code":"пІӣ","page":198,"end":false},{"code":"пІң","page":198,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҺЩҖЩ°ШӘЩҸ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҸ ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ ЩҠЩҺШЈЩ’Щ…ЩҸШұЩҸЩҲЩҶЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ ЩҲЩҺЩҠЩҺЩҶЩ’ЩҮЩҺЩҲЩ’ЩҶЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩғЩҺШұЩҗ ЩҲЩҺЩҠЩҸЩӮЩҗЩҠЩ…ЩҸЩҲЩҶЩҺ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩҠЩҸШӨЩ’ШӘЩҸЩҲЩҶЩҺ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺЩҠЩҸШ·ЩҗЩҠШ№ЩҸЩҲЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҺЩҮЩҸЫҘЩ“ Ыҡ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШіЩҺЩҠЩҺШұЩ’ШӯЩҺЩ…ЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺШІЩҗЩҠШІЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"},{"key":"9:72","surah":9,"ayah":72,"num":1307,"page":198,"words":[{"code":"пІқ","page":198,"end":false},{"code":"пІһ","page":198,"end":false},{"code":"пІҹ","page":198,"end":false},{"code":"пІ ","page":198,"end":false},{"code":"пІЎ","page":198,"end":false},{"code":"пІў","page":198,"end":false},{"code":"пІЈ","page":198,"end":false},{"code":"пІӨ","page":198,"end":false},{"code":"пІҘ","page":198,"end":false},{"code":"пІҰ","page":198,"end":false},{"code":"пІ§","page":198,"end":false},{"code":"пІЁ","page":198,"end":false},{"code":"пІ©","page":198,"end":false},{"code":"пІӘ","page":198,"end":false},{"code":"пІ«","page":198,"end":false},{"code":"пІ¬пІӯ","page":198,"end":false},{"code":"пІ®","page":198,"end":false},{"code":"пІҜ","page":198,"end":false},{"code":"пІ°","page":198,"end":false},{"code":"пІұпІІ","page":198,"end":false},{"code":"пІі","page":198,"end":false},{"code":"пІҙ","page":198,"end":false},{"code":"пІө","page":198,"end":false},{"code":"пІ¶","page":198,"end":false},{"code":"пІ·","page":198,"end":true}],"text":"ЩҲЩҺШ№ЩҺШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҲЩҺЩ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҶЩҺ Ш·ЩҺЩҠЩ‘ЩҗШЁЩҺШ©ЩӢЫӯ ЩҒЩҗЩү Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҗ Ш№ЩҺШҜЩ’ЩҶЩҚЫў Ыҡ ЩҲЩҺШұЩҗШ¶Щ’ЩҲЩҺЩ°ЩҶЩҢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺЩғЩ’ШЁЩҺШұЩҸ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ЩҒЩҺЩҲЩ’ШІЩҸ ЩұЩ„Щ’Ш№ЩҺШёЩҗЩҠЩ…ЩҸ"}]}
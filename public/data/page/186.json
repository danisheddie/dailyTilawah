пІ‘","page":186,"end":false},{"code":"пІ’","page":186,"end":false},{"code":"пІ“","page":186,"end":false},{"code":"пІ”пІ•","page":186,"end":false},{"code":"пІ–","page":186,"end":false},{"code":"пІ—","page":186,"end":false},{"code":"пІҳ","page":186,"end":false},{"code":"пІҷ","page":186,"end":false},{"code":"пІҡ","page":186,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩҮЩҺШ§Ш¬ЩҺШұЩҸЩҲШ§Ыҹ ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҮЩҺШҜЩҸЩҲШ§Ыҹ ШЁЩҗШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§ЩҲЩҺЩҲШ§Ыҹ ЩҲЩ‘ЩҺЩҶЩҺШөЩҺШұЩҸЩҲЩ“Ш§Ыҹ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҸ ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҸЩҮЩҺШ§Ш¬ЩҗШұЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩҠЩҺШӘЩҗЩҮЩҗЩ… Щ…Щ‘ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҸЩҮЩҺШ§Ш¬ЩҗШұЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺШҘЩҗЩҶЩҗ ЩұШіЩ’ШӘЩҺЩҶШөЩҺШұЩҸЩҲЩғЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҗЩҠЩҶЩҗ ЩҒЩҺШ№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҺШөЩ’ШұЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ° ЩӮЩҺЩҲЩ’Щ…ЩҚЫӯ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҢЫӯ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ ШЁЩҺШөЩҗЩҠШұЩҢЫӯ"},{"key":"8:73","surah":8,"ayah":73,"num":1233,"page":186,"words":[{"code":"пІӣ","page":186,"end":false},{"code":"пІң","page":186,"end":false},{"code":"пІқ","page":186,"end":false},{"code":"пІһ","page":186,"end":false},{"code":"пІҹпІ ","page":186,"end":false},{"code":"пІЎ","page":186,"end":false},{"code":"пІў","page":186,"end":false},{"code":"пІЈ","page":186,"end":false},{"code":"пІӨ","page":186,"end":false},{"code":"пІҘ","page":186,"end":false},{"code":"пІҰ","page":186,"end":false},{"code":"пІ§","page":186,"end":false},{"code":"пІЁ","page":186,"end":false},{"code":"пІ©","page":186,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҺШ№Щ’Ш¶ЩҸЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҸ ШЁЩҺШ№Щ’Ш¶ЩҚ Ыҡ ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲЩҮЩҸ ШӘЩҺЩғЩҸЩҶ ЩҒЩҗШӘЩ’ЩҶЩҺШ©ЩҢЫӯ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ 
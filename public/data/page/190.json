0,"end":false},{"code":"пұҠ","page":190,"end":false},{"code":"пұӢ","page":190,"end":true}],"text":"ЩҠЩҸШЁЩҺШҙЩ‘ЩҗШұЩҸЩҮЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҸЩҮЩҸЩ… ШЁЩҗШұЩҺШӯЩ’Щ…ЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ ЩҲЩҺШұЩҗШ¶Щ’ЩҲЩҺЩ°ЩҶЩҚЫў ЩҲЩҺШ¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҶЩҺШ№ЩҗЩҠЩ…ЩҢЫӯ Щ…Щ‘ЩҸЩӮЩҗЩҠЩ…ЩҢ"},{"key":"9:22","surah":9,"ayah":22,"num":1257,"page":190,"words":[{"code":"пұҢ","page":190,"end":false},{"code":"пұҚ","page":190,"end":false},{"code":"пұҺпұҸ","page":190,"end":false},{"code":"пұҗ","page":190,"end":false},{"code":"пұ‘","page":190,"end":false},{"code":"пұ’","page":190,"end":false},{"code":"пұ“","page":190,"end":false},{"code":"пұ”","page":190,"end":false},{"code":"пұ•","page":190,"end":true}],"text":"Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҗЩҠЩҶЩҺ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺШЁЩҺШҜЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҗЩҶШҜЩҺЩҮЩҸЫҘЩ“ ШЈЩҺШ¬Щ’ШұЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"},{"key":"9:23","surah":9,"ayah":23,"num":1258,"page":190,"words":[{"code":"пұ–","page":190,"end":false},{"code":"пұ—","page":190,"end":false},{"code":"пұҳ","page":190,"end":false},{"code":"пұҷ","page":190,"end":false},{"code":"пұҡ","page":190,"end":false},{"code":"пұӣ","page":190,"end":false},{"code":"пұң","page":190,"end":false},{"code":"пұқ","page":190,"end":false},{"code":"пұһ","page":190,"end":false},{"code":"пұҹ","page":190,"end":false},{"code":"пұ ","page":190,"end":false},{"code":"пұЎ","page":190,"end":false},{"code":"пұўпұЈ","page":190,"end":false},{"code":"пұӨ","page":190,"end":false},{"code":"пұҘ","page":190,"end":false},{"code":"пұҰ","page":190,"end":false},{"code":"пұ§","page":190,"end":false},{"code":"пұЁ","page":190,"end":false},{"code":"пұ©","page":190,"end":false},{"code":"пұӘ","page":190,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ„ЩҺШ§ ШӘЩҺШӘЩ‘ЩҺШ®ЩҗШ°ЩҸЩҲЩ“Ш§Ыҹ ШЎЩҺШ§ШЁЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШҘЩҗШ®Щ’ЩҲЩҺЩ°ЩҶЩҺЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’Щ„ЩҗЩҠЩҺШ§Щ“ШЎЩҺ ШҘЩҗЩҶЩҗ ЩұШіЩ’ШӘЩҺШӯЩҺШЁЩ‘ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩғЩҸЩҒЩ’ШұЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҗ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҗЩҶЩғЩҸЩ…Щ’ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"9:24","surah":9,"ayah":24,"num":1259,"page":190,"words":[{"code":"пұ«","page":190,"end":false},{"code":"пұ¬","page":190,"end":false},{"code":"пұӯ","page":190,"end":false},{"code":"пұ®","page":190,"end":false},{"code":"пұҜ","page":190,"end":false},{"code":"пұ°","page":190,"end":false},{"code":"пұұ","page":190,"end":false},{"code":"пұІ","page":190,"end":false},{"code":"пұі","page":190,"end":false},{"code":"пұҙ","page":190,"end":false},{"code":"пұө","page":190,"end":false},{"code":"пұ¶","page":190,"end":false},{"code":"пұ·","page":190,"end":false},{"code":"пұё","page":190,"end":false},{"code":"пұ№","page":190,"end":false},{"code":"пұә","page":190,"end":false},{"code":"пұ»","page":190,"end":false},{"code":"пұј","page":190,"end":false},{"code":"пұҪ","page":190,"end":false},{"code":"пұҫ","page":190,"end":false},{"code":"пұҝ","page":190,"end":false},{"code":"пІҖ","page":190,"end":false},{"code":"пІҒ","page":190,"end":false},{"code":"пІӮ","page":190,"end":false},{"code":"пІғ","page":190,"end":false},{"code":"пІ„","page":190,"end":false},{"code":"пІ…","page":190,"end":false},{"code":"пІҶпІҮ","page":190,"end":false},{"code":"пІҲ","page":190,"end":false},{"code":"пІү","page":190,"end":false},{"code":"пІҠ","page":190,"end":false},{"code":"пІӢ","page":190,"end":false},{"code":"пІҢ","page":190,"end":false},{"code":"пІҚ","page":190,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ ШЎЩҺШ§ШЁЩҺШ§Щ“ШӨЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШЁЩ’ЩҶЩҺШ§Щ“ШӨЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШҘЩҗШ®Щ’ЩҲЩҺЩ°ЩҶЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШІЩ’ЩҲЩҺЩ°Ш¬ЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШ№ЩҺШҙЩҗЩҠШұЩҺШӘЩҸЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҢ ЩұЩӮЩ’ШӘЩҺШұЩҺЩҒЩ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҺШ§ ЩҲЩҺШӘЩҗШ¬ЩҺЩҖЩ°ШұЩҺШ©ЩҢЫӯ ШӘЩҺШ®Щ’ШҙЩҺЩҲЩ’ЩҶЩҺ ЩғЩҺШіЩҺШ§ШҜЩҺЩҮЩҺШ§ ЩҲЩҺЩ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҶЩҸ ШӘЩҺШұЩ’Ш¶ЩҺЩҲЩ’ЩҶЩҺЩҮЩҺШ§Щ“ ШЈЩҺШӯЩҺШЁЩ‘ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШ¬ЩҗЩҮЩҺШ§ШҜЩҚЫў ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„ЩҗЩҮЩҗЫҰ ЩҒЩҺШӘЩҺШұЩҺШЁЩ‘ЩҺШөЩҸЩҲШ§Ыҹ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШЈЩ’ШӘЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗШЈЩҺЩ…Щ’ШұЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШ§ ЩҠЩҺЩҮЩ’ШҜЩҗЩү ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩҒЩҺЩҖЩ°ШіЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"9:25","surah":9,"ayah":25,"num":1260,"page":190,"words":[{"code":"пІҺ","page":190,"end":false},{"code":"пІҸ","page":190,"end":false},{"code":"пІҗ","page":190,"end":false},{"code":"пІ‘","page":190,"end":false},{"code":"пІ’","page":190,"end":false},{"code":"пІ“","page":190,"end":false},{"code":"пІ”","page":190,"end":false},{"code":"пІ•","page":190,"end":false},{"code":"пІ–","page":190,"end":false},{"code":"пІ—","page":190,"end":false},{"code":"пІҳ","page":190,"end":false},{"code":"пІҷ","page":190,"end":false},{"code":"пІҡ","page":190,"end":false},{"code":"пІӣ","page":190,"end":false},{"code":"пІң","page":190,"end":false},{"code":"пІқ","page":190,"end":false},{"code":"пІһ","page":190,"end":false},{"code":"пІҹ","page":190,"end":false},{"code":"пІ ","page":190,"end":false},{"code":"пІЎ","page":190,"end":false},{"code":"пІў","page":190,"end":false},{"code":"пІЈ","page":190,"end":false},{"code":"пІӨ","page":190,"end":false},{"code":"пІҘ","page":190,"end":true}],"text":"Щ„ЩҺЩӮЩҺШҜЩ’ ЩҶЩҺШөЩҺШұЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҗЩү Щ…ЩҺЩҲЩҺШ§Ш·ЩҗЩҶЩҺ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩҚЫў Ыҷ ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ШӯЩҸЩҶЩҺЩҠЩ’ЩҶЩҚ Ыҷ ШҘЩҗШ°Щ’ ШЈЩҺШ№Щ’Ш¬ЩҺШЁЩҺШӘЩ’ЩғЩҸЩ…Щ’ ЩғЩҺШ«Щ’ШұЩҺШӘЩҸЩғЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩ…Щ’ ШӘЩҸШәЩ’ЩҶЩҗ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ ЩҲЩҺШ¶ЩҺШ§ЩӮЩҺШӘЩ’ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҸ ШЁЩҗЩ…ЩҺШ§ ШұЩҺШӯЩҸШЁЩҺШӘЩ’ Ш«ЩҸЩ…Щ‘ЩҺ ЩҲЩҺЩ„Щ‘ЩҺЩҠЩ’ШӘЩҸЩ… Щ…Щ‘ЩҸШҜЩ’ШЁЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"9:26","surah":9,"ayah":26,"num":1261,"page":190,"words":[{"code":"пІҰ","page":190,"end":false},{"code":"пІ§","page":190,"end":false},{"code":"пІЁ","page":190,"end":false},{"code":"пІ©","page":190,"end":false},{"code":"пІӘ","page":190,"end":false},{"code":"пІ«","page":190,"end":false},{"code":"пІ¬","page":190,"end":false},{"code":"пІӯ","page":190,"end":false},{"code":"пІ®","page":190,"end":false},{"code":"пІҜ","page":190,"end":false},{"code":"пІ°","page":190,"end":false},{"code":"пІұ","page":190,"end":false},{"code":"пІІ","page":190,"end":false},{"code":"пІі","page":190,"end":false},{"code":"пІҙпІө","page":190,"end":false},{"code":"пІ¶","page":190,"end":false},{"code":"пІ·","page":190,"end":false},{"code":"пІё","page":190,"end":false},{"code":"пІ№","page":190,"end":true}],"text":"Ш«ЩҸЩ…Щ‘ЩҺ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩғЩҗЩҠЩҶЩҺШӘЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩүЩ° ШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ ЩҲЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ Ш¬ЩҸЩҶЩҸЩҲШҜЩӢЫӯШ§ Щ„Щ‘ЩҺЩ…Щ’ ШӘЩҺШұЩҺЩҲЩ’ЩҮЩҺШ§ ЩҲЩҺШ№ЩҺШ°Щ‘ЩҺШЁЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ Ш¬ЩҺШІЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"}]}
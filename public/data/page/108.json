":108,"end":false},{"code":"пұҝ","page":108,"end":false},{"code":"пІҖ","page":108,"end":false},{"code":"пІҒ","page":108,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ ЩӮЩҸЩ…Щ’ШӘЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©Щҗ ЩҒЩҺЩұШәЩ’ШіЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҲЩҸШ¬ЩҸЩҲЩҮЩҺЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺШұЩҺШ§ЩҒЩҗЩӮЩҗ ЩҲЩҺЩұЩ…Щ’ШіЩҺШӯЩҸЩҲШ§Ыҹ ШЁЩҗШұЩҸШЎЩҸЩҲШіЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШұЩ’Ш¬ЩҸЩ„ЩҺЩғЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’ЩғЩҺШ№Щ’ШЁЩҺЩҠЩ’ЩҶЩҗ Ыҡ ЩҲЩҺШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ Ш¬ЩҸЩҶЩҸШЁЩӢЫӯШ§ ЩҒЩҺЩұШ·Щ‘ЩҺЩҮЩ‘ЩҺШұЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҺШұЩ’Ш¶ЩҺЩүЩ°Щ“ ШЈЩҺЩҲЩ’ Ш№ЩҺЩ„ЩҺЩүЩ° ШіЩҺЩҒЩҺШұЩҚ ШЈЩҺЩҲЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺ ШЈЩҺШӯЩҺШҜЩҢЫӯ Щ…Щ‘ЩҗЩҶЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШәЩҺШ§Щ“ШҰЩҗШ·Щҗ ШЈЩҺЩҲЩ’ Щ„ЩҺЩҖЩ°Щ…ЩҺШіЩ’ШӘЩҸЩ…ЩҸ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҺ ЩҒЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШ¬ЩҗШҜЩҸЩҲШ§Ыҹ Щ…ЩҺШ§Щ“ШЎЩӢЫӯ ЩҒЩҺШӘЩҺЩҠЩҺЩ…Щ‘ЩҺЩ…ЩҸЩҲШ§Ыҹ ШөЩҺШ№ЩҗЩҠШҜЩӢЫӯШ§ Ш·ЩҺЩҠЩ‘ЩҗШЁЩӢЫӯШ§ ЩҒЩҺЩұЩ…Щ’ШіЩҺШӯЩҸЩҲШ§Ыҹ ШЁЩҗЩҲЩҸШ¬ЩҸЩҲЩҮЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҠЩ’ШҜЩҗЩҠЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ Ыҡ Щ…ЩҺШ§ ЩҠЩҸШұЩҗЩҠШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҗЩҠЩҺШ¬Щ’Ш№ЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЩ’ ШӯЩҺШұЩҺШ¬ЩҚЫў ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ ЩҠЩҸШұЩҗЩҠШҜЩҸ Щ„ЩҗЩҠЩҸШ·ЩҺЩҮЩ‘ЩҗШұЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҗЩҠЩҸШӘЩҗЩ…Щ‘ЩҺ ЩҶЩҗШ№Щ’Щ…ЩҺШӘЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШҙЩ’ЩғЩҸШұЩҸЩҲЩҶЩҺ"},{"key":"5:7","surah":5,"ayah":7,"num":676,"page":108,"words":[{"code":"пІӮ","page":108,"end":false},{"code":"пІғ","page":108,"end":false},{"code":"пІ„","page":108,"end":false},{"code":"пІ…","page":108,"end":false},{"code":"пІҶ","page":108,"end":false},{"code":"пІҮ","page":108,"end":false},{"code":"пІҲ","page":108,"end":false},{"code":"пІү","page":108,"end":false},{"code":"пІҠ","page":108,"end":false},{"code":"пІӢ","page":108,"end":false},{"code":"пІҢ","page":108,"end":false},{"code":"пІҚпІҺ","page":108,"end":false},{"code":"пІҸ","page":108,"end":false},{"code":"пІҗпІ‘","page":108,"end":false},{"code":"пІ’","page":108,"end":false},{"code":"пІ“","page":108,"end":false},{"code":"пІ”","page":108,"end":false},{"code":"пІ•","page":108,"end":false},{"code":"пІ–","page":108,"end":false},{"code":"пІ—","page":108,"end":true}],"text":"ЩҲЩҺЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҶЩҗШ№Щ’Щ…ЩҺШ©ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҲЩҺШ§Ш«ЩҺЩӮЩҺЩғЩҸЩ… ШЁЩҗЩҮЩҗЫҰЩ“ ШҘЩҗШ°Щ’ ЩӮЩҸЩ„Щ’ШӘЩҸЩ…Щ’ ШіЩҺЩ…ЩҗШ№Щ’ЩҶЩҺШ§ ЩҲЩҺШЈЩҺШ·ЩҺШ№Щ’ЩҶЩҺШ§ Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗШ°ЩҺШ§ШӘЩҗ ЩұЩ„ШөЩ‘ЩҸШҜЩҸЩҲШұЩҗ"},{"key":"5:8","surah":5,"ayah":8,"num":677,"page":108,"words":[{"code":"пІҳ","page":108,"end":false},{"code":"пІҷ","page":108,"end":false},{"code":"пІҡ","page":108,"end":false},{"code":"пІӣ","page":108,"end":false},{"code":"пІң","page":108,"end":false},{"code":"пІқ","page":108,"end":false},{"code":"пІһ","page":108,"end":false},{"code":"пІҹпІ ","page":108,"end":false},{"code":"пІЎ","page":108,"end":false},{"code":"пІў","page":108,"end":false},{"code":"пІЈ","page":108,"end":false},{"code":"пІӨ","page":108,"end":false},{"code":"пІҘ","page":108,"end":false},{"code":"пІҰ","page":108,"end":false},{"code":"пІ§пІЁ","page":108,"end":false},{"code":"пІ©","page":108,"end":false},{"code":"пІӘ","page":108,"end":false},{"code":"пІ«","page":108,"end":false},{"code":"пІ¬пІӯ","page":108,"end":false},{"code":"пІ®","page":108,"end":false},{"code":"пІҜпІ°","page":108,"end":false},{"code":"пІұ","page":108,"end":false},{"code":"пІІ","page":108,"end":false},{"code":"пІі","page":108,"end":false},{"code":"пІҙ","page":108,"end":false},{"code":"пІө","page":108,"end":false},{"code":"пІ¶","page":108,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩғЩҸЩҲЩҶЩҸЩҲШ§Ыҹ ЩӮЩҺЩҲЩ‘ЩҺЩ°Щ…ЩҗЩҠЩҶЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ШҙЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҺ ШЁЩҗЩұЩ„Щ’ЩӮЩҗШіЩ’Ш·Щҗ Ы– ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШ¬Щ’ШұЩҗЩ…ЩҺЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ ШҙЩҺЩҶЩҺЩҖЩ”ЩҺШ§ЩҶЩҸ ЩӮЩҺЩҲЩ’Щ…ЩҚ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШҜЩҗЩ„ЩҸЩҲШ§Ыҹ Ыҡ ЩұШ№Щ’ШҜЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҮЩҸЩҲЩҺ ШЈЩҺЩӮЩ’ШұЩҺШЁЩҸ Щ„ЩҗЩ„ШӘЩ‘ЩҺЩӮЩ’ЩҲЩҺЩүЩ° Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш®ЩҺШЁЩҗЩҠШұЩҢЫў ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"5:9","surah":5,"ayah":9,"num":678,"page":108,"words":[{"code":"пІ·","page":108,"end":false},{"code":"пІё","page":108,"end":false},{"code":"пІ№","page":108,"end":false},{"code":"пІә","page":108,"end":false},{"code":"пІ»","page":108,"end":false},{"code":"пІј","page":108,"end":false},{"code":"пІҪ","page":108,"end":false},{"code":"пІҫ","page":108,"end":false},{"code":"пІҝ","page":108,"end":false},{"code":"піҖ","page":108,"end":false},{"code":"піҒ","page":108,"end":true}],"text":"ЩҲЩҺШ№ЩҺШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ Ыҷ Щ„ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺШәЩ’ЩҒЩҗШұЩҺШ©ЩҢЫӯ ЩҲЩҺШЈЩҺШ¬Щ’ШұЩҢ Ш№ЩҺШёЩҗЩҠЩ…ЩҢЫӯ"}]}
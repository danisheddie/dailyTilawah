"code":"пұҠ","page":115,"end":false},{"code":"пұӢ","page":115,"end":false},{"code":"пұҢпұҚ","page":115,"end":false},{"code":"пұҺ","page":115,"end":false},{"code":"пұҸ","page":115,"end":false},{"code":"пұҗ","page":115,"end":false},{"code":"пұ‘","page":115,"end":false},{"code":"пұ’","page":115,"end":false},{"code":"пұ“пұ”","page":115,"end":false},{"code":"пұ•","page":115,"end":false},{"code":"пұ–","page":115,"end":false},{"code":"пұ—","page":115,"end":false},{"code":"пұҳ","page":115,"end":false},{"code":"пұҷпұҡ","page":115,"end":false},{"code":"пұӣ","page":115,"end":false},{"code":"пұң","page":115,"end":false},{"code":"пұқ","page":115,"end":false},{"code":"пұһ","page":115,"end":false},{"code":"пұҹ","page":115,"end":true}],"text":"ШіЩҺЩ…Щ‘ЩҺЩҖЩ°Ш№ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҗ ШЈЩҺЩғЩ‘ЩҺЩҖЩ°Щ„ЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„ШіЩ‘ЩҸШӯЩ’ШӘЩҗ Ыҡ ЩҒЩҺШҘЩҗЩҶ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲЩғЩҺ ЩҒЩҺЩұШӯЩ’ЩғЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЈЩҺШ№Щ’ШұЩҗШ¶Щ’ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШ№Щ’ШұЩҗШ¶Щ’ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩҶ ЩҠЩҺШ¶ЩҸШұЩ‘ЩҸЩҲЩғЩҺ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ Ы– ЩҲЩҺШҘЩҗЩҶЩ’ ШӯЩҺЩғЩҺЩ…Щ’ШӘЩҺ ЩҒЩҺЩұШӯЩ’ЩғЩҸЩ… ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’ЩӮЩҗШіЩ’Ш·Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҸШӯЩҗШЁЩ‘ЩҸ ЩұЩ„Щ’Щ…ЩҸЩӮЩ’ШіЩҗШ·ЩҗЩҠЩҶЩҺ"},{"key":"5:43","surah":5,"ayah":43,"num":712,"page":115,"words":[{"code":"пұ ","page":115,"end":false},{"code":"пұЎ","page":115,"end":false},{"code":"пұў","page":115,"end":false},{"code":"пұЈ","page":115,"end":false},{"code":"пұӨ","page":115,"end":false},{"code":"пұҘ","page":115,"end":false},{"code":"пұҰ","page":115,"end":false},{"code":"пұ§","page":115,"end":false},{"code":"пұЁ","page":115,"end":false},{"code":"пұ©","page":115,"end":false},{"code":"пұӘ","page":115,"end":false},{"code":"пұ«пұ¬","page":115,"end":false},{"code":"пұӯ","page":115,"end":false},{"code":"пұ®","page":115,"end":false},{"code":"пұҜ","page":115,"end":false},{"code":"пұ°","page":115,"end":true}],"text":"ЩҲЩҺЩғЩҺЩҠЩ’ЩҒЩҺ ЩҠЩҸШӯЩҺЩғЩ‘ЩҗЩ…ЩҸЩҲЩҶЩҺЩғЩҺ ЩҲЩҺШ№ЩҗЩҶШҜЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ШӘЩ‘ЩҺЩҲЩ’ШұЩҺЩүЩ°Ш©ЩҸ ЩҒЩҗЩҠЩҮЩҺШ§ ШӯЩҸЩғЩ’Щ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҺШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҲЩ’ЩҶЩҺ Щ…ЩҗЩҶЫў ШЁЩҺШ№Щ’ШҜЩҗ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Ыҡ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"5:44","surah":5,"ayah":44,"num":713,"page":115,"words":[{"code":"пұұ","page":115,"end":false},{"code":"пұІ","page":115,"end":false},{"code":"пұі","page":115,"end":false},{"code":"пұҙ","page":115,"end":false},{"code":"пұө","page":115,"end":false},{"code":"пұ¶пұ·","page":115,"end":false},{"code":"пұё","page":115,"end":false},{"code":"пұ№","page":115,"end":false},{"code":"пұә","page":115,"end":false},{"code":"пұ»","page":115,"end":false},{"code":"пұј","page":115,"end":false},{"code":"пұҪ","page":115,"end":false},{"code":"пұҫ","page":115,"end":false},{"code":"пұҝ","page":115,"end":false},{"code":"пІҖ","page":115,"end":false},{"code":"пІҒ","page":115,"end":false},{"code":"пІӮ","page":115,"end":false},{"code":"пІғ","page":115,"end":false},{"code":"пІ„","page":115,"end":false},{"code":"пІ…","page":115,"end":false},{"code":"пІҶ","page":115,"end":false},{"code":"пІҮ","page":115,"end":false},{"code":"пІҲпІү","page":115,"end":false},{"code":"пІҠ","page":115,"end":false},{"code":"пІӢ","page":115,"end":false},{"code":"пІҢ","page":115,"end":false},{"code":"пІҚ","page":115,"end":false},{"code":"пІҺ","page":115,"end":false},{"code":"пІҸ","page":115,"end":false},{"code":"пІҗ","page":115,"end":false},{"code":"пІ‘","page":115,"end":false},{"code":"пІ’пІ“","page":115,"end":false},{"code":"пІ”","page":115,"end":false},{"code":"пІ•","page":115,"end":false},{"code":"пІ–","page":115,"end":false},{"code":"пІ—","page":115,"end":false},{"code":"пІҳ","page":115,"end":false},{"code":"пІҷ","page":115,"end":false},{"code":"пІҡ","page":115,"end":false},{"code":"пІӣ","page":115,"end":false},{"code":"пІң","page":115,"end":false},{"code":"пІқ","page":115,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ ЩұЩ„ШӘЩ‘ЩҺЩҲЩ’ШұЩҺЩүЩ°Ш©ЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҮЩҸШҜЩӢЫӯЩү ЩҲЩҺЩҶЩҸЩҲШұЩҢЫӯ Ыҡ ЩҠЩҺШӯЩ’ЩғЩҸЩ…ЩҸ ШЁЩҗЩҮЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩҸЩҲЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҺШіЩ’Щ„ЩҺЩ…ЩҸЩҲШ§Ыҹ Щ„ЩҗЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҮЩҺШ§ШҜЩҸЩҲШ§Ыҹ ЩҲЩҺЩұЩ„ШұЩ‘ЩҺШЁЩ‘ЩҺЩҖЩ°ЩҶЩҗЩҠЩ‘ЩҸЩҲЩҶЩҺ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШӯЩ’ШЁЩҺШ§ШұЩҸ ШЁЩҗЩ…ЩҺШ§ ЩұШіЩ’ШӘЩҸШӯЩ’ЩҒЩҗШёЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШҙЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҺ Ыҡ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШ®Щ’ШҙЩҺЩҲЩҸШ§Ыҹ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩҲЩҺЩұШ®Щ’ШҙЩҺЩҲЩ’ЩҶЩҗ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШҙЩ’ШӘЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩү Ш«ЩҺЩ…ЩҺЩҶЩӢЫӯШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШӯЩ’ЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"5:45","surah":5,"ayah":45,"num":714,"page":115,"words":[{"code":"пІһ","page":115,"end":false},{"code":"пІҹ","page":115,"end":false},{"code":"пІ ","page":115,"end":false},{"code":"пІЎ","page":115,"end":false},{"code":"пІў","page":115,"end":false},{"code":"пІЈ","page":115,"end":false},{"code":"пІӨ","page":115,"end":false},{"code":"пІҘ","page":115,"end":false},{"code":"пІҰ","page":115,"end":false},{"code":"пІ§","page":115,"end":false},{"code":"пІЁ","page":115,"end":false},{"code":"пІ©","page":115,"end":false},{"code":"пІӘ","page":115,"end":false},{"code":"пІ«","page":115,"end":false},{"code":"пІ¬","page":115,"end":false},{"code":"пІӯпІ®","page":115,"end":false},{"code":"пІҜ","page":115,"end":false},{"code":"пІ°","page":115,"end":false},{"code":"пІұ","page":115,"end":false},{"code":"пІІ","page":115,"end":false},{"code":"пІі","page":115,"end":false},{"code":"пІҙпІө","page":115,"end":false},{"code":"пІ¶","page":115,"end":false},{"code":"пІ·","page":115,"end":false},{"code":"пІё","page":115,"end":false},{"code":"пІ№","page":115,"end":false},{"code":"пІә","page":115,"end":false},{"code":"пІ»","page":115,"end":false},{"code":"пІј","page":115,"end":false},{"code":"пІҪ","page":115,"end":false},{"code":"пІҫ","page":115,"end":false},{"code":"пІҝ","page":115,"end":true}],"text":"ЩҲЩҺЩғЩҺШӘЩҺШЁЩ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§Щ“ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„ЩҶЩ‘ЩҺЩҒЩ’ШіЩҺ ШЁЩҗЩұЩ„ЩҶЩ‘ЩҺЩҒЩ’ШіЩҗ ЩҲЩҺЩұЩ„Щ’Ш№ЩҺЩҠЩ’ЩҶЩҺ ШЁЩҗЩұЩ„Щ’Ш№ЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺЩҶЩҒЩҺ ШЁЩҗЩұЩ„Щ’ШЈЩҺЩҶЩҒЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҸШ°ЩҸЩҶЩҺ ШЁЩҗЩұЩ„Щ’ШЈЩҸШ°ЩҸЩҶЩҗ ЩҲЩҺЩұЩ„ШіЩ‘ЩҗЩҶЩ‘ЩҺ ШЁЩҗЩұЩ„ШіЩ‘ЩҗЩҶЩ‘Щҗ ЩҲЩҺЩұЩ„Щ’Ш¬ЩҸШұЩҸЩҲШӯЩҺ ЩӮЩҗШөЩҺШ§ШөЩҢЫӯ Ыҡ ЩҒЩҺЩ…ЩҺЩҶ ШӘЩҺШөЩҺШҜЩ‘ЩҺЩӮЩҺ ШЁЩҗЩҮЩҗЫҰ ЩҒЩҺЩҮЩҸЩҲЩҺ ЩғЩҺЩҒЩ‘ЩҺШ§ШұЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЫҘ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШӯЩ’ЩғЩҸЩ… ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ЩҮЩҸЩ…ЩҸ ЩұЩ„ШёЩ‘ЩҺЩҖЩ°Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"}]}
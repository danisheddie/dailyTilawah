ҠЩ’ЩҶЩҺШ§ Щ…ЩҺШ§Щ“ШҰЩҗШҜЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ШӘЩҺЩғЩҸЩҲЩҶЩҸ Щ„ЩҺЩҶЩҺШ§ Ш№ЩҗЩҠШҜЩӢЫӯШ§ Щ„Щ‘ЩҗШЈЩҺЩҲЩ‘ЩҺЩ„ЩҗЩҶЩҺШ§ ЩҲЩҺШЎЩҺШ§Ш®ЩҗШұЩҗЩҶЩҺШ§ ЩҲЩҺШЎЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩғЩҺ Ы– ЩҲЩҺЩұШұЩ’ШІЩҸЩӮЩ’ЩҶЩҺШ§ ЩҲЩҺШЈЩҺЩҶШӘЩҺ Ш®ЩҺЩҠЩ’ШұЩҸ ЩұЩ„ШұЩ‘ЩҺЩ°ШІЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"5:115","surah":5,"ayah":115,"num":784,"page":127,"words":[{"code":"пұҷ","page":127,"end":false},{"code":"пұҡ","page":127,"end":false},{"code":"пұӣ","page":127,"end":false},{"code":"пұң","page":127,"end":false},{"code":"пұқпұһ","page":127,"end":false},{"code":"пұҹ","page":127,"end":false},{"code":"пұ ","page":127,"end":false},{"code":"пұЎ","page":127,"end":false},{"code":"пұў","page":127,"end":false},{"code":"пұЈ","page":127,"end":false},{"code":"пұӨ","page":127,"end":false},{"code":"пұҘ","page":127,"end":false},{"code":"пұҰ","page":127,"end":false},{"code":"пұ§","page":127,"end":false},{"code":"пұЁ","page":127,"end":false},{"code":"пұ©","page":127,"end":false},{"code":"пұӘ","page":127,"end":false},{"code":"пұ«","page":127,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҘЩҗЩҶЩ‘ЩҗЩү Щ…ЩҸЩҶЩҺШІЩ‘ЩҗЩ„ЩҸЩҮЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ы– ЩҒЩҺЩ…ЩҺЩҶ ЩҠЩҺЩғЩ’ЩҒЩҸШұЩ’ ШЁЩҺШ№Щ’ШҜЩҸ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҗЩүЩ“ ШЈЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҸЩҮЩҸЫҘ Ш№ЩҺШ°ЩҺШ§ШЁЩӢЫӯШ§ Щ„Щ‘ЩҺШ§Щ“ ШЈЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҸЩҮЩҸЫҘЩ“ ШЈЩҺШӯЩҺШҜЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҺЩҖЩ°Щ„ЩҺЩ…ЩҗЩҠЩҶЩҺ"},{"key":"5:116","surah":5,"ayah":116,"num":785,"page":127,"words":[{"code":"пұ¬","page":127,"end":false},{"code":"пұӯ","page":127,"end":false},{"code":"пұ®","page":127,"end":false},{"code":"пұҜ","page":127,"end":false},{"code":"пұ°","page":127,"end":false},{"code":"пұұ","page":127,"end":false},{"code":"пұІ","page":127,"end":false},{"code":"пұі","page":127,"end":false},{"code":"пұҙ","page":127,"end":false},{"code":"пұө","page":127,"end":false},{"code":"пұ¶","page":127,"end":false},{"code":"пұ·","page":127,"end":false},{"code":"пұё","page":127,"end":false},{"code":"пұ№","page":127,"end":false},{"code":"пұәпұ»","page":127,"end":false},{"code":"пұј","pa
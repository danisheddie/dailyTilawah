page":358,"end":false},{"code":"пұҮ","page":358,"end":false},{"code":"пұҲ","page":358,"end":false},{"code":"пұү","page":358,"end":false},{"code":"пұҠ","page":358,"end":false},{"code":"пұӢпұҢ","page":358,"end":false},{"code":"пұҚ","page":358,"end":false},{"code":"пұҺ","page":358,"end":false},{"code":"пұҸ","page":358,"end":false},{"code":"пұҗ","page":358,"end":false},{"code":"пұ‘пұ’","page":358,"end":false},{"code":"пұ“","page":358,"end":false},{"code":"пұ”","page":358,"end":false},{"code":"пұ•","page":358,"end":false},{"code":"пұ–","page":358,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°ЩҺШ§ ШЁЩҺЩ„ЩҺШәЩҺ ЩұЩ„Щ’ШЈЩҺШ·Щ’ЩҒЩҺЩҖЩ°Щ„ЩҸ Щ…ЩҗЩҶЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ШӯЩҸЩ„ЩҸЩ…ЩҺ ЩҒЩҺЩ„Щ’ЩҠЩҺШіЩ’ШӘЩҺЩҖЩ”Щ’Ш°ЩҗЩҶЩҸЩҲШ§Ыҹ ЩғЩҺЩ…ЩҺШ§ ЩұШіЩ’ШӘЩҺЩҖЩ”Щ’Ш°ЩҺЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩҮЩҗЩ…Щ’ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…Щ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"},{"key":"24:60","surah":24,"ayah":60,"num":2851,"page":358,"words":[{"code":"пұ—","page":358,"end":false},{"code":"пұҳ","page":358,"end":false},{"code":"пұҷ","page":358,"end":false},{"code":"пұҡ","page":358,"end":false},{"code":"пұӣ","page":358,"end":false},{"code":"пұң","page":358,"end":false},{"code":"пұқ","page":358,"end":false},{"code":"пұһ","page":358,"end":false},{"code":"пұҹ","page":358,"end":false},{"code":"пұ ","page":358,"end":false},{"code":"пұЎ","page":358,"end":false},{"code":"пұў","page":358,"end":false},{"code":"пұЈ","page":358,"end":false},{"code":"пұӨ","page":358,"end":false},{"code":"пұҘ","page":358,"end":false},{"code":"пұҰпұ§","page":358,"end":false},{"code":"пұЁ","page":358,"end":false},{"code":"пұ©","page":358,"end":false},{"code":"пұӘ","page":358,"end":false},{"code":"пұ«пұ¬","page":358,"end":false},{"code":"пұӯ","page":358,"end":false},{"code":"пұ®","page":358,"end":false},{"code":"пұҜ","page":358,"end":false},{"code":"пұ°","page":358,"end":true}],"text":"ЩҲЩҺЩұЩ„Щ’ЩӮЩҺЩҲЩҺЩ°Ш№ЩҗШҜЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ ЩұЩ„Щ‘ЩҺЩҖЩ°ШӘЩҗЩү Щ„ЩҺШ§ ЩҠЩҺШұЩ’Ш¬ЩҸЩҲЩҶЩҺ ЩҶЩҗЩғЩҺШ§ШӯЩӢЫӯШ§ ЩҒЩҺЩ„ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ Ш¬ЩҸЩҶЩҺШ§ШӯЩҢ ШЈЩҺЩҶ ЩҠЩҺШ¶ЩҺШ№Щ’ЩҶЩҺ Ш«ЩҗЩҠЩҺШ§ШЁЩҺЩҮЩҸЩҶЩ‘ЩҺ ШәЩҺЩҠЩ’ШұЩҺ Щ…ЩҸШӘЩҺШЁЩҺШұЩ‘ЩҗШ¬ЩҺЩҖЩ°ШӘЩҚЫӯ ШЁЩҗШІЩҗЩҠЩҶЩҺШ©ЩҚЫў Ы– ЩҲЩҺШЈЩҺЩҶ ЩҠЩҺШіЩ’ШӘЩҺШ№Щ’ЩҒЩҗЩҒЩ’ЩҶЩҺ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩҮЩҸЩҶЩ‘ЩҺ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩ…ЩҗЩҠШ№ЩҢ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"24:61","surah":24,"ayah":61,"num":2852,"page":358,"words":[{"code":"пұұ","page":358,"end":false},{"code":"пұІ","page":358,"end":false},{"code":"пұі","page":358,"end":false},{"code":"пұҙ","page":358,"end":false},{"code":"пұө","page":358,"end":false},{"code":"пұ¶","page":358,"end":false},{"code":"пұ·","page":358,"end":false},{"code":"пұё","page":358,"end":false},{"code":"пұ№","page":358,"end":false},{"code":"пұә","page":358,"end":false},{"code":"пұ»","page":358,"end":false},{"code":"пұј","page":358,"end":false},{"code":"пұҪ","page":358,"end":false},{"code":"пұҫ","page":358,"end":false},{"code":"пұҝ","page":358,"end":false},{"code":"пІҖ","page":358,"end":false},{"code":"пІҒ","page":358,"end":false},{"code":"пІӮ","page":358,"end":false},{"code":"пІғ","page":358,"end":false},{"code":"пІ„","page":358,"end":false},{"code":"пІ…","page":358,"end":false},{"code":"пІҶ","page":358,"end":false},{"code":"пІҮ","page":358,"end":false},{"code":"пІҲ","page":358,"end":false},{"code":"пІү","page":358,"end":false},{"code":"пІҠ","page":358,"end":false},{"code":"пІӢ","page":358,"end":false},{"code":"пІҢ","page":358,"end":false},{"code":"пІҚ","page":358,"end":false},{"code":"пІҺ","page":358,"end":false},{"code":"пІҸ","page":358,"end":false},{"code":"пІҗ","page":358,"end":false},{"code":"пІ‘","page":358,"end":false},{"code":"пІ’","page":358,"end":false},{"code":"пІ“","page":358,"end":false},{"code":"пІ”","page":358,"end":false},{"code":"пІ•","page":358,"end":false},{"code":"пІ–","page":358,"end":false},{"code":"пІ—","page":358,"end":false},{"code":"пІҳ","page":358,"end":false},{"code":"пІҷ","page":358,"end":false},{"code":"пІҡ","page":358,"end":false},{"code":"пІӣ","page":358,"end":false},{"code":"пІң","page":358,"end":false},{"code":"пІқ","page":358,"end":false},{"code":"пІһ","page":358,"end":false},{"code":"пІҹ","page":358,"end":false},{"code":"пІ ","page":358,"end":false},{"code":"пІЎпІў","page":358,"end":false},{"code":"пІЈ","page":358,"end":false},{"code":"пІӨ","page":358,"end":false},{"code":"пІҘ","page":358,"end":false},{"code":"пІҰ","page":358,"end":false},{"code":"пІ§","page":358,"end":false},{"code":"пІЁ","page":358,"end":false},{"code":"пІ©","page":358,"end":false},{"code":"пІӘпІ«","page":358,"end":false},{"code":"пІ¬","page":358,"end":false},{"code":"пІӯ","page":358,"end":false},{"code":"пІ®","page":358,"end":false},{"code":"пІҜ","page":358,"end":false},{"code":"пІ°","page":358,"end":false},{"code":"пІұ","page":358,"end":false},{"code":"пІІ","page":358,"end":false},{"code":"пІі","page":358,"end":false},{"code":"пІҙ","page":358,"end":false},{"code":"пІө","page":358,"end":false},{"code":"пІ¶","page":358,"end":false},{"code":"пІ·пІё","page":358,"end":false},{"code":"пІ№","page":358,"end":false},{"code":"пІә","page":358,"end":false},{"code":"пІ»","page":358,"end":false},{"code":"пІј","page":358,"end":false},{"code":"пІҪ","page":358,"end":false},{"code":"пІҫ","page":358,"end":false},{"code":"пІҝ","page":358,"end":false},{"code":"піҖ","page":358,"end":true}],"text":"Щ„Щ‘ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’Щ…ЩҺЩүЩ° ШӯЩҺШұЩҺШ¬ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШ№Щ’ШұЩҺШ¬Щҗ ШӯЩҺШұЩҺШ¬ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҺШұЩҗЩҠШ¶Щҗ ШӯЩҺШұЩҺШ¬ЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҶ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶЫў ШЁЩҸЩҠЩҸЩҲШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШЎЩҺШ§ШЁЩҺШ§Щ“ШҰЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШЈЩҸЩ…Щ‘ЩҺЩҮЩҺЩҖЩ°ШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШҘЩҗШ®Щ’ЩҲЩҺЩ°ЩҶЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШЈЩҺШ®ЩҺЩҲЩҺЩ°ШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ…ЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ Ш№ЩҺЩ…Щ‘ЩҺЩҖЩ°ШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ ШЈЩҺШ®Щ’ЩҲЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШЁЩҸЩҠЩҸЩҲШӘЩҗ Ш®ЩҺЩҖЩ°Щ„ЩҺЩҖЩ°ШӘЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ Щ…ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩ’ШӘЩҸЩ… Щ…Щ‘ЩҺЩҒЩҺШ§ШӘЩҗШӯЩҺЩҮЩҸЫҘЩ“ ШЈЩҺЩҲЩ’ ШөЩҺШҜЩҗЩҠЩӮЩҗЩғЩҸЩ…Щ’ Ыҡ Щ„ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ш¬ЩҸЩҶЩҺШ§ШӯЩҢ ШЈЩҺЩҶ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲШ§Ыҹ Ш¬ЩҺЩ…ЩҗЩҠШ№ЩӢШ§ ШЈЩҺЩҲЩ’ ШЈЩҺШҙЩ’ШӘЩҺШ§ШӘЩӢЫӯШ§ Ыҡ ЩҒЩҺШҘЩҗШ°ЩҺШ§ ШҜЩҺШ®ЩҺЩ„Щ’ШӘЩҸЩ… ШЁЩҸЩҠЩҸЩҲШӘЩӢЫӯШ§ ЩҒЩҺШіЩҺЩ„Щ‘ЩҗЩ…ЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ°Щ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ШӘЩҺШӯЩҗЩҠЩ‘ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҸШЁЩҺЩҖЩ°ШұЩҺЩғЩҺШ©ЩӢЫӯ Ш·ЩҺЩҠЩ‘ЩҗШЁЩҺШ©ЩӢЫӯ Ыҡ ЩғЩҺШ°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗ Щ„ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"}]}
пұ…","page":182,"end":false},{"code":"пұҶ","page":182,"end":false},{"code":"пұҮ","page":182,"end":false},{"code":"пұҲ","page":182,"end":false},{"code":"пұү","page":182,"end":false},{"code":"пұҠ","page":182,"end":false},{"code":"пұӢ","page":182,"end":false},{"code":"пұҢ","page":182,"end":false},{"code":"пұҚ","page":182,"end":false},{"code":"пұҺ","page":182,"end":false},{"code":"пұҸ","page":182,"end":false},{"code":"пұҗ","page":182,"end":false},{"code":"пұ‘","page":182,"end":false},{"code":"пұ’","page":182,"end":false},{"code":"пұ“","page":182,"end":false},{"code":"пұ”","page":182,"end":false},{"code":"пұ•","page":182,"end":false},{"code":"пұ–","page":182,"end":false},{"code":"пұ—","page":182,"end":false},{"code":"пұҳ","page":182,"end":false},{"code":"пұҷ","page":182,"end":false},{"code":"пұҡ","page":182,"end":false},{"code":"пұӣ","page":182,"end":false},{"code":"пұң","page":182,"end":false},{"code":"пұқпұһ","page":182,"end":false},{"code":"пұҹ","page":182,"end":false},{"code":"пұ ","page":182,"end":false},{"code":"пұЎ","page":182,"end":false},{"code":"пұў","page":182,"end":false},{"code":"пұЈ","page":182,"end":false},{"code":"пұӨ","page":182,"end":true}],"text":"Ыһ ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩ…ЩҺШ§ ШәЩҺЩҶЩҗЩ…Щ’ШӘЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩҒЩҺШЈЩҺЩҶЩ‘ЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ Ш®ЩҸЩ…ЩҸШіЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҗЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ЩҲЩҺЩ„ЩҗШ°ЩҗЩү ЩұЩ„Щ’ЩӮЩҸШұЩ’ШЁЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’ЩҠЩҺШӘЩҺЩҖЩ°Щ…ЩҺЩүЩ° ЩҲЩҺЩұЩ„Щ’Щ…ЩҺШіЩҺЩҖЩ°ЩғЩҗЩҠЩҶЩҗ ЩҲЩҺЩұШЁЩ’ЩҶЩҗ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШЎЩҺШ§Щ…ЩҺЩҶШӘЩҸЩ… ШЁЩҗЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩүЩ° Ш№ЩҺШЁЩ’ШҜЩҗЩҶЩҺШ§ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩҒЩҸШұЩ’ЩӮЩҺШ§ЩҶЩҗ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ШӘЩҺЩӮЩҺЩү ЩұЩ„Щ’Ш¬ЩҺЩ…Щ’Ш№ЩҺШ§ЩҶЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢ"},{"key":"8:42","surah":8,"ayah":42,"num":1202,"page":182,"words":[{"code":"пұҘ","page":182,"end":false},{"code":"пұҰ","page":182,"end":false},{"code":"пұ§","page":182,"end":false},{"code":"пұЁ","page":182,"end":false},{"code":"пұ©","page":182,"end":false},{"code":"пұӘ","page":182,"end":false},{"code":"пұ«","page":182,"end":false},{"code":"пұ¬","page":182,"end":false},{"code":"пұӯ","page":182,"end":false},{"code":"пұ®пұҜ","page":182,"end":false},{"code":"пұ°","page":182,"end":false},{"code":"пұұ","page":182,"end":false},{"code":"пұІ","page":182,"end":false},{"code":"пұі","page":182,"end":false},{"code":"пұҙ","page":182,"end":false},{"code":"пұө","page":182,"end":false},{"code":"пұ¶","page":182,"end":false},{"code":"пұ·","page":182,"end":false},{"code":"пұё","page":182,"end":false},{"code":"пұ№","page":182,"end":false},{"code":"пұә","page":182,"end":false},{"code":"пұ»","page":182,"end":false},{"code":"пұј","page":182,"end":false},{"code":"пұҪ","page":182,"end":false},{"code":"пұҫ","page":182,"end":false},{"code":"пұҝ","page":182,"end":false},{"code":"пІҖ","page":182,"end":false},{"code":"пІҒ","page":182,"end":false},{"code":"пІӮ","page":182,"end":false},{"code":"пІғ","page":182,"end":false},{"code":"пІ„пІ…","page":182,"end":false},{"code":"пІҶ","page":182,"end":false},{"code":"пІҮ","page":182,"end":false},{"code":"пІҲ","page":182,"end":false},{"code":"пІү","page":182,"end":false},{"code":"пІҠ","page":182,"end":true}],"text":"ШҘЩҗШ°Щ’ ШЈЩҺЩҶШӘЩҸЩ… ШЁЩҗЩұЩ„Щ’Ш№ЩҸШҜЩ’ЩҲЩҺШ©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҲЩҺЩҮЩҸЩ… ШЁЩҗЩұЩ„Щ’Ш№ЩҸШҜЩ’ЩҲЩҺШ©Щҗ ЩұЩ„Щ’ЩӮЩҸШөЩ’ЩҲЩҺЩүЩ° ЩҲЩҺЩұЩ„ШұЩ‘ЩҺЩғЩ’ШЁЩҸ ШЈЩҺШіЩ’ЩҒЩҺЩ„ЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ„ЩҺЩҲЩ’ ШӘЩҺЩҲЩҺШ§Ш№ЩҺШҜШӘЩ‘ЩҸЩ…Щ’ Щ„ЩҺЩұШ®Щ’ШӘЩҺЩ„ЩҺЩҒЩ’ШӘЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’Щ…ЩҗЩҠШ№ЩҺЩҖЩ°ШҜЩҗ Ыҷ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶ Щ„Щ‘ЩҗЩҠЩҺЩӮЩ’Ш¶ЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺЩ…Щ’ШұЩӢЫӯШ§ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҺЩҒЩ’Ш№ЩҸЩҲЩ„ЩӢЫӯШ§ Щ„Щ‘ЩҗЩҠЩҺЩҮЩ’Щ„ЩҗЩғЩҺ Щ…ЩҺЩҶЩ’ ЩҮЩҺЩ„ЩҺЩғЩҺ Ш№ЩҺЩҶЫў ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺШ©ЩҚЫў ЩҲЩҺЩҠЩҺШӯЩ’ЩҠЩҺЩүЩ° Щ…ЩҺЩҶЩ’ ШӯЩҺЩүЩ‘ЩҺ Ш№ЩҺЩҶЫў ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺШ©ЩҚЫў Ы— ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺШіЩҺЩ…ЩҗЩҠШ№ЩҢ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ"},{"key":"8:43","surah":8,"ayah":43,"num":1203,"page":182,"words":[{"code":"пІӢ","page":182,"end":false},{"code":"пІҢ","page":182,"end":false},{"code":"пІҚ","page":182,"end":false},{"code":"пІҺ","page":182,"end":false},{"code":"пІҸ","page":182,"end":false},{"code":"пІҗпІ‘","page":182,"end":false},{"code":"пІ’","page":182,"end":false},{"code":"пІ“","page":182,"end":false},{"code":"пІ”","page":182,"end":false},{"code":"пІ•","page":182,"end":false},{"code":"пІ–","page":182,"end":false},{"code":"пІ—","page":182,"end":false},{"code":"пІҳ","page":182,"end":false},{"code":"пІҷ","page":182,"end":false},{"code":"пІҡ","page":182,"end":false},{"code":"пІӣпІң","page":182,"end":false},{"code":"пІқ","page":182,"end":false},{"code":"пІһ","page":182,"end":false},{"code":"пІҹ","page":182,"end":false},{"code":"пІ ","page":182,"end":false},{"code":"пІЎ","page":182,"end":true}],"text":"ШҘЩҗШ°Щ’ ЩҠЩҸШұЩҗЩҠЩғЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҗЩү Щ…ЩҺЩҶЩҺШ§Щ…ЩҗЩғЩҺ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ Ы– ЩҲЩҺЩ„ЩҺЩҲЩ’ ШЈЩҺШұЩҺЩүЩ°ЩғЩҺЩҮЩҸЩ…Щ’ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ„Щ‘ЩҺЩҒЩҺШҙЩҗЩ„Щ’ШӘЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШӘЩҺЩҶЩҺЩҖЩ°ШІЩҺШ№Щ’ШӘЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺЩ…Щ’ШұЩҗ ЩҲЩҺЩ„ЩҺЩҖЩ°ЩғЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШіЩҺЩ„Щ‘ЩҺЩ…ЩҺ Ы— ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗШ°ЩҺШ§ШӘЩҗ ЩұЩ„ШөЩ‘ЩҸШҜЩҸЩҲШұЩҗ"},{"key":"8:44","surah":8,"ayah":44,"num":1204,"page":182,"words":[{"code":"пІў","page":182,"end":false},{"code":"пІЈ","page":182,"end":false},{"code":"пІӨ","page":182,"end":false},{"code":"пІҘ","page":182,"end":false},{"code":"пІҰ","page":182,"end":false},{"code":"пІ§","page":182,"end":false},{"code":"пІЁ","page":182,"end":false},{"code":"пІ©","page":182,"end":false},{"code":"пІӘ","page":182,"end":false},{"code":"пІ«","page":182,"end":false},{"code":"пІ¬","page":182,"end":false},{"code":"пІӯ","page":182,"end":false},{"code":"пІ®","page":182,"end":false},{"code":"пІҜ","page":182,"end":false},{"code":"пІ°пІұ","page":182,"end":false},{"code":"пІІ","page":182,"end":false},{"code":"пІі","page":182,"end":false},{"code":"пІҙ","page":182,"end":false},{"code":"пІө","page":182,"end":false},{"code":"пІ¶","page":182,"end":true}],"text":"ЩҲЩҺШҘЩҗШ°Щ’ ЩҠЩҸШұЩҗЩҠЩғЩҸЩ…ЩҸЩҲЩҮЩҸЩ…Щ’ ШҘЩҗШ°Щҗ ЩұЩ„Щ’ШӘЩҺЩӮЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ЩҒЩҗЩүЩ“ ШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҗЩғЩҸЩ…Щ’ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ ЩҲЩҺЩҠЩҸЩӮЩҺЩ„Щ‘ЩҗЩ„ЩҸЩғЩҸЩ…Щ’ ЩҒЩҗЩүЩ“ ШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҗЩҮЩҗЩ…Щ’ Щ„ЩҗЩҠЩҺЩӮЩ’Ш¶ЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺЩ…Щ’ШұЩӢЫӯШ§ ЩғЩҺШ§ЩҶЩҺ Щ…ЩҺЩҒЩ’Ш№ЩҸЩҲЩ„ЩӢЫӯШ§ Ы— ЩҲЩҺШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҸ"},{"key":"8:45","surah":8,"ayah":45,"num":1205,"page":182,"words":[{"code":"пІ·","page":182,"end":false},{"code":"пІё","page":182,"end":false},{"code":"пІ№","page":182,"end":false},{"code":"пІә","page":182,"end":false},{"code":"пІ»","page":182,"end":false},{"code":"пІј","page":182,"end":false},{"code":"пІҪ","page":182,"end":false},{"code":"пІҫ","page":182,"end":false},{"code":"пІҝ","page":182,"end":false},{"code":"піҖ","page":182,"end":false},{"code":"піҒ","page":182,"end":false},{"code":"піӮ","page":182,"end":false},{"code":"піғ","page":182,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ Щ„ЩҺЩӮЩҗЩҠШӘЩҸЩ…Щ’ ЩҒЩҗШҰЩҺШ©ЩӢЫӯ ЩҒЩҺЩұШ«Щ’ШЁЩҸШӘЩҸЩҲШ§Ыҹ ЩҲЩҺЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ„Щ‘ЩҺШ№ЩҺЩ„Щ‘ЩҺЩғЩҸЩ…Щ’ ШӘЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"}]}
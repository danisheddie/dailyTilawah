ҺШӯЩҗЩҠЩ…Щҗ"},{"key":"5:11","surah":5,"ayah":11,"num":680,"page":109,"words":[{"code":"пұү","page":109,"end":false},{"code":"пұҠ","page":109,"end":false},{"code":"пұӢ","page":109,"end":false},{"code":"пұҢ","page":109,"end":false},{"code":"пұҚ","page":109,"end":false},{"code":"пұҺ","page":109,"end":false},{"code":"пұҸ","page":109,"end":false},{"code":"пұҗ","page":109,"end":false},{"code":"пұ‘","page":109,"end":false},{"code":"пұ’","page":109,"end":false},{"code":"пұ“","page":109,"end":false},{"code":"пұ”","page":109,"end":false},{"code":"пұ•","page":109,"end":false},{"code":"пұ–","page":109,"end":false},{"code":"пұ—","page":109,"end":false},{"code":"пұҳ","page":109,"end":false},{"code":"пұҷпұҡ","page":109,"end":false},{"code":"пұӣ","page":109,"end":false},{"code":"пұңпұқ","page":109,"end":false},{"code":"пұһ","page":109,"end":false},{"code":"пұҹ","page":109,"end":false},{"code":"пұ ","page":109,"end":false},{"code":"пұЎ","page":109,"end":false},{"code":"пұў","page":109,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШ°Щ’ЩғЩҸШұЩҸЩҲШ§Ыҹ ЩҶЩҗШ№Щ’Щ…ЩҺШӘЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШҘЩҗШ°Щ’ ЩҮЩҺЩ…Щ‘ЩҺ ЩӮЩҺЩҲЩ’Щ…ЩҢ ШЈЩҺЩҶ ЩҠЩҺШЁЩ’ШіЩҸШ·ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩ…Щ’ ЩҒЩҺЩғЩҺЩҒЩ‘ЩҺ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩ„Щ’ЩҠЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"5:12","surah":5,"ayah":12,"num":681,"page":109,"words":[{"code":"пұЈ пұӨ","page":109,"end":false},{"code":"пұҘ","page":109,"end":false},{"code":"пұҰ","page":109,"end":false},{"code":"пұ§","page":109,"end":false},{"code":"пұЁ","page":109,"end":false},{"code":"пұ©","page":109,"end":false},{"code":"пұӘ","page":109,"end":false},{"code":"пұ«","page":109,"end":false},{"code":"пұ¬","page":109,"end":false},{"code":"пұӯ","page":109,"end":false},{"code":"пұ®пұҜ","page":109,"end":false},{"code":"пұ°","page":109,"end":false},{"code":"пұұ","page":109,"end":false},{"code":"пұІ","page":109,"end":false},{"code":"пұіпұҙ","page":109,"end":false},{"code":"пұө","page":109,"end":false},{"code":"пұ¶","page":109,"end":false},{"code":"пұ·","page":109,"end":false},{"code":"пұё","page":109,"end":false},{"code":"пұ№","page":109,"end":false},{"code":"пұә","page":109,"end":false},{"code":"пұ»","page":109,"end":false},{"code":"пұј","page":109,"end":false},{"code":"пұҪ","page":109,"end":false},{"code":"пұҫ","page":109,"end":false},{"code":"пұҝ","page":109,"end":false},{"code":"пІҖ","page":109,"end":false},{"code":"пІҒ","page":109,"end":false},{"code":"пІӮ","page":109,"end":false},{"code":"пІғ","page":109,"end":false},{"code":"пІ„","page":109,"end":false},{"code":"пІ…","page":109,"end":false},{"code":"пІҶ","page":109,"end":false},{"code":"пІҮ","page":109,"end":false},{"code":"пІҲ","page":109,"end":false},{"code":"пІүпІҠ","page":109,"end":false},{"code":"пІӢ","page":109,"end":false},{"code":"пІҢ","page":109,"end":false},{"code":"пІҚ","page":109,"end":false},{"code":"пІҺ","page":109,"end":false},{"code":"пІҸ","page":109,"end":false},{"code":"пІҗ","page":109,"end":false},{"code":"пІ‘","page":109,"end":false},{"code":"пІ’","page":109,"end":false},{"code":"пІ“","page":109,"end":false},{"code":"пІ”","page":109,"end":true}],"text":"Ыһ ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЈЩҺШ®ЩҺШ°ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҺ ШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩҲЩҺШЁЩҺШ№ЩҺШ«Щ’ЩҶЩҺШ§ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…ЩҸ ЩұШ«Щ’ЩҶЩҺЩүЩ’ Ш№ЩҺШҙЩҺШұЩҺ ЩҶЩҺЩӮЩҗЩҠШЁЩӢЫӯШ§ Ы– ЩҲЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҘЩҗЩҶЩ‘ЩҗЩү Щ…ЩҺШ№ЩҺЩғЩҸЩ…Щ’ Ы– Щ„ЩҺШҰЩҗЩҶЩ’ ШЈЩҺЩӮЩҺЩ…Щ’ШӘЩҸЩ…ЩҸ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҠЩ’ШӘЩҸЩ…ЩҸ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§Щ…ЩҺЩҶШӘЩҸЩ… ШЁЩҗШұЩҸШіЩҸЩ„ЩҗЩү ЩҲЩҺШ№ЩҺШІЩ‘ЩҺШұЩ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩӮЩ’ШұЩҺШ¶Щ’ШӘЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩӮЩҺШұЩ’Ш¶ЩӢШ§ ШӯЩҺШіЩҺЩҶЩӢЫӯШ§ Щ„Щ‘ЩҺШЈЩҸЩғЩҺЩҒЩ‘ЩҗШұЩҺЩҶЩ‘ЩҺ Ш№ЩҺЩҶЩғЩҸЩ…Щ’ ШіЩҺЩҠЩ‘ЩҗЩҖЩ”ЩҺШ§ШӘЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШЈЩҸШҜЩ’Ш®ЩҗЩ„ЩҺЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў ШӘЩҺШ¬Щ’ШұЩҗЩү Щ…ЩҗЩҶ ШӘЩҺШӯЩ’ШӘЩҗЩҮЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҶЩ’ЩҮЩҺЩҖЩ°ШұЩҸ Ыҡ ЩҒЩҺЩ…ЩҺЩҶ ЩғЩҺЩҒЩҺШұЩҺ ШЁЩҺШ№Щ’ШҜЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ ЩҒЩҺЩӮЩҺШҜЩ’ Ш¶ЩҺЩ„Щ‘ЩҺ ШіЩҺЩҲЩҺШ§Щ“ШЎЩҺ ЩұЩ„ШіЩ‘ЩҺШЁЩҗЩҠЩ„Щҗ"},{"key":"5:13","surah":5,"ayah":13,"num":682,"page":109,"words":[{"code":"пІ•","page":109,"end":false},{"code":"пІ–","page":109,"end":false},{"code":"пІ—","page":109,"end":false},{"code":"пІҳ","page":109,"end":false},{"code":"пІҷ","page":109,"end":false},{"code":"пІҡ","page":109,"end":false},{"code":"пІӣпІң","page":109,"end":false},{"code":"пІқ","page":109,"end":false},{"code":"пІһ","page":109,"end":false},{"code":"пІҹ","page":109,"end":false},{"code":"пІ ","page":109,"end":false},{"code":"пІЎ","page":109,"end":false},{"code":"пІў","page":109,"end":false},{"code":"пІЈ","page":109,"end":false},{"code":"пІӨ","page":109,"end":false},{"code":"пІҘпІҰ","page":109,"end":false},{"code":"пІ§","page":109,"end":false},{"code":"пІЁ","page":109,"end":false},{"code":"пІ©","page":109,"end":false},{"code":"пІӘ","page":109,"end":false},{"code":"пІ«","page":109,"end":false},{"code":"пІ¬","page":109,"end":false},{"code":"пІӯ","page":109,"end":false},{"code":"пІ®","page":109,"end":false},{"code":"пІҜпІ°","page":109,"end":false},{"code":"пІұ","page":109,"end":false},{"code":"пІІ","page":109,"end":false},{"code":"пІіпІҙ","page":109,"end":false},{"code":"пІө","page":109,"end":false},{"code":"пІ¶","page":109,"end":false},{"code":"пІ·","page":109,"end":false},{"code":"пІё","page":109,"end":false},{"code":"пІ№","page":109,"end":true}],"text":"ЩҒЩҺШЁЩҗЩ…ЩҺШ§ ЩҶЩҺЩӮЩ’Ш¶ЩҗЩҮЩҗЩ… Щ…Щ‘ЩҗЩҠШ«ЩҺЩҖЩ°ЩӮЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ№ЩҺЩҶЩ‘ЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩӮЩҸЩ„ЩҸЩҲШЁЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺЩҖЩ°ШіЩҗЩҠЩҺШ©ЩӢЫӯ Ы– ЩҠЩҸШӯЩҺШұЩ‘ЩҗЩҒЩҸЩҲЩҶЩҺ ЩұЩ„Щ’ЩғЩҺЩ„ЩҗЩ…ЩҺ Ш№ЩҺЩҶ Щ…Щ‘ЩҺЩҲЩҺШ§Ш¶ЩҗШ№ЩҗЩҮЩҗЫҰ Ыҷ ЩҲЩҺЩҶЩҺШіЩҸЩҲШ§Ыҹ ШӯЩҺШёЩ‘ЩӢЫӯШ§ Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ Ш°ЩҸЩғЩ‘ЩҗШұЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШІЩҺШ§Щ„ЩҸ ШӘЩҺШ·Щ‘ЩҺЩ„ЩҗШ№ЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° Ш®ЩҺШ§Щ“ШҰЩҗЩҶЩҺШ©ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҒЩҺЩұШ№Щ’ЩҒЩҸ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ ЩҲЩҺЩұШөЩ’ЩҒЩҺШӯЩ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҸШӯЩҗШЁЩ‘ЩҸ ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"}]}
page":257,"end":false},{"code":"пІұ","page":257,"end":false},{"code":"пІІ","page":257,"end":true}],"text":"ЩҠЩҺШӘЩҺШ¬ЩҺШұЩ‘ЩҺШ№ЩҸЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺЩғЩҺШ§ШҜЩҸ ЩҠЩҸШіЩҗЩҠШәЩҸЩҮЩҸЫҘ ЩҲЩҺЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҗ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҸ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ Щ…ЩҺЩғЩҺШ§ЩҶЩҚЫў ЩҲЩҺЩ…ЩҺШ§ ЩҮЩҸЩҲЩҺ ШЁЩҗЩ…ЩҺЩҠЩ‘ЩҗШӘЩҚЫў Ы– ЩҲЩҺЩ…ЩҗЩҶ ЩҲЩҺШұЩҺШ§Щ“ШҰЩҗЩҮЩҗЫҰ Ш№ЩҺШ°ЩҺШ§ШЁЩҢ ШәЩҺЩ„ЩҗЩҠШёЩҢЫӯ"},{"key":"14:18","surah":14,"ayah":18,"num":1768,"page":257,"words":[{"code":"пІі","page":257,"end":false},{"code":"пІҙ","page":257,"end":false},{"code":"пІө","page":257,"end":false},{"code":"пІ¶пІ·","page":257,"end":false},{"code":"пІё","page":257,"end":false},{"code":"пІ№","page":257,"end":false},{"code":"пІә","page":257,"end":false},{"code":"пІ»","page":257,"end":false},{"code":"пІј","page":257,"end":false},{"code":"пІҪ","page":257,"end":false},{"code":"пІҫ","page":257,"end":false},{"code":"пІҝпіҖ","page":257,"end":false},{"code":"піҒ","page":257,"end":false},{"code":"піӮ","page":257,"end":false},{"code":"піғ","page":257,"end":false},{"code":"пі„","page":257,"end":false},{"code":"пі…","page":257,"end":false},{"code":"піҶпіҮ","page":257,"end":false},{"code":"піҲ","page":257,"end":false},{"code":"піү","page":257,"end":false},{"code":"піҠ","page":257,"end":false},{"code":"піӢ","page":257,"end":false},{"code":"піҢ","page":257,"end":true}],"text":"Щ…Щ‘ЩҺШ«ЩҺЩ„ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ШЁЩҗШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ Ы– ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҸЩҮЩҸЩ…Щ’ ЩғЩҺШұЩҺЩ…ЩҺШ§ШҜЩҚ ЩұШҙЩ’ШӘЩҺШҜЩ‘ЩҺШӘЩ’ ШЁЩҗЩҮЩҗ ЩұЩ„ШұЩ‘ЩҗЩҠШӯЩҸ ЩҒЩҗЩү ЩҠЩҺЩҲЩ’Щ…ЩҚ Ш№ЩҺШ§ШөЩҗЩҒЩҚЫў Ы– Щ„Щ‘ЩҺШ§ ЩҠЩҺЩӮЩ’ШҜЩҗШұЩҸЩҲЩҶЩҺ Щ…ЩҗЩ…Щ‘ЩҺШ§ ЩғЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ° ШҙЩҺЩүЩ’ШЎЩҚЫў Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҮЩҸЩҲЩҺ ЩұЩ„Ш¶Щ‘ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҸ ЩұЩ„Щ’ШЁЩҺШ№ЩҗЩҠШҜЩҸ"}]}
ҠШ¶ЩҺШ©Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩғЩҺШ§ЩҶЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩӢШ§ ШӯЩҺЩғЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"4:25","surah":4,"ayah":25,"num":518,"page":82,"words":[{"code":"пұІ","page":82,"end":false},{"code":"пұі","page":82,"end":false},{"code":"пұҙ","page":82,"end":false},{"code":"пұө","page":82,"end":false},{"code":"пұ¶","page":82,"end":false},{"code":"пұ·","page":82,"end":false},{"code":"пұё","page":82,"end":false},{"code":"пұ№","page":82,"end":false},{"code":"пұә","page":82,"end":false},{"code":"пұ»","page":82,"end":false},{"code":"пұј","page":82,"end":false},{"code":"пұҪ","page":82,"end":false},{"code":"пұҫ","page":82,"end":false},{"code":"пұҝ","page":82,"end":false},{"code":"пІҖ","page":82,"end":false},{"code":"пІҒпІӮ","page":82,"end":false},{"code":"пІғ","page":82,"end":false},{"code":"пІ„","page":82,"end":false},{"code":"пІ…пІҶ","page":82,"end":false},{"code":"пІҮ","page":82,"end":false},{"code":"пІҲ","page":82,"end":false},{"code":"пІүпІҠ","page":82,"end":false},{"code":"пІӢ","page":82,"end":false},{"code":"пІҢ","page":82,"end":false},{"code":"пІҚ","page":82,"end":false},{"code":"пІҺ","page":82,"end":false},{"code":"пІҸ","page":82,"end":false},{"code":"пІҗ","page":82,"end":false},{"code":"пІ‘","page":82,"end":false},{"code":"пІ’","page":82,"end":false},{"code":"пІ“","page":82,"end":false},{"code":"пІ”","page":82,"end":false},{"code":"пІ•","page":82,"end":false},{"code":"пІ–пІ—","page":82,"end":false},{"code":"пІҳ","page":82,"end":false},{"code":"пІҷ","page":82,"end":false},{"code":"пІҡ","page":82,"end":false},{"code":"пІӣ","page":82,"end":false},{"code":"пІң","page":82,"end":false},{"code":"пІқ","page":82,"end":false},{"code":"пІһ","page":82,"end":false},{"code":"пІҹ","page":82,"end":false},{"code":"пІ ","page":82,"end":false},{"code":"пІЎ","page":82,"end":false},{"code":"пІў","page":82,"end":false},{"code":"пІЈпІӨ","page":82,"end":false},{"code":"пІҘ","page":82,"end":false},{"code":"пІҰ","page":82,"end":false},{"code":"пІ§","page":82,"end":false},{"code":"пІЁ","page":82,"end":false},{"code":"пІ©пІӘ","page":82,"end":false},{"code":"пІ«","page":82,"end":false},{"code":"пІ¬","page":82,"end":false},{"code":"пІӯ","page":82,"end":false},{"code":"пІ®пІҜ","page":82,"end":false},{"code":"пІ°","page":82,"end":false},{"code":"пІұ","page":82,"end":false},{"code":"пІІ","page":82,"end":false},{"code":"пІі","page":82,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺШіЩ’ШӘЩҺШ·ЩҗШ№Щ’ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ш·ЩҺЩҲЩ’Щ„ЩӢШ§ ШЈЩҺЩҶ ЩҠЩҺЩҶЩғЩҗШӯЩҺ ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШөЩҺЩҶЩҺЩҖЩ°ШӘЩҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҒЩҺЩ…ЩҗЩҶ Щ…Щ‘ЩҺШ§ Щ…ЩҺЩ„ЩҺЩғЩҺШӘЩ’ ШЈЩҺЩҠЩ’Щ…ЩҺЩҖЩ°ЩҶЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ЩҒЩҺШӘЩҺЩҠЩҺЩҖЩ°ШӘЩҗЩғЩҸЩ…ЩҸ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ Ыҡ ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЈЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШЁЩҗШҘЩҗЩҠЩ…ЩҺЩҖЩ°ЩҶЩҗЩғЩҸЩ… Ыҡ ШЁЩҺШ№Щ’Ш¶ЩҸЩғЩҸЩ… Щ…Щ‘ЩҗЩҶЫў ШЁЩҺШ№Щ’Ш¶ЩҚЫў Ыҡ ЩҒЩҺЩұЩҶЩғЩҗШӯЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ШЈЩҺЩҮЩ’Щ„ЩҗЩҮЩҗЩҶЩ‘ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҸЩҲЩҮЩҸЩҶЩ‘ЩҺ ШЈЩҸШ¬ЩҸЩҲШұЩҺЩҮЩҸЩҶЩ‘ЩҺ ШЁЩҗЩұЩ„Щ’Щ…ЩҺШ№Щ’ШұЩҸЩҲЩҒЩҗ Щ…ЩҸШӯЩ’ШөЩҺЩҶЩҺЩҖЩ°ШӘЩҚ ШәЩҺЩҠЩ’ШұЩҺ Щ…ЩҸШіЩҺЩҖЩ°ЩҒЩҗШӯЩҺЩҖЩ°ШӘЩҚЫў ЩҲЩҺЩ„ЩҺШ§ Щ…ЩҸШӘЩ‘ЩҺШ®ЩҗШ°ЩҺЩ°ШӘЩҗ ШЈЩҺШ®Щ’ШҜЩҺШ§ЩҶЩҚЫў Ыҡ ЩҒЩҺШҘЩҗШ°ЩҺШ§Щ“ ШЈЩҸШӯЩ’ШөЩҗЩҶЩ‘ЩҺ ЩҒЩҺШҘЩҗЩҶЩ’ ШЈЩҺШӘЩҺЩҠЩ’ЩҶЩҺ ШЁЩҗЩҒЩҺЩҖЩ°ШӯЩҗШҙЩҺШ©ЩҚЫў ЩҒЩҺШ№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩҶЩ‘ЩҺ ЩҶЩҗШөЩ’ЩҒЩҸ Щ…ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШөЩҺЩҶЩҺЩҖЩ°ШӘЩҗ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҗЩ…ЩҺЩҶЩ’ Ш®ЩҺШҙЩҗЩүЩҺ ЩұЩ„Щ’Ш№ЩҺЩҶЩҺШӘЩҺ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ Ыҡ ЩҲЩҺШЈЩҺЩҶ ШӘЩҺШөЩ’ШЁЩҗШұЩҸЩҲШ§Ыҹ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"4:26","surah":4,"ayah":26,"num":519,"page":82,"words":[{"code":"пІҙ","page":82,"end":false},{"code":"пІө","page":82,"end":false},{"code":"пІ¶","page":82,"end":false},{"code":"пІ·","page":82,"end":false},{"code":"пІё","page":82,"end":false},{"code":"пІ№","page":82,"end":false},{"code":"пІә","page":82,"end":false},{"code":"пІ»","page":82,"end":false},{"code":"пІј","page":82,"end":false},{"code":"пІҪ","page":82,"end":false},{"code":"пІҫпІҝ","page":82,"end":false},{"code":"піҖ","page":82,"end":false},{"code":"піҒ","page":82,"end":false},{"code":"піӮ","page":82,"end":false},{"code":"піғ","page":82,"end":true}],"text":"ЩҠЩҸШұЩҗЩҠШҜЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҗЩҠЩҸШЁЩҺЩҠЩ‘ЩҗЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҺЩҮЩ’ШҜЩҗЩҠЩҺЩғЩҸЩ…Щ’ ШіЩҸЩҶЩҺЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩҠЩҺШӘЩҸЩҲШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢЫӯ"}]}
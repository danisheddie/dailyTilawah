e":398,"end":false},{"code":"пұЈ","page":398,"end":false},{"code":"пұӨ","page":398,"end":false},{"code":"пұҘ","page":398,"end":false},{"code":"пұҰ","page":398,"end":false},{"code":"пұ§","page":398,"end":false},{"code":"пұЁ","page":398,"end":false},{"code":"пұ©","page":398,"end":false},{"code":"пұӘ","page":398,"end":false},{"code":"пұ«","page":398,"end":false},{"code":"пұ¬","page":398,"end":false},{"code":"пұӯ","page":398,"end":false},{"code":"пұ®","page":398,"end":false},{"code":"пұҜ","page":398,"end":false},{"code":"пұ°пұұ","page":398,"end":false},{"code":"пұІ","page":398,"end":false},{"code":"пұі","page":398,"end":false},{"code":"пұҙ","page":398,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШЈЩҺЩҲЩ’Ш«ЩҺЩҖЩ°ЩҶЩӢЫӯШ§ ЩҲЩҺШӘЩҺШ®Щ’Щ„ЩҸЩӮЩҸЩҲЩҶЩҺ ШҘЩҗЩҒЩ’ЩғЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ„ЩҺШ§ ЩҠЩҺЩ…Щ’Щ„ЩҗЩғЩҸЩҲЩҶЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ШұЩҗШІЩ’ЩӮЩӢЫӯШ§ ЩҒЩҺЩұШЁЩ’ШӘЩҺШәЩҸЩҲШ§Ыҹ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„ШұЩ‘ЩҗШІЩ’ЩӮЩҺ ЩҲЩҺЩұШ№Щ’ШЁЩҸШҜЩҸЩҲЩҮЩҸ ЩҲЩҺЩұШҙЩ’ЩғЩҸШұЩҸЩҲШ§Ыҹ Щ„ЩҺЩҮЩҸЫҘЩ“ Ы– ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"29:18","surah":29,"ayah":18,"num":3358,"page":398,"words":[{"code":"пұө","page":398,"end":false},{"code":"пұ¶","page":398,"end":false},{"code":"пұ·","page":398,"end":false},{"code":"пұё","page":398,"end":false},{"code":"пұ№","page":398,"end":false},{"code":"пұә","page":398,"end":false},{"code":"пұ»пұј","page":398,"end":false},{"code":"пұҪ","page":398,"end":false},{"code":"пұҫ","page":398,"end":false},{"code":"пұҝ","page":398,"end":false},{"code":"пІҖ","page":398,"end":false},{"code":"пІҒ","page":398,"end":false},{"code":"пІӮ","page":398,"end":false},{"code":"пІғ","page":398,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶ ШӘЩҸЩғЩҺШ°Щ‘ЩҗШЁЩҸЩҲШ§Ыҹ ЩҒЩҺЩӮЩҺШҜЩ’ ЩғЩҺШ°Щ‘ЩҺШЁЩҺ ШЈЩҸЩ…ЩҺЩ…ЩҢЫӯ Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҸЩ…Щ’ Ы– ЩҲЩҺЩ…ЩҺШ§ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ’ШЁЩҺЩ„ЩҺЩҖЩ°ШәЩҸ ЩұЩ„Щ’Щ…ЩҸШЁЩҗЩҠЩҶЩҸ"},{"key":"29:19","surah":29,"ayah"
},{"code":"пұЈ","page":543,"end":false},{"code":"пұӨ","page":543,"end":false},{"code":"пұҘпұҰ","page":543,"end":false},{"code":"пұ§","page":543,"end":false},{"code":"пұЁ","page":543,"end":false},{"code":"пұ©","page":543,"end":false},{"code":"пұӘ","page":543,"end":false},{"code":"пұ«","page":543,"end":false},{"code":"пұ¬пұӯ","page":543,"end":false},{"code":"пұ®","page":543,"end":false},{"code":"пұҜ","page":543,"end":false},{"code":"пұ°","page":543,"end":false},{"code":"пұұ","page":543,"end":false},{"code":"пұІ","page":543,"end":false},{"code":"пұі","page":543,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы– Щ…ЩҺШ§ ЩҠЩҺЩғЩҸЩҲЩҶЩҸ Щ…ЩҗЩҶ ЩҶЩ‘ЩҺШ¬Щ’ЩҲЩҺЩүЩ° Ш«ЩҺЩ„ЩҺЩҖЩ°Ш«ЩҺШ©ЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ ШұЩҺШ§ШЁЩҗШ№ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ Ш®ЩҺЩ…Щ’ШіЩҺШ©ЩҚ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ ШіЩҺШ§ШҜЩҗШіЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺШҜЩ’ЩҶЩҺЩүЩ° Щ…ЩҗЩҶ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ЩҲЩҺЩ„ЩҺШ§Щ“ ШЈЩҺЩғЩ’Ш«ЩҺШұЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩҮЩҸЩҲЩҺ Щ…ЩҺШ№ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺЩҠЩ’ЩҶЩҺ Щ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ Ы– Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҸЩҶЩҺШЁЩ‘ЩҗШҰЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ Ш№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢ"},{"key":"58:8","surah":58,"ayah":8,"num":5112,"page":543,"words":[{"code":"пұҙ","page":543,"end":false},{"code":"пұө","page":543,"end":false},{"code":"пұ¶","page":543,"end":false},{"code":"пұ·","page":543,"end":false},{"code":"пұё","page":543,"end":false},{"code":"пұ№","page":543,"end":false},{"code":"пұә","page":543,"end":false},{"code":"пұ»","page":543,"end":false},{"code":"пұј","page":543,"end":false},{"code":"пұҪ","page":543,"end":false},{"code":"пұҫ","page":543,"end":false},{"code":"пұҝ","page":543,"end":false},{"code":"пІҖ","page":543,"end":false},{"code":"пІҒ","page":543,"end":false},{"code":"пІӮ","page":543,"end":false},{"code":"пІғ","page":543,"end":false},{"code":"пІ„пІ…","page":543,"end":false},{"code":"пІҶ","page":543,"end":false},{"code":"пІҮ","page":543,"end":false},{"code":"пІҲ","page":543,"end":false},{"code":"пІү","page":543,"end":false},{"code":"пІҠ","page":543,"end":false},{"code":"пІӢ","page":543,"end":false},{"code":"пІҢ","page":543,"end":false},{"code":"пІҚ","page":543,"end":false},{"code":"пІҺ","page":543,"end":false},{"code":"пІҸ","page":543,"end":false},{"code":"пІҗ","page":543,"end":false},{"code":"пІ‘","page":543,"end":false},{"code":"пІ’","page":543,"end":false},{"code":"пІ“","page":543,"end":false},{"code":"пІ”","page":543,"end":false},{"code":"пІ•пІ–","page":543,"end":false},{"code":"пІ—","page":543,"end":false},{"code":"пІҳ","page":543,"end":false},{"code":"пІҷпІҡ","page":543,"end":false},{"code":"пІӣ","page":543,"end":false},{"code":"пІң","page":543,"end":false},{"code":"пІқ","page":543,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ШӘЩҺШұЩҺ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҶЩҸЩҮЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩҗ ЩұЩ„ЩҶЩ‘ЩҺШ¬Щ’ЩҲЩҺЩүЩ° Ш«ЩҸЩ…Щ‘ЩҺ ЩҠЩҺШ№ЩҸЩҲШҜЩҸЩҲЩҶЩҺ Щ„ЩҗЩ…ЩҺШ§ ЩҶЩҸЩҮЩҸЩҲШ§Ыҹ Ш№ЩҺЩҶЩ’ЩҮЩҸ ЩҲЩҺЩҠЩҺШӘЩҺЩҶЩҺЩҖЩ°Ш¬ЩҺЩҲЩ’ЩҶЩҺ ШЁЩҗЩұЩ„Щ’ШҘЩҗШ«Щ’Щ…Щҗ ЩҲЩҺЩұЩ„Щ’Ш№ЩҸШҜЩ’ЩҲЩҺЩ°ЩҶЩҗ ЩҲЩҺЩ…ЩҺШ№Щ’ШөЩҗЩҠЩҺШӘЩҗ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ЩҲЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲЩғЩҺ ШӯЩҺЩҠЩ‘ЩҺЩҲЩ’ЩғЩҺ ШЁЩҗЩ…ЩҺШ§ Щ„ЩҺЩ…Щ’ ЩҠЩҸШӯЩҺЩҠЩ‘ЩҗЩғЩҺ ШЁЩҗЩҮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ЩҒЩҗЩүЩ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ…Щ’ Щ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҸЩҶЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ЩҶЩҺЩӮЩҸЩҲЩ„ЩҸ Ыҡ ШӯЩҺШіЩ’ШЁЩҸЩҮЩҸЩ…Щ’ Ш¬ЩҺЩҮЩҺЩҶЩ‘ЩҺЩ…ЩҸ ЩҠЩҺШөЩ’Щ„ЩҺЩҲЩ’ЩҶЩҺЩҮЩҺШ§ Ы– ЩҒЩҺШЁЩҗШҰЩ’ШіЩҺ ЩұЩ„Щ’Щ…ЩҺШөЩҗЩҠШұЩҸ"},{"key":"58:9","surah":58,"ayah":9,"num":5113,"page":543,"words":[{"code":"пІһ","page":543,"end":false},{"code":"пІҹ","page":543,"end":false},{"code":"пІ ","page":543,"end":false},{"code":"пІЎ","page":543,"end":false},{"code":"пІў","page":543,"end":false},{"code":"пІЈ","page":543,"end":false},{"code":"пІӨ","page":543,"end":false},{"code":"пІҘ","page":543,"end":false},{"code":"пІҰ","page":543,"end":false},{"code":"пІ§","page":543,"end":false},{"code":"пІЁ","page":543,"end":false},{"code":"пІ©","page":543,"end":false},{"code":"пІӘ","page":543,"end":false},{"code":"пІ«пІ¬","page":543,"end":false},{"code":"пІӯ","page":543,"end":false},{"code":"пІ®","page":543,"end":false},{"code":"пІҜ","page":543,"end":false},{"code":"пІ°","page":543,"end":false},{"code":"пІұ","page":543,"end":false},{"code":"пІІ","page":543,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ ШӘЩҺЩҶЩҺЩҖЩ°Ш¬ЩҺЩҠЩ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩҺЩҶЩҺЩҖЩ°Ш¬ЩҺЩҲЩ’Ш§Ыҹ ШЁЩҗЩұЩ„Щ’ШҘЩҗШ«Щ’Щ…Щҗ ЩҲЩҺЩұЩ„Щ’Ш№ЩҸШҜЩ’ЩҲЩҺЩ°ЩҶЩҗ ЩҲЩҺЩ…ЩҺШ№Щ’ШөЩҗЩҠЩҺШӘЩҗ ЩұЩ„ШұЩ‘ЩҺШіЩҸЩҲЩ„Щҗ ЩҲЩҺШӘЩҺЩҶЩҺЩҖЩ°Ш¬ЩҺЩҲЩ’Ш§Ыҹ ШЁЩҗЩұЩ„Щ’ШЁЩҗШұЩ‘Щҗ ЩҲЩҺЩұЩ„ШӘЩ‘ЩҺЩӮЩ’ЩҲЩҺЩүЩ° Ы– ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШӘЩҸШӯЩ’ШҙЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"58:10","surah":58,"ayah":10,"num":5114,"page":543,"words":[{"code":"пІі","page":543,"end":false},{"code":"пІҙ","page":543,"end":false},{"code":"пІө","page":543,"end":false},{"code":"пІ¶","page":543,"end":false},{"code":"пІ·","page":543,"end":false},{"code":"пІё","page":543,"end":false},{"code":"пІ№","page":543,"end":false},{"code":"пІә","page":543,"end":false},{"code":"пІ»","page":543,"end":false},{"code":"пІј","page":543,"end":false},{"code":"пІҪ","page":543,"end":false},{"code":"пІҫ","page":543,"end":false},{"code":"пІҝпіҖ","page":543,"end":false},{"code":"піҒ","page":543,"end":false},{"code":"піӮ","page":543,"end":false},{"code":"піғ","page":543,"end":false},{"code":"пі„","page":543,"end":false},{"code":"пі…","page":543,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШ¬Щ’ЩҲЩҺЩүЩ° Щ…ЩҗЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҗ Щ„ЩҗЩҠЩҺШӯЩ’ШІЩҸЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩ„ЩҺЩҠЩ’ШіЩҺ ШЁЩҗШ¶ЩҺШ§Щ“ШұЩ‘ЩҗЩҮЩҗЩ…Щ’ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢШ§ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҗШҘЩҗШ°Щ’ЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҡ ЩҲЩҺШ№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҒЩҺЩ„Щ’ЩҠЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щҗ ЩұЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"58:11","surah":58,"ayah":11,"num":5115,"page":543,"words":[{"code":"піҶ","page":543,"end":false},{"code":"піҮ","page":543,"end":false},{"c
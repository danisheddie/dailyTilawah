Ш№ЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…Щ’ ЩҠЩҺЩҮЩ’ШӘЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"32:4","surah":32,"ayah":4,"num":3507,"page":415,"words":[{"code":"пұ ","page":415,"end":false},{"code":"пұЎ","page":415,"end":false},{"code":"пұў","page":415,"end":false},{"code":"пұЈ","page":415,"end":false},{"code":"пұӨ","page":415,"end":false},{"code":"пұҘ","page":415,"end":false},{"code":"пұҰ","page":415,"end":false},{"code":"пұ§","page":415,"end":false},{"code":"пұЁ","page":415,"end":false},{"code":"пұ©","page":415,"end":false},{"code":"пұӘ","page":415,"end":false},{"code":"пұ«","page":415,"end":false},{"code":"пұ¬","page":415,"end":false},{"code":"пұӯпұ®","page":415,"end":false},{"code":"пұҜ","page":415,"end":false},{"code":"пұ°","page":415,"end":false},{"code":"пұұ","page":415,"end":false},{"code":"пұІ","page":415,"end":false},{"code":"пұі","page":415,"end":false},{"code":"пұҙ","page":415,"end":false},{"code":"пұө","page":415,"end":false},{"code":"пұ¶пұ·","page":415,"end":false},{"code":"пұё","page":415,"end":false},{"code":"пұ№","page":415,"end":false},{"code":"пұә","page":415,"end":true}],"text":"ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ЩҲЩҺЩ…ЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…ЩҺШ§ ЩҒЩҗЩү ШіЩҗШӘЩ‘ЩҺШ©Щҗ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚЫў Ш«ЩҸЩ…Щ‘ЩҺ ЩұШіЩ’ШӘЩҺЩҲЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’Ш№ЩҺШұЩ’ШҙЩҗ Ы– Щ…ЩҺШ§ Щ„ЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЫҰ Щ…ЩҗЩҶ ЩҲЩҺЩ„ЩҗЩүЩ‘ЩҚЫў ЩҲЩҺЩ„ЩҺШ§ ШҙЩҺЩҒЩҗЩҠШ№ЩҚ Ыҡ ШЈЩҺЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШӘЩҺШ°ЩҺЩғЩ‘ЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"32:5","surah":32,"ayah":5,"num":3508,"page":415,"words":[{"code":"пұ»","page":415,"end":false},{"code":"пұј","page":415,"end":false},{"code":"пұҪ","page":415,"end":false},{"code":"пұҫ","page":415,"end":false},{"code":"пұҝ","page":415,"end":false},{"code":"пІҖ","page":415,"end":false},{"code":"пІҒ","page":415,"end":false},{"code":"пІӮ","page":415,"end":false},{"code":"пІғ","page":415,"end":false},{"code":"пІ„","page":415,"end":false},{"code":"пІ…","page":415,"end":false},{"code":"пІҶ","page":415,"end":false},{"code":"пІҮ","page":415,"end"
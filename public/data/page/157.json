page":157,"end":false},{"code":"пІҜ","page":157,"end":false},{"code":"пІ°","page":157,"end":false},{"code":"пІұ","page":157,"end":false},{"code":"пІІ","page":157,"end":false},{"code":"пІі","page":157,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸЩҒЩ’ШіЩҗШҜЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЁЩҺШ№Щ’ШҜЩҺ ШҘЩҗШөЩ’Щ„ЩҺЩҖЩ°ШӯЩҗЩҮЩҺШ§ ЩҲЩҺЩұШҜЩ’Ш№ЩҸЩҲЩҮЩҸ Ш®ЩҺЩҲЩ’ЩҒЩӢЫӯШ§ ЩҲЩҺШ·ЩҺЩ…ЩҺШ№ЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩӮЩҺШұЩҗЩҠШЁЩҢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШӯЩ’ШіЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"7:57","surah":7,"ayah":57,"num":1011,"page":157,"words":[{"code":"пІҙ","page":157,"end":false},{"code":"пІө","page":157,"end":false},{"code":"пІ¶","page":157,"end":false},{"code":"пІ·","page":157,"end":false},{"code":"пІё","page":157,"end":false},{"code":"пІ№","page":157,"end":false},{"code":"пІә","page":157,"end":false},{"code":"пІ»пІј","page":157,"end":false},{"code":"пІҪ","page":157,"end":false},{"code":"пІҫ","page":157,"end":false},{"code":"пІҝ","page":157,"end":false},{"code":"піҖ","page":157,"end":false},{"code":"піҒ","page":157,"end":false},{"code":"піӮ","page":157,"end":false},{"code":"піғ","page":157,"end":false},{"code":"пі„","page":157,"end":false},{"code":"пі…","page":157,"end":false},{"code":"піҶ","page":157,"end":false},{"code":"піҮ","page":157,"end":false},{"code":"піҲ","page":157,"end":false},{"code":"піү","page":157,"end":false},{"code":"піҠ","page":157,"end":false},{"code":"піӢ","page":157,"end":false},{"code":"піҢпіҚ","page":157,"end":false},{"code":"піҺ","page":157,"end":false},{"code":"піҸ","page":157,"end":false},{"code":"піҗ","page":157,"end":false},{"code":"пі‘","page":157,"end":false},{"code":"пі’","page":157,"end":false},{"code":"пі“","page":157,"end":true}],"text":"ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҸШұЩ’ШіЩҗЩ„ЩҸ ЩұЩ„ШұЩ‘ЩҗЩҠЩҺЩҖЩ°ШӯЩҺ ШЁЩҸШҙЩ’ШұЩӢЫўШ§ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩҠЩҺШҜЩҺЩүЩ’ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰ Ы– ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§Щ“ ШЈЩҺЩӮЩҺЩ„Щ‘ЩҺШӘЩ’ ШіЩҺШӯЩҺШ§ШЁЩӢЫӯШ§ Ш«ЩҗЩӮЩҺШ§Щ„ЩӢЫӯШ§ ШіЩҸЩӮЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸ Щ„ЩҗШЁЩҺЩ„ЩҺШҜЩҚЫў Щ…Щ‘ЩҺЩҠЩ‘ЩҗШӘЩҚЫў ЩҒЩҺШЈЩҺЩҶШІЩҺЩ
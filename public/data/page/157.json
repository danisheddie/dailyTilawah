nd":false},{"code":"пұ©","page":157,"end":false},{"code":"пұӘпұ«","page":157,"end":false},{"code":"пұ¬","page":157,"end":false},{"code":"пұӯ","page":157,"end":false},{"code":"пұ®","page":157,"end":false},{"code":"пұҜ","page":157,"end":false},{"code":"пұ°","page":157,"end":false},{"code":"пұұ","page":157,"end":false},{"code":"пұІ","page":157,"end":false},{"code":"пұі","page":157,"end":false},{"code":"пұҙ","page":157,"end":true}],"text":"ЩҮЩҺЩ„Щ’ ЩҠЩҺЩҶШёЩҸШұЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„ЩҺЩҮЩҸЫҘ Ыҡ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҺШЈЩ’ШӘЩҗЩү ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„ЩҸЩҮЩҸЫҘ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҶЩҺШіЩҸЩҲЩҮЩҸ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҸ ЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ ШұЩҸШіЩҸЩ„ЩҸ ШұЩҺШЁЩ‘ЩҗЩҶЩҺШ§ ШЁЩҗЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҒЩҺЩҮЩҺЩ„ Щ„Щ‘ЩҺЩҶЩҺШ§ Щ…ЩҗЩҶ ШҙЩҸЩҒЩҺШ№ЩҺШ§Щ“ШЎЩҺ ЩҒЩҺЩҠЩҺШҙЩ’ЩҒЩҺШ№ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҶЩҺШ§Щ“ ШЈЩҺЩҲЩ’ ЩҶЩҸШұЩҺШҜЩ‘ЩҸ ЩҒЩҺЩҶЩҺШ№Щ’Щ…ЩҺЩ„ЩҺ ШәЩҺЩҠЩ’ШұЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩғЩҸЩҶЩ‘ЩҺШ§ ЩҶЩҺШ№Щ’Щ…ЩҺЩ„ЩҸ Ыҡ ЩӮЩҺШҜЩ’ Ш®ЩҺШіЩҗШұЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩҒЩҸШіЩҺЩҮЩҸЩ…Щ’ ЩҲЩҺШ¶ЩҺЩ„Щ‘ЩҺ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ… Щ…Щ‘ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"7:54","surah":7,"ayah":54,"num":1008,"page":157,"words":[{"code":"пұө","page":157,"end":false},{"code":"пұ¶","page":157,"end":false},{"code":"пұ·","page":157,"end":false},{"code":"пұё","page":157,"end":false},{"code":"пұ№","page":157,"end":false},{"code":"пұә","page":157,"end":false},{"code":"пұ»","page":157,"end":false},{"code":"пұј","page":157,"end":false},{"code":"пұҪ","page":157,"end":false},{"code":"пұҫ","page":157,"end":false},{"code":"пұҝ","page":157,"end":false},{"code":"пІҖ","page":157,"end":false},{"code":"пІҒ","page":157,"end":false},{"code":"пІӮпІғ","page":157,"end":false},{"code":"пІ„","page":157,"end":false},{"code":"пІ…","page":157,"end":false},{"code":"пІҶ","page":157,"end":false},{"code":"пІҮ","page":157,"end":false},{"code":"пІҲ","page":157,"end":false},{"code":"пІү","page":157,"end":false},{"code":"пІҠ","page":157,"end":false},{"code":"пІӢ","page":157,"end":false},{"code":"пІҢ","page":157,"end":false},{"code":"пІҚпІҺ"
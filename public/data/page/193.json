:193,"end":false},{"code":"пұҮ","page":193,"end":false},{"code":"пұҲ","page":193,"end":false},{"code":"пұү","page":193,"end":false},{"code":"пұҠ","page":193,"end":false},{"code":"пұӢ","page":193,"end":false},{"code":"пұҢ","page":193,"end":false},{"code":"пұҚ","page":193,"end":false},{"code":"пұҺ","page":193,"end":false},{"code":"пұҸ","page":193,"end":false},{"code":"пұҗ","page":193,"end":false},{"code":"пұ‘","page":193,"end":false},{"code":"пұ’","page":193,"end":false},{"code":"пұ“","page":193,"end":false},{"code":"пұ”","page":193,"end":false},{"code":"пұ•","page":193,"end":false},{"code":"пұ–","page":193,"end":false},{"code":"пұ—пұҳ","page":193,"end":false},{"code":"пұҷ","page":193,"end":false},{"code":"пұҡ","page":193,"end":false},{"code":"пұӣ","page":193,"end":false},{"code":"пұңпұқ","page":193,"end":false},{"code":"пұһ","page":193,"end":false},{"code":"пұҹ","page":193,"end":false},{"code":"пұ ","page":193,"end":false},{"code":"пұЎ","page":193,"end":false},{"code":"пұў","page":193,"end":false},{"code":"пұЈ","page":193,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩұЩ„ЩҶЩ‘ЩҺШіЩҗЩүЩ“ШЎЩҸ ШІЩҗЩҠЩҺШ§ШҜЩҺШ©ЩҢЫӯ ЩҒЩҗЩү ЩұЩ„Щ’ЩғЩҸЩҒЩ’ШұЩҗ Ы– ЩҠЩҸШ¶ЩҺЩ„Щ‘ЩҸ ШЁЩҗЩҮЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩҠЩҸШӯЩҗЩ„Щ‘ЩҸЩҲЩҶЩҺЩҮЩҸЫҘ Ш№ЩҺШ§Щ…ЩӢЫӯШ§ ЩҲЩҺЩҠЩҸШӯЩҺШұЩ‘ЩҗЩ…ЩҸЩҲЩҶЩҺЩҮЩҸЫҘ Ш№ЩҺШ§Щ…ЩӢЫӯШ§ Щ„Щ‘ЩҗЩҠЩҸЩҲЩҺШ§Ш·ЩҗЩҖЩ”ЩҸЩҲШ§Ыҹ Ш№ЩҗШҜЩ‘ЩҺШ©ЩҺ Щ…ЩҺШ§ ШӯЩҺШұЩ‘ЩҺЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҺЩҠЩҸШӯЩҗЩ„Щ‘ЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ШӯЩҺШұЩ‘ЩҺЩ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ШІЩҸЩҠЩ‘ЩҗЩҶЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШіЩҸЩҲЩ“ШЎЩҸ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҗЩҮЩҗЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШ§ ЩҠЩҺЩҮЩ’ШҜЩҗЩү ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"9:38","surah":9,"ayah":38,"num":1273,"page":193,"words":[{"code":"пұӨ","page":193,"end":false},{"code":"пұҘ","page":193,"end":false},{"code":"пұҰ","page":193,"end":false},{"code":"пұ§","page":193,"end":false},{"code":"пұЁ","page":193,"end":false},{"code":"пұ©","page":193,"end":false},{"code":"пұӘ","page":193,"end":false},{"code":"пұ«","page":193,"end":false},{"code":"пұ¬","page":193,"end":false},{"code":"пұӯ","page":193,"end":false},{"code":"пұ®","page":193,"end":false},{"code":"пұҜ","page":193,"end":false},{"code":"пұ°","page":193,"end":false},{"code":"пұұ","page":193,"end":false},{"code":"пұІпұі","page":193,"end":false},{"code":"пұҙ","page":193,"end":false},{"code":"пұө","page":193,"end":false},{"code":"пұ¶","page":193,"end":false},{"code":"пұ·","page":193,"end":false},{"code":"пұёпұ№","page":193,"end":false},{"code":"пұә","page":193,"end":false},{"code":"пұ»","page":193,"end":false},{"code":"пұј","page":193,"end":false},{"code":"пұҪ","page":193,"end":false},{"code":"пұҫ","page":193,"end":false},{"code":"пұҝ","page":193,"end":false},{"code":"пІҖ","page":193,"end":false},{"code":"пІҒ","page":193,"end":false},{"code":"пІӮ","page":193,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ Щ„ЩҺЩғЩҸЩ…Щ’ ШҘЩҗШ°ЩҺШ§ ЩӮЩҗЩҠЩ„ЩҺ Щ„ЩҺЩғЩҸЩ…ЩҸ ЩұЩҶЩҒЩҗШұЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ШіЩҺШЁЩҗЩҠЩ„Щҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұШ«Щ‘ЩҺШ§ЩӮЩҺЩ„Щ’ШӘЩҸЩ…Щ’ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ШЈЩҺШұЩҺШ¶ЩҗЩҠШӘЩҸЩ… ШЁЩҗЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ Ыҡ ЩҒЩҺЩ…ЩҺШ§ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҸ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩӮЩҺЩ„ЩҗЩҠЩ„ЩҢ"},{"key":"9:39","surah":9,"ayah":39,"num":1274,"page":193,"words":[{"code":"пІғ","page":193,"end":false},{"code":"пІ„","page":193,"end":false},{"code":"пІ…","page":193,"end":false},{"code":"пІҶ","page":193,"end":false},{"code":"пІҮ","page":193,"end":false},{"code":"пІҲ","page":193,"end":false},{"code":"пІү","page":193,"end":false},{"code":"пІҠ","page":193,"end":false},{"code":"пІӢ","page":193,"end":false},{"code":"пІҢ","page":193,"end":false},{"code":"пІҚпІҺ","page":193,"end":false},{"code":"пІҸ","page":193,"end":false},{"code":"пІҗ","page":193,"end":false},{"code":"пІ‘","page":193,"end":false},{"code":"пІ’","page":193,"end":false},{"code":"пІ“","page":193,"end":false},{"code":"пІ”","page":193,"end":true}],"text":"ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺЩҶЩҒЩҗШұЩҸЩҲШ§Ыҹ ЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩ’ЩғЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩӢШ§ ШЈЩҺЩ„ЩҗЩҠЩ…ЩӢЫӯШ§ ЩҲЩҺЩҠЩҺШіЩ’ШӘЩҺШЁЩ’ШҜЩҗЩ„Щ’ ЩӮЩҺЩҲЩ’Щ…ЩӢШ§ ШәЩҺЩҠЩ’ШұЩҺЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ¶ЩҸШұЩ‘ЩҸЩҲЩҮЩҸ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢ"},{"key":"9:40","surah":9,"ayah":40,"num":1275,"page":193,"words":[{"code":"пІ•","page":193,"end":false},{"code":"пІ–","page":193,"end":false},{"code":"пІ—","page":193,"end":false},{"code":"пІҳ","page":193,"end":false},{"code":"пІҷ","page":193,"end":false},{"code":"пІҡ","page":193,"end":false},{"code":"пІӣ","page":193,"end":false},{"code":"пІң","page":193,"end":false},{"code":"пІқ","page":193,"end":false},{"code":"пІһ","page":193,"end":false},{"code":"пІҹ","page":193,"end":false},{"code":"пІ ","page":193,"end":false},{"code":"пІЎ","page":193,"end":false},{"code":"пІў","page":193,"end":false},{"code":"пІЈ","page":193,"end":false},{"code":"пІӨ","page":193,"end":false},{"code":"пІҘ","page":193,"end":false},{"code":"пІҰ","page":193,"end":false},{"code":"пІ§","page":193,"end":false},{"code":"пІЁ","page":193,"end":false},{"code":"пІ©","page":193,"end":false},{"code":"пІӘ","page":193,"end":false},{"code":"пІ«пІ¬","page":193,"end":false},{"code":"пІӯ","page":193,"end":false},{"code":"пІ®","page":193,"end":false},{"code":"пІҜ","page":193,"end":false},{"code":"пІ°","page":193,"end":false},{"code":"пІұ","page":193,"end":false},{"code":"пІІ","page":193,"end":false},{"code":"пІі","page":193,"end":false},{"code":"пІҙ","page":193,"end":false},{"code":"пІө","page":193,"end":false},{"code":"пІ¶","page":193,"end":false},{"code":"пІ·","page":193,"end":false},{"code":"пІё","page":193,"end":false},{"code":"пІ№пІә","page":193,"end":false},{"code":"пІ»","page":193,"end":false},{"code":"пІј","page":193,"end":false},{"code":"пІҪ","page":193,"end":false},{"code":"пІҫпІҝ","page":193,"end":false},{"code":"піҖ","page":193,"end":false},{"code":"піҒ","page":193,"end":false},{"code":"піӮ","page":193,"end":false},{"code":"піғ","page":193,"end":true}],"text":"ШҘЩҗЩ„Щ‘ЩҺШ§ ШӘЩҺЩҶШөЩҸШұЩҸЩҲЩҮЩҸ ЩҒЩҺЩӮЩҺШҜЩ’ ЩҶЩҺШөЩҺШұЩҺЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШҘЩҗШ°Щ’ ШЈЩҺШ®Щ’ШұЩҺШ¬ЩҺЩҮЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Ш«ЩҺШ§ЩҶЩҗЩүЩҺ ЩұШ«Щ’ЩҶЩҺЩҠЩ’ЩҶЩҗ ШҘЩҗШ°Щ’ ЩҮЩҸЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШәЩҺШ§ШұЩҗ ШҘЩҗШ°Щ’ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸ Щ„ЩҗШөЩҺЩҖЩ°ШӯЩҗШЁЩҗЩҮЩҗЫҰ Щ„ЩҺШ§ ШӘЩҺШӯЩ’ШІЩҺЩҶЩ’ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҺШ№ЩҺЩҶЩҺШ§ Ы– ЩҒЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШіЩҺЩғЩҗЩҠЩҶЩҺШӘЩҺЩҮЩҸЫҘ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩҲЩҺШЈЩҺЩҠЩ‘ЩҺШҜЩҺЩҮЩҸЫҘ ШЁЩҗШ¬ЩҸЩҶЩҸЩҲШҜЩҚЫў Щ„Щ‘ЩҺЩ…Щ’ ШӘЩҺШұЩҺЩҲЩ’ЩҮЩҺШ§ ЩҲЩҺШ¬ЩҺШ№ЩҺЩ„ЩҺ ЩғЩҺЩ„ЩҗЩ…ЩҺШ©ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ ЩұЩ„ШіЩ‘ЩҸЩҒЩ’Щ„ЩҺЩүЩ° Ы— ЩҲЩҺЩғЩҺЩ„ЩҗЩ…ЩҺШ©ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҮЩҗЩүЩҺ ЩұЩ„Щ’Ш№ЩҸЩ„Щ’ЩҠЩҺШ§ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺШІЩҗЩҠШІЩҢ ШӯЩҺЩғЩҗЩҠЩ…ЩҢ"}]}
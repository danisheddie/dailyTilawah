alse},{"code":"піҚ","end":false},{"code":"піҺ","end":false},{"code":"піҸ","end":false}]},{"lineNumber":15,"words":[{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–","end":true}]}],"verses":[{"key":"41:12","surah":41,"ayah":12,"num":4230,"page":478,"words":[{"code":"пұҒ","page":478,"end":false},{"code":"пұӮ","page":478,"end":false},{"code":"пұғ","page":478,"end":false},{"code":"пұ„","page":478,"end":false},{"code":"пұ…","page":478,"end":false},{"code":"пұҶ","page":478,"end":false},{"code":"пұҮ","page":478,"end":false},{"code":"пұҲ","page":478,"end":false},{"code":"пұү","page":478,"end":false},{"code":"пұҠпұӢ","page":478,"end":false},{"code":"пұҢ","page":478,"end":false},{"code":"пұҚ","page":478,"end":false},{"code":"пұҺ","page":478,"end":false},{"code":"пұҸ","page":478,"end":false},{"code":"пұҗпұ‘","page":478,"end":false},{"code":"пұ’","page":478,"end":false},{"code":"пұ“","page":478,"end":false},{"code":"пұ”","page":478,"end":false},{"code":"пұ•","page":478,"end":false},{"code":"пұ–","page":478,"end":true}],"text":"ЩҒЩҺЩӮЩҺШ¶ЩҺЩүЩ°ЩҮЩҸЩҶЩ‘ЩҺ ШіЩҺШЁЩ’Ш№ЩҺ ШіЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺШ§ШӘЩҚЫў ЩҒЩҗЩү ЩҠЩҺЩҲЩ’Щ…ЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺШЈЩҺЩҲЩ’ШӯЩҺЩүЩ° ЩҒЩҗЩү ЩғЩҸЩ„Щ‘Щҗ ШіЩҺЩ…ЩҺШ§Щ“ШЎЩҚ ШЈЩҺЩ…Щ’ШұЩҺЩҮЩҺШ§ Ыҡ ЩҲЩҺШІЩҺЩҠЩ‘ЩҺЩҶЩ‘ЩҺШ§ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҺ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ ШЁЩҗЩ…ЩҺШөЩҺЩҖЩ°ШЁЩҗЩҠШӯЩҺ ЩҲЩҺШӯЩҗЩҒЩ’ШёЩӢЫӯШ§ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШӘЩҺЩӮЩ’ШҜЩҗЩҠШұЩҸ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҗ ЩұЩ„Щ’Ш№ЩҺЩ„ЩҗЩҠЩ…Щҗ"},{"key":"41:13","surah":41,"ayah":13,"num":4231,"page":478,"words":[{"code":"пұ—","page":478,"end":false},{"code":"пұҳ","page":478,"end":false},{"code":"пұҷ","page":478,"end":false},{"code":"пұҡ","page":478,"end":false},{"code":"пұӣ","page":478,"end":false},{"code":"пұң","page":478,"end":false},{"code":"пұқ","page":478,"end":false},{"code":"пұһ","page":478,"end":false},{"code":"пұҹ","page":478,"end":false},{"code":"пұ ","page":478,"end":true}],"text":"ЩҒЩҺШҘЩҗЩҶЩ’ ШЈЩҺШ№Щ’ШұЩҺШ¶ЩҸЩҲШ§Ыҹ ЩҒЩҺЩӮЩҸЩ„Щ’ ШЈЩҺЩҶШ°ЩҺШұЩ’ШӘЩҸЩғЩҸЩ…Щ’ ШөЩҺЩҖЩ°Ш№ЩҗЩӮЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗШ«Щ’Щ„ЩҺ ШөЩҺЩҖЩ°Ш№ЩҗЩӮЩҺШ©Щҗ Ш№ЩҺШ§ШҜЩҚЫў ЩҲЩҺШ«ЩҺЩ…ЩҸЩҲШҜЩҺ"},{"key":"41:14","surah":41,"ayah":14,"num":4232,"page":478,"words":[{"code":"пұЎ","page":478,"end":false},{"code":"пұў","page":478,"end":false},{"code":"пұЈ","page":478,"end":false},{"code":"пұӨ","page":478,"end":false},{"code":"пұҘ","page":478,"end":false},{"code":"пұҰ","page":478,"end":false},{"code":"пұ§","page":478,"end":false},{"code":"пұЁ","page":478,"end":false},{"code":"пұ©","page":478,"end":false},{"code":"пұӘ","page":478,"end":false},{"code":"пұ«","page":478,"end":false},{"code":"пұ¬пұӯ","page":478,"end":false},{"code":"пұ®","page":478,"end":false},{"code":"пұҜ","page":478,"end":false},{"code":"пұ°","page":478,"end":false},{"code":"пұұ","page":478,"end":false},{"code":"пұІ","page":478,"end":false},{"code":"пұі","page":478,"end":false},{"code":"пұҙ","page":478,"end":false},{"code":"пұө","page":478,"end":false},{"code":"пұ¶","page":478,"end":false},{"code":"пұ·","page":478,"end":false},{"code":"пұё","page":478,"end":false},{"code":"пұ№","page":478,"end":true}],"text":"ШҘЩҗШ°Щ’ Ш¬ЩҺШ§Щ“ШЎЩҺШӘЩ’ЩҮЩҸЩ…ЩҸ ЩұЩ„ШұЩ‘ЩҸШіЩҸЩ„ЩҸ Щ…ЩҗЩҶЫў ШЁЩҺЩҠЩ’ЩҶЩҗ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩҮЩҗЩ…Щ’ ЩҲЩҺЩ…ЩҗЩҶЩ’ Ш®ЩҺЩ„Щ’ЩҒЩҗЩҮЩҗЩ…Щ’ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ы– ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ„ЩҺЩҲЩ’ ШҙЩҺШ§Щ“ШЎЩҺ ШұЩҺШЁЩ‘ЩҸЩҶЩҺШ§ Щ„ЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©ЩӢЫӯ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺШ§ ШЁЩҗЩ…ЩҺШ§Щ“ ШЈЩҸШұЩ’ШіЩҗЩ„Щ’ШӘЩҸЩ… ШЁЩҗЩҮЩҗЫҰ ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҸЩҲЩҶЩҺ"},{"key":"41:15","surah":41,"ayah":15,"num":4233,"page":478,"words":[{"code":"пұә","page":478,"end":false},{"code":"пұ»","page":478,"end":false},{"code":"пұј","page":478,"end":false},{"code":"пұҪ","page":478,"end":false},{"code":"пұҫ","page":478,"end":false},{"code":"пұҝ","page":478,"end":false},{"code":"пІҖ","page":478,"end":false},{"code":"пІҒ","page":478,"end":false},{"code":"пІӮ","page":478,"end":false},{"code":"пІғ","page":478,"end":false},{"code":"пІ„","page":478,"end":false},{"code":"пІ…пІҶ","page":478,"end":false},{"code":"пІҮ","page":478,"end":false},{"code":"пІҲ","page":478,"end":false},{"code":"пІү","page":478,"end":false},{"code":"пІҠ","page":478,"end":false},{"code":"пІӢ","page":478,"end":false},{"code":"пІҢ","page":478,"end":false},{"code":"пІҚ","page":478,"end":false},{"code":"пІҺ","page":478,"end":false},{"code":"пІҸ","page":478,"end":false},{"code":"пІҗпІ‘","page":478,"end":false},{"code":"пІ’","page":478,"end":false},{"code":"пІ“","page":478,"end":false},{"code":"пІ”","page":478,"end":false},{"code":"пІ•","page":478,"end":true}],"text":"ЩҒЩҺШЈЩҺЩ…Щ‘ЩҺШ§ Ш№ЩҺШ§ШҜЩҢЫӯ ЩҒЩҺЩұШіЩ’ШӘЩҺЩғЩ’ШЁЩҺШұЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩҲЩҺЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ Щ…ЩҺЩҶЩ’ ШЈЩҺШҙЩҺШҜЩ‘ЩҸ Щ…ЩҗЩҶЩ‘ЩҺШ§ ЩӮЩҸЩҲЩ‘ЩҺШ©ЩӢ Ы– ШЈЩҺЩҲЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш®ЩҺЩ„ЩҺЩӮЩҺЩҮЩҸЩ…Щ’ ЩҮЩҸЩҲЩҺ ШЈЩҺШҙЩҺШҜЩ‘ЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ ЩӮЩҸЩҲЩ‘ЩҺШ©ЩӢЫӯ Ы– ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҠЩҺШ¬Щ’ШӯЩҺШҜЩҸЩҲЩҶЩҺ"},{"key":"41:16","surah":41,"ayah":16,"num":4234,"page":478,"words":[{"code":"пІ–","page":478,"end":false},{"code":"пІ—","page":478,"end":false},{"code":"пІҳ","page":478,"end":false},{"code":"пІҷ","page":478,"end":false},{"code":"пІҡ","page":478,"end":false},{"code":"пІӣ","page":478,"end":false},{"code":"пІң","page":478,"end":false},{"code":"пІқ","page":478,"end":false},{"code":"пІһ","page":478,"end":false},{"code":"пІҹ","page":478,"end":false},{"code":"пІ ","page":478,"end":false},{"code":"пІЎ","page":478,"end":false},{"code":"пІўпІЈ","page":478,"end":false},{"code":"пІӨ","page":478,"end":false},{"code":"пІҘ","page":478,"end":false},{"code":"пІҰпІ§","page":478,"end":false},{"code":"пІЁ","page":478,"end":false},{"code":"пІ©","page":478,"end":false},{"code":"пІӘ","page":478,"end":false},{"code":"пІ«","page":478,"end":true}],"text":"ЩҒЩҺШЈЩҺШұЩ’ШіЩҺЩ„Щ’ЩҶЩҺШ§ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШұЩҗЩҠШӯЩӢЫӯШ§ ШөЩҺШұЩ’ШөЩҺШұЩӢЫӯШ§ ЩҒЩҗЩүЩ“ ШЈЩҺЩҠЩ‘ЩҺШ§Щ…ЩҚЫў ЩҶЩ‘ЩҺШӯЩҗШіЩҺШ§ШӘЩҚЫў Щ„Щ‘ЩҗЩҶЩҸШ°ЩҗЩҠЩӮЩҺЩҮЩҸЩ…Щ’ Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ЩұЩ„Щ’Ш®ЩҗШІЩ’ЩүЩҗ ЩҒЩҗЩү ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©Щҗ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ы– ЩҲЩҺЩ„ЩҺШ№ЩҺШ°ЩҺШ§ШЁЩҸ ЩұЩ„Щ’ЩҖЩ”ЩҺШ§Ш®ЩҗШұЩҺШ©Щҗ ШЈЩҺШ®Щ’ШІЩҺЩүЩ° Ы– ЩҲЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸЩҶШөЩҺШұЩҸЩҲЩҶЩҺ"},{"key":"41:17","surah":41,"ayah":17,"num":4235,"page":478,"words":[{"code":"пІ¬","page":478,"end":false},{"code":"пІӯ","page":478,"end":false},{"code":"пІ®","page":478,"end":false},{"code":"пІҜ","page":478,"end":false},{"code":"пІ°","page":478,"end":false},{"code":"пІұ","page":478,"end":false},{"code":"пІІ","page":478,"end":false},{"code":"пІі","page":478,"end":false},{"code":"пІҙ","page":478,"end":false},{"code":"пІө","page":478,"end":false},{"code":"пІ¶","page":478,"end":false},{"code":"пІ·","page":478,"end":false},{"code":"пІё","page":478,"end":false},{"code":"пІ№","page":478,"end":false},{"code":"пІә","page":478,"end":true}],"text":"ЩҲЩҺШЈЩҺЩ…Щ‘ЩҺШ§ Ш«ЩҺЩ…ЩҸЩҲШҜЩҸ ЩҒЩҺЩҮЩҺШҜЩҺЩҠЩ’ЩҶЩҺЩҖЩ°ЩҮЩҸЩ…Щ’ ЩҒЩҺЩұШіЩ’ШӘЩҺШӯЩҺШЁЩ‘ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’Ш№ЩҺЩ…ЩҺЩүЩ° Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ЩҮЩҸШҜЩҺЩүЩ° ЩҒЩҺШЈЩҺШ®ЩҺШ°ЩҺШӘЩ’ЩҮЩҸЩ…Щ’ ШөЩҺЩҖЩ°Ш№ЩҗЩӮЩҺШ©ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҗ ЩұЩ„Щ’ЩҮЩҸЩҲЩҶЩҗ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ШіЩҗШЁЩҸЩҲЩҶЩҺ"},{"key":"41:18","surah":41,"ayah":18,"num":4236,"page":478,"words":[{"code":"пІ»","page":478,"end":false},{"code":"пІј","page":478,"end":false},{"code":"пІҪ","page":478,"end":false},{"code":"пІҫ","page":478,"end":false},{"code":"пІҝ","page":478,"end":false},{"code":"піҖ","page":478,"end":true}],"text":"ЩҲЩҺЩҶЩҺШ¬Щ‘ЩҺЩҠЩ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШӘЩ‘ЩҺЩӮЩҸЩҲЩҶЩҺ"},{"key":"41:19","surah":41,"ayah":19,"num":4237,"page":478,"words":[{"code":"піҒ","page":478,"end":false},{"code":"піӮ","page":478,"end":false},{"code":"піғ","page":478,"end":false},{"code":"пі„","page":478,"end":false},{"code":"пі…","page":478,"end":false},{"code":"піҶ","page":478,"end":false},{"code":"піҮ","page":478,"end":false},{"code":"піҲ","page":478,"end":false},{"code":"піү","page":478,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҸШӯЩ’ШҙЩҺШұЩҸ ШЈЩҺШ№Щ’ШҜЩҺШ§Щ“ШЎЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҒЩҺЩҮЩҸЩ…Щ’ ЩҠЩҸЩҲШІЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"41:20","surah":41,"ayah":20,"num":4238,"page":478,"words":[{"code":"піҠ","page":478,"end":false},{"code":"піӢ","page":478,"end":false},{"code":"піҢ","page":478,"end":false},{"code":"піҚ","page":478,"end":false},{"code":"піҺ","page":478,"end":false},{"code":"піҸ","page":478,"end":false},{"code":"піҗ","page":478,"end":false},{"code":"пі‘","page":478,"end":false},{"code":"пі’","page":478,"end":false},{"code":"пі“","page":478,"end":false},{"code":"пі”","page":478,"end":false},{"code":"пі•","page":478,"end":false},{"code":"пі–","page":478,"end":true}],"text":"ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§ Щ…ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲЩҮЩҺШ§ ШҙЩҺЩҮЩҗШҜЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШіЩҺЩ…Щ’Ш№ЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШЈЩҺШЁЩ’ШөЩҺЩҖЩ°ШұЩҸЩҮЩҸЩ…Щ’ ЩҲЩҺШ¬ЩҸЩ„ЩҸЩҲШҜЩҸЩҮЩҸЩ… ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"}]}
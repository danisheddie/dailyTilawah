rue}],"text":"ЩҮЩҸЩҲЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҢЫӯ Щ…Щ‘ЩҸШӯЩ’ЩғЩҺЩ…ЩҺЩҖЩ°ШӘЩҢ ЩҮЩҸЩҶЩ‘ЩҺ ШЈЩҸЩ…Щ‘ЩҸ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩҲЩҺШЈЩҸШ®ЩҺШұЩҸ Щ…ЩҸШӘЩҺШҙЩҺЩҖЩ°ШЁЩҗЩҮЩҺЩҖЩ°ШӘЩҢЫӯ Ы– ЩҒЩҺШЈЩҺЩ…Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩҮЩҗЩ…Щ’ ШІЩҺЩҠЩ’ШәЩҢЫӯ ЩҒЩҺЩҠЩҺШӘЩ‘ЩҺШЁЩҗШ№ЩҸЩҲЩҶЩҺ Щ…ЩҺШ§ ШӘЩҺШҙЩҺЩҖЩ°ШЁЩҺЩҮЩҺ Щ…ЩҗЩҶЩ’ЩҮЩҸ ЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ’ЩҒЩҗШӘЩ’ЩҶЩҺШ©Щҗ ЩҲЩҺЩұШЁЩ’ШӘЩҗШәЩҺШ§Щ“ШЎЩҺ ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„ЩҗЩҮЩҗЫҰ Ы— ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸ ШӘЩҺШЈЩ’ЩҲЩҗЩҠЩ„ЩҺЩҮЩҸЫҘЩ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы— ЩҲЩҺЩұЩ„ШұЩ‘ЩҺЩ°ШіЩҗШ®ЩҸЩҲЩҶЩҺ ЩҒЩҗЩү ЩұЩ„Щ’Ш№ЩҗЩ„Щ’Щ…Щҗ ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩ‘ЩҺШ§ ШЁЩҗЩҮЩҗЫҰ ЩғЩҸЩ„Щ‘ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҗ ШұЩҺШЁЩ‘ЩҗЩҶЩҺШ§ Ы— ЩҲЩҺЩ…ЩҺШ§ ЩҠЩҺШ°Щ‘ЩҺЩғЩ‘ЩҺШұЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҸЩҲЫҹЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ШЈЩҺЩ„Щ’ШЁЩҺЩҖЩ°ШЁЩҗ"},{"key":"3:8","surah":3,"ayah":8,"num":301,"page":50,"words":[{"code":"пІә","page":50,"end":false},{"code":"пІ»","page":50,"end":false},{"code":"пІј","page":50,"end":false},{"code":"пІҪ","page":50,"end":false},{"code":"пІҫ","page":50,"end":false},{"code":"пІҝ","page":50,"end":false},{"code":"піҖ","page":50,"end":false},{"code":"піҒ","page":50,"end":false},{"code":"піӮ","page":50,"end":false},{"code":"піғ","page":50,"end":false},{"code":"пі„","page":50,"end":false},{"code":"пі…піҶ","page":50,"end":false},{"code":"піҮ","page":50,"end":false},{"code":"піҲ","page":50,"end":false},{"code":"піү","page":50,"end":false},{"code":"піҠ","page":50,"end":true}],"text":"ШұЩҺШЁЩ‘ЩҺЩҶЩҺШ§ Щ„ЩҺШ§ ШӘЩҸШІЩҗШәЩ’ ЩӮЩҸЩ„ЩҸЩҲШЁЩҺЩҶЩҺШ§ ШЁЩҺШ№Щ’ШҜЩҺ ШҘЩҗШ°Щ’ ЩҮЩҺШҜЩҺЩҠЩ’ШӘЩҺЩҶЩҺШ§ ЩҲЩҺЩҮЩҺШЁЩ’ Щ„ЩҺЩҶЩҺШ§ Щ…ЩҗЩҶ Щ„Щ‘ЩҺШҜЩҸЩҶЩғЩҺ ШұЩҺШӯЩ’Щ…ЩҺШ©ЩӢ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ ШЈЩҺЩҶШӘЩҺ ЩұЩ„Щ’ЩҲЩҺЩҮЩ‘ЩҺШ§ШЁЩҸ"},{"key":"3:9","surah":3,"ayah":9,"num":302,"page":50,"words":[{"code":"піӢ","page":50,"end":false},{"code":"піҢ","page":50,"end":false},{"code":"піҚ","page":50,"end":false},{"code":"піҺ","page":50,"end":false},{"code":"піҸ","page":50,"end":false},{"code":"піҗ","p
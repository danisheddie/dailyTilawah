462,"end":false},{"code":"пІҲ","page":462,"end":false},{"code":"пІү","page":462,"end":false},{"code":"пІҠ","page":462,"end":false},{"code":"пІӢпІҢ","page":462,"end":false},{"code":"пІҚ","page":462,"end":false},{"code":"пІҺ","page":462,"end":false},{"code":"пІҸ","page":462,"end":false},{"code":"пІҗ","page":462,"end":false},{"code":"пІ‘","page":462,"end":false},{"code":"пІ’","page":462,"end":true}],"text":"ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩҮЩ’ШҜЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҒЩҺЩ…ЩҺШ§ Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҗЩҶ Щ…Щ‘ЩҸШ¶ЩҗЩ„Щ‘ЩҚ Ы— ШЈЩҺЩ„ЩҺЩҠЩ’ШіЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗШ№ЩҺШІЩҗЩҠШІЩҚЫў Ш°ЩҗЩү ЩұЩҶШӘЩҗЩӮЩҺШ§Щ…ЩҚЫў"},{"key":"39:38","surah":39,"ayah":38,"num":4096,"page":462,"words":[{"code":"пІ“","page":462,"end":false},{"code":"пІ”","page":462,"end":false},{"code":"пІ•","page":462,"end":false},{"code":"пІ–","page":462,"end":false},{"code":"пІ—","page":462,"end":false},{"code":"пІҳ","page":462,"end":false},{"code":"пІҷ","page":462,"end":false},{"code":"пІҡпІӣ","page":462,"end":false},{"code":"пІң","page":462,"end":false},{"code":"пІқ","page":462,"end":false},{"code":"пІһ","page":462,"end":false},{"code":"пІҹ","page":462,"end":false},{"code":"пІ ","page":462,"end":false},{"code":"пІЎ","page":462,"end":false},{"code":"пІў","page":462,"end":false},{"code":"пІЈ","page":462,"end":false},{"code":"пІӨ","page":462,"end":false},{"code":"пІҘ","page":462,"end":false},{"code":"пІҰ","page":462,"end":false},{"code":"пІ§","page":462,"end":false},{"code":"пІЁ","page":462,"end":false},{"code":"пІ©","page":462,"end":false},{"code":"пІӘ","page":462,"end":false},{"code":"пІ«","page":462,"end":false},{"code":"пІ¬","page":462,"end":false},{"code":"пІӯ","page":462,"end":false},{"code":"пІ®","page":462,"end":false},{"code":"пІҜ","page":462,"end":false},{"code":"пІ°","page":462,"end":false},{"code":"пІұпІІ","page":462,"end":false},{"code":"пІі","page":462,"end":false},{"code":"пІҙ","page":462,"end":false},{"code":"пІөпІ¶","page":462,"end":false},{"code":"пІ·","page":462,"end":false},{"code":"пІё","page":462,"end":false},{"code":"пІ№","page":462,"end":false},{"code":"пІә","page":462,"end":true}],"text":"ЩҲЩҺЩ„ЩҺШҰЩҗЩҶ ШіЩҺШЈЩҺЩ„Щ’ШӘЩҺЩҮЩҸЩ… Щ…Щ‘ЩҺЩҶЩ’ Ш®ЩҺЩ„ЩҺЩӮЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ Щ„ЩҺЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩӮЩҸЩ„Щ’ ШЈЩҺЩҒЩҺШұЩҺШЎЩҺЩҠЩ’ШӘЩҸЩ… Щ…Щ‘ЩҺШ§ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ШҘЩҗЩҶЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺЩҶЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗШ¶ЩҸШұЩ‘ЩҚ ЩҮЩҺЩ„Щ’ ЩҮЩҸЩҶЩ‘ЩҺ ЩғЩҺЩҖЩ°ШҙЩҗЩҒЩҺЩҖЩ°ШӘЩҸ Ш¶ЩҸШұЩ‘ЩҗЩҮЩҗЫҰЩ“ ШЈЩҺЩҲЩ’ ШЈЩҺШұЩҺШ§ШҜЩҺЩҶЩҗЩү ШЁЩҗШұЩҺШӯЩ’Щ…ЩҺШ©ЩҚ ЩҮЩҺЩ„Щ’ ЩҮЩҸЩҶЩ‘ЩҺ Щ…ЩҸЩ…Щ’ШіЩҗЩғЩҺЩҖЩ°ШӘЩҸ ШұЩҺШӯЩ’Щ…ЩҺШӘЩҗЩҮЩҗЫҰ Ыҡ ЩӮЩҸЩ„Щ’ ШӯЩҺШіЩ’ШЁЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩҠЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„ЩҸ ЩұЩ„Щ’Щ…ЩҸШӘЩҺЩҲЩҺЩғЩ‘ЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"39:39","surah":39,"ayah":39,"num":4097,"page":462,"words":[{"code":"пІ»","page":462,"end":false},{"code":"пІј","page":462,"end":false},{"code":"пІҪ","page":462,"end":false},{"code":"пІҫ","page":462,"end":false},{"code":"пІҝ","page":462,"end":false},{"code":"піҖ","page":462,"end":false},{"code":"піҒпіӮ","page":462,"end":false},{"code":"піғ","page":462,"end":false},{"code":"пі„","page":462,"end":false},{"code":"пі…","page":462,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ЩҠЩҺЩҖЩ°ЩӮЩҺЩҲЩ’Щ…Щҗ ЩұШ№Щ’Щ…ЩҺЩ„ЩҸЩҲШ§Ыҹ Ш№ЩҺЩ„ЩҺЩүЩ° Щ…ЩҺЩғЩҺШ§ЩҶЩҺШӘЩҗЩғЩҸЩ…Щ’ ШҘЩҗЩҶЩ‘ЩҗЩү Ш№ЩҺЩҖЩ°Щ…ЩҗЩ„ЩҢЫӯ Ы– ЩҒЩҺШіЩҺЩҲЩ’ЩҒЩҺ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"39:40","surah":39,"ayah":40,"num":4098,"page":462,"words":[{"code":"піҶ","page":462,"end":false},{"code":"піҮ","page":462,"end":false},{"code":"піҲ","page":462,"end":false},{"code":"піү","page":462,"end":false},{"code":"піҠ","page":462,"end":false},{"code":"піӢ","page":462,"end":false},{"code":"піҢ","page":462,"end":false},{"code":"піҚ","page":462,"end":false},{"code":"піҺ","page":462,"end":true}],"text":"Щ…ЩҺЩҶ ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҮЩҗ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ ЩҠЩҸШ®Щ’ШІЩҗЩҠЩҮЩҗ ЩҲЩҺЩҠЩҺШӯЩҗЩ„Щ‘ЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ Щ…Щ‘ЩҸЩӮЩҗЩҠЩ…ЩҢ"}]}
җЩү Ш®ЩҺЩ„Щ’ЩӮЩҗ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ЩҲЩҺЩұШ®Щ’ШӘЩҗЩ„ЩҺЩҖЩ°ЩҒЩҗ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„Щҗ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҗ ЩҲЩҺЩұЩ„Щ’ЩҒЩҸЩ„Щ’ЩғЩҗ ЩұЩ„Щ‘ЩҺШӘЩҗЩү ШӘЩҺШ¬Щ’ШұЩҗЩү ЩҒЩҗЩү ЩұЩ„Щ’ШЁЩҺШӯЩ’ШұЩҗ ШЁЩҗЩ…ЩҺШ§ ЩҠЩҺЩҶЩҒЩҺШ№ЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ Щ…ЩҗЩҶ Щ…Щ‘ЩҺШ§Щ“ШЎЩҚЫў ЩҒЩҺШЈЩҺШӯЩ’ЩҠЩҺШ§ ШЁЩҗЩҮЩҗ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶ЩҺ ШЁЩҺШ№Щ’ШҜЩҺ Щ…ЩҺЩҲЩ’ШӘЩҗЩҮЩҺШ§ ЩҲЩҺШЁЩҺШ«Щ‘ЩҺ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩҚЫў ЩҲЩҺШӘЩҺШөЩ’ШұЩҗЩҠЩҒЩҗ ЩұЩ„ШұЩ‘ЩҗЩҠЩҺЩҖЩ°ШӯЩҗ ЩҲЩҺЩұЩ„ШіЩ‘ЩҺШӯЩҺШ§ШЁЩҗ ЩұЩ„Щ’Щ…ЩҸШіЩҺШ®Щ‘ЩҺШұЩҗ ШЁЩҺЩҠЩ’ЩҶЩҺ ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺШ§Щ“ШЎЩҗ ЩҲЩҺЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҺШ№Щ’ЩӮЩҗЩ„ЩҸЩҲЩҶЩҺ"},{"key":"2:165","surah":2,"ayah":165,"num":172,"page":25,"words":[{"code":"пұӯ","page":25,"end":false},{"code":"пұ®","page":25,"end":false},{"code":"пұҜ","page":25,"end":false},{"code":"пұ°","page":25,"end":false},{"code":"пұұ","page":25,"end":false},{"code":"пұІ","page":25,"end":false},{"code":"пұі","page":25,"end":false},{"code":"пұҙ","page":25,"end":false},{"code":"пұө","page":25,"end":false},{"code":"пұ¶","page":25,"end":false},{"code":"пұ·пұё","page":25,"end":false},{"code":"пұ№","page":25,"end":false},{"code":"пұә","page":25,"end":false},{"code":"пұ»","page":25,"end":false},{"code":"пұј","page":25,"end":false},{"code":"пұҪпұҫ","page":25,"end":false},{"code":"пұҝ","page":25,"end":false},{"code":"пІҖ","page":25,"end":false},{"code":"пІҒ","page":25,"end":false},{"code":"пІӮ","page":25,"end":false},{"code":"пІғ","page":25,"end":false},{"code":"пІ„","page":25,"end":false},{"code":"пІ…","page":25,"end":false},{"code":"пІҶ","page":25,"end":false},{"code":"пІҮ","page":25,"end":false},{"code":"пІҲ","page":25,"end":false},{"code":"пІү","page":25,"end":false},{"code":"пІҠ","page":25,"end":false},{"code":"пІӢ","page":25,"end":false},{"code":"пІҢ","page":25,"end":false},{"code":"пІҚ","page":25,"end":false},{"code":"пІҺ","page":25,"end":true}],"text":"ЩҲЩҺ
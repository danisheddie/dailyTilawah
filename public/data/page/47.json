,"end":false},{"code":"пұі","page":47,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Ш§Ыҹ Щ„ЩҺШ§ ЩҠЩҺЩӮЩҸЩҲЩ…ЩҸЩҲЩҶЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩғЩҺЩ…ЩҺШ§ ЩҠЩҺЩӮЩҸЩҲЩ…ЩҸ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҠЩҺШӘЩҺШ®ЩҺШЁЩ‘ЩҺШ·ЩҸЩҮЩҸ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҺШіЩ‘Щҗ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩұЩ„Щ’ШЁЩҺЩҠЩ’Ш№ЩҸ Щ…ЩҗШ«Щ’Щ„ЩҸ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Ш§Ыҹ Ы— ЩҲЩҺШЈЩҺШӯЩҺЩ„Щ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„Щ’ШЁЩҺЩҠЩ’Ш№ЩҺ ЩҲЩҺШӯЩҺШұЩ‘ЩҺЩ…ЩҺ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Ш§Ыҹ Ыҡ ЩҒЩҺЩ…ЩҺЩҶ Ш¬ЩҺШ§Щ“ШЎЩҺЩҮЩҸЫҘ Щ…ЩҺЩҲЩ’Ш№ЩҗШёЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩҮЩҗЫҰ ЩҒЩҺЩұЩҶШӘЩҺЩҮЩҺЩүЩ° ЩҒЩҺЩ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ§ ШіЩҺЩ„ЩҺЩҒЩҺ ЩҲЩҺШЈЩҺЩ…Щ’ШұЩҸЩҮЩҸЫҘЩ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ЩҲЩҺЩ…ЩҺЩҶЩ’ Ш№ЩҺШ§ШҜЩҺ ЩҒЩҺШЈЩҸЩҲЫҹЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺ ШЈЩҺШөЩ’ШӯЩҺЩҖЩ°ШЁЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ Ы– ЩҮЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Ш®ЩҺЩҖЩ°Щ„ЩҗШҜЩҸЩҲЩҶЩҺ"},{"key":"2:276","surah":2,"ayah":276,"num":283,"page":47,"words":[{"code":"пұҙ","page":47,"end":false},{"code":"пұө","page":47,"end":false},{"code":"пұ¶","page":47,"end":false},{"code":"пұ·","page":47,"end":false},{"code":"пұёпұ№","page":47,"end":false},{"code":"пұә","page":47,"end":false},{"code":"пұ»","page":47,"end":false},{"code":"пұј","page":47,"end":false},{"code":"пұҪ","page":47,"end":false},{"code":"пұҫ","page":47,"end":false},{"code":"пұҝ","page":47,"end":false},{"code":"пІҖ","page":47,"end":true}],"text":"ЩҠЩҺЩ…Щ’ШӯЩҺЩӮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Ш§Ыҹ ЩҲЩҺЩҠЩҸШұЩ’ШЁЩҗЩү ЩұЩ„ШөЩ‘ЩҺШҜЩҺЩӮЩҺЩҖЩ°ШӘЩҗ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШ§ ЩҠЩҸШӯЩҗШЁЩ‘ЩҸ ЩғЩҸЩ„Щ‘ЩҺ ЩғЩҺЩҒЩ‘ЩҺШ§ШұЩҚ ШЈЩҺШ«ЩҗЩҠЩ…ЩҚ"},{"key":"2:277","surah":2,"ayah":277,"num":284,"page":47,"words":[{"code":"пІҒ","page":47,"end":false},{"code":"пІӮ","page":47,"end":false},{"code":"пІғ","page":47,"end":false},{"code":"пІ„","page":47,"end":false},{"code":"пІ…","page":47,"end":false},{"code":"пІҶ","page":47,"end":false},{"code":"пІҮ","page":47,"end":false},{"code":"пІҲ","page":47,"end":false},{"code":"пІү","page":47,"end":false},{"code":"пІҠ","page":47,"end":false},{"code":"пІӢ","page":47,"end":false},{"code":"пІҢ","page":47,"end":false},{"code":"пІҚ","page":47,"end":false},{"code":"пІҺ","page":47,"end":false},{"code":"пІҸ","page":47,"end":false},{"code":"пІҗ","page":47,"end":false},{"code":"пІ‘","page":47,"end":false},{"code":"пІ’","page":47,"end":false},{"code":"пІ“","page":47,"end":false},{"code":"пІ”","page":47,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩҲЩҺШ№ЩҺЩ…ЩҗЩ„ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩҖЩ°Щ„ЩҗШӯЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺШЈЩҺЩӮЩҺШ§Щ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҲЩҸШ§Ыҹ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ Щ„ЩҺЩҮЩҸЩ…Щ’ ШЈЩҺШ¬Щ’ШұЩҸЩҮЩҸЩ…Щ’ Ш№ЩҗЩҶШҜЩҺ ШұЩҺШЁЩ‘ЩҗЩҮЩҗЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ Ш®ЩҺЩҲЩ’ЩҒЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ЩҲЩҺЩ„ЩҺШ§ ЩҮЩҸЩ…Щ’ ЩҠЩҺШӯЩ’ШІЩҺЩҶЩҸЩҲЩҶЩҺ"},{"key":"2:278","surah":2,"ayah":278,"num":285,"page":47,"words":[{"code":"пІ•","page":47,"end":false},{"code":"пІ–","page":47,"end":false},{"code":"пІ—","page":47,"end":false},{"code":"пІҳ","page":47,"end":false},{"code":"пІҷ","page":47,"end":false},{"code":"пІҡ","page":47,"end":false},{"code":"пІӣ","page":47,"end":false},{"code":"пІң","page":47,"end":false},{"code":"пІқ","page":47,"end":false},{"code":"пІһ","page":47,"end":false},{"code":"пІҹ","page":47,"end":false},{"code":"пІ ","page":47,"end":false},{"code":"пІЎ","page":47,"end":false},{"code":"пІў","page":47,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲШ§Ыҹ ЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҲЩҺШ°ЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ШЁЩҺЩӮЩҗЩүЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШұЩ‘ЩҗШЁЩҺЩҲЩ°Щ“Ш§Ыҹ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ… Щ…Щ‘ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"2:279","surah":2,"ayah":279,"num":286,"page":47,"words":[{"code":"пІЈ","page":47,"end":false},{"code":"пІӨ","page":47,"end":false},{"code":"пІҘ","page":47,"end":false},{"code":"пІҰ","page":47,"end":false},{"code":"пІ§","page":47,"end":false},{"code":"пІЁ","page":47,"end":false},{"code":"пІ©","page":47,"end":false},{"code":"пІӘпІ«","page":47,"end":false},{"code":"пІ¬","page":47,"end":false},{"code":"пІӯ","page":47,"end":false},{"code":"пІ®","page":47,"end":false},{"code":"пІҜ","page":47,"end":false},{"code":"пІ°","page":47,"end":false},{"code":"пІұ","page":47,"end":false},{"code":"пІІ","page":47,"end":false},{"code":"пІі","page":47,"end":false},{"code":"пІҙ","page":47,"end":false},{"code":"пІө","page":47,"end":true}],"text":"ЩҒЩҺШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ШӘЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҺШЈЩ’Ш°ЩҺЩҶЩҸЩҲШ§Ыҹ ШЁЩҗШӯЩҺШұЩ’ШЁЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ Ы– ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШЁЩ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩғЩҸЩ…Щ’ ШұЩҸШЎЩҸЩҲШіЩҸ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ Щ„ЩҺШ§ ШӘЩҺШёЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:280","surah":2,"ayah":280,"num":287,"page":47,"words":[{"code":"пІ¶","page":47,"end":false},{"code":"пІ·","page":47,"end":false},{"code":"пІё","page":47,"end":false},{"code":"пІ№","page":47,"end":false},{"code":"пІә","page":47,"end":false},{"code":"пІ»","page":47,"end":false},{"code":"пІјпІҪ","page":47,"end":false},{"code":"пІҫ","page":47,"end":false},{"code":"пІҝ","page":47,"end":false},{"code":"піҖ","page":47,"end":false},{"code":"піҒ","page":47,"end":false},{"code":"піӮ","page":47,"end":false},{"code":"піғ","page":47,"end":false},{"code":"пі„","page":47,"end":false},{"code":"пі…","page":47,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ Ш°ЩҸЩҲ Ш№ЩҸШіЩ’ШұЩҺШ©ЩҚЫў ЩҒЩҺЩҶЩҺШёЩҗШұЩҺШ©ЩҢ ШҘЩҗЩ„ЩҺЩүЩ° Щ…ЩҺЩҠЩ’ШіЩҺШұЩҺШ©ЩҚЫў Ыҡ ЩҲЩҺШЈЩҺЩҶ ШӘЩҺШөЩҺШҜЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ Ш®ЩҺЩҠЩ’ШұЩҢЫӯ Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ Ы– ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"2:281","surah":2,"ayah":281,"num":288,"page":47,"words":[{"code":"піҶ","page":47,"end":false},{"code":"піҮ","page":47,"end":false},{"code":"піҲ","page":47,"end":false},{"code":"піү","page":47,"end":false},{"code":"піҠ","page":47,"end":false},{"code":"піӢпіҢ","page":47,"end":false},{"code":"піҚ","page":47,"end":false},{"code":"піҺ","page":47,"end":false},{"code":"піҸ","page":47,"end":false},{"code":"піҗ","page":47,"end":false},{"code":"пі‘","page":47,"end":false},{"code":"пі’","page":47,"end":false},{"code":"пі“","page":47,"end":false},{"code":"пі”","page":47,"end":false},{"code":"пі•","page":47,"end":false},{"code":"пі–","page":47,"end":true}],"text":"ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩҠЩҺЩҲЩ’Щ…ЩӢЫӯШ§ ШӘЩҸШұЩ’Ш¬ЩҺШ№ЩҸЩҲЩҶЩҺ ЩҒЩҗЩҠЩҮЩҗ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– Ш«ЩҸЩ…Щ‘ЩҺ ШӘЩҸЩҲЩҺЩҒЩ‘ЩҺЩүЩ° ЩғЩҸЩ„Щ‘ЩҸ ЩҶЩҺЩҒЩ’ШіЩҚЫў Щ…Щ‘ЩҺШ§ ЩғЩҺШіЩҺШЁЩҺШӘЩ’ ЩҲЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҸШёЩ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"}]}
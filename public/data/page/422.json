…ЩҺЩҶ ЩҠЩҺЩӮЩ’ЩҶЩҸШӘЩ’ Щ…ЩҗЩҶЩғЩҸЩҶЩ‘ЩҺ Щ„ЩҗЩ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰ ЩҲЩҺШӘЩҺШ№Щ’Щ…ЩҺЩ„Щ’ ШөЩҺЩҖЩ°Щ„ЩҗШӯЩӢЫӯШ§ ЩҶЩ‘ЩҸШӨЩ’ШӘЩҗЩҮЩҺШ§Щ“ ШЈЩҺШ¬Щ’ШұЩҺЩҮЩҺШ§ Щ…ЩҺШұЩ‘ЩҺШӘЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺШЈЩҺШ№Щ’ШӘЩҺШҜЩ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҺШ§ ШұЩҗШІЩ’ЩӮЩӢЫӯШ§ ЩғЩҺШұЩҗЩҠЩ…ЩӢЫӯШ§"},{"key":"33:32","surah":33,"ayah":32,"num":3565,"page":422,"words":[{"code":"пұ‘","page":422,"end":false},{"code":"пұ’","page":422,"end":false},{"code":"пұ“","page":422,"end":false},{"code":"пұ”","page":422,"end":false},{"code":"пұ•","page":422,"end":false},{"code":"пұ–","page":422,"end":false},{"code":"пұ—","page":422,"end":false},{"code":"пұҳпұҷ","page":422,"end":false},{"code":"пұҡ","page":422,"end":false},{"code":"пұӣ","page":422,"end":false},{"code":"пұң","page":422,"end":false},{"code":"пұқ","page":422,"end":false},{"code":"пұһ","page":422,"end":false},{"code":"пұҹ","page":422,"end":false},{"code":"пұ ","page":422,"end":false},{"code":"пұЎ","page":422,"end":false},{"code":"пұў","page":422,"end":false},{"code":"пұЈ","page":422,"end":false},{"code":"пұӨ","page":422,"end":false},{"code":"пұҘ","page":422,"end":true}],"text":"ЩҠЩҺЩҖЩ°ЩҶЩҗШіЩҺШ§Щ“ШЎЩҺ ЩұЩ„ЩҶЩ‘ЩҺШЁЩҗЩүЩ‘Щҗ Щ„ЩҺШіЩ’ШӘЩҸЩҶЩ‘ЩҺ ЩғЩҺШЈЩҺШӯЩҺШҜЩҚЫў Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҗШіЩҺШ§Щ“ШЎЩҗ Ыҡ ШҘЩҗЩҶЩҗ ЩұШӘЩ‘ЩҺЩӮЩҺЩҠЩ’ШӘЩҸЩҶЩ‘ЩҺ ЩҒЩҺЩ„ЩҺШ§ ШӘЩҺШ®Щ’Ш¶ЩҺШ№Щ’ЩҶЩҺ ШЁЩҗЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ„Щҗ ЩҒЩҺЩҠЩҺШ·Щ’Щ…ЩҺШ№ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩҒЩҗЩү ЩӮЩҺЩ„Щ’ШЁЩҗЩҮЩҗЫҰ Щ…ЩҺШұЩҺШ¶ЩҢЫӯ ЩҲЩҺЩӮЩҸЩ„Щ’ЩҶЩҺ ЩӮЩҺЩҲЩ’Щ„ЩӢЫӯШ§ Щ…Щ‘ЩҺШ№Щ’ШұЩҸЩҲЩҒЩӢЫӯШ§"},{"key":"33:33","surah":33,"ayah":33,"num":3566,"page":422,"words":[{"code":"пұҰ","page":422,"end":false},{"code":"пұ§","page":422,"end":false},{"code":"пұЁ","page":422,"end":false},{"code":"пұ©","page":422,"end":false},{"code":"пұӘ","page":422,"end":false},{"code":"пұ«","page":422,"end":false},{"code":"пұ¬","page":422,"end":false},{"code":"пұӯпұ®","page":422,"end":false},{"code":"пұҜ","page":422,"end":false},{"code":"пұ°","page":422,"end":false},{"code":"пұұ","page":422,"end":false},{"code":"пұІ","page":422,"end":false},{"code":"пұі","page":42
©","page":388,"end":false},{"code":"пұӘ","page":388,"end":false},{"code":"пұ«","page":388,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩ…Щ‘ЩҺШ§ ЩҲЩҺШұЩҺШҜЩҺ Щ…ЩҺШ§Щ“ШЎЩҺ Щ…ЩҺШҜЩ’ЩҠЩҺЩҶЩҺ ЩҲЩҺШ¬ЩҺШҜЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЈЩҸЩ…Щ‘ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ ЩҠЩҺШіЩ’ЩӮЩҸЩҲЩҶЩҺ ЩҲЩҺЩҲЩҺШ¬ЩҺШҜЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗЩҮЩҗЩ…ЩҸ ЩұЩ…Щ’ШұЩҺШЈЩҺШӘЩҺЩҠЩ’ЩҶЩҗ ШӘЩҺШ°ЩҸЩҲШҜЩҺШ§ЩҶЩҗ Ы– ЩӮЩҺШ§Щ„ЩҺ Щ…ЩҺШ§ Ш®ЩҺШ·Щ’ШЁЩҸЩғЩҸЩ…ЩҺШ§ Ы– ЩӮЩҺШ§Щ„ЩҺШӘЩҺШ§ Щ„ЩҺШ§ ЩҶЩҺШіЩ’ЩӮЩҗЩү ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҸШөЩ’ШҜЩҗШұЩҺ ЩұЩ„ШұЩ‘ЩҗШ№ЩҺШ§Щ“ШЎЩҸ Ы– ЩҲЩҺШЈЩҺШЁЩҸЩҲЩҶЩҺШ§ ШҙЩҺЩҠЩ’Ш®ЩҢЫӯ ЩғЩҺШЁЩҗЩҠШұЩҢЫӯ"},{"key":"28:24","surah":28,"ayah":24,"num":3276,"page":388,"words":[{"code":"пұ¬","page":388,"end":false},{"code":"пұӯ","page":388,"end":false},{"code":"пұ®","page":388,"end":false},{"code":"пұҜ","page":388,"end":false},{"code":"пұ°","page":388,"end":false},{"code":"пұұ","page":388,"end":false},{"code":"пұІ","page":388,"end":false},{"code":"пұі","page":388,"end":false},{"code":"пұҙ","page":388,"end":false},{"code":"пұө","page":388,"end":false},{"code":"пұ¶","page":388,"end":false},{"code":"пұ·","page":388,"end":false},{"code":"пұё","page":388,"end":false},{"code":"пұ№","page":388,"end":false},{"code":"пұә","page":388,"end":false},{"code":"пұ»","page":388,"end":true}],"text":"ЩҒЩҺШіЩҺЩӮЩҺЩүЩ° Щ„ЩҺЩҮЩҸЩ…ЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩүЩ°Щ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„ШёЩ‘ЩҗЩ„Щ‘Щҗ ЩҒЩҺЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘Щҗ ШҘЩҗЩҶЩ‘ЩҗЩү Щ„ЩҗЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШІЩҺЩ„Щ’ШӘЩҺ ШҘЩҗЩ„ЩҺЩүЩ‘ЩҺ Щ…ЩҗЩҶЩ’ Ш®ЩҺЩҠЩ’ШұЩҚЫў ЩҒЩҺЩӮЩҗЩҠШұЩҢЫӯ"},{"key":"28:25","surah":28,"ayah":25,"num":3277,"page":388,"words":[{"code":"пұј","page":388,"end":false},{"code":"пұҪ","page":388,"end":false},{"code":"пұҫ","page":388,"end":false},{"code":"пұҝ","page":388,"end":false},{"code":"пІҖ","page":388,"end":false},{"code":"пІҒ","page":388,"end":false},{"code":"пІӮ","page":388,"end":false},{"code":"пІғ","page":388,"end":false},{"code":"пІ„","page":388,"end":false},{"code":"пІ…","page":388,"end":false},{"code":"пІҶ","page":388,"end":false},{"code":"пІҮ","page":388,"end":false},{"code":"пІҲ","pag
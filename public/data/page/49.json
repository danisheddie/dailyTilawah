ҺШ©ЩҺ Ыҡ ЩҲЩҺЩ…ЩҺЩҶ ЩҠЩҺЩғЩ’ШӘЩҸЩ…Щ’ЩҮЩҺШ§ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘЩ“ ШЎЩҺШ§Ш«ЩҗЩ…ЩҢЫӯ ЩӮЩҺЩ„Щ’ШЁЩҸЩҮЩҸЫҘ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩ…ЩҺШ§ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"2:284","surah":2,"ayah":284,"num":291,"page":49,"words":[{"code":"пұ§","page":49,"end":false},{"code":"пұЁ","page":49,"end":false},{"code":"пұ©","page":49,"end":false},{"code":"пұӘ","page":49,"end":false},{"code":"пұ«","page":49,"end":false},{"code":"пұ¬","page":49,"end":false},{"code":"пұӯпұ®","page":49,"end":false},{"code":"пұҜ","page":49,"end":false},{"code":"пұ°","page":49,"end":false},{"code":"пұұ","page":49,"end":false},{"code":"пұІ","page":49,"end":false},{"code":"пұі","page":49,"end":false},{"code":"пұҙ","page":49,"end":false},{"code":"пұө","page":49,"end":false},{"code":"пұ¶","page":49,"end":false},{"code":"пұ·","page":49,"end":false},{"code":"пұёпұ№","page":49,"end":false},{"code":"пұә","page":49,"end":false},{"code":"пұ»","page":49,"end":false},{"code":"пұј","page":49,"end":false},{"code":"пұҪ","page":49,"end":false},{"code":"пұҫ","page":49,"end":false},{"code":"пұҝпІҖ","page":49,"end":false},{"code":"пІҒ","page":49,"end":false},{"code":"пІӮ","page":49,"end":false},{"code":"пІғ","page":49,"end":false},{"code":"пІ„","page":49,"end":false},{"code":"пІ…","page":49,"end":false},{"code":"пІҶ","page":49,"end":true}],"text":"Щ„Щ‘ЩҗЩ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ы— ЩҲЩҺШҘЩҗЩҶ ШӘЩҸШЁЩ’ШҜЩҸЩҲШ§Ыҹ Щ…ЩҺШ§ ЩҒЩҗЩүЩ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩҲЩ’ ШӘЩҸШ®Щ’ЩҒЩҸЩҲЩҮЩҸ ЩҠЩҸШӯЩҺШ§ШіЩҗШЁЩ’ЩғЩҸЩ… ШЁЩҗЩҮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы– ЩҒЩҺЩҠЩҺШәЩ’ЩҒЩҗШұЩҸ Щ„ЩҗЩ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ ЩҲЩҺЩҠЩҸШ№ЩҺШ°Щ‘ЩҗШЁЩҸ Щ…ЩҺЩҶ ЩҠЩҺШҙЩҺШ§Щ“ШЎЩҸ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҺЩүЩ° ЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚЫў ЩӮЩҺШҜЩҗЩҠШұЩҢ"},{"key":"2:285","surah":2,"ayah":285,"num":292,"page":49,"words":[{"code":"пІҮ","page":49,"end":false},{"code":"пІҲ","page":49,"end":false},{"code":"пІү","page":49,"end":false},{"code":"пІҠ","page":49,"end":false},{"code":"пІӢ","page":49,"end":fa
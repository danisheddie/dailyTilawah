]},{"lineNumber":14,"words":[{"code":"піҚ","end":false},{"code":"піҺ","end":true},{"code":"піҸ","end":false},{"code":"піҗ","end":false},{"code":"пі‘","end":false},{"code":"пі’","end":false},{"code":"пі“","end":false},{"code":"пі”","end":false},{"code":"пі•","end":false},{"code":"пі–пі—","end":false}]},{"lineNumber":15,"words":[{"code":"піҳ","end":false},{"code":"піҷ","end":false},{"code":"піҡ","end":false},{"code":"піӣ","end":false},{"code":"пің","end":false},{"code":"піқпіһ","end":false},{"code":"піҹ","end":false},{"code":"пі ","end":false},{"code":"піЎ","end":false},{"code":"піў","end":false},{"code":"піЈ","end":true}]}],"verses":[{"key":"27:77","surah":27,"ayah":77,"num":3236,"page":384,"words":[{"code":"пұҒ","page":384,"end":false},{"code":"пұӮ","page":384,"end":false},{"code":"пұғ","page":384,"end":false},{"code":"пұ„","page":384,"end":false},{"code":"пұ…","page":384,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺЩҮЩҸШҜЩӢЫӯЩү ЩҲЩҺШұЩҺШӯЩ’Щ…ЩҺШ©ЩҢЫӯ Щ„Щ‘ЩҗЩ„Щ’Щ…ЩҸШӨЩ’Щ…ЩҗЩҶЩҗЩҠЩҶЩҺ"},{"key":"27:78","surah":27,"ayah":78,"num":3237,"page":384,"words":[{"code":"пұҶ","page":384,"end":false},{"code":"пұҮ","page":384,"end":false},{"code":"пұҲ","page":384,"end":false},{"code":"пұү","page":384,"end":false},{"code":"пұҠпұӢ","page":384,"end":false},{"code":"пұҢ","page":384,"end":false},{"code":"пұҚ","page":384,"end":false},{"code":"пұҺ","page":384,"end":false},{"code":"пұҸ","page":384,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ШұЩҺШЁЩ‘ЩҺЩғЩҺ ЩҠЩҺЩӮЩ’Ш¶ЩҗЩү ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ… ШЁЩҗШӯЩҸЩғЩ’Щ…ЩҗЩҮЩҗЫҰ Ыҡ ЩҲЩҺЩҮЩҸЩҲЩҺ ЩұЩ„Щ’Ш№ЩҺШІЩҗЩҠШІЩҸ ЩұЩ„Щ’Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҸ"},{"key":"27:79","surah":27,"ayah":79,"num":3238,"page":384,"words":[{"code":"пұҗ","page":384,"end":false},{"code":"пұ‘","page":384,"end":false},{"code":"пұ’пұ“","page":384,"end":false},{"code":"пұ”","page":384,"end":false},{"code":"пұ•","page":384,"end":false},{"code":"пұ–","page":384,"end":false},{"code":"пұ—","page":384,"end":false},{"code":"пұҳ","page":384,"end":true}],"text":"ЩҒЩҺШӘЩҺЩҲЩҺЩғЩ‘ЩҺЩ„Щ’ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ы– ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ’ШӯЩҺЩӮЩ‘Щҗ ЩұЩ„Щ’Щ…ЩҸШЁЩҗЩҠЩҶЩҗ"},{"key":"27:80","surah":27,"ayah":80,"num":3239,"page":384,"words":[{"code":"пұҷ","page":384,"end":false},{"code":"пұҡ","page":384,"end":false},{"code":"пұӣ","page":384,"end":false},{"code":"пұң","page":384,"end":false},{"code":"пұқ","page":384,"end":false},{"code":"пұһ","page":384,"end":false},{"code":"пұҹ","page":384,"end":false},{"code":"пұ ","page":384,"end":false},{"code":"пұЎ","page":384,"end":false},{"code":"пұў","page":384,"end":false},{"code":"пұЈ","page":384,"end":false},{"code":"пұӨ","page":384,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺЩғЩҺ Щ„ЩҺШ§ ШӘЩҸШіЩ’Щ…ЩҗШ№ЩҸ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҺЩүЩ° ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШіЩ’Щ…ЩҗШ№ЩҸ ЩұЩ„ШөЩ‘ЩҸЩ…Щ‘ЩҺ ЩұЩ„ШҜЩ‘ЩҸШ№ЩҺШ§Щ“ШЎЩҺ ШҘЩҗШ°ЩҺШ§ ЩҲЩҺЩ„Щ‘ЩҺЩҲЩ’Ш§Ыҹ Щ…ЩҸШҜЩ’ШЁЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"27:81","surah":27,"ayah":81,"num":3240,"page":384,"words":[{"code":"пұҘ","page":384,"end":false},{"code":"пұҰ","page":384,"end":false},{"code":"пұ§","page":384,"end":false},{"code":"пұЁ","page":384,"end":false},{"code":"пұ©","page":384,"end":false},{"code":"пұӘпұ«","page":384,"end":false},{"code":"пұ¬","page":384,"end":false},{"code":"пұӯ","page":384,"end":false},{"code":"пұ®","page":384,"end":false},{"code":"пұҜ","page":384,"end":false},{"code":"пұ°","page":384,"end":false},{"code":"пұұ","page":384,"end":false},{"code":"пұІ","page":384,"end":false},{"code":"пұі","page":384,"end":false},{"code":"пұҙ","page":384,"end":true}],"text":"ЩҲЩҺЩ…ЩҺШ§Щ“ ШЈЩҺЩҶШӘЩҺ ШЁЩҗЩҮЩҺЩҖЩ°ШҜЩҗЩү ЩұЩ„Щ’Ш№ЩҸЩ…Щ’ЩүЩҗ Ш№ЩҺЩҶ Ш¶ЩҺЩ„ЩҺЩҖЩ°Щ„ЩҺШӘЩҗЩҮЩҗЩ…Щ’ Ы– ШҘЩҗЩҶ ШӘЩҸШіЩ’Щ…ЩҗШ№ЩҸ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩҶ ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҒЩҺЩҮЩҸЩ… Щ…Щ‘ЩҸШіЩ’Щ„ЩҗЩ…ЩҸЩҲЩҶЩҺ"},{"key":"27:82","surah":27,"ayah":82,"num":3241,"page":384,"words":[{"code":"пұө пұ¶","page":384,"end":false},{"code":"пұ·","page":384,"end":false},{"code":"пұё","page":384,"end":false},{"code":"пұ№","page":384,"end":false},{"code":"пұә","page":384,"end":false},{"code":"пұ»","page":384,"end":false},{"code":"пұј","page":384,"end":false},{"code":"пұҪ","page":384,"end":false},{"code":"пұҫ","page":384,"end":false},{"code":"пұҝ","page":384,"end":false},{"code":"пІҖ","page":384,"end":false},{"code":"пІҒ","page":384,"end":false},{"code":"пІӮ","page":384,"end":false},{"code":"пІғ","page":384,"end":false},{"code":"пІ„","page":384,"end":false},{"code":"пІ…","page":384,"end":false},{"code":"пІҶ","page":384,"end":true}],"text":"Ыһ ЩҲЩҺШҘЩҗШ°ЩҺШ§ ЩҲЩҺЩӮЩҺШ№ЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ„ЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…Щ’ ШЈЩҺШ®Щ’ШұЩҺШ¬Щ’ЩҶЩҺШ§ Щ„ЩҺЩҮЩҸЩ…Щ’ ШҜЩҺШ§Щ“ШЁЩ‘ЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШӘЩҸЩғЩҺЩ„Щ‘ЩҗЩ…ЩҸЩҮЩҸЩ…Щ’ ШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҺ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ Щ„ЩҺШ§ ЩҠЩҸЩҲЩӮЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"27:83","surah":27,"ayah":83,"num":3242,"page":384,"words":[{"code":"пІҮ","page":384,"end":false},{"code":"пІҲ","page":384,"end":false},{"code":"пІү","page":384,"end":false},{"code":"пІҠ","page":384,"end":false},{"code":"пІӢ","page":384,"end":false},{"code":"пІҢ","page":384,"end":false},{"code":"пІҚ","page":384,"end":false},{"code":"пІҺ","page":384,"end":false},{"code":"пІҸ","page":384,"end":false},{"code":"пІҗ","page":384,"end":false},{"code":"пІ‘","page":384,"end":false},{"code":"пІ’","page":384,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҶЩҺШӯЩ’ШҙЩҸШұЩҸ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘Щҗ ШЈЩҸЩ…Щ‘ЩҺШ©ЩҚЫў ЩҒЩҺЩҲЩ’Ш¬ЩӢЫӯШ§ Щ…Щ‘ЩҗЩ…Щ‘ЩҺЩҶ ЩҠЩҸЩғЩҺШ°Щ‘ЩҗШЁЩҸ ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ ЩҒЩҺЩҮЩҸЩ…Щ’ ЩҠЩҸЩҲШІЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"27:84","surah":27,"ayah":84,"num":3243,"page":384,"words":[{"code":"пІ“","page":384,"end":false},{"code":"пІ”","page":384,"end":false},{"code":"пІ•","page":384,"end":false},{"code":"пІ–","page":384,"end":false},{"code":"пІ—","page":384,"end":false},{"code":"пІҳ","page":384,"end":false},{"code":"пІҷ","page":384,"end":false},{"code":"пІҡ","page":384,"end":false},{"code":"пІӣ","page":384,"end":false},{"code":"пІң","page":384,"end":false},{"code":"пІқ","page":384,"end":false},{"code":"пІһ","page":384,"end":false},{"code":"пІҹ","page":384,"end":false},{"code":"пІ ","page":384,"end":true}],"text":"ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲ ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺЩғЩҺШ°Щ‘ЩҺШЁЩ’ШӘЩҸЩ… ШЁЩҗЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩү ЩҲЩҺЩ„ЩҺЩ…Щ’ ШӘЩҸШӯЩҗЩҠШ·ЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҺШ§ Ш№ЩҗЩ„Щ’Щ…ЩӢШ§ ШЈЩҺЩ…Щ‘ЩҺШ§Ш°ЩҺШ§ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШӘЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ"},{"key":"27:85","surah":27,"ayah":85,"num":3244,"page":384,"words":[{"code":"пІЎ","page":384,"end":false},{"code":"пІў","page":384,"end":false},{"code":"пІЈ","page":384,"end":false},{"code":"пІӨ","page":384,"end":false},{"code":"пІҘ","page":384,"end":false},{"code":"пІҰ","page":384,"end":false},{"code":"пІ§","page":384,"end":false},{"code":"пІЁ","page":384,"end":false},{"code":"пІ©","page":384,"end":true}],"text":"ЩҲЩҺЩҲЩҺЩӮЩҺШ№ЩҺ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ„ЩҸ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ… ШЁЩҗЩ…ЩҺШ§ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲШ§Ыҹ ЩҒЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺШ§ ЩҠЩҺЩҶШ·ЩҗЩӮЩҸЩҲЩҶЩҺ"},{"key":"27:86","surah":27,"ayah":86,"num":3245,"page":384,"words":[{"code":"пІӘ","page":384,"end":false},{"code":"пІ«","page":384,"end":false},{"code":"пІ¬","page":384,"end":false},{"code":"пІӯ","page":384,"end":false},{"code":"пІ®","page":384,"end":false},{"code":"пІҜ","page":384,"end":false},{"code":"пІ°","page":384,"end":false},{"code":"пІұ","page":384,"end":false},{"code":"пІІпІі","page":384,"end":false},{"code":"пІҙ","page":384,"end":false},{"code":"пІө","page":384,"end":false},{"code":"пІ¶","page":384,"end":false},{"code":"пІ·","page":384,"end":false},{"code":"пІё","page":384,"end":false},{"code":"пІ№","page":384,"end":false},{"code":"пІә","page":384,"end":true}],"text":"ШЈЩҺЩ„ЩҺЩ…Щ’ ЩҠЩҺШұЩҺЩҲЩ’Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺШ§ Ш¬ЩҺШ№ЩҺЩ„Щ’ЩҶЩҺШ§ ЩұЩ„Щ‘ЩҺЩҠЩ’Щ„ЩҺ Щ„ЩҗЩҠЩҺШіЩ’ЩғЩҸЩҶЩҸЩҲШ§Ыҹ ЩҒЩҗЩҠЩҮЩҗ ЩҲЩҺЩұЩ„ЩҶЩ‘ЩҺЩҮЩҺШ§ШұЩҺ Щ…ЩҸШЁЩ’ШөЩҗШұЩӢШ§ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩҒЩҗЩү Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ„ЩҺЩҖЩ”ЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҚЫў Щ„Щ‘ЩҗЩӮЩҺЩҲЩ’Щ…ЩҚЫў ЩҠЩҸШӨЩ’Щ…ЩҗЩҶЩҸЩҲЩҶЩҺ"},{"key":"27:87","surah":27,"ayah":87,"num":3246,"page":384,"words":[{"code":"пІ»","page":384,"end":false},{"code":"пІј","page":384,"end":false},{"code":"пІҪ","page":384,"end":false},{"code":"пІҫ","page":384,"end":false},{"code":"пІҝ","page":384,"end":false},{"code":"піҖ","page":384,"end":false},{"code":"піҒ","page":384,"end":false},{"code":"піӮ","page":384,"end":false},{"code":"піғ","page":384,"end":false},{"code":"пі„","page":384,"end":false},{"code":"пі…","page":384,"end":false},{"code":"піҶ","page":384,"end":false},{"code":"піҮ","page":384,"end":false},{"code":"піҲ","page":384,"end":false},{"code":"піүпіҠ","page":384,"end":false},{"code":"піӢ","page":384,"end":false},{"code":"піҢ","page":384,"end":false},{"code":"піҚ","page":384,"end":false},{"code":"піҺ","page":384,"end":true}],"text":"ЩҲЩҺЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҠЩҸЩҶЩҒЩҺШ®ЩҸ ЩҒЩҗЩү ЩұЩ„ШөЩ‘ЩҸЩҲШұЩҗ ЩҒЩҺЩҒЩҺШІЩҗШ№ЩҺ Щ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺЩҶ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩҶ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩҲЩҺЩғЩҸЩ„Щ‘ЩҢ ШЈЩҺШӘЩҺЩҲЩ’ЩҮЩҸ ШҜЩҺЩ°Ш®ЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"27:88","surah":27,"ayah":88,"num":3247,"page":384,"words":[{"code":"піҸ","page":384,"end":false},{"code":"піҗ","page":384,"end":false},{"code":"пі‘","page":384,"end":false},{"code":"пі’","page":384,"end":false},{"code":"пі“","page":384,"end":false},{"code":"пі”","page":384,"end":false},{"code":"пі•","page":384,"end":false},{"code":"пі–пі—","page":384,"end":false},{"code":"піҳ","page":384,"end":false},{"code":"піҷ","page":384,"end":false},{"code":"піҡ","page":384,"end":false},{"code":"піӣ","page":384,"end":false},{"code":"пің","page":384,"end":false},{"code":"піқпіһ","page":384,"end":false},{"code":"піҹ","page":384,"end":false},{"code":"пі ","page":384,"end":false},{"code":"піЎ","page":384,"end":false},{"code":"піў","page":384,"end":false},{"code":"піЈ","page":384,"end":true}],"text":"ЩҲЩҺШӘЩҺШұЩҺЩү ЩұЩ„Щ’Ш¬ЩҗШЁЩҺШ§Щ„ЩҺ ШӘЩҺШӯЩ’ШіЩҺШЁЩҸЩҮЩҺШ§ Ш¬ЩҺШ§Щ…ЩҗШҜЩҺШ©ЩӢЫӯ ЩҲЩҺЩҮЩҗЩүЩҺ ШӘЩҺЩ…ЩҸШұЩ‘ЩҸ Щ…ЩҺШұЩ‘ЩҺ ЩұЩ„ШіЩ‘ЩҺШӯЩҺШ§ШЁЩҗ Ыҡ ШөЩҸЩҶЩ’Ш№ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЈЩҺШӘЩ’ЩӮЩҺЩҶЩҺ ЩғЩҸЩ„Щ‘ЩҺ ШҙЩҺЩүЩ’ШЎЩҚ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ Ш®ЩҺШЁЩҗЩҠШұЩҢЫў ШЁЩҗЩ…ЩҺШ§ ШӘЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲЩҶЩҺ"}]}
e":74,"end":false},{"code":"пұ…","page":74,"end":false},{"code":"пұҶ","page":74,"end":false},{"code":"пұҮ","page":74,"end":false},{"code":"пұҲ","page":74,"end":false},{"code":"пұү","page":74,"end":false},{"code":"пұҠ","page":74,"end":false},{"code":"пұӢпұҢ","page":74,"end":false},{"code":"пұҚ","page":74,"end":false},{"code":"пұҺ","page":74,"end":false},{"code":"пұҸ","page":74,"end":false},{"code":"пұҗ","page":74,"end":false},{"code":"пұ‘","page":74,"end":false},{"code":"пұ’","page":74,"end":false},{"code":"пұ“","page":74,"end":false},{"code":"пұ”","page":74,"end":false},{"code":"пұ•","page":74,"end":false},{"code":"пұ–","page":74,"end":false},{"code":"пұ—","page":74,"end":false},{"code":"пұҳ","page":74,"end":true}],"text":"Щ„Щ‘ЩҺЩӮЩҺШҜЩ’ ШіЩҺЩ…ЩҗШ№ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩӮЩҺЩҲЩ’Щ„ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ЩҒЩҺЩӮЩҗЩҠШұЩҢЫӯ ЩҲЩҺЩҶЩҺШӯЩ’ЩҶЩҸ ШЈЩҺШәЩ’ЩҶЩҗЩҠЩҺШ§Щ“ШЎЩҸ Ыҳ ШіЩҺЩҶЩҺЩғЩ’ШӘЩҸШЁЩҸ Щ…ЩҺШ§ ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩҲЩҺЩӮЩҺШӘЩ’Щ„ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’ШЈЩҺЩҶЫўШЁЩҗЩҠЩҺШ§Щ“ШЎЩҺ ШЁЩҗШәЩҺЩҠЩ’ШұЩҗ ШӯЩҺЩӮЩ‘ЩҚЫў ЩҲЩҺЩҶЩҺЩӮЩҸЩҲЩ„ЩҸ Ш°ЩҸЩҲЩӮЩҸЩҲШ§Ыҹ Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ЩұЩ„Щ’ШӯЩҺШұЩҗЩҠЩӮЩҗ"},{"key":"3:182","surah":3,"ayah":182,"num":475,"page":74,"words":[{"code":"пұҷ","page":74,"end":false},{"code":"пұҡ","page":74,"end":false},{"code":"пұӣ","page":74,"end":false},{"code":"пұң","page":74,"end":false},{"code":"пұқ","page":74,"end":false},{"code":"пұһ","page":74,"end":false},{"code":"пұҹ","page":74,"end":false},{"code":"пұ ","page":74,"end":false},{"code":"пұЎ","page":74,"end":false},{"code":"пұў","page":74,"end":true}],"text":"Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗЩ…ЩҺШ§ ЩӮЩҺШҜЩ‘ЩҺЩ…ЩҺШӘЩ’ ШЈЩҺЩҠЩ’ШҜЩҗЩҠЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ„ЩҺЩҠЩ’ШіЩҺ ШЁЩҗШёЩҺЩ„Щ‘ЩҺШ§Щ…ЩҚЫў Щ„Щ‘ЩҗЩ„Щ’Ш№ЩҺШЁЩҗЩҠШҜЩҗ"},{"key":"3:183","surah":3,"ayah":183,"num":476,"page":74,"words":[{"code":"пұЈ","page":74,"end":false},{"code":"пұӨ","page":74,"end":false},{"code":"пұҘ","page":74,"end":false},{"code":"пұҰ","page":74,"end":false},{"code":"пұ§","page":74,"end":false},{"code":"пұЁ","page":74,"end":false},{"code":"пұ©","page":74,"end":false},{"code":"пұӘ","page":74,"end":false},{"code":"пұ«","page":74,"end":false},{"code":"пұ¬","page":74,"end":false},{"code":"пұӯ","page":74,"end":false},{"code":"пұ®","page":74,"end":false},{"code":"пұҜ","page":74,"end":false},{"code":"пұ°пұұ","page":74,"end":false},{"code":"пұІ","page":74,"end":false},{"code":"пұі","page":74,"end":false},{"code":"пұҙ","page":74,"end":false},{"code":"пұө","page":74,"end":false},{"code":"пұ¶","page":74,"end":false},{"code":"пұ·","page":74,"end":false},{"code":"пұё","page":74,"end":false},{"code":"пұ№","page":74,"end":false},{"code":"пұә","page":74,"end":false},{"code":"пұ»","page":74,"end":false},{"code":"пұј","page":74,"end":false},{"code":"пұҪ","page":74,"end":false},{"code":"пұҫ","page":74,"end":false},{"code":"пұҝ","page":74,"end":false},{"code":"пІҖ","page":74,"end":true}],"text":"ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩӮЩҺШ§Щ„ЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ш№ЩҺЩҮЩҗШҜЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§Щ“ ШЈЩҺЩ„Щ‘ЩҺШ§ ЩҶЩҸШӨЩ’Щ…ЩҗЩҶЩҺ Щ„ЩҗШұЩҺШіЩҸЩҲЩ„ЩҚ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШЈЩ’ШӘЩҗЩҠЩҺЩҶЩҺШ§ ШЁЩҗЩӮЩҸШұЩ’ШЁЩҺШ§ЩҶЩҚЫў ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҮЩҸ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҸ Ы— ЩӮЩҸЩ„Щ’ ЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺЩғЩҸЩ…Щ’ ШұЩҸШіЩҸЩ„ЩҢЫӯ Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩү ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺШЁЩҗЩұЩ„Щ‘ЩҺШ°ЩҗЩү ЩӮЩҸЩ„Щ’ШӘЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҗЩ…ЩҺ ЩӮЩҺШӘЩҺЩ„Щ’ШӘЩҸЩ…ЩҸЩҲЩҮЩҸЩ…Щ’ ШҘЩҗЩҶ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ШөЩҺЩҖЩ°ШҜЩҗЩӮЩҗЩҠЩҶЩҺ"},{"key":"3:184","surah":3,"ayah":184,"num":477,"page":74,"words":[{"code":"пІҒ","page":74,"end":false},{"code":"пІӮ","page":74,"end":false},{"code":"пІғ","page":74,"end":false},{"code":"пІ„","page":74,"end":false},{"code":"пІ…","page":74,"end":false},{"code":"пІҶ","page":74,"end":false},{"code":"пІҮ","page":74,"end":false},{"code":"пІҲ","page":74,"end":false},{"code":"пІү","page":74,"end":false},{"code":"пІҠ","page":74,"end":false},{"code":"пІӢ","page":74,"end":false},{"code":"пІҢ","page":74,"end":false},{"code":"пІҚ","page":74,"end":true}],"text":"ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲЩғЩҺ ЩҒЩҺЩӮЩҺШҜЩ’ ЩғЩҸШ°Щ‘ЩҗШЁЩҺ ШұЩҸШіЩҸЩ„ЩҢЫӯ Щ…Щ‘ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҺ Ш¬ЩҺШ§Щ“ШЎЩҸЩҲ ШЁЩҗЩұЩ„Щ’ШЁЩҺЩҠЩ‘ЩҗЩҶЩҺЩҖЩ°ШӘЩҗ ЩҲЩҺЩұЩ„ШІЩ‘ЩҸШЁЩҸШұЩҗ ЩҲЩҺЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ЩұЩ„Щ’Щ…ЩҸЩҶЩҗЩҠШұЩҗ"},{"key":"3:185","surah":3,"ayah":185,"num":478,"page":74,"words":[{"code":"пІҺ","page":74,"end":false},{"code":"пІҸ","page":74,"end":false},{"code":"пІҗ","page":74,"end":false},{"code":"пІ‘пІ’","page":74,"end":false},{"code":"пІ“","page":74,"end":false},{"code":"пІ”","page":74,"end":false},{"code":"пІ•","page":74,"end":false},{"code":"пІ–","page":74,"end":false},{"code":"пІ—пІҳ","page":74,"end":false},{"code":"пІҷ","page":74,"end":false},{"code":"пІҡ","page":74,"end":false},{"code":"пІӣ","page":74,"end":false},{"code":"пІң","page":74,"end":false},{"code":"пІқ","page":74,"end":false},{"code":"пІһ","page":74,"end":false},{"code":"пІҹ","page":74,"end":false},{"code":"пІ пІЎ","page":74,"end":false},{"code":"пІў","page":74,"end":false},{"code":"пІЈ","page":74,"end":false},{"code":"пІӨ","page":74,"end":false},{"code":"пІҘ","page":74,"end":false},{"code":"пІҰ","page":74,"end":false},{"code":"пІ§","page":74,"end":false},{"code":"пІЁ","page":74,"end":true}],"text":"ЩғЩҸЩ„Щ‘ЩҸ ЩҶЩҺЩҒЩ’ШіЩҚЫў Ш°ЩҺШ§Щ“ШҰЩҗЩӮЩҺШ©ЩҸ ЩұЩ„Щ’Щ…ЩҺЩҲЩ’ШӘЩҗ Ы— ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ШӘЩҸЩҲЩҺЩҒЩ‘ЩҺЩҲЩ’ЩҶЩҺ ШЈЩҸШ¬ЩҸЩҲШұЩҺЩғЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ЩӮЩҗЩҠЩҺЩҖЩ°Щ…ЩҺШ©Щҗ Ы– ЩҒЩҺЩ…ЩҺЩҶ ШІЩҸШӯЩ’ШІЩҗШӯЩҺ Ш№ЩҺЩҶЩҗ ЩұЩ„ЩҶЩ‘ЩҺШ§ШұЩҗ ЩҲЩҺШЈЩҸШҜЩ’Ш®ЩҗЩ„ЩҺ ЩұЩ„Щ’Ш¬ЩҺЩҶЩ‘ЩҺШ©ЩҺ ЩҒЩҺЩӮЩҺШҜЩ’ ЩҒЩҺШ§ШІЩҺ Ы— ЩҲЩҺЩ…ЩҺШ§ ЩұЩ„Щ’ШӯЩҺЩҠЩҺЩҲЩ°Ш©ЩҸ ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҸ ЩұЩ„Щ’ШәЩҸШұЩҸЩҲШұЩҗ"},{"key":"3:186","surah":3,"ayah":186,"num":479,"page":74,"words":[{"code":"пІ© пІӘ","page":74,"end":false},{"code":"пІ«","page":74,"end":false},{"code":"пІ¬","page":74,"end":false},{"code":"пІӯ","page":74,"end":false},{"code":"пІ®","page":74,"end":false},{"code":"пІҜ","page":74,"end":false},{"code":"пІ°","page":74,"end":false},{"code":"пІұ","page":74,"end":false},{"code":"пІІ","page":74,"end":false},{"code":"пІі","page":74,"end":false},{"code":"пІҙ","page":74,"end":false},{"code":"пІө","page":74,"end":false},{"code":"пІ¶","page":74,"end":false},{"code":"пІ·","page":74,"end":false},{"code":"пІё","page":74,"end":false},{"code":"пІ№пІә","page":74,"end":false},{"code":"пІ»","page":74,"end":false},{"code":"пІј","page":74,"end":false},{"code":"пІҪ","page":74,"end":false},{"code":"пІҫ","page":74,"end":false},{"code":"пІҝ","page":74,"end":false},{"code":"піҖ","page":74,"end":false},{"code":"піҒ","page":74,"end":false},{"code":"піӮ","page":74,"end":false},{"code":"піғ","page":74,"end":true}],"text":"Ыһ Щ„ЩҺШӘЩҸШЁЩ’Щ„ЩҺЩҲЩҸЩҶЩ‘ЩҺ ЩҒЩҗЩүЩ“ ШЈЩҺЩ…Щ’ЩҲЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺШЈЩҺЩҶЩҒЩҸШіЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺШӘЩҺШіЩ’Щ…ЩҺШ№ЩҸЩҶЩ‘ЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҸЩҲШӘЩҸЩҲШ§Ыҹ ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ Щ…ЩҗЩҶ ЩӮЩҺШЁЩ’Щ„ЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҗЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЈЩҺШҙЩ’ШұЩҺЩғЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺШ°ЩӢЫӯЩү ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Ыҡ ЩҲЩҺШҘЩҗЩҶ ШӘЩҺШөЩ’ШЁЩҗШұЩҸЩҲШ§Ыҹ ЩҲЩҺШӘЩҺШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ Щ…ЩҗЩҶЩ’ Ш№ЩҺШІЩ’Щ…Щҗ ЩұЩ„Щ’ШЈЩҸЩ…ЩҸЩҲШұЩҗ"}]}
":"пІ·","page":216,"end":false},{"code":"пІё","page":216,"end":false},{"code":"пІ№","page":216,"end":false},{"code":"пІә","page":216,"end":false},{"code":"пІ»","page":216,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҸЩҲШ§Ыҹ ЩұШӘЩ‘ЩҺШ®ЩҺШ°ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ЩҲЩҺЩ„ЩҺШҜЩӢЫӯШ§ Ы— ШіЩҸШЁЩ’ШӯЩҺЩҖЩ°ЩҶЩҺЩҮЩҸЫҘ Ы– ЩҮЩҸЩҲЩҺ ЩұЩ„Щ’ШәЩҺЩҶЩҗЩүЩ‘ЩҸ Ы– Щ„ЩҺЩҮЩҸЫҘ Щ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„ШіЩ‘ЩҺЩ…ЩҺЩҖЩ°ЩҲЩҺЩ°ШӘЩҗ ЩҲЩҺЩ…ЩҺШ§ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ Ыҡ ШҘЩҗЩҶЩ’ Ш№ЩҗЩҶШҜЩҺЩғЩҸЩ… Щ…Щ‘ЩҗЩҶ ШіЩҸЩ„Щ’Ш·ЩҺЩҖЩ°ЩҶЩҚЫӯ ШЁЩҗЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ Ыҡ ШЈЩҺШӘЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Щ…ЩҺШ§ Щ„ЩҺШ§ ШӘЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"},{"key":"10:69","surah":10,"ayah":69,"num":1433,"page":216,"words":[{"code":"пІј","page":216,"end":false},{"code":"пІҪ","page":216,"end":false},{"code":"пІҫ","page":216,"end":false},{"code":"пІҝ","page":216,"end":false},{"code":"піҖ","page":216,"end":false},{"code":"піҒ","page":216,"end":false},{"code":"піӮ","page":216,"end":false},{"code":"піғ","page":216,"end":false},{"code":"пі„","page":216,"end":false},{"code":"пі…","page":216,"end":true}],"text":"ЩӮЩҸЩ„Щ’ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩҠЩҺЩҒЩ’ШӘЩҺШұЩҸЩҲЩҶЩҺ Ш№ЩҺЩ„ЩҺЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩұЩ„Щ’ЩғЩҺШ°ЩҗШЁЩҺ Щ„ЩҺШ§ ЩҠЩҸЩҒЩ’Щ„ЩҗШӯЩҸЩҲЩҶЩҺ"},{"key":"10:70","surah":10,"ayah":70,"num":1434,"page":216,"words":[{"code":"піҶ","page":216,"end":false},{"code":"піҮ","page":216,"end":false},{"code":"піҲ","page":216,"end":false},{"code":"піү","page":216,"end":false},{"code":"піҠ","page":216,"end":false},{"code":"піӢ","page":216,"end":false},{"code":"піҢ","page":216,"end":false},{"code":"піҚ","page":216,"end":false},{"code":"піҺ","page":216,"end":false},{"code":"піҸ","page":216,"end":false},{"code":"піҗ","page":216,"end":false},{"code":"пі‘","page":216,"end":false},{"code":"пі’","page":216,"end":false},{"code":"пі“","page":216,"end":true}],"text":"Щ…ЩҺШӘЩҺЩҖЩ°Ш№ЩҢЫӯ ЩҒЩҗЩү ЩұЩ„ШҜЩ‘ЩҸЩҶЩ’ЩҠЩҺШ§ Ш«ЩҸЩ…Щ‘ЩҺ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҺШұЩ’Ш¬ЩҗШ№ЩҸЩҮЩҸЩ…Щ’ Ш«ЩҸЩ…Щ‘ЩҺ ЩҶЩҸШ°ЩҗЩҠЩӮЩҸЩҮЩҸЩ…ЩҸ ЩұЩ„Щ’Ш№ЩҺШ°ЩҺШ§ШЁЩҺ ЩұЩ„ШҙЩ‘ЩҺШҜЩҗЩҠШҜЩҺ ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ§ЩҶЩҸЩҲШ§Ыҹ ЩҠЩҺЩғЩ’ЩҒЩҸШұЩҸЩҲЩҶЩҺ"}]}
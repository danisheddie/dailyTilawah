":false},{"code":"пұҘпұҰ","page":234,"end":false},{"code":"пұ§","page":234,"end":false},{"code":"пұЁ","page":234,"end":false},{"code":"пұ©","page":234,"end":false},{"code":"пұӘ","page":234,"end":false},{"code":"пұ«","page":234,"end":false},{"code":"пұ¬","page":234,"end":true}],"text":"ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ ШЎЩҺШ§ШӘЩҺЩҠЩ’ЩҶЩҺШ§ Щ…ЩҸЩҲШіЩҺЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҺ ЩҒЩҺЩұШ®Щ’ШӘЩҸЩ„ЩҗЩҒЩҺ ЩҒЩҗЩҠЩҮЩҗ Ыҡ ЩҲЩҺЩ„ЩҺЩҲЩ’Щ„ЩҺШ§ ЩғЩҺЩ„ЩҗЩ…ЩҺШ©ЩҢЫӯ ШіЩҺШЁЩҺЩӮЩҺШӘЩ’ Щ…ЩҗЩҶ ШұЩ‘ЩҺШЁЩ‘ЩҗЩғЩҺ Щ„ЩҺЩӮЩҸШ¶ЩҗЩүЩҺ ШЁЩҺЩҠЩ’ЩҶЩҺЩҮЩҸЩ…Щ’ Ыҡ ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ Щ„ЩҺЩҒЩҗЩү ШҙЩҺЩғЩ‘ЩҚЫў Щ…Щ‘ЩҗЩҶЩ’ЩҮЩҸ Щ…ЩҸШұЩҗЩҠШЁЩҚЫў"},{"key":"11:111","surah":11,"ayah":111,"num":1584,"page":234,"words":[{"code":"пұӯ","page":234,"end":false},{"code":"пұ®","page":234,"end":false},{"code":"пұҜ","page":234,"end":false},{"code":"пұ°","page":234,"end":false},{"code":"пұұ","page":234,"end":false},{"code":"пұІпұі","page":234,"end":false},{"code":"пұҙ","page":234,"end":false},{"code":"пұө","page":234,"end":false},{"code":"пұ¶","page":234,"end":false},{"code":"пұ·","page":234,"end":false},{"code":"пұё","page":234,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ ЩғЩҸЩ„Щ‘ЩӢЫӯШ§ Щ„Щ‘ЩҺЩ…Щ‘ЩҺШ§ Щ„ЩҺЩҠЩҸЩҲЩҺЩҒЩ‘ЩҗЩҠЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ШұЩҺШЁЩ‘ЩҸЩғЩҺ ШЈЩҺШ№Щ’Щ…ЩҺЩҖЩ°Щ„ЩҺЩҮЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ШЁЩҗЩ…ЩҺШ§ ЩҠЩҺШ№Щ’Щ…ЩҺЩ„ЩҸЩҲЩҶЩҺ Ш®ЩҺШЁЩҗЩҠШұЩҢЫӯ"},{"key":"11:112","surah":11,"ayah":112,"num":1585,"page":234,"words":[{"code":"пұ№","page":234,"end":false},{"code":"пұә","page":234,"end":false},{"code":"пұ»","page":234,"end":false},{"code":"пұј","page":234,"end":false},{"code":"пұҪ","page":234,"end":false},{"code":"пұҫ","page":234,"end":false},{"code":"пұҝ","page":234,"end":false},{"code":"пІҖпІҒ","page":234,"end":false},{"code":"пІӮ","page":234,"end":false},{"code":"пІғ","page":234,"end":false},{"code":"пІ„","page":234,"end":false},{"code":"пІ…","page":234,"end":false},{"code":"пІҶ","page":234,"end":true}],"text":"ЩҒЩҺЩұШіЩ’ШӘЩҺЩӮЩҗЩ…Щ’ ЩғЩҺЩ…ЩҺШ§Щ“ ШЈЩҸЩ…ЩҗШұЩ’ШӘЩҺ ЩҲЩҺЩ…ЩҺЩҶ ШӘЩҺШ§ШЁЩҺ Щ…ЩҺШ№ЩҺЩғЩҺ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШ·Щ’ШәЩҺЩҲЩ’Ш§Ыҹ Ыҡ ШҘЩҗЩҶЩ‘
"code":"пұғ","page":187,"end":false},{"code":"пұ„","page":187,"end":false},{"code":"пұ…","page":187,"end":false},{"code":"пұҶ","page":187,"end":false},{"code":"пұҮ","page":187,"end":false},{"code":"пұҲ","page":187,"end":false},{"code":"пұү","page":187,"end":false},{"code":"пұҠ","page":187,"end":true}],"text":"ШЁЩҺШұЩҺШ§Щ“ШЎЩҺШ©ЩҢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШұЩҺШіЩҸЩҲЩ„ЩҗЩҮЩҗЫҰЩ“ ШҘЩҗЩ„ЩҺЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ Ш№ЩҺЩҖЩ°ЩҮЩҺШҜШӘЩ‘ЩҸЩ… Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ"},{"key":"9:2","surah":9,"ayah":2,"num":1237,"page":187,"words":[{"code":"пұӢ","page":187,"end":false},{"code":"пұҢ","page":187,"end":false},{"code":"пұҚ","page":187,"end":false},{"code":"пұҺ","page":187,"end":false},{"code":"пұҸ","page":187,"end":false},{"code":"пұҗ","page":187,"end":false},{"code":"пұ‘","page":187,"end":false},{"code":"пұ’","page":187,"end":false},{"code":"пұ“","page":187,"end":false},{"code":"пұ”","page":187,"end":false},{"code":"пұ•","page":187,"end":false},{"code":"пұ–","page":187,"end":false},{"code":"пұ—","page":187,"end":false},{"code":"пұҳ","page":187,"end":false},{"code":"пұҷ","page":187,"end":true}],"text":"ЩҒЩҺШіЩҗЩҠШӯЩҸЩҲШ§Ыҹ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺШұЩ’Ш¶Щҗ ШЈЩҺШұЩ’ШЁЩҺШ№ЩҺШ©ЩҺ ШЈЩҺШҙЩ’ЩҮЩҸШұЩҚЫў ЩҲЩҺЩұШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶЩ‘ЩҺЩғЩҸЩ…Щ’ ШәЩҺЩҠЩ’ШұЩҸ Щ…ЩҸШ№Щ’Ш¬ЩҗШІЩҗЩү ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ыҷ ЩҲЩҺШЈЩҺЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Щ…ЩҸШ®Щ’ШІЩҗЩү ЩұЩ„Щ’ЩғЩҺЩҖЩ°ЩҒЩҗШұЩҗЩҠЩҶЩҺ"},{"key":"9:3","surah":9,"ayah":3,"num":1238,"page":187,"words":[{"code":"пұҡ","page":187,"end":false},{"code":"пұӣ","page":187,"end":false},{"code":"пұң","page":187,"end":false},{"code":"пұқ","page":187,"end":false},{"code":"пұһ","page":187,"end":false},{"code":"пұҹ","page":187,"end":false},{"code":"пұ ","page":187,"end":false},{"code":"пұЎ","page":187,"end":false},{"code":"пұў","page":187,"end":false},{"code":"пұЈ","page":187,"end":false},{"code":"пұӨ","page":187,"end":false},{"code":"пұҘ","page":187,"end":false},{"code":"пұҰ","page":187,"end":false},{"code":"пұ§","page":187,"end":false},{"code":"пұЁпұ©","page"
Ыҹ Щ„ЩҺЩҮЩҸЩ…Щ’ ЩғЩҸЩ„Щ‘ЩҺ Щ…ЩҺШұЩ’ШөЩҺШҜЩҚЫў Ыҡ ЩҒЩҺШҘЩҗЩҶ ШӘЩҺШ§ШЁЩҸЩҲШ§Ыҹ ЩҲЩҺШЈЩҺЩӮЩҺШ§Щ…ЩҸЩҲШ§Ыҹ ЩұЩ„ШөЩ‘ЩҺЩ„ЩҺЩҲЩ°Ш©ЩҺ ЩҲЩҺШЎЩҺШ§ШӘЩҺЩҲЩҸШ§Ыҹ ЩұЩ„ШІЩ‘ЩҺЩғЩҺЩҲЩ°Ш©ЩҺ ЩҒЩҺШ®ЩҺЩ„Щ‘ЩҸЩҲШ§Ыҹ ШіЩҺШЁЩҗЩҠЩ„ЩҺЩҮЩҸЩ…Щ’ Ыҡ ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢЫӯ ШұЩ‘ЩҺШӯЩҗЩҠЩ…ЩҢЫӯ"},{"key":"9:6","surah":9,"ayah":6,"num":1241,"page":187,"words":[{"code":"пІі","page":187,"end":false},{"code":"пІҙ","page":187,"end":false},{"code":"пІө","page":187,"end":false},{"code":"пІ¶","page":187,"end":false},{"code":"пІ·","page":187,"end":false},{"code":"пІё","page":187,"end":false},{"code":"пІ№","page":187,"end":false},{"code":"пІә","page":187,"end":false},{"code":"пІ»","page":187,"end":false},{"code":"пІј","page":187,"end":false},{"code":"пІҪ","page":187,"end":false},{"code":"пІҫ","page":187,"end":false},{"code":"пІҝпіҖ","page":187,"end":false},{"code":"піҒ","page":187,"end":false},{"code":"піӮ","page":187,"end":false},{"code":"піғ","page":187,"end":false},{"code":"пі„","page":187,"end":false},{"code":"пі…","page":187,"end":false},{"code":"піҶ","page":187,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ’ ШЈЩҺШӯЩҺШҜЩҢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШҙЩ’ШұЩҗЩғЩҗЩҠЩҶЩҺ ЩұШіЩ’ШӘЩҺШ¬ЩҺШ§ШұЩҺЩғЩҺ ЩҒЩҺШЈЩҺШ¬ЩҗШұЩ’ЩҮЩҸ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҺ ЩғЩҺЩ„ЩҺЩҖЩ°Щ…ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ Ш«ЩҸЩ…Щ‘ЩҺ ШЈЩҺШЁЩ’Щ„ЩҗШәЩ’ЩҮЩҸ Щ…ЩҺШЈЩ’Щ…ЩҺЩҶЩҺЩҮЩҸЫҘ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҺ ШЁЩҗШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЩ…Щ’ ЩӮЩҺЩҲЩ’Щ…ЩҢЫӯ Щ„Щ‘ЩҺШ§ ЩҠЩҺШ№Щ’Щ„ЩҺЩ…ЩҸЩҲЩҶЩҺ"}]}
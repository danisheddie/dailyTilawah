"page":48,"end":false},{"code":"пІ¶","page":48,"end":false},{"code":"пІ·","page":48,"end":false},{"code":"пІёпІ№","page":48,"end":false},{"code":"пІә","page":48,"end":false},{"code":"пІ»","page":48,"end":false},{"code":"пІј","page":48,"end":false},{"code":"пІҪ","page":48,"end":false},{"code":"пІҫпІҝ","page":48,"end":false},{"code":"піҖ","page":48,"end":false},{"code":"піҒ","page":48,"end":false},{"code":"піӮ","page":48,"end":false},{"code":"піғ","page":48,"end":false},{"code":"пі„пі…","page":48,"end":false},{"code":"піҶ","page":48,"end":false},{"code":"піҮпіҲ","page":48,"end":false},{"code":"піү","page":48,"end":false},{"code":"піҠпіӢ","page":48,"end":false},{"code":"піҢ","page":48,"end":false},{"code":"піҚ","page":48,"end":false},{"code":"піҺ","page":48,"end":false},{"code":"піҸ","page":48,"end":false},{"code":"піҗ","page":48,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺЩҠЩ‘ЩҸЩҮЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШЎЩҺШ§Щ…ЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ ШӘЩҺШҜЩҺШ§ЩҠЩҺЩҶШӘЩҸЩ… ШЁЩҗШҜЩҺЩҠЩ’ЩҶЩҚ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҚЫў Щ…Щ‘ЩҸШіЩҺЩ…Щ‘ЩӢЫӯЩү ЩҒЩҺЩұЩғЩ’ШӘЩҸШЁЩҸЩҲЩҮЩҸ Ыҡ ЩҲЩҺЩ„Щ’ЩҠЩҺЩғЩ’ШӘЩҸШЁ ШЁЩ‘ЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩғЩҺШ§ШӘЩҗШЁЩҢЫў ШЁЩҗЩұЩ„Щ’Ш№ЩҺШҜЩ’Щ„Щҗ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШЈЩ’ШЁЩҺ ЩғЩҺШ§ШӘЩҗШЁЩҢ ШЈЩҺЩҶ ЩҠЩҺЩғЩ’ШӘЩҸШЁЩҺ ЩғЩҺЩ…ЩҺШ§ Ш№ЩҺЩ„Щ‘ЩҺЩ…ЩҺЩҮЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ыҡ ЩҒЩҺЩ„Щ’ЩҠЩҺЩғЩ’ШӘЩҸШЁЩ’ ЩҲЩҺЩ„Щ’ЩҠЩҸЩ…Щ’Щ„ЩҗЩ„Щҗ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘ЩҸ ЩҲЩҺЩ„Щ’ЩҠЩҺШӘЩ‘ЩҺЩӮЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШұЩҺШЁЩ‘ЩҺЩҮЩҸЫҘ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШЁЩ’Ш®ЩҺШіЩ’ Щ…ЩҗЩҶЩ’ЩҮЩҸ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§ Ыҡ ЩҒЩҺШҘЩҗЩҶ ЩғЩҺШ§ЩҶЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩү Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩұЩ„Щ’ШӯЩҺЩӮЩ‘ЩҸ ШіЩҺЩҒЩҗЩҠЩҮЩӢШ§ ШЈЩҺЩҲЩ’ Ш¶ЩҺШ№ЩҗЩҠЩҒЩӢШ§ ШЈЩҺЩҲЩ’ Щ„ЩҺШ§ ЩҠЩҺШіЩ’ШӘЩҺШ·ЩҗЩҠШ№ЩҸ ШЈЩҺЩҶ ЩҠЩҸЩ…ЩҗЩ„Щ‘ЩҺ ЩҮЩҸЩҲЩҺ ЩҒЩҺЩ„Щ’ЩҠЩҸЩ…Щ’Щ„ЩҗЩ„Щ’ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩҸЩҮЩҸЫҘ ШЁЩҗЩұЩ„Щ’Ш№ЩҺШҜЩ’Щ„Щҗ Ыҡ ЩҲЩҺЩұШіЩ’ШӘЩҺШҙЩ’ЩҮЩҗШҜЩҸЩҲШ§Ыҹ ШҙЩҺЩҮЩҗЩҠШҜЩҺЩҠЩ’ЩҶЩҗ Щ…ЩҗЩҶ ШұЩ‘ЩҗШ¬ЩҺШ§Щ„ЩҗЩғЩҸЩ…Щ’ Ы– ЩҒЩҺШҘЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ЩҠЩҺЩғЩҸЩҲЩҶЩҺШ§ ШұЩҺШ¬ЩҸЩ„ЩҺЩҠЩ’ЩҶЩҗ ЩҒЩҺШұЩҺШ¬ЩҸЩ„ЩҢЫӯ ЩҲЩҺЩұЩ…Щ’ШұЩҺШЈЩҺШӘЩҺШ§ЩҶЩҗ Щ…ЩҗЩ…Щ‘ЩҺЩҶ ШӘЩҺШұЩ’Ш¶ЩҺЩҲЩ’ЩҶЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„ШҙЩ‘ЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҗ ШЈЩҺЩҶ ШӘЩҺШ¶ЩҗЩ„Щ‘ЩҺ ШҘЩҗШӯЩ’ШҜЩҺЩүЩ°ЩҮЩҸЩ…ЩҺШ§ ЩҒЩҺШӘЩҸШ°ЩҺЩғЩ‘ЩҗШұЩҺ ШҘЩҗШӯЩ’ШҜЩҺЩүЩ°ЩҮЩҸЩ…ЩҺШ§ ЩұЩ„Щ’ШЈЩҸШ®Щ’ШұЩҺЩүЩ° Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҺШЈЩ’ШЁЩҺ ЩұЩ„ШҙЩ‘ЩҸЩҮЩҺШҜЩҺШ§Щ“ШЎЩҸ ШҘЩҗШ°ЩҺШ§ Щ…ЩҺШ§ ШҜЩҸШ№ЩҸЩҲШ§Ыҹ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ШӘЩҺШіЩ’ЩҖЩ”ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ ШЈЩҺЩҶ ШӘЩҺЩғЩ’ШӘЩҸШЁЩҸЩҲЩҮЩҸ ШөЩҺШәЩҗЩҠШұЩӢШ§ ШЈЩҺЩҲЩ’ ЩғЩҺШЁЩҗЩҠШұЩӢШ§ ШҘЩҗЩ„ЩҺЩүЩ°Щ“ ШЈЩҺШ¬ЩҺЩ„ЩҗЩҮЩҗЫҰ Ыҡ Ш°ЩҺЩ°Щ„ЩҗЩғЩҸЩ…Щ’ ШЈЩҺЩӮЩ’ШіЩҺШ·ЩҸ Ш№ЩҗЩҶШҜЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЈЩҺЩӮЩ’ЩҲЩҺЩ…ЩҸ Щ„ЩҗЩ„ШҙЩ‘ЩҺЩҮЩҺЩҖЩ°ШҜЩҺШ©Щҗ ЩҲЩҺШЈЩҺШҜЩ’ЩҶЩҺЩүЩ°Щ“ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺШұЩ’ШӘЩҺШ§ШЁЩҸЩҲЩ“Ш§Ыҹ Ы– ШҘЩҗЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩҶ ШӘЩҺЩғЩҸЩҲЩҶЩҺ ШӘЩҗШ¬ЩҺЩҖЩ°ШұЩҺШ©ЩӢ ШӯЩҺШ§Ш¶ЩҗШұЩҺШ©ЩӢЫӯ ШӘЩҸШҜЩҗЩҠШұЩҸЩҲЩҶЩҺЩҮЩҺШ§ ШЁЩҺЩҠЩ’ЩҶЩҺЩғЩҸЩ…Щ’ ЩҒЩҺЩ„ЩҺЩҠЩ’ШіЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ Ш¬ЩҸЩҶЩҺШ§ШӯЩҢ ШЈЩҺЩ„Щ‘ЩҺШ§ ШӘЩҺЩғЩ’ШӘЩҸШЁЩҸЩҲЩҮЩҺШ§ Ы— ЩҲЩҺШЈЩҺШҙЩ’ЩҮЩҗШҜЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШ°ЩҺШ§ ШӘЩҺШЁЩҺШ§ЩҠЩҺШ№Щ’ШӘЩҸЩ…Щ’ Ыҡ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸШ¶ЩҺШ§Щ“ШұЩ‘ЩҺ ЩғЩҺШ§ШӘЩҗШЁЩҢЫӯ ЩҲЩҺЩ„ЩҺШ§ ШҙЩҺЩҮЩҗЩҠШҜЩҢЫӯ Ыҡ ЩҲЩҺШҘЩҗЩҶ ШӘЩҺЩҒЩ’Ш№ЩҺЩ„ЩҸЩҲШ§Ыҹ ЩҒЩҺШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩҒЩҸШіЩҸЩҲЩӮЩҢЫў ШЁЩҗЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұШӘЩ‘ЩҺЩӮЩҸЩҲШ§Ыҹ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ Ы– ЩҲЩҺЩҠЩҸШ№ЩҺЩ„Щ‘ЩҗЩ…ЩҸЩғЩҸЩ…ЩҸ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ ШЁЩҗЩғЩҸЩ„Щ‘Щҗ ШҙЩҺЩүЩ’ШЎЩҚ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"}]}
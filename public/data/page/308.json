ЩҶЩҺШ§ ЩҠЩҸШұЩ’Ш¬ЩҺШ№ЩҸЩҲЩҶЩҺ"},{"key":"19:41","surah":19,"ayah":41,"num":2291,"page":308,"words":[{"code":"пұ—","page":308,"end":false},{"code":"пұҳ","page":308,"end":false},{"code":"пұҷ","page":308,"end":false},{"code":"пұҡпұӣ","page":308,"end":false},{"code":"пұң","page":308,"end":false},{"code":"пұқ","page":308,"end":false},{"code":"пұһ","page":308,"end":false},{"code":"пұҹ","page":308,"end":false},{"code":"пұ ","page":308,"end":true}],"text":"ЩҲЩҺЩұШ°Щ’ЩғЩҸШұЩ’ ЩҒЩҗЩү ЩұЩ„Щ’ЩғЩҗШӘЩҺЩҖЩ°ШЁЩҗ ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҺ Ыҡ ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩғЩҺШ§ЩҶЩҺ ШөЩҗШҜЩ‘ЩҗЩҠЩӮЩӢЫӯШ§ ЩҶЩ‘ЩҺШЁЩҗЩҠЩ‘ЩӢШ§"},{"key":"19:42","surah":19,"ayah":42,"num":2292,"page":308,"words":[{"code":"пұЎ","page":308,"end":false},{"code":"пұў","page":308,"end":false},{"code":"пұЈ","page":308,"end":false},{"code":"пұӨ","page":308,"end":false},{"code":"пұҘ","page":308,"end":false},{"code":"пұҰ","page":308,"end":false},{"code":"пұ§","page":308,"end":false},{"code":"пұЁ","page":308,"end":false},{"code":"пұ©","page":308,"end":false},{"code":"пұӘ","page":308,"end":false},{"code":"пұ«","page":308,"end":false},{"code":"пұ¬","page":308,"end":false},{"code":"пұӯ","page":308,"end":false},{"code":"пұ®","page":308,"end":false},{"code":"пұҜ","page":308,"end":false},{"code":"пұ°","page":308,"end":true}],"text":"ШҘЩҗШ°Щ’ ЩӮЩҺШ§Щ„ЩҺ Щ„ЩҗШЈЩҺШЁЩҗЩҠЩҮЩҗ ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШӘЩҗ Щ„ЩҗЩ…ЩҺ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҸ Щ…ЩҺШ§ Щ„ЩҺШ§ ЩҠЩҺШіЩ’Щ…ЩҺШ№ЩҸ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸШЁЩ’ШөЩҗШұЩҸ ЩҲЩҺЩ„ЩҺШ§ ЩҠЩҸШәЩ’ЩҶЩҗЩү Ш№ЩҺЩҶЩғЩҺ ШҙЩҺЩҠЩ’ЩҖЩ”ЩӢЫӯШ§"},{"key":"19:43","surah":19,"ayah":43,"num":2293,"page":308,"words":[{"code":"пұұ","page":308,"end":false},{"code":"пұІ","page":308,"end":false},{"code":"пұі","page":308,"end":false},{"code":"пұҙ","page":308,"end":false},{"code":"пұө","page":308,"end":false},{"code":"пұ¶","page":308,"end":false},{"code":"пұ·","page":308,"end":false},{"code":"пұё","page":308,"end":false},{"code":"пұ№","page":308,"end":false},{"code":"пұә","page":308,"end":false},{"code":"пұ»","page":308,"end":false},{"code":"пұј","page":308,"end":false},{"code":"пұҪ","page":308,"end":false},{"code":"пұҫ","page":308,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШӘЩҗ ШҘЩҗЩҶЩ‘ЩҗЩү ЩӮЩҺШҜЩ’ Ш¬ЩҺШ§Щ“ШЎЩҺЩҶЩҗЩү Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Ш№ЩҗЩ„Щ’Щ…Щҗ Щ…ЩҺШ§ Щ„ЩҺЩ…Щ’ ЩҠЩҺШЈЩ’ШӘЩҗЩғЩҺ ЩҒЩҺЩұШӘЩ‘ЩҺШЁЩҗШ№Щ’ЩҶЩҗЩүЩ“ ШЈЩҺЩҮЩ’ШҜЩҗЩғЩҺ ШөЩҗШұЩҺЩ°Ш·ЩӢЫӯШ§ ШіЩҺЩҲЩҗЩҠЩ‘ЩӢЫӯШ§"},{"key":"19:44","surah":19,"ayah":44,"num":2294,"page":308,"words":[{"code":"пұҝ","page":308,"end":false},{"code":"пІҖ","page":308,"end":false},{"code":"пІҒ","page":308,"end":false},{"code":"пІӮпІғ","page":308,"end":false},{"code":"пІ„","page":308,"end":false},{"code":"пІ…","page":308,"end":false},{"code":"пІҶ","page":308,"end":false},{"code":"пІҮ","page":308,"end":false},{"code":"пІҲ","page":308,"end":false},{"code":"пІү","page":308,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШӘЩҗ Щ„ЩҺШ§ ШӘЩҺШ№Щ’ШЁЩҸШҜЩҗ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҺ Ы– ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҺ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҗЩ„ШұЩ‘ЩҺШӯЩ’Щ…ЩҺЩҖЩ°ЩҶЩҗ Ш№ЩҺШөЩҗЩҠЩ‘ЩӢЫӯШ§"},{"key":"19:45","surah":19,"ayah":45,"num":2295,"page":308,"words":[{"code":"пІҠ","page":308,"end":false},{"code":"пІӢ","page":308,"end":false},{"code":"пІҢ","page":308,"end":false},{"code":"пІҚ","page":308,"end":false},{"code":"пІҺ","page":308,"end":false},{"code":"пІҸ","page":308,"end":false},{"code":"пІҗ","page":308,"end":false},{"code":"пІ‘","page":308,"end":false},{"code":"пІ’","page":308,"end":false},{"code":"пІ“","page":308,"end":false},{"code":"пІ”","page":308,"end":false},{"code":"пІ•","page":308,"end":true}],"text":"ЩҠЩҺЩҖЩ°Щ“ШЈЩҺШЁЩҺШӘЩҗ ШҘЩҗЩҶЩ‘ЩҗЩүЩ“ ШЈЩҺШ®ЩҺШ§ЩҒЩҸ ШЈЩҺЩҶ ЩҠЩҺЩ…ЩҺШіЩ‘ЩҺЩғЩҺ Ш№ЩҺШ°ЩҺШ§ШЁЩҢЫӯ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ШұЩ‘ЩҺШӯЩ’Щ…ЩҺЩҖЩ°ЩҶЩҗ ЩҒЩҺШӘЩҺЩғЩҸЩҲЩҶЩҺ Щ„ЩҗЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҗ ЩҲЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§"},{"key":"19:46","surah":19,"ayah":46,"num":2296,"page":308,"words":[{"code":"пІ–","page":308,"end":false},{"code":"пІ—","page":308,"end":false},{"code":"пІҳ","page":308,"end":false},{"code":"пІҷ","page":308,"end":false},{"code":"пІҡ","page":308,"end":false},{"code":"пІӣпІң","page":308,"end":false},{"code":"пІқ","page":308,"end":false},{"code":"пІһ","page":308,"end":false},{"code":"пІҹ","page":308,"end":false},{"code":"пІ пІЎ","page":308,"end":false},{"code":"пІў","page":308,"end":false},{"code":"пІЈ","page":308,"end":false},{"code":"пІӨ","page":308,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШЈЩҺШұЩҺШ§ШәЩҗШЁЩҢ ШЈЩҺЩҶШӘЩҺ Ш№ЩҺЩҶЩ’ ШЎЩҺШ§Щ„ЩҗЩҮЩҺШӘЩҗЩү ЩҠЩҺЩҖЩ°Щ“ШҘЩҗШЁЩ’ШұЩҺЩ°ЩҮЩҗЩҠЩ…ЩҸ Ы– Щ„ЩҺШҰЩҗЩҶ Щ„Щ‘ЩҺЩ…Щ’ ШӘЩҺЩҶШӘЩҺЩҮЩҗ Щ„ЩҺШЈЩҺШұЩ’Ш¬ЩҸЩ…ЩҺЩҶЩ‘ЩҺЩғЩҺ Ы– ЩҲЩҺЩұЩҮЩ’Ш¬ЩҸШұЩ’ЩҶЩҗЩү Щ…ЩҺЩ„ЩҗЩҠЩ‘ЩӢЫӯШ§"},{"key":"19:47","surah":19,"ayah":47,"num":2297,"page":308,"words":[{"code":"пІҘ","page":308,"end":false},{"code":"пІҰ","page":308,"end":false},{"code":"пІ§пІЁ","page":308,"end":false},{"code":"пІ©","page":308,"end":false},{"code":"пІӘ","page":308,"end":false},{"code":"пІ«пІ¬","page":308,"end":false},{"code":"пІӯ","page":308,"end":false},{"code":"пІ®","page":308,"end":false},{"code":"пІҜ","page":308,"end":false},{"code":"пІ°","page":308,"end":false},{"code":"пІұ","page":308,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШіЩҺЩ„ЩҺЩҖЩ°Щ…ЩҢ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҺ Ы– ШіЩҺШЈЩҺШіЩ’ШӘЩҺШәЩ’ЩҒЩҗШұЩҸ Щ„ЩҺЩғЩҺ ШұЩҺШЁЩ‘ЩҗЩүЩ“ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЫҘ ЩғЩҺШ§ЩҶЩҺ ШЁЩҗЩү ШӯЩҺЩҒЩҗЩҠЩ‘ЩӢЫӯШ§"},{"key":"19:48","surah":19,"ayah":48,"num":2298,"page":308,"words":[{"code":"пІІ","page":308,"end":false},{"code":"пІі","page":308,"end":false},{"code":"пІҙ","page":308,"end":false},{"code":"пІө","page":308,"end":false},{"code":"пІ¶","page":308,"end":false},{"code":"пІ·","page":308,"end":false},{"code":"пІё","page":308,"end":false},{"code":"пІ№","page":308,"end":false},{"code":"пІә","page":308,"end":false},{"code":"пІ»","page":308,"end":false},{"code":"пІј","page":308,"end":false},{"code":"пІҪ","page":308,"end":false},{"code":"пІҫ","page":308,"end":false},{"code":"пІҝ","page":308,"end":false},{"code":"піҖ","page":308,"end":true}],"text":"ЩҲЩҺШЈЩҺШ№Щ’ШӘЩҺШІЩҗЩ„ЩҸЩғЩҸЩ…Щ’ ЩҲЩҺЩ…ЩҺШ§ ШӘЩҺШҜЩ’Ш№ЩҸЩҲЩҶЩҺ Щ…ЩҗЩҶ ШҜЩҸЩҲЩҶЩҗ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҗ ЩҲЩҺШЈЩҺШҜЩ’Ш№ЩҸЩҲШ§Ыҹ ШұЩҺШЁЩ‘ЩҗЩү Ш№ЩҺШіЩҺЩүЩ°Щ“ ШЈЩҺЩ„Щ‘ЩҺШ§Щ“ ШЈЩҺЩғЩҸЩҲЩҶЩҺ ШЁЩҗШҜЩҸШ№ЩҺШ§Щ“ШЎЩҗ ШұЩҺШЁЩ‘ЩҗЩү ШҙЩҺЩӮЩҗЩҠЩ
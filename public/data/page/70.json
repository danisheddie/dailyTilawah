ЩҸЩҲЩҶЩҺ ЩҒЩҗЩүЩ“ ШЈЩҺЩҶЩҒЩҸШіЩҗЩҮЩҗЩ… Щ…Щ‘ЩҺШ§ Щ„ЩҺШ§ ЩҠЩҸШЁЩ’ШҜЩҸЩҲЩҶЩҺ Щ„ЩҺЩғЩҺ Ы– ЩҠЩҺЩӮЩҸЩҲЩ„ЩҸЩҲЩҶЩҺ Щ„ЩҺЩҲЩ’ ЩғЩҺШ§ЩҶЩҺ Щ„ЩҺЩҶЩҺШ§ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’ШЈЩҺЩ…Щ’ШұЩҗ ШҙЩҺЩүЩ’ШЎЩҢЫӯ Щ…Щ‘ЩҺШ§ ЩӮЩҸШӘЩҗЩ„Щ’ЩҶЩҺШ§ ЩҮЩҺЩҖЩ°ЩҮЩҸЩҶЩҺШ§ Ы— ЩӮЩҸЩ„ Щ„Щ‘ЩҺЩҲЩ’ ЩғЩҸЩҶШӘЩҸЩ…Щ’ ЩҒЩҗЩү ШЁЩҸЩҠЩҸЩҲШӘЩҗЩғЩҸЩ…Щ’ Щ„ЩҺШЁЩҺШұЩҺШІЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҸШӘЩҗШЁЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗЩ…ЩҸ ЩұЩ„Щ’ЩӮЩҺШӘЩ’Щ„ЩҸ ШҘЩҗЩ„ЩҺЩүЩ° Щ…ЩҺШ¶ЩҺШ§Ш¬ЩҗШ№ЩҗЩҮЩҗЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҗЩҠЩҺШЁЩ’ШӘЩҺЩ„ЩҗЩүЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ…ЩҺШ§ ЩҒЩҗЩү ШөЩҸШҜЩҸЩҲШұЩҗЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҗЩҠЩҸЩ…ЩҺШӯЩ‘ЩҗШөЩҺ Щ…ЩҺШ§ ЩҒЩҗЩү ЩӮЩҸЩ„ЩҸЩҲШЁЩҗЩғЩҸЩ…Щ’ Ы— ЩҲЩҺЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩ„ЩҗЩҠЩ…ЩҢЫў ШЁЩҗШ°ЩҺШ§ШӘЩҗ ЩұЩ„ШөЩ‘ЩҸШҜЩҸЩҲШұЩҗ"},{"key":"3:155","surah":3,"ayah":155,"num":448,"page":70,"words":[{"code":"пІ•","page":70,"end":false},{"code":"пІ–","page":70,"end":false},{"code":"пІ—","page":70,"end":false},{"code":"пІҳ","page":70,"end":false},{"code":"пІҷ","page":70,"end":false},{"code":"пІҡ","page":70,"end":false},{"code":"пІӣ","page":70,"end":false},{"code":"пІң","page":70,"end":false},{"code":"пІқ","page":70,"end":false},{"code":"пІһ","page":70,"end":false},{"code":"пІҹ","page":70,"end":false},{"code":"пІ ","page":70,"end":false},{"code":"пІЎпІў","page":70,"end":false},{"code":"пІЈ","page":70,"end":false},{"code":"пІӨ","page":70,"end":false},{"code":"пІҘ","page":70,"end":false},{"code":"пІҰпІ§","page":70,"end":false},{"code":"пІЁ","page":70,"end":false},{"code":"пІ©","page":70,"end":false},{"code":"пІӘ","page":70,"end":false},{"code":"пІ«","page":70,"end":false},{"code":"пІ¬","page":70,"end":true}],"text":"ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШӘЩҺЩҲЩҺЩ„Щ‘ЩҺЩҲЩ’Ш§Ыҹ Щ…ЩҗЩҶЩғЩҸЩ…Щ’ ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩұЩ„Щ’ШӘЩҺЩӮЩҺЩү ЩұЩ„Щ’Ш¬ЩҺЩ…Щ’Ш№ЩҺШ§ЩҶЩҗ ШҘЩҗЩҶЩ‘ЩҺЩ…ЩҺШ§ ЩұШіЩ’ШӘЩҺШІЩҺЩ„Щ‘ЩҺЩҮЩҸЩ…ЩҸ ЩұЩ„ШҙЩ‘ЩҺЩҠЩ’Ш·ЩҺЩҖЩ°ЩҶЩҸ ШЁЩҗШЁЩҺШ№Щ’Ш¶Щҗ Щ…ЩҺШ§ ЩғЩҺШіЩҺШЁЩҸЩҲШ§Ыҹ Ы– ЩҲЩҺЩ„ЩҺЩӮЩҺШҜЩ’ Ш№ЩҺЩҒЩҺШ§ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Ш№ЩҺЩҶЩ’ЩҮЩҸЩ…Щ’ Ы— ШҘЩҗЩҶЩ‘ЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҺ ШәЩҺЩҒЩҸЩҲШұЩҢ ШӯЩҺЩ„ЩҗЩҠЩ…ЩҢЫӯ"},{"key":"3:156","surah":3,"ayah":156,"num":449,"page":70,"words":[{"code":"пІӯ","page":70,"end"
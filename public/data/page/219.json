age":219,"end":false},{"code":"пұ©","page":219,"end":false},{"code":"пұӘ","page":219,"end":true}],"text":"Ыһ ЩҲЩҺШ¬ЩҺЩҖЩ°ЩҲЩҺШІЩ’ЩҶЩҺШ§ ШЁЩҗШЁЩҺЩҶЩҗЩүЩ“ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩұЩ„Щ’ШЁЩҺШӯЩ’ШұЩҺ ЩҒЩҺШЈЩҺШӘЩ’ШЁЩҺШ№ЩҺЩҮЩҸЩ…Щ’ ЩҒЩҗШұЩ’Ш№ЩҺЩҲЩ’ЩҶЩҸ ЩҲЩҺШ¬ЩҸЩҶЩҸЩҲШҜЩҸЩҮЩҸЫҘ ШЁЩҺШәЩ’ЩҠЩӢЫӯШ§ ЩҲЩҺШ№ЩҺШҜЩ’ЩҲЩӢШ§ Ы– ШӯЩҺШӘЩ‘ЩҺЩүЩ°Щ“ ШҘЩҗШ°ЩҺШ§Щ“ ШЈЩҺШҜЩ’ШұЩҺЩғЩҺЩҮЩҸ ЩұЩ„Щ’ШәЩҺШұЩҺЩӮЩҸ ЩӮЩҺШ§Щ„ЩҺ ШЎЩҺШ§Щ…ЩҺЩҶШӘЩҸ ШЈЩҺЩҶЩ‘ЩҺЩҮЩҸЫҘ Щ„ЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҖЩ°ЩҮЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ЩұЩ„Щ‘ЩҺШ°ЩҗЩүЩ“ ШЎЩҺШ§Щ…ЩҺЩҶЩҺШӘЩ’ ШЁЩҗЩҮЩҗЫҰ ШЁЩҺЩҶЩҸЩҲЩ“Ш§Ыҹ ШҘЩҗШіЩ’ШұЩҺЩ°Щ“ШЎЩҗЩҠЩ„ЩҺ ЩҲЩҺШЈЩҺЩҶЩҺШ§Ы  Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸШіЩ’Щ„ЩҗЩ…ЩҗЩҠЩҶЩҺ"},{"key":"10:91","surah":10,"ayah":91,"num":1455,"page":219,"words":[{"code":"пұ«","page":219,"end":false},{"code":"пұ¬","page":219,"end":false},{"code":"пұӯ","page":219,"end":false},{"code":"пұ®","page":219,"end":false},{"code":"пұҜ","page":219,"end":false},{"code":"пұ°","page":219,"end":false},{"code":"пұұ","page":219,"end":false},{"code":"пұІ","page":219,"end":true}],"text":"ШЎЩҺШ§Щ“Щ„Щ’ЩҖЩ”ЩҺЩҖЩ°ЩҶЩҺ ЩҲЩҺЩӮЩҺШҜЩ’ Ш№ЩҺШөЩҺЩҠЩ’ШӘЩҺ ЩӮЩҺШЁЩ’Щ„ЩҸ ЩҲЩҺЩғЩҸЩҶШӘЩҺ Щ…ЩҗЩҶЩҺ ЩұЩ„Щ’Щ…ЩҸЩҒЩ’ШіЩҗШҜЩҗЩҠЩҶЩҺ"},{"key":"10:92","surah":10,"ayah":92,"num":1456,"page":219,"words":[{"code":"пұі","page":219,"end":false},{"code":"пұҙ","page":219,"end":false},{"code":"пұө","page":219,"end":false},{"code":"пұ¶","page":219,"end":false},{"code":"пұ·","page":219,"end":false},{"code":"пұё","page":219,"end":false},{"code":"пұ№пұә","page":219,"end":false},{"code":"пұ»","page":219,"end":false},{"code":"пұј","page":219,"end":false},{"code":"пұҪ","page":219,"end":false},{"code":"пұҫ","page":219,"end":false},{"code":"пұҝ","page":219,"end":false},{"code":"пІҖ","page":219,"end":false},{"code":"пІҒ","page":219,"end":false},{"code":"пІӮ","page":219,"end":true}],"text":"ЩҒЩҺЩұЩ„Щ’ЩҠЩҺЩҲЩ’Щ…ЩҺ ЩҶЩҸЩҶЩҺШ¬Щ‘ЩҗЩҠЩғЩҺ ШЁЩҗШЁЩҺШҜЩҺЩҶЩҗЩғЩҺ Щ„ЩҗШӘЩҺЩғЩҸЩҲЩҶЩҺ Щ„ЩҗЩ…ЩҺЩҶЩ’ Ш®ЩҺЩ„Щ’ЩҒЩҺЩғЩҺ ШЎЩҺШ§ЩҠЩҺШ©ЩӢЫӯ Ыҡ ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ ЩғЩҺШ«ЩҗЩҠШұЩӢЫӯШ§ Щ…Щ‘ЩҗЩҶЩҺ ЩұЩ„ЩҶЩ‘ЩҺШ§ШіЩҗ Ш№ЩҺЩҶЩ’ ШЎЩҺШ§ЩҠЩҺЩҖЩ°ШӘЩҗЩҶЩҺШ§ Щ„Щ
page":343,"end":true}],"text":"ЩҒЩҺШЈЩҺЩҶШҙЩҺШЈЩ’ЩҶЩҺШ§ Щ„ЩҺЩғЩҸЩ… ШЁЩҗЩҮЩҗЫҰ Ш¬ЩҺЩҶЩ‘ЩҺЩҖЩ°ШӘЩҚЫў Щ…Щ‘ЩҗЩҶ ЩҶЩ‘ЩҺШ®ЩҗЩҠЩ„ЩҚЫў ЩҲЩҺШЈЩҺШ№Щ’ЩҶЩҺЩҖЩ°ШЁЩҚЫў Щ„Щ‘ЩҺЩғЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ ЩҒЩҺЩҲЩҺЩ°ЩғЩҗЩҮЩҸ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩҢЫӯ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ"},{"key":"23:20","surah":23,"ayah":20,"num":2693,"page":343,"words":[{"code":"пұһ","page":343,"end":false},{"code":"пұҹ","page":343,"end":false},{"code":"пұ ","page":343,"end":false},{"code":"пұЎ","page":343,"end":false},{"code":"пұў","page":343,"end":false},{"code":"пұЈ","page":343,"end":false},{"code":"пұӨ","page":343,"end":false},{"code":"пұҘ","page":343,"end":false},{"code":"пұҰ","page":343,"end":false},{"code":"пұ§","page":343,"end":true}],"text":"ЩҲЩҺШҙЩҺШ¬ЩҺШұЩҺШ©ЩӢЫӯ ШӘЩҺШ®Щ’ШұЩҸШ¬ЩҸ Щ…ЩҗЩҶ Ш·ЩҸЩҲШұЩҗ ШіЩҺЩҠЩ’ЩҶЩҺШ§Щ“ШЎЩҺ ШӘЩҺЩҶЫўШЁЩҸШӘЩҸ ШЁЩҗЩұЩ„ШҜЩ‘ЩҸЩҮЩ’ЩҶЩҗ ЩҲЩҺШөЩҗШЁЩ’ШәЩҚЫў Щ„Щ‘ЩҗЩ„Щ’ЩҖЩ”ЩҺШ§ЩғЩҗЩ„ЩҗЩҠЩҶЩҺ"},{"key":"23:21","surah":23,"ayah":21,"num":2694,"page":343,"words":[{"code":"пұЁ","page":343,"end":false},{"code":"пұ©","page":343,"end":false},{"code":"пұӘ","page":343,"end":false},{"code":"пұ«","page":343,"end":false},{"code":"пұ¬пұӯ","page":343,"end":false},{"code":"пұ®","page":343,"end":false},{"code":"пұҜ","page":343,"end":false},{"code":"пұ°","page":343,"end":false},{"code":"пұұ","page":343,"end":false},{"code":"пұІ","page":343,"end":false},{"code":"пұі","page":343,"end":false},{"code":"пұҙ","page":343,"end":false},{"code":"пұө","page":343,"end":false},{"code":"пұ¶","page":343,"end":false},{"code":"пұ·","page":343,"end":false},{"code":"пұё","page":343,"end":true}],"text":"ЩҲЩҺШҘЩҗЩҶЩ‘ЩҺ Щ„ЩҺЩғЩҸЩ…Щ’ ЩҒЩҗЩү ЩұЩ„Щ’ШЈЩҺЩҶЩ’Ш№ЩҺЩҖЩ°Щ…Щҗ Щ„ЩҺШ№ЩҗШЁЩ’ШұЩҺШ©ЩӢЫӯ Ы– ЩҶЩ‘ЩҸШіЩ’ЩӮЩҗЩҠЩғЩҸЩ… Щ…Щ‘ЩҗЩ…Щ‘ЩҺШ§ ЩҒЩҗЩү ШЁЩҸШ·ЩҸЩҲЩҶЩҗЩҮЩҺШ§ ЩҲЩҺЩ„ЩҺЩғЩҸЩ…Щ’ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҺЩҶЩҺЩҖЩ°ЩҒЩҗШ№ЩҸ ЩғЩҺШ«ЩҗЩҠШұЩҺШ©ЩҢЫӯ ЩҲЩҺЩ…ЩҗЩҶЩ’ЩҮЩҺШ§ ШӘЩҺШЈЩ’ЩғЩҸЩ„ЩҸЩҲЩҶЩҺ"},{"key":"23:22","surah":23,"ayah":22,"num":2695,"page":343,"words":[{"code":"пұ№","page":343,"end":false},{"code":"пұә","page":343,"end":false},{"code"
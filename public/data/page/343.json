"end":false},{"code":"пІӨ","page":343,"end":false},{"code":"пІҘ","page":343,"end":false},{"code":"пІҰ","page":343,"end":false},{"code":"пІ§","page":343,"end":false},{"code":"пІЁ","page":343,"end":false},{"code":"пІ©","page":343,"end":false},{"code":"пІӘ","page":343,"end":true}],"text":"ЩҒЩҺЩӮЩҺШ§Щ„ЩҺ ЩұЩ„Щ’Щ…ЩҺЩ„ЩҺШӨЩҸШ§Ыҹ ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ЩғЩҺЩҒЩҺШұЩҸЩҲШ§Ыҹ Щ…ЩҗЩҶ ЩӮЩҺЩҲЩ’Щ…ЩҗЩҮЩҗЫҰ Щ…ЩҺШ§ ЩҮЩҺЩҖЩ°Ш°ЩҺШ§Щ“ ШҘЩҗЩ„Щ‘ЩҺШ§ ШЁЩҺШҙЩҺШұЩҢЫӯ Щ…Щ‘ЩҗШ«Щ’Щ„ЩҸЩғЩҸЩ…Щ’ ЩҠЩҸШұЩҗЩҠШҜЩҸ ШЈЩҺЩҶ ЩҠЩҺШӘЩҺЩҒЩҺШ¶Щ‘ЩҺЩ„ЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩғЩҸЩ…Щ’ ЩҲЩҺЩ„ЩҺЩҲЩ’ ШҙЩҺШ§Щ“ШЎЩҺ ЩұЩ„Щ„Щ‘ЩҺЩҮЩҸ Щ„ЩҺШЈЩҺЩҶШІЩҺЩ„ЩҺ Щ…ЩҺЩ„ЩҺЩҖЩ°Щ“ШҰЩҗЩғЩҺШ©ЩӢЫӯ Щ…Щ‘ЩҺШ§ ШіЩҺЩ…ЩҗШ№Щ’ЩҶЩҺШ§ ШЁЩҗЩҮЩҺЩҖЩ°Ш°ЩҺШ§ ЩҒЩҗЩүЩ“ ШЎЩҺШ§ШЁЩҺШ§Щ“ШҰЩҗЩҶЩҺШ§ ЩұЩ„Щ’ШЈЩҺЩҲЩ‘ЩҺЩ„ЩҗЩҠЩҶЩҺ"},{"key":"23:25","surah":23,"ayah":25,"num":2698,"page":343,"words":[{"code":"пІ«","page":343,"end":false},{"code":"пІ¬","page":343,"end":false},{"code":"пІӯ","page":343,"end":false},{"code":"пІ®","page":343,"end":false},{"code":"пІҜ","page":343,"end":false},{"code":"пІ°","page":343,"end":false},{"code":"пІұ","page":343,"end":false},{"code":"пІІ","page":343,"end":false},{"code":"пІі","page":343,"end":false},{"code":"пІҙ","page":343,"end":false},{"code":"пІө","page":343,"end":true}],"text":"ШҘЩҗЩҶЩ’ ЩҮЩҸЩҲЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ ШұЩҺШ¬ЩҸЩ„ЩҢЫў ШЁЩҗЩҮЩҗЫҰ Ш¬ЩҗЩҶЩ‘ЩҺШ©ЩҢЫӯ ЩҒЩҺШӘЩҺШұЩҺШЁЩ‘ЩҺШөЩҸЩҲШ§Ыҹ ШЁЩҗЩҮЩҗЫҰ ШӯЩҺШӘЩ‘ЩҺЩүЩ° ШӯЩҗЩҠЩҶЩҚЫў"},{"key":"23:26","surah":23,"ayah":26,"num":2699,"page":343,"words":[{"code":"пІ¶","page":343,"end":false},{"code":"пІ·","page":343,"end":false},{"code":"пІё","page":343,"end":false},{"code":"пІ№","page":343,"end":false},{"code":"пІә","page":343,"end":false},{"code":"пІ»","page":343,"end":true}],"text":"ЩӮЩҺШ§Щ„ЩҺ ШұЩҺШЁЩ‘Щҗ ЩұЩҶШөЩҸШұЩ’ЩҶЩҗЩү ШЁЩҗЩ…ЩҺШ§ ЩғЩҺШ°Щ‘ЩҺШЁЩҸЩҲЩҶЩҗ"},{"key":"23:27","surah":23,"ayah":27,"num":2700,"page":343,"words":[{"code":"пІј","page":343,"end":false},{"code":"пІҪ","page":343,"end":false},{"code":"пІҫ","page":343,"end":false},{"code":"пІҝ","page":343,"end":false},{"code":"піҖ","page":343,"end":false},{"code":"піҒ","page":343,"end":false},{"code":"піӮ","page":343,"end":false},{"code":"піғ","page":343,"end":false},{"code":"пі„","page":343,"end":false},{"code":"пі…","page":343,"end":false},{"code":"піҶ","page":343,"end":false},{"code":"піҮ","page":343,"end":false},{"code":"піҲ","page":343,"end":false},{"code":"піү","page":343,"end":false},{"code":"піҠ","page":343,"end":false},{"code":"піӢ","page":343,"end":false},{"code":"піҢ","page":343,"end":false},{"code":"піҚ","page":343,"end":false},{"code":"піҺ","page":343,"end":false},{"code":"піҸ","page":343,"end":false},{"code":"піҗ","page":343,"end":false},{"code":"пі‘","page":343,"end":false},{"code":"пі’","page":343,"end":false},{"code":"пі“","page":343,"end":false},{"code":"пі”пі•","page":343,"end":false},{"code":"пі–","page":343,"end":false},{"code":"пі—","page":343,"end":false},{"code":"піҳ","page":343,"end":false},{"code":"піҷ","page":343,"end":false},{"code":"піҡ","page":343,"end":false},{"code":"піӣ","page":343,"end":false},{"code":"пің","page":343,"end":false},{"code":"піқ","page":343,"end":true}],"text":"ЩҒЩҺШЈЩҺЩҲЩ’ШӯЩҺЩҠЩ’ЩҶЩҺШ§Щ“ ШҘЩҗЩ„ЩҺЩҠЩ’ЩҮЩҗ ШЈЩҺЩҶЩҗ ЩұШөЩ’ЩҶЩҺШ№Щҗ ЩұЩ„Щ’ЩҒЩҸЩ„Щ’ЩғЩҺ ШЁЩҗШЈЩҺШ№Щ’ЩҠЩҸЩҶЩҗЩҶЩҺШ§ ЩҲЩҺЩҲЩҺШӯЩ’ЩҠЩҗЩҶЩҺШ§ ЩҒЩҺШҘЩҗШ°ЩҺШ§ Ш¬ЩҺШ§Щ“ШЎЩҺ ШЈЩҺЩ…Щ’ШұЩҸЩҶЩҺШ§ ЩҲЩҺЩҒЩҺШ§ШұЩҺ ЩұЩ„ШӘЩ‘ЩҺЩҶЩ‘ЩҸЩҲШұЩҸ Ыҷ ЩҒЩҺЩұШіЩ’Щ„ЩҸЩғЩ’ ЩҒЩҗЩҠЩҮЩҺШ§ Щ…ЩҗЩҶ ЩғЩҸЩ„Щ‘ЩҚЫў ШІЩҺЩҲЩ’Ш¬ЩҺЩҠЩ’ЩҶЩҗ ЩұШ«Щ’ЩҶЩҺЩҠЩ’ЩҶЩҗ ЩҲЩҺШЈЩҺЩҮЩ’Щ„ЩҺЩғЩҺ ШҘЩҗЩ„Щ‘ЩҺШ§ Щ…ЩҺЩҶ ШіЩҺШЁЩҺЩӮЩҺ Ш№ЩҺЩ„ЩҺЩҠЩ’ЩҮЩҗ ЩұЩ„Щ’ЩӮЩҺЩҲЩ’Щ„ЩҸ Щ…ЩҗЩҶЩ’ЩҮЩҸЩ…Щ’ Ы– ЩҲЩҺЩ„ЩҺШ§ ШӘЩҸШ®ЩҺЩҖЩ°Ш·ЩҗШЁЩ’ЩҶЩҗЩү ЩҒЩҗЩү ЩұЩ„Щ‘ЩҺШ°ЩҗЩҠЩҶЩҺ ШёЩҺЩ„ЩҺЩ…ЩҸЩҲЩ“Ш§Ыҹ Ы– ШҘЩҗЩҶЩ‘ЩҺЩҮЩҸЩ… Щ…Щ‘ЩҸШәЩ’ШұЩҺЩӮЩҸЩҲЩҶЩҺ"}]}